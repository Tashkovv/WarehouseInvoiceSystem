@inject ILocalizationService Localization

<div class="appbar-popover-anchor">
    <MudIconButton Icon="@Icons.Material.Filled.Language"
                   Color="Color.Inherit"
                   OnClick="@(() => _open = !_open)" />

    @if (_open)
    {
        <MudOverlay Visible="true" OnClick="@(() => _open = false)" LockScroll="false" />
        <MudPopover Open="true" Fixed="false" Class="pa-0 mud-elevation-4"
                    AnchorOrigin="Origin.BottomRight"
                    TransformOrigin="Origin.TopRight"
                    Style="z-index: 1301; min-width: 160px;">
        <MudList T="string" Dense="true" Class="pa-0">
            <MudListItem OnClick="@(() => SelectLanguage("en"))"
                         Class="px-3 py-2" Style="cursor: pointer;">
                <div class="d-flex align-center gap-2">
                    <span class="fi fi-gb" style="width: 22px; height: 16px; border-radius: 2px; flex-shrink: 0;"></span>
                    <span>English</span>
                    @if (Localization.CurrentLanguage == "en")
                    {
                        <MudIcon Icon="@Icons.Material.Filled.Check" Size="Size.Small" Color="Color.Success" Class="ml-1" />
                    }
                </div>
            </MudListItem>
            <MudListItem OnClick="@(() => SelectLanguage("mk"))"
                         Class="px-3 py-2" Style="cursor: pointer;">
                <div class="d-flex align-center gap-2">
                    <span class="fi fi-mk" style="width: 22px; height: 16px; border-radius: 2px; flex-shrink: 0;"></span>
                    <span>Македонски</span>
                    @if (Localization.CurrentLanguage == "mk")
                    {
                        <MudIcon Icon="@Icons.Material.Filled.Check" Size="Size.Small" Color="Color.Success" Class="ml-1" />
                    }
                </div>
            </MudListItem>
        </MudList>
        </MudPopover>
    }
</div>

@code {
    private bool _open;

    private void SelectLanguage(string language)
    {
        _open = false;
        Localization.SetLanguage(language);
    }
}
