@using WarehouseInvoiceSystem.Application.Interfaces
@inject ILocalizationService Localization

<MudCard Elevation="2" Class="mb-4">
    <MudCardContent Class="pb-3">

        @* Row 1: Create + AdditionalActions + Search — all inline *@
        <MudGrid AlignItems="AlignItems.Center" Spacing="2" Style="flex-wrap: nowrap; align-items: center;">
            @if (CreateHref is not null || CreateAction.HasDelegate)
            {
                <MudItem xs="12" Style="flex: 0 0 auto; width: auto;">
                    @if (CreateHref is not null)
                    {
                        <MudButton StartIcon="@Icons.Material.Filled.Add"
                                   Color="Color.Primary"
                                   Variant="Variant.Filled"
                                   Href="@CreateHref">
                            @CreateLabel
                        </MudButton>
                    }
                    else
                    {
                        <MudButton StartIcon="@Icons.Material.Filled.Add"
                                   Color="Color.Primary"
                                   Variant="Variant.Filled"
                                   OnClick="CreateAction">
                            @CreateLabel
                        </MudButton>
                    }
                </MudItem>
            }
            @if (AdditionalActions is not null)
            {
                <MudItem xs="12" Style="flex: 0 0 auto; width: auto;">
                    @AdditionalActions
                </MudItem>
            }
            <MudItem xs="12" Style="flex: 1 1 auto; min-width: 0;">
                <MudTextField T="string"
                              Value="SearchValue"
                              ValueChanged="SearchValueChanged"
                              Placeholder="@Localization.GetString("Search")"
                              Adornment="Adornment.Start"
                              AdornmentIcon="@Icons.Material.Filled.Search"
                              IconSize="Size.Medium"
                              Immediate="true"
                              DebounceInterval="300"
                              Class="mt-0" />
            </MudItem>
        </MudGrid>

        @* Row 2: Quick filters + Clear All button *@
        @if (Filters is not null)
        {
            <MudDivider Class="mt-3 mb-2" />
            <div class="wis-toolbar-filters">
                @Filters
                @if (HasAnyActiveFilter)
                {
                    <MudButton StartIcon="@Icons.Material.Filled.FilterAltOff"
                               Variant="Variant.Text"
                               Color="Color.Default"
                               Size="Size.Small"
                               Class="wis-toolbar-clearall-btn"
                               OnClick="OnClearAll">
                        @Localization.GetString("ClearFilters")
                    </MudButton>
                }
            </div>
        }

        @* Row 3: Advanced filter toggle + collapsible panel *@
        @if (AdvancedFilters is not null)
        {
            <MudDivider Class="mt-3 mb-1" />
            <div class="wis-toolbar-advanced-toggle">
                <MudButton StartIcon="@(_showAdvancedFilters ? Icons.Material.Filled.ExpandLess
                                                             : Icons.Material.Filled.ExpandMore)"
                       Variant="Variant.Text"
                       Color="Color.Default"
                       Size="Size.Small"
                       Class="wis-toolbar-advanced-btn"
                       OnClick="@(() => _showAdvancedFilters = !_showAdvancedFilters)">
                @Localization.GetString("AdvancedFilters")
            </MudButton>
            @if (ActiveAdvancedFilterCount > 0)
                {
                    <MudChip T="string"
                             Size="Size.Small"
                             Color="Color.Primary"
                             Variant="Variant.Filled"
                             Class="wis-toolbar-advanced-badge">
                        @ActiveAdvancedFilterCount
                    </MudChip>
                }
            </div>

            @if (_showAdvancedFilters)
            {
                <div class="wis-toolbar-advanced-panel">
                    @AdvancedFilters
                </div>
            }
        }

    </MudCardContent>
</MudCard>

@code {
    [Parameter] public string? CreateHref { get; set; }
    [Parameter] public EventCallback CreateAction { get; set; }
    [Parameter] public string CreateLabel { get; set; } = string.Empty;
    [Parameter] public string SearchValue { get; set; } = string.Empty;
    [Parameter] public EventCallback<string> SearchValueChanged { get; set; }

    /// <summary>
    /// Extra action buttons (e.g. Export) rendered inline on Row 1 between Create and Search.
    /// </summary>
    [Parameter] public RenderFragment? AdditionalActions { get; set; }

    /// <summary>
    /// Quick enum/boolean filters — Row 2, always visible.
    /// Use FilterPopoverList with Label set.
    /// </summary>
    [Parameter] public RenderFragment? Filters { get; set; }

    /// <summary>
    /// True when any quick filter is active. The toolbar shows "Clear All" when true.
    /// Pass: _filterFoo != null || _filterBar != null etc.
    /// </summary>
    [Parameter] public bool HasAnyActiveFilter { get; set; }

    /// <summary>
    /// Fires when the "Clear All" button is clicked.
    /// The page component should reset all filter state and reload.
    /// </summary>
    [Parameter] public EventCallback OnClearAll { get; set; }

    /// <summary>
    /// Complex filters — Row 3, collapsible.
    /// </summary>
    [Parameter] public RenderFragment? AdvancedFilters { get; set; }

    /// <summary>
    /// Count of active advanced filters for the badge.
    /// </summary>
    [Parameter] public int ActiveAdvancedFilterCount { get; set; }

    private bool _showAdvancedFilters = false;
}
