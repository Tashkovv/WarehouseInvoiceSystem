@inject ILocalizationService Localization

<MudCard Elevation="2" Class="mb-4">
    <MudCardContent Class="pb-3">

        @* Single row: Button | Filters | Advanced toggle | Search | Clear *@
        <div class="wis-toolbar-row">

            @* Create / split button *@
            @if (_primaryAction is not null)
            {
                <div class="wis-toolbar-btn">
                    <WisSplitButton PrimaryAction="@_primaryAction"
                                    Actions="@CreateActions"
                                    AnchorOrigin="Origin.BottomLeft"
                                    TransformOrigin="Origin.TopLeft" />
                </div>
            }

            @* Quick filters *@
            @if (Filters is not null)
            {
                @if (_primaryAction is not null)
                {
                    <div class="wis-toolbar-divider"></div>
                }

                <div class="wis-toolbar-filters-inline">
                    @Filters
                </div>
            }

            @* Advanced filters toggle *@
            @if (AdvancedFilters is not null)
            {
                @if (Filters is not null)
                {
                    <div class="wis-toolbar-divider"></div>
                }
                <div class="d-flex align-center gap-1">
                    <MudButton StartIcon="@Icons.Material.Filled.Tune"
                               Variant="Variant.Text"
                               Color="@(ActiveAdvancedFilterCount > 0 ? Color.Primary : Color.Default)"
                               Size="Size.Small"
                               Class="wis-toolbar-advanced-btn"
                               OnClick="@(() => _showAdvancedFilters = !_showAdvancedFilters)">
                        @Localization.GetString("AdvancedFilters")
                    </MudButton>
                    @if (ActiveAdvancedFilterCount > 0)
                    {
                        <MudChip T="string"
                                 Size="Size.Small"
                                 Color="Color.Primary"
                                 Variant="Variant.Filled"
                                 Class="wis-toolbar-advanced-badge">
                            @ActiveAdvancedFilterCount
                        </MudChip>
                    }
                </div>
            }

            @* Clear — shown when any filter OR search is active *@
            @if (HasAnyActiveFilter || !string.IsNullOrEmpty(SearchValue))
            {
                <div class="wis-toolbar-divider"></div>
                <MudButton StartIcon="@Icons.Material.Filled.FilterAltOff"
                           Variant="Variant.Outlined"
                           Color="Color.Default"
                           Size="Size.Small"
                           Class="wis-toolbar-clearall-btn"
                           OnClick="HandleClearAll">
                    @Localization.GetString("ClearFilters")
                </MudButton>
            }

            @* Search — grows to fill remaining space *@
            <div class="wis-toolbar-search">
                <MudTextField T="string"
                              Value="SearchValue"
                              ValueChanged="OnSearchChanged"
                              Placeholder="@Localization.GetString("Search")"
                              Adornment="Adornment.Start"
                              AdornmentIcon="@Icons.Material.Filled.Search"
                              IconSize="Size.Medium"
                              Immediate="true"
                              DebounceInterval="300"
                              Class="mt-0" />
            </div>
        </div>

        @* Advanced filters panel — collapsible *@
        @if (AdvancedFilters is not null && _showAdvancedFilters)
        {
            <MudDivider Class="mt-3 mb-2" />
            <div class="wis-toolbar-advanced-panel">
                @AdvancedFilters
            </div>
        }

    </MudCardContent>
</MudCard>

@code {
    // ── Create button ──────────────────────────────────────────────────────────
    [Parameter] public EventCallback CreateAction { get; set; }
    [Parameter] public string CreateLabel { get; set; } = string.Empty;
    [Parameter] public string CreateIcon { get; set; } = Icons.Material.Filled.Add;

    /// <summary>
    /// Extra dropdown actions on the create button (e.g. Import).
    /// When provided, the create button becomes a split button.
    /// </summary>
    [Parameter] public List<WisDetailActionItem>? CreateActions { get; set; }

    // ── Filters ────────────────────────────────────────────────────────────────
    [Parameter] public string SearchValue { get; set; } = string.Empty;
    [Parameter] public EventCallback<string> SearchValueChanged { get; set; }
    [Parameter] public RenderFragment? Filters { get; set; }
    [Parameter] public bool HasAnyActiveFilter { get; set; }
    [Parameter] public EventCallback OnClearAll { get; set; }
    [Parameter] public RenderFragment? AdvancedFilters { get; set; }
    [Parameter] public int ActiveAdvancedFilterCount { get; set; }

    private bool _showAdvancedFilters;
    private WisDetailActionItem? _primaryAction;

    protected override void OnParametersSet()
    {
        _primaryAction = CreateAction.HasDelegate
            ? new WisDetailActionItem
            {
                Icon = CreateIcon,
                Label = CreateLabel,
                OnClick = CreateAction
            }
            : null;
    }

    private async Task OnSearchChanged(string value)
    {
        await SearchValueChanged.InvokeAsync(value);
    }

    private async Task HandleClearAll()
    {
        await SearchValueChanged.InvokeAsync(string.Empty);
        if (OnClearAll.HasDelegate)
            await OnClearAll.InvokeAsync();
    }
}
