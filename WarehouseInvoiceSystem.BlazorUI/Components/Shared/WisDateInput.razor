@*
    Form-field date picker — same wis-field visual language as WisInput/WisSelect.
    Renders as a 40px outlined pill with floating label; click opens a static calendar
    in an absolute dropdown. Supports day (default), month, and year picking via OpenTo.

    Uses the same wis-dp-* CSS as WisDatePicker so month/year grids are identical.
*@

<div class="wis-field @(FullWidth ? "wis-field--full" : "") @(_isOpen ? "wis-field--focused" : "") @(HasError ? "wis-field--error" : "") @(Disabled ? "wis-field--disabled" : "") @CssClass"
     tabindex="-1"
     @onfocusout="OnFocusOut">
    <label class="wis-field__label @(_hasValue || _isOpen ? "wis-field__label--float" : "")">
        @Label
        @if (Required)
        {
            <span class="wis-field__required">*</span>
        }
    </label>

    <div class="wis-field__inner wis-select__trigger"
         tabindex="@(Disabled ? -1 : 0)"
         @onclick="Toggle"
         @onclick:stopPropagation
         @onkeydown="OnKeyDown">
        <div class="wis-select__value">
            @if (_localDate.HasValue)
            {
                <span>@_localDate.Value.ToString(DateFormat)</span>
            }
        </div>
        <MudIcon Icon="@Icons.Material.Filled.CalendarMonth"
                 Size="Size.Small"
                 Class="wis-select__chevron" />
    </div>

    @if (_isOpen)
    {
        <div class="wis-date-input__dropdown" @onclick:stopPropagation @onmousedown:preventDefault>

            @if (OpenTo == OpenTo.Year)
            {
                <div class="wis-dp-month-grid">
                    <div class="wis-dp-month-nav">
                        <MudIconButton Icon="@Icons.Material.Filled.ChevronLeft"
                                       Size="Size.Small"
                                       OnClick="@(() => _viewYearOffset -= 12)" />
                        <span class="wis-dp-month-year">
                            @(_viewYear + _viewYearOffset) – @(_viewYear + _viewYearOffset + 11)
                        </span>
                        <MudIconButton Icon="@Icons.Material.Filled.ChevronRight"
                                       Size="Size.Small"
                                       OnClick="@(() => _viewYearOffset += 12)" />
                    </div>
                    <div class="wis-dp-month-cells" style="grid-template-columns: repeat(3, 1fr);">
                        @for (int i = 0; i < 12; i++)
                        {
                            var year = _viewYear + _viewYearOffset + i;
                            bool isSelected = _localDate.HasValue && _localDate.Value.Year == year;
                            bool isDisabled = MaxDate.HasValue && year > MaxDate.Value.Year;
                            <button type="button"
                                    class="wis-dp-month-cell @(isSelected ? "wis-dp-month-cell--selected" : "")"
                                    disabled="@isDisabled"
                                    @onclick="@(() => SelectYear(year))">
                                @year
                            </button>
                        }
                    </div>
                </div>
            }
            else if (OpenTo == OpenTo.Month)
            {
                <div class="wis-dp-month-grid">
                    <div class="wis-dp-month-nav">
                        <MudIconButton Icon="@Icons.Material.Filled.ChevronLeft"
                                       Size="Size.Small"
                                       OnClick="@(() => _viewYear--)" />
                        <span class="wis-dp-month-year">@_viewYear</span>
                        <MudIconButton Icon="@Icons.Material.Filled.ChevronRight"
                                       Size="Size.Small"
                                       OnClick="@(() => _viewYear++)" />
                    </div>
                    <div class="wis-dp-month-cells">
                        @for (int m = 1; m <= 12; m++)
                        {
                            var month = m;
                            var dt = new DateTime(_viewYear, month, 1);
                            bool isSelected = _localDate.HasValue
                                && _localDate.Value.Year == _viewYear
                                && _localDate.Value.Month == month;
                            bool isDisabled = MaxDate.HasValue && dt > MaxDate.Value;
                            <button type="button"
                                    class="wis-dp-month-cell @(isSelected ? "wis-dp-month-cell--selected" : "")"
                                    disabled="@isDisabled"
                                    @onclick="@(() => SelectMonth(month))">
                                @dt.ToString("MMM")
                            </button>
                        }
                    </div>
                </div>
            }
            else
            {
                <div class="wis-dp-calendar">
                    <MudDatePicker Date="@_localDate"
                                   DateChanged="OnDateChanged"
                                   PickerVariant="PickerVariant.Static"
                                   Variant="Variant.Text"
                                   Margin="Margin.None"
                                   DateFormat="@DateFormat"
                                   OpenTo="@OpenTo"
                                   MaxDate="@MaxDate"
                                   Elevation="0"
                                   Class="wis-date-static" />
                </div>
            }

        </div>
    }

    @if (HasError && !string.IsNullOrWhiteSpace(ErrorText))
    {
        <div class="wis-field__helper wis-field__helper--error">@ErrorText</div>
    }
    else if (!string.IsNullOrWhiteSpace(HelperText))
    {
        <div class="wis-field__helper">@HelperText</div>
    }
</div>

@code {
    [Parameter, EditorRequired] public string Label { get; set; } = string.Empty;
    [Parameter] public DateTime? Date { get; set; }
    [Parameter] public EventCallback<DateTime?> DateChanged { get; set; }
    [Parameter] public string DateFormat { get; set; } = "dd MMM yyyy";
    [Parameter] public OpenTo OpenTo { get; set; } = OpenTo.Date;
    [Parameter] public DateTime? MaxDate { get; set; }

    [Parameter] public string? HelperText { get; set; }
    [Parameter] public string? ErrorText { get; set; }
    [Parameter] public bool HasError { get; set; }
    [Parameter] public bool Required { get; set; }
    [Parameter] public bool Disabled { get; set; }
    [Parameter] public bool FullWidth { get; set; } = true;
    [Parameter] public string? CssClass { get; set; }

    private bool _isOpen;
    private DateTime? _localDate;
    private DateTime? _lastSeenDate;
    private int _viewYear = DateTime.Today.Year;
    private int _viewYearOffset;

    private bool _hasValue => _localDate.HasValue;

    protected override void OnParametersSet()
    {
        if (Date != _lastSeenDate)
        {
            _lastSeenDate = Date;
            _localDate = Date;
        }
    }

    private void Toggle()
    {
        if (Disabled) return;
        _isOpen = !_isOpen;
        if (_isOpen)
        {
            _viewYear = _localDate?.Year ?? DateTime.Today.Year;
            _viewYearOffset = 0;
        }
    }

    private void Close() => _isOpen = false;

    private void OnFocusOut(FocusEventArgs e) => _isOpen = false;

    private void OnKeyDown(KeyboardEventArgs e)
    {
        if (Disabled) return;
        switch (e.Key)
        {
            case "Enter":
            case " ":
                _isOpen = !_isOpen;
                if (_isOpen)
                {
                    _viewYear = _localDate?.Year ?? DateTime.Today.Year;
                    _viewYearOffset = 0;
                }
                break;
            case "Escape":
                _isOpen = false;
                break;
        }
    }

    private async Task OnDateChanged(DateTime? date)
    {
        _localDate = date;
        _isOpen = false;
        await DateChanged.InvokeAsync(date);
    }

    private async Task SelectYear(int year)
    {
        _localDate = new DateTime(year, 1, 1);
        _isOpen = false;
        await DateChanged.InvokeAsync(_localDate);
    }

    private async Task SelectMonth(int month)
    {
        _localDate = new DateTime(_viewYear, month, 1);
        _isOpen = false;
        await DateChanged.InvokeAsync(_localDate);
    }
}
