@inject ILocalizationService Localization
@inject NavigationManager Navigation

<MudCard Elevation="2"
         Class=@($"dashboard-card {(_isHovered ? "dashboard-card-hover" : "")}")
         @onmouseenter="OnMouseEnter"
         @onmouseleave="OnMouseLeave"
         @onclick="NavigateToLink"
         Style="@($"cursor: {(!string.IsNullOrEmpty(Link) ? "pointer" : "default")}; transition: all 0.2s ease; height: 100%; border-top: 4px solid {GetAccentColor()}; background-color: rgba({GetAccentColorRgb()}, 0.05); overflow: hidden;")">
    <MudCardContent Class="pa-5">
        <div class="d-flex align-center justify-space-between">
            <!-- Left side: Icon in colored circle -->
            @if (!string.IsNullOrEmpty(Icon))
            {
                <div class="d-flex align-center justify-center rounded-circle"
                     style="@($"min-width: 56px; height: 56px; background-color: rgba({GetAccentColorRgb()}, 0.12);")">
                    <MudIcon Icon="@Icon" Color="@IconColor" Size="Size.Large" />
                </div>
            }

            <!-- Right side: Content -->
            <div class="flex-grow-1 ml-4 text-right">
                <MudText Typo="Typo.caption" Color="Color.Secondary" Style="text-transform: uppercase; letter-spacing: 0.05em;">
                    @Title
                </MudText>
                <MudText Typo="Typo.h4" Class="font-weight-bold my-1" Style="line-height: 1.1;">
                    @Value
                </MudText>
                @if (SubtitleLines is { Count: > 0 })
                {
                    @foreach (var line in SubtitleLines)
                    {
                        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="d-block">@line</MudText>
                    }
                }
                else if (!string.IsNullOrEmpty(Subtitle))
                {
                    <MudText Typo="Typo.caption" Color="Color.Secondary">
                        @Subtitle
                    </MudText>
                }
                @if (!string.IsNullOrEmpty(Trend))
                {
                    <div class="d-flex align-center justify-start gap-1 mt-1">
                        <MudIcon Icon="@(TrendPositive ? Icons.Material.Filled.TrendingUp : Icons.Material.Filled.TrendingDown)"
                                 Size="Size.Small"
                                 Color="@(TrendPositive ? Color.Success : Color.Error)" />
                        <MudText Typo="Typo.caption" Color="@(TrendPositive ? Color.Success : Color.Error)">
                            @Trend
                        </MudText>
                    </div>
                }
            </div>

            <!-- Arrow indicator on hover -->
            @if (_isHovered && !string.IsNullOrEmpty(Link))
            {
                <div class="ml-3">
                    <MudIcon Icon="@Icons.Material.Filled.ArrowForward" Size="Size.Small" Color="@IconColor" />
                </div>
            }
        </div>
    </MudCardContent>
</MudCard>

@code {
    [Parameter] public string Title { get; set; } = string.Empty;
    [Parameter] public string Value { get; set; } = string.Empty;
    [Parameter] public string? Subtitle { get; set; }
    [Parameter] public IReadOnlyList<string>? SubtitleLines { get; set; }
    [Parameter] public string? Icon { get; set; }
    [Parameter] public Color IconColor { get; set; } = Color.Primary;
    [Parameter] public string? Link { get; set; }
    [Parameter] public string? Trend { get; set; }
    [Parameter] public bool TrendPositive { get; set; } = true;

    private bool _isHovered = false;

    private void OnMouseEnter() => _isHovered = true;
    private void OnMouseLeave() => _isHovered = false;

    private void NavigateToLink()
    {
        if (!string.IsNullOrEmpty(Link))
            Navigation.NavigateTo(Link);
    }

    private string GetAccentColor() => IconColor switch
    {
        Color.Primary   => "var(--mud-palette-primary)",
        Color.Secondary => "var(--mud-palette-secondary)",
        Color.Success   => "var(--mud-palette-success)",
        Color.Warning   => "var(--mud-palette-warning)",
        Color.Error     => "var(--mud-palette-error)",
        Color.Info      => "var(--mud-palette-info)",
        Color.Tertiary  => "var(--mud-palette-tertiary)",
        _               => "var(--mud-palette-primary)"
    };

    private string GetAccentColorRgb() => IconColor switch
    {
        Color.Primary   => "var(--mud-palette-primary-rgb)",
        Color.Secondary => "var(--mud-palette-secondary-rgb)",
        Color.Success   => "var(--mud-palette-success-rgb)",
        Color.Warning   => "var(--mud-palette-warning-rgb)",
        Color.Error     => "var(--mud-palette-error-rgb)",
        Color.Info      => "var(--mud-palette-info-rgb)",
        Color.Tertiary  => "var(--mud-palette-tertiary-rgb)",
        _               => "var(--mud-palette-primary-rgb)"
    };
}
