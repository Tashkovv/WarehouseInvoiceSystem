@typeparam T
@implements IDisposable
@inject ILocalizationService Localization

<div class="wis-pager">

    <span class="wis-pager__rpp-label">@Localization.GetString("ItemsPerPage")</span>

    <div class="wis-pager__rpp-container">
        <div class="wis-pager__rpp-pill" @onclick="TogglePicker" @onclick:stopPropagation>
            <span class="wis-pager__rpp-value">@_rowsPerPage</span>
            <MudIcon Icon="@(_isOpen ? Icons.Material.Filled.ArrowDropUp : Icons.Material.Filled.ArrowDropDown)"
                     Size="Size.Small"
                     Class="wis-pager__rpp-chevron" />
        </div>

        @if (_isOpen)
        {
            <div class="wis-pager__rpp-dropdown" @onclick:stopPropagation>
                @foreach (int size in PageSizeOptions)
                {
                    int s = size;
                    <div class="wis-pager__rpp-option @(s == _rowsPerPage ? "wis-pager__rpp-option--active" : "")"
                         @onclick="@(() => SelectSize(s))">
                        @size
                    </div>
                }
            </div>
        }
    </div>

    @if (_isOpen)
    {
        <MudOverlay Visible="true" OnClick="TogglePicker" LockScroll="false" />
    }

    <div class="wis-pager__sep"></div>

    <div class="wis-pager__nav">
        <MudIconButton Icon="@Icons.Material.Filled.FirstPage"
                       Size="Size.Small"
                       Disabled="@(_currentPage == 0)"
                       OnClick="GoFirst"
                       Class="wis-pager__btn" />
        <MudIconButton Icon="@Icons.Material.Filled.ChevronLeft"
                       Size="Size.Small"
                       Disabled="@(_currentPage == 0)"
                       OnClick="GoPrev"
                       Class="wis-pager__btn" />

        <span class="wis-pager__info">@_firstItem–@_lastItem @Localization.GetString("Of") @_totalItems</span>

        <MudIconButton Icon="@Icons.Material.Filled.ChevronRight"
                       Size="Size.Small"
                       Disabled="@(_currentPage >= _lastPage)"
                       OnClick="GoNext"
                       Class="wis-pager__btn" />
        <MudIconButton Icon="@Icons.Material.Filled.LastPage"
                       Size="Size.Small"
                       Disabled="@(_currentPage >= _lastPage)"
                       OnClick="GoLast"
                       Class="wis-pager__btn" />
    </div>

</div>

@code {
    [CascadingParameter] public MudDataGrid<T> DataGrid { get; set; } = null!;
    [Parameter] public int[] PageSizeOptions { get; set; } = [10, 25, 50, 100];

    private bool _isOpen;

    private int _currentPage => DataGrid?.CurrentPage ?? 0;
    private int _rowsPerPage => DataGrid?.RowsPerPage ?? PageSizeOptions[0];
    private int _totalItems => DataGrid?.GetFilteredItemsCount() ?? 0;
    private int _firstItem => _totalItems == 0 ? 0 : _currentPage * _rowsPerPage + 1;
    private int _lastItem => Math.Min((_currentPage + 1) * _rowsPerPage, _totalItems);
    private int _lastPage => _rowsPerPage > 0
        ? (int)Math.Max(0, Math.Ceiling(_totalItems / (double)_rowsPerPage) - 1)
        : 0;

    protected override void OnInitialized()
    {
        if (DataGrid is not null)
            DataGrid.PagerStateHasChangedEvent += OnPagerStateChanged;
    }

    private void OnPagerStateChanged()
        => InvokeAsync(StateHasChanged);

    private void TogglePicker() => _isOpen = !_isOpen;

    private async Task SelectSize(int size)
    {
        _isOpen = false;
        if (DataGrid is not null)
            await DataGrid.SetRowsPerPageAsync(size);
    }

    private void GoFirst() { DataGrid?.NavigateTo(Page.First); }
    private void GoPrev()  { DataGrid?.NavigateTo(Page.Previous); }
    private void GoNext()  { DataGrid?.NavigateTo(Page.Next); }
    private void GoLast()  { DataGrid?.NavigateTo(Page.Last); }

    public void Dispose()
    {
        if (DataGrid is not null)
            DataGrid.PagerStateHasChangedEvent -= OnPagerStateChanged;
    }
}
