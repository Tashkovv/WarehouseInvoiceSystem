@typeparam TValue where TValue : notnull
@using WarehouseInvoiceSystem.Domain.Queries.Common
@inject ILocalizationService Localization
@inject IJSRuntime JS
@implements IAsyncDisposable

@*
    Form-field combobox — same wis-field visual language as WisInput/WisSelect.
    The trigger IS the search input: clicking or typing opens the dropdown and
    filters results server-side. Selecting an item fills the trigger with the
    item label. Blurring without a selection restores the previous label.
    Infinite scroll via JS wisAutocomplete.attachScrollListener.
*@

<div class="wis-field @(FullWidth ? "wis-field--full" : "") @(_isOpen ? "wis-field--focused" : "") @(HasError ? "wis-field--error" : "") @(Disabled ? "wis-field--disabled" : "") @CssClass"
     tabindex="-1"
     @onfocusout="OnFocusOut">
    <label class="wis-field__label @(!string.IsNullOrEmpty(_inputText) || _isOpen ? "wis-field__label--float" : "")">
        @Label
        @if (Required)
        {
            <span class="wis-field__required">*</span>
        }
    </label>

    <div class="wis-field__inner" @onclick="FocusInputAsync">
        <input @ref="_inputRef"
               type="text"
               class="wis-field__input"
               value="@_inputText"
               placeholder="@Localization.GetString("Search")"
               disabled="@Disabled"
               @onfocus="OnFocus"
               @oninput="OnInput"
               @onkeydown="OnKeyDown"
               @onclick:stopPropagation />
        @if (_selectedItem is not null && !Disabled)
        {
            <button type="button"
                    class="wis-ac-input__clear"
                    @onclick="ClearAsync"
                    @onclick:stopPropagation
                    @onmousedown:preventDefault>
                <MudIcon Icon="@Icons.Material.Filled.Close" Size="Size.Small" />
            </button>
        }
        else
        {
            <MudIcon Icon="@Icons.Material.Filled.Search"
                     Size="Size.Small"
                     Class="wis-select__chevron" />
        }
    </div>

    @if (_isOpen)
    {
        <div class="wis-ac-input__dropdown" @onclick:stopPropagation @onmousedown:preventDefault>
            <div id="@_scrollContainerId" class="wis-ac-input__list">
                @if (_loading)
                {
                    <div class="wis-ac-input__status">
                        <MudProgressCircular Size="Size.Small" Indeterminate="true" Color="Color.Primary" />
                    </div>
                }
                else if (_inputText.Length == 1)
                {
                    <MudText Typo="Typo.caption" Color="Color.Secondary" Class="wis-ac-input__status-text">
                        @Localization.GetString("TypeMoreCharacters")
                    </MudText>
                }
                else if (!_items.Any() && !_isLoadingMore)
                {
                    <MudText Typo="Typo.caption" Color="Color.Secondary" Class="wis-ac-input__status-text">
                        @Localization.GetString("NoResults")
                    </MudText>
                }
                else
                {
                    @foreach (WisAutocompleteItem<TValue> item in _items)
                    {
                        bool isSelected = _selectedItem is not null && Equals(_selectedItem.Value, item.Value);
                        var captured = item;
                        <div class="wis-autocomplete-item @(isSelected ? "wis-autocomplete-item--selected" : "")"
                             @onclick="@(() => SelectItemAsync(captured))">
                            <span class="wis-autocomplete-item__label">@captured.Label</span>
                            @if (!string.IsNullOrEmpty(captured.SubLabel))
                            {
                                <span class="wis-autocomplete-item__sublabel">@captured.SubLabel</span>
                            }
                        </div>
                    }

                    @if (_isLoadingMore)
                    {
                        <div class="wis-ac-input__status">
                            <MudProgressCircular Size="Size.Small" Indeterminate="true" Color="Color.Primary" />
                        </div>
                    }
                }
            </div>
        </div>
    }

    @if (HasError && !string.IsNullOrWhiteSpace(ErrorText))
    {
        <div class="wis-field__helper wis-field__helper--error">@ErrorText</div>
    }
    else if (!string.IsNullOrWhiteSpace(HelperText))
    {
        <div class="wis-field__helper">@HelperText</div>
    }
</div>

@code {
    // ── Parameters ────────────────────────────────────────────────────────────

    [Parameter, EditorRequired] public string Label { get; set; } = string.Empty;

    /// <summary>
    /// Server-side data source. Called with (searchTerm, page, cancellationToken).
    /// Return PageSize items per call — the component handles paging and appending.
    /// </summary>
    [Parameter, EditorRequired]
    public Func<string, int, CancellationToken, Task<PagedResult<WisAutocompleteItem<TValue>>>>? LoadItems { get; set; }

    [Parameter] public TValue? SelectedValue { get; set; }
    [Parameter] public EventCallback<TValue?> SelectedValueChanged { get; set; }

    /// <summary>
    /// Optional display label shown in the trigger when SelectedValue is pre-set from
    /// outside before the user ever opens the dropdown. Avoids a silent fetch just to
    /// resolve the label text.
    /// </summary>
    [Parameter] public string? InitialLabel { get; set; }

    [Parameter] public string? HelperText { get; set; }
    [Parameter] public string? ErrorText { get; set; }
    [Parameter] public bool HasError { get; set; }
    [Parameter] public bool Required { get; set; }
    [Parameter] public bool Disabled { get; set; }
    [Parameter] public bool FullWidth { get; set; } = true;
    [Parameter] public string? CssClass { get; set; }
    [Parameter] public int PageSize { get; set; } = 10;
    [Parameter] public int DebounceMs { get; set; } = 300;

    // ── Internal state ────────────────────────────────────────────────────────

    private bool _isOpen;
    private bool _loading;
    private bool _isLoadingMore;
    private bool _hasMore;
    private int _page = 1;
    private string _inputText = string.Empty;
    private List<WisAutocompleteItem<TValue>> _items = [];
    private WisAutocompleteItem<TValue>? _selectedItem;

    private ElementReference _inputRef;
    private CancellationTokenSource _cts = new();
    private Timer? _debounceTimer;
    private DotNetObjectReference<WisAutocompleteInput<TValue>>? _dotNetRef;
    private readonly string _scrollContainerId = $"wis-aci-{Guid.NewGuid():N}";

    // ── Parameter sync ────────────────────────────────────────────────────────

    protected override async Task OnParametersSetAsync()
    {
        if (SelectedValue is null || SelectedValue.Equals(default(TValue)))
        {
            _selectedItem = null;
            if (!_isOpen) _inputText = string.Empty;
        }
        else if (_selectedItem is null)
        {
            if (!string.IsNullOrEmpty(InitialLabel))
            {
                _selectedItem = new WisAutocompleteItem<TValue> { Value = SelectedValue, Label = InitialLabel };
                _inputText = InitialLabel;
            }
            else
            {
                await FetchLabelAsync(SelectedValue);
            }
        }
    }

    private async Task FetchLabelAsync(TValue value)
    {
        if (LoadItems is null) return;
        try
        {
            var cts = new CancellationTokenSource();
            var result = await LoadItems("", 1, cts.Token);
            _selectedItem = result.Items.FirstOrDefault(i => Equals(i.Value, value));
            _inputText = _selectedItem?.Label ?? string.Empty;
        }
        catch { }
    }

    // ── Focus / Open ──────────────────────────────────────────────────────────

    private async Task OnFocus()
    {
        if (_isOpen) return;
        await OpenAsync();
    }

    private async Task FocusInputAsync()
    {
        if (Disabled) return;
        await _inputRef.FocusAsync();
    }

    private async Task OpenAsync()
    {
        _isOpen = true;
        await FetchPageAsync(_inputText, 1, replace: true);
        await Task.Delay(50);
        _dotNetRef ??= DotNetObjectReference.Create(this);
        await JS.InvokeVoidAsync("wisAutocomplete.attachScrollListener", _scrollContainerId, _dotNetRef, 40);
    }

    // ── Close / FocusOut ──────────────────────────────────────────────────────

    private void OnFocusOut(FocusEventArgs e)
    {
        _isOpen = false;
        _debounceTimer?.Change(Timeout.Infinite, Timeout.Infinite);
        // Restore the displayed text to the committed selection
        _inputText = _selectedItem?.Label ?? string.Empty;
        _ = JS.InvokeVoidAsync("wisAutocomplete.removeScrollListener", _scrollContainerId);
    }

    // ── Search / Input ────────────────────────────────────────────────────────

    private void OnInput(ChangeEventArgs e)
    {
        _inputText = e.Value?.ToString() ?? string.Empty;
        _debounceTimer?.Dispose();

        if (_inputText.Length == 1)
        {
            _items = [];
            StateHasChanged();
            return;
        }

        _debounceTimer = new Timer(async _ =>
        {
            await InvokeAsync(async () =>
                await FetchPageAsync(_inputText, 1, replace: true));
        }, null, DebounceMs, Timeout.Infinite);
    }

    // ── Infinite scroll (called from JS) ─────────────────────────────────────

    [JSInvokable]
    public async Task OnScrolledToBottom()
    {
        if (_isLoadingMore || !_hasMore) return;
        await FetchPageAsync(_inputText, _page + 1, replace: false);
    }

    // ── Core fetch ────────────────────────────────────────────────────────────

    private async Task FetchPageAsync(string searchTerm, int page, bool replace)
    {
        if (LoadItems is null) return;

        await _cts.CancelAsync();
        _cts = new CancellationTokenSource();
        var token = _cts.Token;

        if (replace) { _loading = true; _items = []; }
        else { _isLoadingMore = true; }
        StateHasChanged();

        try
        {
            var result = await LoadItems(searchTerm, page, token);
            if (token.IsCancellationRequested) return;

            if (replace) _items = result.Items;
            else _items.AddRange(result.Items);

            _page = result.Page;
            _hasMore = result.Page < result.TotalPages;

            if (SelectedValue is not null && _selectedItem is null)
            {
                _selectedItem = _items.FirstOrDefault(i => Equals(i.Value, SelectedValue));
                if (_selectedItem is not null) _inputText = _selectedItem.Label;
            }
        }
        catch (OperationCanceledException) { }
        finally
        {
            if (!token.IsCancellationRequested)
            {
                _loading = false;
                _isLoadingMore = false;
                StateHasChanged();
            }
        }
    }

    // ── Selection ─────────────────────────────────────────────────────────────

    private async Task SelectItemAsync(WisAutocompleteItem<TValue> item)
    {
        _selectedItem = item;
        _inputText = item.Label;
        _isOpen = false;
        await SelectedValueChanged.InvokeAsync(item.Value);
    }

    private async Task ClearAsync()
    {
        _selectedItem = null;
        _inputText = string.Empty;
        _isOpen = false;
        await SelectedValueChanged.InvokeAsync(default);
    }

    private void OnKeyDown(KeyboardEventArgs e)
    {
        if (Disabled) return;
        if (e.Key == "Escape") _isOpen = false;
    }

    // ── Disposal ──────────────────────────────────────────────────────────────

    public async ValueTask DisposeAsync()
    {
        _debounceTimer?.Dispose();
        _cts.Cancel();
        _cts.Dispose();

        if (_dotNetRef is not null)
        {
            try { await JS.InvokeVoidAsync("wisAutocomplete.removeScrollListener", _scrollContainerId, CancellationToken.None); }
            catch (JSDisconnectedException) { }
            catch (OperationCanceledException) { }
            catch { }
            _dotNetRef.Dispose();
        }
    }
}
