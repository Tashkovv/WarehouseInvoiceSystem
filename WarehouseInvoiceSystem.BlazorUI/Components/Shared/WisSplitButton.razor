@inject IJSRuntime JS
@inject ILocalizationService Localization

@if (PrimaryAction is not null || (Actions is not null && Actions.Count > 0))
{
    <div style="position: relative; display: inline-flex;" @ref="_container">

        @* ── Split button: primary + arrow ── *@
        @if (PrimaryAction is not null && Actions is not null && Actions.Count > 0)
        {
            <div class="wis-split-btn @GetColorClass(PrimaryAction.Color)" data-wis-split-btn="true">
                <button class="wis-split-btn__primary @(PrimaryAction.Disabled ? "wis-split-btn__primary--disabled" : "")"
                        type="button"
                        disabled="@PrimaryAction.Disabled"
                        title="@(PrimaryAction.Disabled? PrimaryAction.DisabledReason ?? string.Empty : string.Empty)"
                        @onclick="PrimaryAction.OnClick">
                    @if (!string.IsNullOrEmpty(PrimaryAction.Icon))
                    {
                        <span class="wis-split-btn__icon">
                            <MudIcon Icon="@PrimaryAction.Icon" Size="Size.Small" />
                        </span>
                    }
                    <span>@PrimaryAction.Label</span>
                </button>

                <div class="wis-split-btn__divider"></div>

                <button class="wis-split-btn__arrow"
                        type="button"
                        @onclick="ToggleDropdown">
                    @ChevronSvg
                </button>
            </div>
        }

        @* ── Primary only ── *@
        else if (PrimaryAction is not null)
        {
            <WisButton Action="@PrimaryAction" />
        }

        @* ── Dropdown only ── *@
        else if (Actions is not null && Actions.Count > 0)
        {
            <button class="wis-split-btn__primary @(HideLabel ? "wis-split-btn__primary--icon-only" : "wis-split-btn__primary--solo")"
                    type="button"
                    @onclick="ToggleDropdown">
                @if (!HideLabel)
                {
                    <span>@Localization.GetString("Actions")</span>
                }
                <span class="wis-split-btn__icon">
                    @ChevronSvg
                </span>
            </button>
        }

        @* ── Overlay + Popover ── *@
        @if (_open)
        {
            <MudOverlay Visible="true"
                        OnClick="CloseDropdown"
                        ZIndex="1399"
                        AutoClose="false" />
        }

        <MudPopover Open="_open"
                    AnchorOrigin="@AnchorOrigin"
                    TransformOrigin="@TransformOrigin"
                    Paper="true"
                    Class="wis-split-btn__popover"
                    Style="@($"z-index: 1400; min-width: {_buttonWidth}px;")">
            @if (Actions is not null)
            {
                foreach (WisDetailActionItem item in Actions)
                {
                    @if (item.IsDividerBefore)
                    {
                        <MudDivider />
                    }
                    <button class="wis-split-btn__menu-item @(item.Disabled ? "wis-split-btn__menu-item--disabled" : "")"
                            type="button"
                            disabled="@item.Disabled"
                            title="@(item.Disabled ? item.DisabledReason ?? string.Empty : string.Empty)"
                            @onclick="@(() => OnMenuItemClick(item))">
                        <span class="wis-split-btn__menu-icon">
                            <MudIcon Icon="@item.Icon"
                                     Size="Size.Small"
                                     Color="@(item.Disabled ? Color.Default : item.Color)" />
                        </span>
                        <span class="@(item.Disabled ? "" : GetTextColorClass(item.Color))">
                            @item.Label
                        </span>
                    </button>
                }
            }
        </MudPopover>

    </div>
}

@code {
    [Parameter] public WisDetailActionItem? PrimaryAction { get; set; }
    [Parameter] public List<WisDetailActionItem>? Actions { get; set; }

    /// <summary>
    /// Where the popover anchors on the button. Default: BottomRight (detail header).
    /// Use BottomLeft for toolbar buttons so the menu opens leftward under the button.
    /// </summary>
    [Parameter] public Origin AnchorOrigin { get; set; } = Origin.BottomRight;
    [Parameter] public Origin TransformOrigin { get; set; } = Origin.TopRight;
    [Parameter] public bool HideLabel { get; set; }

    private bool _open;
    private ElementReference _container;
    private double _buttonWidth = 180;

    private RenderFragment ChevronSvg =>
        @<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            @if (_open)
            {
                    <path d="M7 14l5-5 5 5" />
            }
            else
            {
                    <path d="M7 10l5 5 5-5" />
            }
        </svg>;

private async Task ToggleDropdown()
{
_open = !_open;
if (_open)
{
try
{
double w = await JS.InvokeAsync<double>(
"eval", "document.querySelector('[data-wis-split-btn]')?.offsetWidth ?? 180");
if (w > 0) _buttonWidth = w;
}
catch { /* fallback */ }
}
}

private void CloseDropdown() => _open = false;

private async Task OnMenuItemClick(WisDetailActionItem item)
{
_open = false;
await item.OnClick.InvokeAsync();
}

private static string GetColorClass(Color color) => color switch
{
Color.Success   => "wis-btn-color--success",
Color.Error     => "wis-btn-color--error",
Color.Warning   => "wis-btn-color--warning",
Color.Info      => "wis-btn-color--info",
Color.Secondary => "wis-btn-color--secondary",
_               => "wis-btn-color--primary"
};

private static string GetTextColorClass(Color color) => color switch
{
Color.Error   => "wis-text-error",
Color.Success => "wis-text-success",
Color.Warning => "wis-text-warning",
Color.Info    => "wis-text-info",
_             => ""
};
}
