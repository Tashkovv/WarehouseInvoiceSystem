@using WarehouseInvoiceSystem.Application.DTOs.Product
@using WarehouseInvoiceSystem.Application.DTOs.StockLevel
@using WarehouseInvoiceSystem.Domain.Queries
@using WarehouseInvoiceSystem.Domain.Queries.Common
@inject IProductService ProductService
@inject ILocalizationService Localization

@* ── Read-only view ── *@
@if (ReadOnly)
{
    <MudTable Items="Items"
              Hover="true"
              Elevation="0"
              Class="wis-secondary-list">
        <HeaderContent>
            <MudTh>@Localization.GetString("Product")</MudTh>
            <MudTh Class="text-right">@Localization.GetString("Quantity")</MudTh>
            <MudTh Class="text-right">@Localization.GetString("UnitPrice")</MudTh>
            <MudTh Class="text-right">@Localization.GetString("TaxRate")</MudTh>
            @if (Type == InvoiceType.Receivable)
            {
                <MudTh Class="text-right">@Localization.GetString("Discount")</MudTh>
            }
            <MudTh Class="text-right">@Localization.GetString("Amount")</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="@Localization.GetString("Product")">
                <MudText Typo="Typo.body2">
                    @context.SelectedProduct?.Code - @context.SelectedProduct?.Name
                </MudText>
                @if (!string.IsNullOrWhiteSpace(context.Description))
                {
                    <MudText Typo="Typo.caption" Color="Color.Secondary">@context.Description</MudText>
                }
            </MudTd>
            <MudTd DataLabel="@Localization.GetString("Quantity")" Class="text-right">
                <MudText Typo="Typo.body2">
                    @context.Quantity.ToString("N0") @context.SelectedProduct?.Unit
                </MudText>
            </MudTd>
            <MudTd DataLabel="@Localization.GetString("UnitPrice")" Class="text-right">
                <MudText Typo="Typo.body2">@context.UnitPrice.ToString("C")</MudText>
            </MudTd>
            <MudTd DataLabel="@Localization.GetString("TaxRate")" Class="text-right">
                <MudText Typo="Typo.body2">@context.TaxRate.ToString("N0")%</MudText>
            </MudTd>
            @if (Type == InvoiceType.Receivable)
            {
                <MudTd DataLabel="@Localization.GetString("Discount")" Class="text-right">
                    <MudText Typo="Typo.body2">@context.DiscountPercentage.ToString("N0")%</MudText>
                </MudTd>
            }
            <MudTd DataLabel="@Localization.GetString("Amount")" Class="text-right">
                <MudText Typo="Typo.body2" Color="Color.Primary">@context.LineTotal.ToString("C")</MudText>
            </MudTd>
        </RowTemplate>
        <NoRecordsContent>
            <MudText Typo="Typo.body2" Color="Color.Secondary" Class="pa-4">
                @Localization.GetString("AddLineItems")
            </MudText>
        </NoRecordsContent>
    </MudTable>
}
else
{
    @* ── Edit view ── *@
    <div class="wis-li-editor pa-3">

        @* Header row *@
        <div class="wis-li-header">
            <div class="wis-li-col-product">@Localization.GetString("Product")</div>
            @if (Type == InvoiceType.Receivable && Items.Any(i => i.SelectedProduct != null))
            {
                <div class="wis-li-col-stock">@Localization.GetString("Available")</div>
            }
            <div class="wis-li-col-qty">@Localization.GetString("Quantity")</div>
            <div class="wis-li-col-price">@Localization.GetString("UnitPrice")</div>
            <div class="wis-li-col-tax">@Localization.GetString("TaxRate")</div>
            @if (Type == InvoiceType.Receivable)
            {
                <div class="wis-li-col-disc">@Localization.GetString("Discount")</div>
            }
            <div class="wis-li-col-total">@Localization.GetString("Amount")</div>
            <div class="wis-li-col-del"></div>
        </div>

        @* Data rows *@
        @foreach (var item in Items)
        {
            var captured = item;
            bool showStock = Type == InvoiceType.Receivable && Items.Any(i => i.SelectedProduct != null);

            <div class="wis-li-row">
                <div class="wis-li-col-product">
                    <WisAutocompleteInput TValue="Guid"
                                          SelectedValue="@(captured.SelectedProduct?.Id ?? Guid.Empty)"
                                          SelectedValueChanged="@(id => OnProductSelectedById(captured, id))"
                                          LoadItems="LoadProductItems"
                                          InitialLabel="@(captured.SelectedProduct != null ? $"{captured.SelectedProduct.Code} - {captured.SelectedProduct.Name}" : null)"
                                          FullWidth="true" />
                </div>

                @if (showStock)
                {
                    <div class="wis-li-col-stock">
                        @if (captured.SelectedProduct != null)
                        {
                            var itemStock = GetStockLevel(captured.SelectedProduct.Id);
                            <MudChip T="string"
                                     Size="Size.Small"
                                     Color="@(itemStock != null ? GetStockColor(itemStock) : Color.Error)"
                                     Variant="Variant.Outlined">
                                @($"{(itemStock?.AvailableQuantity ?? 0m):N0} {captured.SelectedProduct.Unit}")
                            </MudChip>
                        }
                    </div>
                }

                <div class="wis-li-col-qty">
                    <WisAmountInput Value="@((decimal?)captured.Quantity)"
                                    ValueChanged="@(v => { captured.Quantity = v ?? 0; CalculateTotals(); })"
                                    AdornmentText="@(captured.SelectedProduct?.Unit ?? "")"
                                    FullWidth="true" />
                </div>

                <div class="wis-li-col-price">
                    <WisAmountInput Value="@((decimal?)captured.UnitPrice)"
                                    ValueChanged="@(v => { captured.UnitPrice = v ?? 0; CalculateTotals(); })"
                                    AdornmentText="@Localization.CurrencySymbol"
                                    FullWidth="true" />
                </div>

                <div class="wis-li-col-tax">
                    <WisAmountInput Value="@((decimal?)captured.TaxRate)"
                                    ValueChanged="@(v => OnTaxRateChanged(captured, v ?? 0))"
                                    AdornmentText="%"
                                    FullWidth="true" />
                </div>

                @if (Type == InvoiceType.Receivable)
                {
                    <div class="wis-li-col-disc">
                        <WisAmountInput Value="@((decimal?)captured.DiscountPercentage)"
                                        ValueChanged="@(v => { captured.DiscountPercentage = Math.Clamp(v ?? 0, 0, 100); CalculateTotals(); })"
                                        AdornmentText="%"
                                        FullWidth="true" />
                    </div>
                }

                <div class="wis-li-col-total">
                    <MudText Typo="Typo.body1" Color="Color.Primary" Class="font-weight-medium tabular-numbers">
                        @captured.LineTotal.ToString("C")
                    </MudText>
                </div>

                <div class="wis-li-col-del">
                    <MudIconButton Icon="@Icons.Material.Outlined.Delete"
                                   Color="Color.Error"
                                   Size="Size.Small"
                                   OnClick="@(() => RemoveItem(captured))" />
                </div>
            </div>
        }

        @* Add row button *@
        <div class="d-flex justify-start pt-2">
            <WisButton Action="@(new WisDetailActionItem
                               {
                                   Icon = Icons.Material.Filled.Add,
                                   Label = Localization.GetString("AddItem"),
                                   OnClick = EventCallback.Factory.Create(this, AddItem),
                                   Color = Color.Info
                               })"
                       ButtonSize="Size.Small" />
        </div>

    </div>
}

@code {
    [Parameter, EditorRequired] public InvoiceType Type { get; set; }
    [Parameter, EditorRequired] public Guid WarehouseId { get; set; }
    [Parameter] public Dictionary<Guid, StockLevelDto> StockByProduct { get; set; } = [];
    [Parameter] public List<LineItemEditorModel> Items { get; set; } = [];
    [Parameter] public EventCallback<List<LineItemEditorModel>> ItemsChanged { get; set; }
    [Parameter] public bool ReadOnly { get; set; }

    private decimal _subtotal;
    private decimal _discountTotal;
    private decimal _taxAmount;
    private decimal _total;

    private readonly Dictionary<Guid, ProductDto> _productCache = [];

    protected override void OnParametersSet() => CalculateTotals();

    private async Task<PagedResult<WisAutocompleteItem<Guid>>> LoadProductItems(
        string search, int page, CancellationToken ct)
    {
        GetProductsQuery query = new() { Page = page, PageSize = 20, IsActive = true };
        if (!string.IsNullOrWhiteSpace(search)) query.Search = search;
        PagedResult<ProductDto> result = await ProductService.GetPagedAsync(query, ct);

        foreach (ProductDto p in result.Items)
            _productCache[p.Id] = p;

        IEnumerable<ProductDto> items = result.Items;
        if (Type == InvoiceType.Receivable && StockByProduct.Count > 0)
            items = items.OrderBy(p => GetStockLevel(p.Id)?.AvailableQuantity == 0m ? 1 : 0);

        return new PagedResult<WisAutocompleteItem<Guid>>
        {
            Items = items.Select(p =>
            {
                StockLevelDto? stock = GetStockLevel(p.Id);
                string subLabel = p.Unit;
                if (Type == InvoiceType.Receivable && stock != null)
                    subLabel += $"  ·  {stock.AvailableQuantity:N0} {Localization.GetString("Available").ToLower()}";
                return new WisAutocompleteItem<Guid>
                {
                    Value = p.Id,
                    Label = $"{p.Code} - {p.Name}",
                    SubLabel = subLabel,
                };
            }).ToList(),
            Page = result.Page,
            PageSize = result.PageSize,
            TotalCount = result.TotalCount,
        };
    }

    private void OnProductSelectedById(LineItemEditorModel item, Guid? id)
    {
        Guid productId = id ?? Guid.Empty;
        if (productId == Guid.Empty)
        {
            OnProductSelected(item, null);
            return;
        }
        if (_productCache.TryGetValue(productId, out ProductDto? product))
            OnProductSelected(item, product);
    }

    private void OnProductSelected(LineItemEditorModel item, ProductDto? product)
    {
        item.SelectedProduct = product;
        if (product is null) return;
        item.Description = product.Description ?? string.Empty;
        item.UnitPrice = Type == InvoiceType.Receivable ? product.SellingPrice : product.CostPrice;
        CalculateTotals();
    }

    private void OnTaxRateChanged(LineItemEditorModel item, decimal value)
    {
        item.TaxRate = Math.Clamp(value, 0m, 100m);
        CalculateTotals();
    }

    private async Task AddItem()
    {
        Items.Add(new LineItemEditorModel());
        await ItemsChanged.InvokeAsync(Items);
    }

    private async Task RemoveItem(LineItemEditorModel item)
    {
        Items.Remove(item);
        CalculateTotals();
        await ItemsChanged.InvokeAsync(Items);
    }

    private void CalculateTotals()
    {
        _subtotal = Items.Sum(i => i.Quantity * i.UnitPrice);
        _discountTotal = Items.Sum(i => (i.Quantity * i.UnitPrice) * (i.DiscountPercentage / 100m));
        _taxAmount = Items.Sum(i =>
        {
            decimal net = (i.Quantity * i.UnitPrice) * (1 - i.DiscountPercentage / 100m);
            return net * (i.TaxRate / 100m);
        });
        _total = _subtotal - _discountTotal + _taxAmount;
    }

    private StockLevelDto? GetStockLevel(Guid productId)
        => StockByProduct.TryGetValue(productId, out StockLevelDto? s) ? s : null;

    private static Color GetStockColor(StockLevelDto stock)
    {
        if (stock.AvailableQuantity == 0m) return Color.Error;
        if (stock.MinimumQuantity.HasValue && stock.AvailableQuantity <= stock.MinimumQuantity.Value) return Color.Warning;
        return Color.Success;
    }
}
