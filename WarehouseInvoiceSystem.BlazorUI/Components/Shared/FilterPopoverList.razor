@typeparam TValue

<div style="position: relative; display: inline-flex; align-items: center;">

    @* Labeled trigger (toolbar mode) vs icon-only trigger (legacy/header mode) *@
    @if (Label is not null)
    {
        <button class="wis-filter-btn @(_isFilterActive ? "wis-filter-btn--active" : "") @(_isFilterActive && _selectedItem is not null ? GetColorClass(_selectedItem.Color) : "")"
                @onclick="TogglePopover"
                type="button">
            <span class="wis-filter-btn__label @(_isFilterActive ? "wis-filter-btn__label--selected" : "")">
                @(_selectedItem is not null ? _selectedItem.Label : Label)
            </span>
            <span class="wis-filter-btn__icon">
                <MudIcon Icon="@Icons.Material.Filled.ArrowDropDown"
                         Size="Size.Small" />
            </span>
        </button>
    }
    else
    {
        <MudIconButton Icon="@Icons.Material.Filled.FilterList"
                       Size="Size.Small"
                       Color="@(_isFilterActive ? Color.Primary : Color.Default)"
                       OnClick="TogglePopover" />
    }

    @if (_open)
    {
        <MudOverlay Visible="true"
                    OnClick="Close"
                    ZIndex="1399"
                    AutoClose="false" />
    }

    <MudPopover Open="_open"
                AnchorOrigin="@PopoverAnchorOrigin"
                TransformOrigin="@PopoverTransformOrigin"
                Fixed="true"
                Paper="true"
                Class="pa-3"
                Style="z-index: 1400; min-width: 180px;">
        <MudStack Spacing="0">
            <div style="max-height: 260px; overflow-y: auto;">
                @if (Mode == FilterSelectionMode.Single)
                {
                    <MudRadioGroup T="TValue"
                                   Value="_singleValue"
                                   ValueChanged="OnSingleValueChanged"
                                   Class="filter-radio-group">
                        @foreach (FilterPopoverItem<TValue> item in Items)
                        {
                            <div class="d-flex align-center py-1 px-1 rounded"
                                 style="gap: 8px; cursor: pointer;"
                                 @onclick="@(() => OnSingleValueChanged(item.Value))">
                                <MudRadio T="TValue"
                                          Value="item.Value"
                                          Dense="true"
                                          Class="ma-0 pa-0"
                                          @onclick:stopPropagation />
                                <MudChip T="string"
                                         Size="Size.Small"
                                         Color="item.Color"
                                         Variant="@FilterVariant"
                                         Icon="@item.Icon"
                                         Class="ma-0">
                                    @item.Label
                                </MudChip>
                            </div>
                        }
                    </MudRadioGroup>
                }
                else
                {
                    @foreach (FilterPopoverItem<TValue> item in Items)
                    {
                        bool isChecked = _multiValues.Contains(item.Value);
                        <div class="d-flex align-center py-1 px-1 rounded"
                             style="gap: 8px; cursor: pointer;">
                            <MudCheckBox T="bool"
                                         Value="isChecked"
                                         ValueChanged="@((v) => OnMultiValueChanged(item.Value, v))"
                                         Dense="true"
                                         Class="ma-0 pa-0" />
                            <MudChip T="string"
                                     Size="Size.Small"
                                     Color="item.Color"
                                     Variant="@FilterVariant"
                                     Icon="@item.Icon"
                                     Class="ma-0"
                                     OnClick="@(() => OnMultiValueChanged(item.Value, !isChecked))">
                                @item.Label
                            </MudChip>
                        </div>
                    }
                }
            </div>
        </MudStack>
    </MudPopover>
</div>

@code {
    /// <summary>  When set, renders a labeled pill button instead of a bare icon. </summary>
    [Parameter]
    public string? Label { get; set; }

    [Parameter, EditorRequired]
    public IEnumerable<FilterPopoverItem<TValue>> Items { get; set; } = [];

    [Parameter]
    public FilterSelectionMode Mode { get; set; } = FilterSelectionMode.Single;

    // Single select
    [Parameter]
    public TValue? SelectedValue { get; set; }

    [Parameter]
    public EventCallback<TValue?> SelectedValueChanged { get; set; }

    // Multi select
    [Parameter]
    public IReadOnlyCollection<TValue> SelectedValues { get; set; } = [];

    [Parameter]
    public EventCallback<IReadOnlyCollection<TValue>> SelectedValuesChanged { get; set; }

    /// <summary>Controls which edge of the trigger the popover anchors to. Default: BottomLeft.</summary>
    [Parameter]
    public Origin PopoverAnchorOrigin { get; set; } = Origin.BottomLeft;

    /// <summary>Controls which edge of the popover aligns to the anchor. Default: TopLeft.</summary>
    [Parameter]
    public Origin PopoverTransformOrigin { get; set; } = Origin.TopLeft;

    /// <summary> Controls what is the variant type of the mud chip. Default: Variant.Filled. </summary>
    [Parameter]
    public Variant FilterVariant { get; set; } = Variant.Filled;

    private bool _open = false;
    private TValue? _singleValue;
    private List<TValue?> _multiValues = [];

    private bool _isFilterActive => Mode == FilterSelectionMode.Single
        ? !Equals(_singleValue, default(TValue))
        : _multiValues.Count > 0;

    // Resolved selected item — non-null whenever something is selected, including the default item
    private FilterPopoverItem<TValue>? _selectedItem =>
        Mode == FilterSelectionMode.Single && _singleValue is not null
            ? Items.FirstOrDefault(i => Equals(i.Value, _singleValue))
            : null;

    protected override void OnParametersSet()
    {
        _singleValue = SelectedValue;
        _multiValues = SelectedValues?.Cast<TValue?>().ToList() ?? [];
    }

    private static string GetColorClass(Color color) => color switch
    {
        Color.Success => "wis-filter-btn--success",
        Color.Warning => "wis-filter-btn--warning",
        Color.Error => "wis-filter-btn--error",
        Color.Info => "wis-filter-btn--info",
        Color.Primary => "wis-filter-btn--primary",
        _ => ""
    };

    private void TogglePopover() => _open = !_open;
    private void Close() => _open = false;

    private async Task OnSingleValueChanged(TValue value)
    {
        // Toggle off if already selected
        if (Equals(_singleValue, value) && _isFilterActive)
        {
            _singleValue = default;
            _open = false;
            await SelectedValueChanged.InvokeAsync(default);
            return;
        }

        _singleValue = value;
        _open = false;
        await SelectedValueChanged.InvokeAsync(value);
    }

    private async Task OnMultiValueChanged(TValue value, bool isChecked)
    {
        if (isChecked)
        {
            if (!_multiValues.Contains(value))
                _multiValues.Add(value);
        }
        else
        {
            _multiValues.Remove(value);
        }

        await SelectedValuesChanged.InvokeAsync(_multiValues.Cast<TValue>().ToList().AsReadOnly());
    }
}
