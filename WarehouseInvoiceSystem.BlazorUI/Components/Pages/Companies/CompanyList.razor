@page "/companies"
@implements IDisposable
@using WarehouseInvoiceSystem.Application.DTOs.Company
@using WarehouseInvoiceSystem.Domain.Queries
@using WarehouseInvoiceSystem.Domain.Queries.Common
@using WarehouseInvoiceSystem.Domain.Enums
@inject ICompanyService CompanyService
@inject ILocalizationService Localization
@inject NavigationManager Navigation
@inject IDialogService DialogService
@inject ISnackbar Snackbar

<PageTitle>@Localization.GetString("Companies") - @Localization.GetString("InvoiceSystem")</PageTitle>

<div class="wis-page-header">
    <MudText Typo="Typo.h3" Class="wis-page-title">
        @Localization.GetString("Companies")
    </MudText>
</div>

<WisGridToolbar CreateAction="OpenCreateDialog"
                CreateLabel="@Localization.GetString("Company")"
                SearchValue="@_searchString"
                SearchValueChanged="OnSearch"
                HasAnyActiveFilter="@(_filterType.HasValue || _filterIsActive.HasValue)"
                OnClearAll="ClearAllFilters">
    <Filters>
        <FilterPopoverList TValue="CompanyType?"
                           Label="@Localization.GetString("Type")"
                           Items="_typeFilterItems"
                           Mode="FilterSelectionMode.Single"
                           SelectedValue="_filterType"
                           SelectedValueChanged="OnTypeFilterChanged" />
        <FilterPopoverList TValue="bool?"
                           Label="@Localization.GetString("Status")"
                           Items="_statusFilterItems"
                           Mode="FilterSelectionMode.Single"
                           SelectedValue="_filterIsActive"
                           SelectedValueChanged="OnStatusFilterChanged" />
    </Filters>
</WisGridToolbar>

<MudCard Elevation="2" Class="mb-4">
    <MudCardContent Class="pa-0">
        <MudDataGrid T="CompanyDto"
                     @ref="_grid"
                     ServerData="LoadServerData"
                     RowClick="OnRowClick"
                     RowClassFunc="GetRowClass"
                     ReadOnly="true"
                     Hover="true"
                     FixedHeader="true"
                     Height="100%"
                     Filterable="false"
                     ShowColumnOptions="false"
                     ColumnResizeMode="ResizeMode.Column"
                     SortMode="SortMode.Single"
                     Class="wis-data-grid">
            <Columns>

                <PropertyColumn Property="x => x.Name"
                                Title="@Localization.GetString("Name")"
                                Sortable="true"
                                IsEditable="false"
                                CellClass="wis-cell-primary" />

                <PropertyColumn Property="x => x.Type"
                                Title="@Localization.GetString("Type")"
                                Sortable="false"
                                IsEditable="false">
                    <CellTemplate>
                        <MudChip T="string"
                                 Size="Size.Small"
                                 Color="@GetTypeColor(context.Item.Type)">
                            @GetTypeText(context.Item.Type)
                        </MudChip>
                    </CellTemplate>
                </PropertyColumn>

                <PropertyColumn Property="x => x.ContactPerson"
                                Title="@Localization.GetString("ContactPerson")"
                                Sortable="true"
                                IsEditable="false" />

                <PropertyColumn Property="x => x.Email"
                                Title="@Localization.GetString("Email")"
                                Sortable="true"
                                IsEditable="false" />

                <PropertyColumn Property="x => x.Phone"
                                Title="@Localization.GetString("Phone")"
                                Sortable="false"
                                IsEditable="false" />

                <PropertyColumn Property="x => x.IsActive"
                                Title="@Localization.GetString("Status")"
                                Sortable="false"
                                IsEditable="false">
                    <CellTemplate>
                        <MudChip T="string"
                                 Size="Size.Small"
                                 Color="@(context.Item.IsActive ? Color.Success : Color.Default)">
                            @(context.Item.IsActive ? Localization.GetString("ActiveCompany")
                                                        : Localization.GetString("InactiveCompany"))
                        </MudChip>
                    </CellTemplate>
                </PropertyColumn>

                <TemplateColumn Sortable="false"
                                Filterable="false"
                                IsEditable="false"
                                HeaderClass="wis-col-actions-2"
                                CellClass="wis-col-actions-2">
                    <CellTemplate>
                        <MudStack Row="true" Spacing="0">
                            <MudIconButton Icon="@Icons.Material.Filled.Edit"
                                           Size="Size.Small"
                                           Color="Color.Primary"
                                           Title="@Localization.GetString("Edit")"
                                           OnClick="@(() => OpenEditDialog(context.Item))" />
                            <MudIconButton Icon="@Icons.Material.Filled.Receipt"
                                           Size="Size.Small"
                                           Color="Color.Secondary"
                                           Title="@Localization.GetString("ViewInvoices")"
                                           OnClick="@(() => ViewCompanyInvoices(context.Item.Id))" />
                        </MudStack>
                    </CellTemplate>
                </TemplateColumn>

            </Columns>

            <NoRecordsContent>
                <WisNoRecordsContent Icon="@Icons.Material.Filled.Business"
                                     Message="@Localization.GetString("NoCompaniesFound")" />
            </NoRecordsContent>

            <LoadingContent>
                <WisLoadingContent />
            </LoadingContent>

            <PagerContent>
                <WisPagerContent T="CompanyDto" />
            </PagerContent>

        </MudDataGrid>
    </MudCardContent>
</MudCard>

@code {
    private MudDataGrid<CompanyDto> _grid = null!;
    private string _searchString = string.Empty;
    private CompanyType? _filterType = null;
    private bool? _filterIsActive = null;

    private List<FilterPopoverItem<CompanyType?>> _typeFilterItems = [];
    private List<FilterPopoverItem<bool?>> _statusFilterItems = [];

    protected override void OnInitialized()
    {
        Localization.OnLanguageChanged += OnLanguageChanged;
        BuildFilterItems();
    }

    private void BuildFilterItems()
    {
        _typeFilterItems =
        [
            new() { Label = Localization.GetString("All"),             Value = null,               Color = Color.Info  },
            new() { Label = Localization.GetString("Client"),          Value = CompanyType.Client, Color = Color.Success  },
            new() { Label = Localization.GetString("Vendor"),          Value = CompanyType.Vendor, Color = Color.Warning  },
            new() { Label = Localization.GetString("ClientAndVendor"), Value = CompanyType.Both,   Color = Color.Primary  },
        ];

        _statusFilterItems =
        [
            new() { Label = Localization.GetString("All"),             Value = null,  Color = Color.Info },
            new() { Label = Localization.GetString("ActiveCompany"),   Value = true,  Color = Color.Success },
            new() { Label = Localization.GetString("InactiveCompany"), Value = false, Color = Color.Default },
        ];
    }

    private async void OnLanguageChanged()
    {
        BuildFilterItems();
        await InvokeAsync(StateHasChanged);
    }

    private async Task<GridData<CompanyDto>> LoadServerData(GridState<CompanyDto> state, CancellationToken ct)
    {
        string? sortBy = state.SortDefinitions.FirstOrDefault()?.SortBy;
        bool ascending = state.SortDefinitions.FirstOrDefault()?.Descending == false;

        GetCompaniesQuery query = new()
        {
            Page = state.Page + 1,
            PageSize = state.PageSize,
            SortBy = sortBy,
            SortAscending = ascending,
            Search = _searchString,
            Type = _filterType,
            IsActive = _filterIsActive
        };

        PagedResult<CompanyDto> result = await CompanyService.GetPagedAsync(query);

        return new GridData<CompanyDto>
        {
            Items = result.Items,
            TotalItems = result.TotalCount
        };
    }

    private string GetRowClass(CompanyDto item, int index) => item.Type switch
    {
        CompanyType.Client => "row-status-success",
        CompanyType.Vendor => "row-status-warning",
        CompanyType.Both => "row-status-primary",
        _ => "row-status-default"
    };

    private Color GetTypeColor(CompanyType type) => type switch
    {
        CompanyType.Client => Color.Success,
        CompanyType.Vendor => Color.Warning,
        CompanyType.Both => Color.Primary,
        _ => Color.Default
    };

    private string GetTypeText(CompanyType type) => type switch
    {
        CompanyType.Client => Localization.GetString("Client"),
        CompanyType.Vendor => Localization.GetString("Vendor"),
        CompanyType.Both => Localization.GetString("ClientAndVendor"),
        _ => type.ToString()
    };

    private async Task OnSearch(string text)
    {
        _searchString = text;
        await _grid.ReloadServerData();
    }

    private async Task OnTypeFilterChanged(CompanyType? value)
    {
        _filterType = value;
        await _grid.ReloadServerData();
    }

    private async Task OnStatusFilterChanged(bool? value)
    {
        _filterIsActive = value;
        await _grid.ReloadServerData();
    }

    private async void OnRowClick(DataGridRowClickEventArgs<CompanyDto> args)
    {
        if (args.MouseEventArgs.Detail == 2)
            Navigation.NavigateTo($"/companies/{args.Item.Id}");
    }

    private void ViewCompanyInvoices(Guid id) =>
        Navigation.NavigateTo($"/invoices?companyId={id}");

    private async Task OpenCreateDialog()
    {
        DialogOptions options = new()
        {
            MaxWidth = MaxWidth.Medium,
            FullWidth = true,
            CloseOnEscapeKey = true
        };

        IDialogReference dialog = await DialogService.ShowAsync<CompanyDialog>(
            Localization.GetString("CreateCompany"), options);

        DialogResult? result = await dialog.Result;

        if (result is { Canceled: false, Data: CompanyDto created })
            await CreateCompany(created);
    }

    private async Task OpenEditDialog(CompanyDto company)
    {
        DialogParameters<CompanyDialog> parameters = new();
        parameters.Add(x => x.Company, company);

        DialogOptions options = new()
        {
            MaxWidth = MaxWidth.Medium,
            FullWidth = true,
            CloseOnEscapeKey = true
        };

        IDialogReference dialog = await DialogService.ShowAsync<CompanyDialog>(
            Localization.GetString("EditCompany"), parameters, options);

        DialogResult? result = await dialog.Result;

        if (result is { Canceled: false, Data: CompanyDto edited })
            await SaveCompany(edited);
    }

    private async Task CreateCompany(CompanyDto item)
    {
        try
        {
            CreateCompanyDto createDto = new()
            {
                Name = item.Name,
                Type = item.Type,
                ContactPerson = item.ContactPerson,
                Email = item.Email,
                Phone = item.Phone,
                Address = item.Address,
                TaxId = item.TaxId,
                PaymentTermsDays = item.PaymentTermsDays,
                CreditLimit = item.CreditLimit
            };

            await CompanyService.CreateCompanyAsync(createDto);
            Snackbar.Add(Localization.GetString("CompanyCreated"), Severity.Success);
            await _grid.ReloadServerData();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error creating company: {ex.Message}");
            Snackbar.Add(Localization.GetString("ErrorCreatingCompany"), Severity.Error);
        }
    }

    private async Task SaveCompany(CompanyDto item)
    {
        try
        {
            UpdateCompanyDto updateDto = new()
            {
                Name = item.Name,
                Type = item.Type,
                ContactPerson = item.ContactPerson,
                Email = item.Email,
                Phone = item.Phone,
                Address = item.Address,
                TaxId = item.TaxId,
                PaymentTermsDays = item.PaymentTermsDays,
                CreditLimit = item.CreditLimit,
                IsActive = item.IsActive
            };

            await CompanyService.UpdateCompanyAsync(item.Id, updateDto);
            Snackbar.Add(Localization.GetString("CompanyUpdated"), Severity.Success);
            await _grid.ReloadServerData();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error saving company: {ex.Message}");
            Snackbar.Add(Localization.GetString("ErrorUpdatingCompany"), Severity.Error);
        }
    }

    private async Task ClearAllFilters()
    {
        _filterType = null;
        _filterIsActive = null;
        await _grid.ReloadServerData();
    }

    public void Dispose()
    {
        Localization.OnLanguageChanged -= OnLanguageChanged;
    }
}
