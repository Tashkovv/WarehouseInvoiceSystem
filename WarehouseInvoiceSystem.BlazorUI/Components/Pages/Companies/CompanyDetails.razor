@page "/companies/{Id:guid}"
@implements IDisposable
@using WarehouseInvoiceSystem.Application.DTOs.Company
@using WarehouseInvoiceSystem.Application.DTOs.Invoice
@using WarehouseInvoiceSystem.Application.Interfaces
@inject ICompanyService CompanyService
@inject IInvoiceService InvoiceService
@inject ILocalizationService Localization
@inject NavigationManager Navigation
@inject IDialogService DialogService
@inject ISnackbar Snackbar

<PageTitle>@Localization.GetString("CompanyDetails") - @Localization.GetString("InvoiceSystem")</PageTitle>

@if (_loading)
{
    <MudProgressLinear Color="Color.Primary" Indeterminate="true" />
}
else if (_company == null)
{
    <MudAlert Severity="Severity.Error">@Localization.GetString("ErrorLoadingCompany")</MudAlert>
}
else
{
    <div class="d-flex justify-space-between align-center mb-4">
        <div>
            <MudButton StartIcon="@Icons.Material.Filled.ArrowBack"
                       Variant="Variant.Text"
                       Href="/companies">
                @Localization.GetString("BackToCompanies")
            </MudButton>
        </div>
        <div>
            <MudButton StartIcon="@Icons.Material.Filled.Edit"
                       Color="Color.Primary"
                       Variant="Variant.Filled"
                       Class="mr-2"
                       Href="@($"/companies/edit/{Id}")">
                @Localization.GetString("Edit")
            </MudButton>
            <MudButton StartIcon="@Icons.Material.Filled.Delete"
                       Color="Color.Error"
                       Variant="Variant.Outlined"
                       OnClick="DeleteCompany">
                @Localization.GetString("Delete")
            </MudButton>
        </div>
    </div>

    <MudGrid>
        <!-- Company Header - Single Card -->
        <MudItem xs="12">
            <MudCard Elevation="2">
                <MudCardContent Class="pa-6">
                    <MudGrid Spacing="4">
                        <!-- Left: Company Name + Type + Status + Contact -->
                        <MudItem xs="12" md="6">
                            <MudStack Spacing="2">
                                <div class="d-flex align-center gap-3 flex-wrap">
                                    <MudText Typo="Typo.h4" Class="mb-0">@_company.Name</MudText>
                                    <MudChip T="string" Size="Size.Small" Color="GetTypeColor(_company.Type)">
                                        @GetTypeText(_company.Type)
                                    </MudChip>
                                    <MudChip T="string" Size="Size.Small" Color="@(_company.IsActive? Color.Success: Color.Default)">
                                        @(_company.IsActive? Localization.GetString("ActiveCompany") : Localization.GetString("InactiveCompany"))
                                    </MudChip>
                                </div>

                                <MudDivider Class="my-2" />

                                <!-- Contact Information -->
                                <MudStack Spacing="1">
                                    @if (!string.IsNullOrWhiteSpace(_company.ContactPerson))
                                    {
                                        <div class="d-flex align-center">
                                            <MudIcon Icon="@Icons.Material.Filled.Person" Size="Size.Small" Class="mr-2" Color="Color.Secondary" />
                                            <MudText Typo="Typo.body2">
                                                <span class="text-secondary">@Localization.GetString("ContactPerson"):</span>
                                                <strong>@_company.ContactPerson</strong>
                                            </MudText>
                                        </div>
                                    }

                                    @if (!string.IsNullOrWhiteSpace(_company.Phone))
                                    {
                                        <div class="d-flex align-center">
                                            <MudIcon Icon="@Icons.Material.Filled.Phone" Size="Size.Small" Class="mr-2" Color="Color.Secondary" />
                                            <MudText Typo="Typo.body2">
                                                <strong>@_company.Phone</strong>
                                            </MudText>
                                        </div>
                                    }

                                    @if (!string.IsNullOrWhiteSpace(_company.Email))
                                    {
                                        <div class="d-flex align-center">
                                            <MudIcon Icon="@Icons.Material.Filled.Email" Size="Size.Small" Class="mr-2" Color="Color.Secondary" />
                                            <MudText Typo="Typo.body2">
                                                <strong>@_company.Email</strong>
                                            </MudText>
                                        </div>
                                    }

                                    @if (!string.IsNullOrWhiteSpace(_company.Address))
                                    {
                                        <div class="d-flex align-center">
                                            <MudIcon Icon="@Icons.Material.Filled.LocationOn" Size="Size.Small" Class="mr-2" Color="Color.Secondary" />
                                            <MudText Typo="Typo.body2">
                                                @_company.Address
                                            </MudText>
                                        </div>
                                    }
                                </MudStack>
                            </MudStack>
                        </MudItem>

                        <!-- Divider (visible on medium+ screens) -->
                        <MudHidden Breakpoint="Breakpoint.SmAndDown">
                            <MudItem md="1" Class="d-flex align-center justify-center">
                                <MudDivider Vertical="true" />
                            </MudItem>
                        </MudHidden>

                        <!-- Right: Financial Info + Balance -->
                        <MudItem xs="12" md="5">
                            <MudStack Spacing="3">
                                <!-- Tax ID & Payment Terms -->
                                @if (!string.IsNullOrWhiteSpace(_company.TaxId))
                                {
                                    <div>
                                        <div class="d-flex align-center mb-1">
                                            <MudIcon Icon="@Icons.Material.Filled.Receipt" Size="Size.Small" Class="mr-1" Color="Color.Secondary" />
                                            <MudText Typo="Typo.caption" Color="Color.Secondary">@Localization.GetString("TaxID")</MudText>
                                        </div>
                                        <MudText Typo="Typo.body1" Class="font-weight-medium">
                                            @_company.TaxId
                                        </MudText>
                                    </div>
                                }

                                <MudStack Row="true" Spacing="4">
                                    <div style="flex: 1;">
                                        <div class="d-flex align-center mb-1">
                                            <MudIcon Icon="@Icons.Material.Filled.CalendarMonth" Size="Size.Small" Class="mr-1" Color="Color.Secondary" />
                                            <MudText Typo="Typo.caption" Color="Color.Secondary">@Localization.GetString("PaymentTerms")</MudText>
                                        </div>
                                        <MudText Typo="Typo.body1" Class="font-weight-medium">
                                            @_company.PaymentTermsDays @Localization.GetString("Days")
                                        </MudText>
                                    </div>

                                    @if (_company.CreditLimit != 0)
                                    {
                                        <div style="flex: 1;">
                                            <div class="d-flex align-center mb-1">
                                                <MudIcon Icon="@Icons.Material.Filled.CreditCard" Size="Size.Small" Class="mr-1" Color="Color.Secondary" />
                                                <MudText Typo="Typo.caption" Color="Color.Secondary">@Localization.GetString("CreditLimit")</MudText>
                                            </div>
                                            <MudText Typo="Typo.body1" Class="font-weight-medium">
                                                @_company.CreditLimit.ToString("C")
                                            </MudText>
                                        </div>
                                    }
                                </MudStack>

                                <MudDivider />

                                <!-- Balance Information -->
                                @if (_loadingBalance)
                                {
                                    <MudProgressLinear Color="Color.Primary" Indeterminate="true" Size="Size.Small" />
                                }
                                else if (_balance != null)
                                {
                                    <div>
                                        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-2">@Localization.GetString("BalanceOverview")</MudText>

                                        <MudStack Row="true" Spacing="3" Class="mb-2">
                                            <div style="flex: 1;">
                                                <MudText Typo="Typo.caption" Color="Color.Secondary">@Localization.GetString("TheyOwe")</MudText>
                                                <MudText Typo="Typo.h6" Color="Color.Success">
                                                    @_balance.TotalOwedToUs.ToString("C")
                                                </MudText>
                                            </div>

                                            <div style="flex: 1;">
                                                <MudText Typo="Typo.caption" Color="Color.Secondary">@Localization.GetString("WeOwe")</MudText>
                                                <MudText Typo="Typo.h6" Color="Color.Warning">
                                                    @_balance.TotalOwedByUs.ToString("C")
                                                </MudText>
                                            </div>
                                        </MudStack>

                                        <MudAlert Severity="@(_balance.NetBalance >= 0 ? Severity.Success : Severity.Warning)"
                                                  Dense="true"
                                                  NoIcon="false"
                                                  Class="pa-2">
                                            <MudText Typo="Typo.caption">@Localization.GetString("NetBalance")</MudText>
                                            <MudText Typo="Typo.h6">
                                                @_balance.NetBalance.ToString("C")
                                                <MudText Typo="Typo.caption" Inline="true" Class="ml-2">
                                                    @if (_balance.NetBalance > 0)
                                                    {
                                                        <text>(@Localization.GetString("TheyOwe"))</text>
                                                    }
                                                    else if (_balance.NetBalance < 0)
                                                    {
                                                        <text>(@Localization.GetString("WeOwe"))</text>
                                                    }
                                                    else
                                                    {
                                                        <text>(@Localization.GetString("Settled"))</text>
                                                    }
                                                </MudText>
                                            </MudText>
                                        </MudAlert>
                                    </div>
                                }
                            </MudStack>
                        </MudItem>
                    </MudGrid>
                </MudCardContent>
            </MudCard>
        </MudItem>

        <!-- Recent Invoices -->
        <MudItem xs="12">
            <MudCard Elevation="2">
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudText Typo="Typo.h6">@Localization.GetString("RecentInvoices")</MudText>
                    </CardHeaderContent>
                    <CardHeaderActions>
                        <MudButton StartIcon="@Icons.Material.Filled.Add"
                                   Color="Color.Primary"
                                   Variant="Variant.Filled"
                                   Size="Size.Small"
                                   Href="/invoices/create">
                            @Localization.GetString("NewInvoice")
                        </MudButton>
                    </CardHeaderActions>
                </MudCardHeader>
                <MudCardContent Class="pa-0">
                    @if (_loadingInvoices)
                    {
                        <div class="pa-6">
                            <MudProgressLinear Color="Color.Primary" Indeterminate="true" />
                        </div>
                    }
                    else if (_invoices == null || !_invoices.Any())
                    {
                        <div class="pa-6 text-center d-flex align-center">
                            <MudIcon Icon="@Icons.Material.Filled.Receipt"
                                     Size="Size.Large"
                                     Color="Color.Secondary"
                                     Class="mb-2 mr-2" />
                            <MudText Color="Color.Secondary">@Localization.GetString("NoInvoicesFound")</MudText>
                        </div>
                    }
                    else
                    {
                        <MudTable Items="_invoices"
                                  Hover="true"
                                  Breakpoint="Breakpoint.Sm"
                                  Dense="true"
                                  Elevation="0"
                                  T="InvoiceDto"
                                  RowClass="table-row-clickable"
                                  OnRowClick="@((TableRowClickEventArgs<InvoiceDto> args) => OnInvoiceRowClick(args))">
                            <HeaderContent>
                                <MudTh>@Localization.GetString("InvoiceNumber")</MudTh>
                                <MudTh>@Localization.GetString("Type")</MudTh>
                                <MudTh>@Localization.GetString("Date")</MudTh>
                                <MudTh>@Localization.GetString("DueDate")</MudTh>
                                <MudTh Style="text-align: right;">@Localization.GetString("Amount")</MudTh>
                                <MudTh>@Localization.GetString("Status")</MudTh>
                            </HeaderContent>
                            <RowTemplate>
                                <MudTd DataLabel="@Localization.GetString("InvoiceNumber")">
                                    <MudText Typo="Typo.body2" Class="font-weight-medium">
                                        @context.InvoiceNumber
                                    </MudText>
                                </MudTd>
                                <MudTd DataLabel="@Localization.GetString("Type")">
                                    <MudChip T="string"
                                             Size="Size.Small"
                                             Color="@(context.Type == InvoiceType.Receivable ? Color.Success : Color.Warning)">
                                        @(context.Type == InvoiceType.Receivable ? Localization.GetString("Receivable") : Localization.GetString("Payable"))
                                    </MudChip>
                                </MudTd>
                                <MudTd DataLabel="@Localization.GetString("Date")">
                                    @context.IssueDate.ToString("dd MMM yyyy")
                                </MudTd>
                                <MudTd DataLabel="@Localization.GetString("DueDate")">
                                    <MudText Color="@(context.DueDate < DateTime.UtcNow && context.Status != InvoiceStatus.Paid ? Color.Error : Color.Default)">
                                        @context.DueDate.ToString("dd MMM yyyy")
                                    </MudText>
                                </MudTd>
                                <MudTd DataLabel="@Localization.GetString("Amount")" Style="text-align: right;">
                                    <MudText Typo="Typo.body2" Class="font-weight-bold">
                                        @context.TotalAmount.ToString("C")
                                    </MudText>
                                </MudTd>
                                <MudTd DataLabel="@Localization.GetString("Status")">
                                    <MudChip T="string" Size="Size.Small" Color="GetStatusColor(context.Status)">
                                        @GetStatusText(context.Status)
                                    </MudChip>
                                </MudTd>
                            </RowTemplate>
                        </MudTable>
                    }
                </MudCardContent>
            </MudCard>
        </MudItem>
    </MudGrid>
}

@code {
    [Parameter]
    public Guid Id { get; set; }

    private bool _loading = true;
    private bool _loadingBalance = true;
    private bool _loadingInvoices = true;
    private CompanyDto? _company;
    private CompanyBalanceDto? _balance;
    private List<InvoiceDto> _invoices = new();

    protected override async Task OnInitializedAsync()
    {
        Localization.OnLanguageChanged += OnLanguageChanged;
        await LoadCompany();
        await LoadBalance();
        await LoadInvoices();
    }

    protected override async Task OnParametersSetAsync()
    {
        await Task.WhenAll(LoadCompany(), LoadBalance(), LoadInvoices());
    }

    private async void OnLanguageChanged()
    {
        await InvokeAsync(StateHasChanged);
    }

    private async Task LoadCompany()
    {
        _loading = true;

        try
        {
            _company = await CompanyService.GetCompanyByIdAsync(Id);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading company: {ex.Message}");
            Snackbar.Add(Localization.GetString("ErrorLoadingCompany"), Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task LoadBalance()
    {
        _loadingBalance = true;

        try
        {
            _balance = await CompanyService.GetCompanyBalanceAsync(Id);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading balance: {ex.Message}");
        }
        finally
        {
            _loadingBalance = false;
        }
    }

    private async Task LoadInvoices()
    {
        _loadingInvoices = true;

        try
        {
            IEnumerable<InvoiceDto> invoices = await InvoiceService.GetInvoicesByCompanyAsync(Id);
            _invoices = invoices.OrderByDescending(i => i.CreatedAt).Take(10).ToList();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading invoices: {ex.Message}");
        }
        finally
        {
            _loadingInvoices = false;
        }
    }

    private Color GetTypeColor(CompanyType type)
    {
        return type switch
        {
            CompanyType.Client => Color.Success,
            CompanyType.Vendor => Color.Warning,
            CompanyType.Both => Color.Info,
            _ => Color.Default
        };
    }

    private string GetTypeText(CompanyType type)
    {
        return type switch
        {
            CompanyType.Client => Localization.GetString("Client"),
            CompanyType.Vendor => Localization.GetString("Vendor"),
            CompanyType.Both => Localization.GetString("ClientAndVendor"),
            _ => type.ToString()
        };
    }

    private Color GetStatusColor(InvoiceStatus status)
    {
        return status switch
        {
            InvoiceStatus.Draft => Color.Default,
            InvoiceStatus.Sent => Color.Info,
            InvoiceStatus.PartiallyPaid => Color.Warning,
            InvoiceStatus.Paid => Color.Success,
            InvoiceStatus.Overdue => Color.Error,
            InvoiceStatus.Cancelled => Color.Default,
            _ => Color.Default
        };
    }

    private string GetStatusText(InvoiceStatus status)
    {
        return status switch
        {
            InvoiceStatus.Draft => Localization.GetString("Draft"),
            InvoiceStatus.Sent => Localization.GetString("Sent"),
            InvoiceStatus.PartiallyPaid => Localization.GetString("PartiallyPaid"),
            InvoiceStatus.Paid => Localization.GetString("PaidStatus"),
            InvoiceStatus.Overdue => Localization.GetString("OverdueStatus"),
            InvoiceStatus.Cancelled => Localization.GetString("Cancelled"),
            _ => status.ToString()
        };
    }

    private void ViewInvoice(Guid id)
    {
        Navigation.NavigateTo($"/invoices/{id}");
    }

    private void OnInvoiceRowClick(TableRowClickEventArgs<InvoiceDto> args)
    {
        if (args.MouseEventArgs.Detail == 2)
        {
            ViewInvoice(args.Item!.Id);
        }
    }

    private async Task DeleteCompany()
    {
        bool? result = await DialogService.ShowMessageBoxAsync(
            new MessageBoxOptions
            {
                Title = Localization.GetString("ConfirmDelete"),
                Message = Localization.GetString("DeleteCompanyConfirm"),
                YesText = Localization.GetString("Yes"),
                CancelText = Localization.GetString("No")
            });

        if (result == true)
        {
            try
            {
                bool deleted = await CompanyService.DeleteCompanyAsync(Id);
                if (deleted)
                {
                    Snackbar.Add(Localization.GetString("CompanyDeleted"), Severity.Success);
                    Navigation.NavigateTo("/companies");
                }
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Error deleting company: {ex.Message}");
                Snackbar.Add(Localization.GetString("ErrorDeletingCompany"), Severity.Error);
            }
        }
    }

    public void Dispose()
    {
        Localization.OnLanguageChanged -= OnLanguageChanged;
    }
}