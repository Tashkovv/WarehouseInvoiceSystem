@page "/companies/{Id:guid}"
@inherits PageBase
@using WarehouseInvoiceSystem.Application.DTOs.Company
@using WarehouseInvoiceSystem.Application.DTOs.Invoice
@using WarehouseInvoiceSystem.Domain.Enums
@using WarehouseInvoiceSystem.Domain.Queries
@using WarehouseInvoiceSystem.Domain.Queries.Common
@inject ICompanyService CompanyService
@inject IInvoiceService InvoiceService

<PageTitle>@Localization.GetString("CompanyDetails") - @Localization.GetString("InvoiceSystem")</PageTitle>

@if (_loading)
{
    <MudProgressLinear Color="Color.Primary" Indeterminate="true" />
}
else if (_company == null)
{
    <MudAlert Severity="Severity.Error">@Localization.GetString("ErrorLoadingCompany")</MudAlert>
}
else
{
    <WisDetailHeader BackHref="/companies"
                     BackLabel="@Localization.GetString("Companies")"
                     PrimaryAction="@_primaryAction"
                     Actions="@_actions" />

    <MudGrid>
        <!-- Company Header Card -->
        <MudItem xs="12">
            <MudCard Elevation="2">
                <MudCardContent Class="pa-4">

                    <!-- Row 1: Name + type chip + status chip -->
                    <div class="wis-detail-identity mb-3">
                        <MudText Typo="Typo.h4" Class="font-weight-bold mb-0">@_company.Name</MudText>
                        <MudChip T="string" Size="Size.Small" Color="@GetCompanyTypeColor(_company.Type)">
                            @GetCompanyTypeText(_company.Type)
                        </MudChip>
                        <MudChip T="string" Size="Size.Small"
                                 Color="@(_company.IsActive ? Color.Success : Color.Default)">
                            @(_company.IsActive? Localization.GetString("ActiveCompany") : Localization.GetString("InactiveCompany"))
                        </MudChip>
                    </div>

                    <!-- Row 2: Contact pills (left) | vertical divider | Company metadata (right) -->
                    <div class="wis-contact-row mb-4">

                        <!-- Left half: contact pills -->
                        <div class="wis-contact-row-left">
                            <div class="wis-detail-contact">
                                @if (!string.IsNullOrWhiteSpace(_company.ContactPerson))
                                {
                                    <div class="wis-detail-contact-item">
                                        <MudIcon Icon="@Icons.Material.Filled.Person" Size="Size.Small" Color="Color.Secondary" />
                                        <MudText Typo="Typo.body2" Color="Color.Secondary">@_company.ContactPerson</MudText>
                                    </div>
                                }
                                @if (!string.IsNullOrWhiteSpace(_company.Phone))
                                {
                                    <div class="wis-detail-contact-item">
                                        <MudIcon Icon="@Icons.Material.Filled.Phone" Size="Size.Small" Color="Color.Secondary" />
                                        <MudText Typo="Typo.body2">@_company.Phone</MudText>
                                    </div>
                                }
                                @if (!string.IsNullOrWhiteSpace(_company.Email))
                                {
                                    <div class="wis-detail-contact-item">
                                        <MudIcon Icon="@Icons.Material.Filled.Email" Size="Size.Small" Color="Color.Secondary" />
                                        <MudText Typo="Typo.body2">@_company.Email</MudText>
                                    </div>
                                }
                                @if (!string.IsNullOrWhiteSpace(_company.Address))
                                {
                                    <div class="wis-detail-contact-item">
                                        <MudIcon Icon="@Icons.Material.Filled.LocationOn" Size="Size.Small" Color="Color.Secondary" />
                                        <MudText Typo="Typo.body2">@_company.Address</MudText>
                                    </div>
                                }
                            </div>
                        </div>

                        <!-- Vertical divider -->
                        <div class="wis-contact-row-divider"></div>

                        <!-- Right half: company metadata with labels -->
                        <div class="wis-contact-row-right">
                            <div class="d-flex gap-8 flex-wrap align-start">
                                @if (!string.IsNullOrWhiteSpace(_company.TaxId))
                                {
                                    <div class="wis-contact-meta-item">
                                        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="wis-section-label">@Localization.GetString("TaxID")</MudText>
                                        <div class="d-flex align-center gap-1">
                                            <MudIcon Icon="@Icons.Material.Filled.Receipt" Size="Size.Small" Color="Color.Secondary" />
                                            <MudText Typo="Typo.body2">@_company.TaxId</MudText>
                                        </div>
                                    </div>
                                }
                                <div class="wis-contact-meta-item">
                                    <MudText Typo="Typo.caption" Color="Color.Secondary" Class="wis-section-label">@Localization.GetString("PaymentTerms")</MudText>
                                    <div class="d-flex align-center gap-1">
                                        <MudIcon Icon="@Icons.Material.Filled.CalendarMonth" Size="Size.Small" Color="Color.Secondary" />
                                        <MudText Typo="Typo.body2">@_company.PaymentTermsDays @Localization.GetString("Days")</MudText>
                                    </div>
                                </div>
                                @if (_company.CreditLimit != 0)
                                {
                                    <div class="wis-contact-meta-item">
                                        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="wis-section-label">@Localization.GetString("CreditLimit")</MudText>
                                        <div class="d-flex align-center gap-1">
                                            <MudIcon Icon="@Icons.Material.Filled.CreditCard" Size="Size.Small" Color="Color.Secondary" />
                                            <MudText Typo="Typo.body2">@_company.CreditLimit.ToString("C")</MudText>
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>

                    </div>

                    @if (_loadingAnalytics)
                    {
                        <MudProgressLinear Color="Color.Primary" Indeterminate="true" Size="Size.Small" />
                    }
                    else if (_analytics.ReceivableTotalCount > 0 || _analytics.PayableTotalCount > 0 || _analytics.PayableCancelledCount > 0 || _analytics.ReceivableCancelledCount > 0)
                    {
                        <MudDivider Class="mb-6" />

                        <div class="wis-ca-outer">

                            <!-- Left col: receivables row + payables row -->
                            <div class="wis-ca-left">

                                @if (_company.Type != CompanyType.Vendor) 
                                {
                                    <!-- Receivables -->
                                    <div class="wis-ca-row">
                                        <div class="wis-ca-stat">
                                            <MudText Typo="Typo.caption" Color="Color.Secondary" Class="wis-section-label">@Localization.GetString("TotalReceivables")</MudText>
                                            <div class="wis-stat-value mud-info-text">@_analytics.ReceivableTotalAmount.ToString("C")</div>
                                            <MudText Typo="Typo.body2" Color="Color.Secondary">@_analytics.ReceivableTotalCount @Localization.GetString("Invoices")</MudText>
                                        </div>
                                        <div class="wis-ca-stat">
                                            <MudText Typo="Typo.caption" Color="Color.Secondary" Class="wis-section-label">@Localization.GetString("Paid")</MudText>
                                            <div class="wis-stat-value mud-success-text">@_analytics.ReceivablePaidAmount.ToString("C")</div>
                                            <MudText Typo="Typo.body2" Color="Color.Secondary">@_analytics.ReceivablePaidCount @Localization.GetString("FullyPaidInvoices")</MudText>
                                        </div>
                                        <div class="wis-ca-stat">
                                            <MudText Typo="Typo.caption" Color="Color.Secondary" Class="wis-section-label">@Localization.GetString("OpenReceivables")</MudText>
                                            @if (_analytics.ReceivableOpenCount > 0)
                                            {
                                                <div class="wis-stat-value mud-warning-text">@_analytics.ReceivableAmountDue.ToString("C")</div>
                                                <MudText Typo="Typo.body2" Color="Color.Warning">@_analytics.ReceivableOpenCount @Localization.GetString("Invoices")</MudText>
                                            }
                                            else
                                            {
                                                <div class="wis-stat-value mud-success-text">—</div>
                                                <MudText Typo="Typo.body2" Color="Color.Success">✓ @Localization.GetString("AllReceivablesPaid")</MudText>
                                            }
                                        </div>
                                        @if (_analytics.ReceivableOverdueCount > 0)
                                        {
                                            <div class="wis-ca-stat">
                                                <MudText Typo="Typo.caption" Color="Color.Secondary" Class="wis-section-label">@Localization.GetString("OverdueReceivables")</MudText>
                                                <div class="wis-stat-value mud-error-text">@_analytics.ReceivableOverdueAmountDue.ToString("C")</div>
                                                <MudText Typo="Typo.body2" Color="Color.Error">@_analytics.ReceivableOverdueCount @Localization.GetString("Invoices")</MudText>
                                            </div>
                                        }
                                        @if (_analytics.ReceivableCancelledCount > 0)
                                        {
                                            <div class="wis-ca-stat">
                                                <MudText Typo="Typo.caption" Color="Color.Secondary" Class="wis-section-label">@Localization.GetString("Cancelled")</MudText>
                                                <div class="wis-stat-value mud-error-text" style="text-decoration: line-through;">@_analytics.ReceivableCancelledAmount.ToString("C")</div>
                                                <MudText Typo="Typo.body2" Color="Color.Error">@_analytics.ReceivableCancelledCount @Localization.GetString("Invoices")</MudText>
                                            </div>
                                        }
                                    </div>
                                }

                                @if (_company.Type == CompanyType.Both)
                                {
                                    <div class="wis-ca-divider"></div>
                                }

                                @if (_company.Type != CompanyType.Client)
                                {
                                    <!-- Payables -->
                                    <div class="wis-ca-row">
                                        <div class="wis-ca-stat">
                                            <MudText Typo="Typo.caption" Color="Color.Secondary" Class="wis-section-label">@Localization.GetString("TotalPayables")</MudText>
                                            <div class="wis-stat-value mud-info-text">@_analytics.PayableTotalAmount.ToString("C")</div>
                                            <MudText Typo="Typo.body2" Color="Color.Secondary">@_analytics.PayableTotalCount @Localization.GetString("Invoices")</MudText>
                                        </div>
                                        <div class="wis-ca-stat">
                                            <MudText Typo="Typo.caption" Color="Color.Secondary" Class="wis-section-label">@Localization.GetString("Paid")</MudText>
                                            <div class="wis-stat-value mud-success-text">@_analytics.PayablePaidAmount.ToString("C")</div>
                                            <MudText Typo="Typo.body2" Color="Color.Secondary">@_analytics.PayablePaidCount @Localization.GetString("FullyPaidInvoices")</MudText>
                                        </div>
                                        <div class="wis-ca-stat">
                                            <MudText Typo="Typo.caption" Color="Color.Secondary" Class="wis-section-label">@Localization.GetString("OpenPayables")</MudText>
                                            @if (_analytics.PayableOpenCount > 0)
                                            {
                                                <div class="wis-stat-value mud-warning-text">@_analytics.PayableAmountDue.ToString("C")</div>
                                                <MudText Typo="Typo.body2" Color="Color.Warning">@_analytics.PayableOpenCount @Localization.GetString("Invoices")</MudText>
                                            }
                                            else
                                            {
                                                <div class="wis-stat-value mud-success-text">—</div>
                                                <MudText Typo="Typo.body2" Color="Color.Success">✓ @Localization.GetString("AllPayablesPaid")</MudText>
                                            }
                                        </div>
                                        @if (_analytics.PayableOverdueCount > 0)
                                        {
                                            <div class="wis-ca-stat">
                                                <MudText Typo="Typo.caption" Color="Color.Secondary" Class="wis-section-label">@Localization.GetString("OverduePayables")</MudText>
                                                <div class="wis-stat-value mud-error-text">@_analytics.PayableOverdueAmountDue.ToString("C")</div>
                                                <MudText Typo="Typo.body2" Color="Color.Error">@_analytics.PayableOverdueCount @Localization.GetString("Invoices")</MudText>
                                            </div>
                                        }
                                        @if (_analytics.PayableCancelledCount > 0)
                                        {
                                            <div class="wis-ca-stat">
                                                <MudText Typo="Typo.caption" Color="Color.Secondary" Class="wis-section-label">@Localization.GetString("Cancelled")</MudText>
                                                <div class="wis-stat-value mud-error-text" style="text-decoration: line-through;">@_analytics.PayableCancelledAmount.ToString("C")</div>
                                                <MudText Typo="Typo.body2" Color="Color.Error">@_analytics.PayableCancelledCount @Localization.GetString("Invoices")</MudText>
                                            </div>
                                        }
                                    </div>
                                }                                

                            </div>

                            <!-- Right col: history centered -->
                            <div class="wis-ca-right">
                                <MudText Typo="Typo.caption" Color="Color.Secondary" Class="wis-section-label mb-2 d-block">@Localization.GetString("InvoiceHistory")</MudText>
                                <div class="wis-detail-history">
                                    <div class="wis-detail-history-dates">
                                        <div>
                                            <MudText Typo="Typo.caption" Color="Color.Secondary">@Localization.GetString("FirstInvoice")</MudText>
                                            <MudText Typo="Typo.body1" Class="font-weight-medium">@(_analytics.FirstInvoiceDate?.ToString("dd MMM yyyy") ?? "—")</MudText>
                                        </div>
                                        <div>
                                            <MudText Typo="Typo.caption" Color="Color.Secondary">@Localization.GetString("LastInvoice")</MudText>
                                            <MudText Typo="Typo.body1" Class="font-weight-medium">@(_analytics.LastInvoiceDate?.ToString("dd MMM yyyy") ?? "—")</MudText>
                                        </div>
                                    </div>
                                    @if (!string.IsNullOrEmpty(_analytics.MostTradedProduct))
                                    {
                                        <div class="wis-detail-history-product">
                                            <MudIcon Icon="@Icons.Material.Filled.Star" Size="Size.Small" Color="Color.Warning" />
                                            <div>
                                                <MudText Typo="Typo.caption" Color="Color.Secondary">@Localization.GetString("MostTradedProduct")</MudText>
                                                <div class="d-flex align-center gap-2">
                                                    <MudText Typo="Typo.body1" Class="wis-capitalize font-weight-medium">@_analytics.MostTradedProduct</MudText>
                                                    <MudText Typo="Typo.body2" Color="Color.Secondary">@_analytics.MostTradedProductQuantity.ToString("N2") @_analytics.MostTradedProductUnit</MudText>
                                                </div>
                                            </div>
                                        </div>
                                    }
                                </div>
                            </div>

                        </div>
                    }

                </MudCardContent>
            </MudCard>
        </MudItem>

        <!-- Recent Invoices -->
        <MudItem xs="12">
            <MudCard Elevation="2">
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudText Typo="Typo.h6">@Localization.GetString("RecentInvoices")</MudText>
                    </CardHeaderContent>
                    <CardHeaderActions>
                        <WisSplitButton PrimaryAction="@_invoicesAction" />
                    </CardHeaderActions>
                </MudCardHeader>
                <MudCardContent Class="pa-0">
                    @if (_loadingInvoices)
                    {
                        <div class="pa-6">
                            <MudProgressLinear Color="Color.Primary" Indeterminate="true" />
                        </div>
                    }
                    else if (_analytics.RecentInvoices.Any())
                    {
                        <MudTable Items="_analytics.RecentInvoices"
                                  Hover="true"
                                  Dense="false"
                                  Elevation="0"
                                  T="RecentInvoiceDto"
                                  Class="wis-secondary-list"
                                  OnRowClick="@ViewInvoice">
                            <HeaderContent>
                                <MudTh>@Localization.GetString("InvoiceNumber")</MudTh>
                                <MudTh>@Localization.GetString("Type")</MudTh>
                                <MudTh>@Localization.GetString("Status")</MudTh>
                                <MudTh>@Localization.GetString("Date")</MudTh>
                                <MudTh>@Localization.GetString("DueDate")</MudTh>
                                <MudTh Class="text-right">@Localization.GetString("Amount")</MudTh>
                            </HeaderContent>
                            <RowTemplate>
                                <MudTd DataLabel="@Localization.GetString("InvoiceNumber")">
                                    <MudText Typo="Typo.body2" Class="font-weight-medium">@context.InvoiceNumber</MudText>
                                </MudTd>
                                <MudTd DataLabel="@Localization.GetString("Type")">
                                    <MudChip T="string" Size="Size.Small"
                                             Color="@(context.Type == InvoiceType.Receivable ? Color.Success : Color.Warning)"
                                             Variant="Variant.Outlined">
                                        @(context.Type == InvoiceType.Receivable ? Localization.GetString("Receivable") : Localization.GetString("Payable"))
                                    </MudChip>
                                </MudTd>
                                <MudTd DataLabel="@Localization.GetString("Status")">
                                    <MudChip T="string" Size="Size.Small" Color="@GetInvoiceStatusColor(context.Status)" Variant="Variant.Outlined">
                                        @GetInvoiceStatusText(context.Status)
                                    </MudChip>
                                </MudTd>
                                <MudTd DataLabel="@Localization.GetString("Date")">
                                    <MudText Typo="Typo.body2">@context.IssueDate.ToString("dd MMM yyyy")</MudText>
                                </MudTd>
                                <MudTd DataLabel="@Localization.GetString("DueDate")">
                                    <MudText Typo="Typo.body2"
                                             Color="@(context.DueDate < DateTime.UtcNow && context.Status != InvoiceStatus.Paid ? Color.Error : Color.Default)">
                                        @context.DueDate.ToString("dd MMM yyyy")
                                    </MudText>
                                </MudTd>
                                <MudTd DataLabel="@Localization.GetString("Amount")" Class="text-right">
                                    <MudText Typo="Typo.body2" Class="font-weight-bold">@context.TotalAmount.ToString("C")</MudText>
                                </MudTd>
                            </RowTemplate>
                        </MudTable>
                    }
                    else
                    {
                        <div class="pa-6 text-center d-flex align-center">
                            <MudIcon Icon="@Icons.Material.Filled.Receipt"
                                     Size="Size.Large"
                                     Color="Color.Secondary"
                                     Class="mr-2" />
                            <MudText Typo="Typo.body1" Color="Color.Secondary">@Localization.GetString("NoInvoicesFound")</MudText>
                        </div>
                    }
                </MudCardContent>
            </MudCard>
        </MudItem>
    </MudGrid>
}

@code {
    [Parameter] public Guid Id { get; set; }

    private bool _loadingAnalytics = true;
    private bool _loadingInvoices = true;
    private CompanyDto? _company;
    private CompanyAnalyticsDto _analytics = new();

    private WisDetailActionItem? _primaryAction;
    private List<WisDetailActionItem> _actions = [];
    private WisDetailActionItem? _invoicesAction;

    protected override async Task OnInitializedAsync()
    {
        await base.OnInitializedAsync();
        await LoadCompany();
        await LoadAnalytics();
    }

    protected override async void OnLanguageChanged()
    {
        BuildActions();
        await InvokeAsync(StateHasChanged);
    }

    private async Task LoadCompany() =>
        await SafeLoadAsync(async () =>
        {
            _company = await CompanyService.GetCompanyByIdAsync(Id, CancellationToken.None);
            if (_company != null)
                BuildActions();
        }, "ErrorLoadingCompany");

    private async Task LoadAnalytics()
    {
        _loadingAnalytics = true;
        _loadingInvoices = true;

        try
        {
            _analytics = await CompanyService.GetCompanyAnalyticsAsync(Id, CancellationToken.None);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading analytics: {ex.Message}");
        }
        finally
        {
            _loadingAnalytics = false;
            _loadingInvoices = false;
        }
    }

    private void BuildActions()
    {
        if (_company is null) return;

        _primaryAction = _act.Primary(Icons.Material.Filled.Edit, Localization.GetString("Edit"), OpenEditDialog);

        _actions =
        [
            _company.IsActive
                ? _act.Warning(Icons.Material.Filled.PowerSettingsNew, Localization.GetString("Deactivate"), ToggleActiveStatus)
                : _act.Success(Icons.Material.Filled.PowerSettingsNew,  Localization.GetString("Activate"),   ToggleActiveStatus),
        ];

        _invoicesAction = _act.Secondary(Icons.Material.Filled.RequestQuote, Localization.GetString("Invoices"), () => Navigation.NavigateTo($"/invoices?companyId={Id}"));
    }

    private async Task OpenEditDialog()
    {
        if (_company is null) return;
        if (await WisDialog.ShowFormAsync<CompanyDialog, bool>(
                Localization.GetString("EditCompany"),
                p => p.Add(x => x.Company, _company)) == true)
            await LoadCompany();
    }

    private void ViewInvoice(TableRowClickEventArgs<RecentInvoiceDto> args)
    {
        Navigation.NavigateTo($"/invoices/{args.Item!.Id}");
    }

    private async Task ToggleActiveStatus()
    {
        if (_company is null) return;

        if (_company.IsActive)
            await DeactivateCompany();
        else
            await ActivateCompany();
    }

    private async Task DeactivateCompany()
    {
        int openCount = _analytics.ReceivableOpenCount + _analytics.PayableOpenCount;
        string message = openCount > 0
            ? string.Format(Localization.GetString("DeactivateCompanyWithOpenInvoices"), openCount)
            : Localization.GetString("DeactivateCompanyConfirm");

        await ConfirmAndExecuteAsync(
            Localization.GetString("DeactivateCompany"), message,
            async () => { await CompanyService.SetActiveStatusAsync(Id, false); await LoadCompany(); },
            "CompanyDeactivated", "ErrorDeactivatingCompany",
            Localization.GetString("Deactivate"), Localization.GetString("Cancel"));
    }

    private async Task ActivateCompany()
    {
        try
        {
            await CompanyService.SetActiveStatusAsync(Id, true);
            Snackbar.Add(Localization.GetString("CompanyActivated"), Severity.Success);
            await LoadCompany();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error activating company: {ex.Message}");
            Snackbar.Add(Localization.GetString("ErrorActivatingCompany"), Severity.Error);
        }
    }

}
