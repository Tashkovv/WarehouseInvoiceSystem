@page "/payments/create"
@implements IDisposable
@using System.Globalization
@using WarehouseInvoiceSystem.Application.DTOs.Invoice
@using WarehouseInvoiceSystem.Application.DTOs.Payment
@using WarehouseInvoiceSystem.Application.Interfaces
@inject IPaymentService PaymentService
@inject IInvoiceService InvoiceService
@inject ILocalizationService Localization
@inject NavigationManager Navigation
@inject ISnackbar Snackbar

<PageTitle>@Localization.GetString("RecordPayment") - @Localization.GetString("InvoiceSystem")</PageTitle>

<div class="d-flex justify-space-between align-center mb-4">
    <MudText Typo="Typo.h4">@Localization.GetString("RecordPayment")</MudText>
    <MudButton StartIcon="@Icons.Material.Filled.ArrowBack"
               Variant="Variant.Text"
               Href="/payments">
        @Localization.GetString("BackToPayments")
    </MudButton>
</div>

@if (_loadingInvoices)
{
    <MudProgressLinear Color="Color.Primary" Indeterminate="true" />
}
else
{
    <MudForm @ref="_form" @bind-IsValid="@_isValid">
        <MudCard Elevation="2" Class="mb-4">
            <MudCardHeader>
                <CardHeaderContent>
                    <MudText Typo="Typo.h6">@Localization.GetString("PaymentDetails")</MudText>
                </CardHeaderContent>
            </MudCardHeader>
            <MudCardContent>
                <MudGrid>
                    <MudItem xs="12" md="4">
                        <MudSelect T="Guid?"
                                   @bind-Value="_selectedInvoiceId"
                                   @bind-Value:after="OnInvoiceSelected"
                                   Label="@Localization.GetString("SelectInvoice")"
                                   Variant="Variant.Outlined"
                                   Required="true"
                                   ReadOnly="_invoiceReadonly"
                                   RequiredError="@Localization.GetString("PleaseSelectInvoice")"
                                   AnchorOrigin="Origin.BottomLeft">
                            @foreach (InvoiceDto invoice in _unpaidInvoices)
                            {
                                <MudSelectItem T="Guid?" Value="invoice.Id">
                                    @invoice.InvoiceNumber - @invoice.CompanyName
                                </MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>

                    <MudItem xs="12" md="4">
                        <MudTextField T="string"
                                      @bind-Value="_recordedBy"
                                      Label="@Localization.GetString("RecordedBy")"
                                      Variant="Variant.Outlined" />
                    </MudItem>

                    <MudItem xs="12" md="4">
                        <MudTextField T="string"
                                      @bind-Value="_referenceNumber"
                                      Label="@Localization.GetString("ReferenceNumber")"
                                      Variant="Variant.Outlined"
                                      Placeholder="@Localization.GetString("EnterReferenceNumber")" />
                    </MudItem>

                    @if (_selectedInvoice != null)
                    {
                        <MudItem xs="12">
                            <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">
                                <div class="d-flex justify-space-between align-start pa-3" style="gap: 1rem;">
                                    <div class="d-flex flex-column flex-grow-1 text-center">
                                        <MudText Typo="Typo.body2" Color="Color.Default" Class="text-nowrap mb-1">
                                            <strong>@Localization.GetString("InvoiceAmount")</strong>
                                        </MudText>
                                        <MudText Typo="Typo.h6" Color="Color.Primary" Class="text-nowrap">
                                            @_selectedInvoice.TotalAmount.ToString("C")
                                        </MudText>
                                    </div>
                                    <div class="d-flex flex-column flex-grow-1 text-center">
                                        <MudText Typo="Typo.body2" Color="Color.Default" Class="text-nowrap mb-1">
                                            <strong>@Localization.GetString("AlreadyPaid")</strong>
                                        </MudText>
                                        <MudText Typo="Typo.h6" Color="Color.Primary" Class="text-nowrap">
                                            @_selectedInvoice.AmountPaid.ToString("C")
                                        </MudText>
                                    </div>
                                    <div class="d-flex flex-column flex-grow-1 text-center">
                                        <MudText Typo="Typo.body2" Color="Color.Default" Class="text-nowrap mb-1">
                                            <strong>@Localization.GetString("RemainingBalance")</strong>
                                        </MudText>
                                        <MudText Typo="Typo.h6" Color="Color.Primary" Class="text-nowrap">
                                            @_selectedInvoice.AmountDue.ToString("C")
                                        </MudText>
                                    </div>
                                </div>
                            </MudAlert>
                        </MudItem>
                    }


                    <MudItem xs="12" md="4">
                        <MudSelect T="PaymentMethod"
                                   @bind-Value="_paymentMethod"
                                   Label="@Localization.GetString("PaymentMethod")"
                                   Variant="Variant.Outlined"
                                   Required="true"
                                   RequiredError="@Localization.GetString("PleaseSelectPaymentMethod")"
                                   AnchorOrigin="Origin.BottomLeft">
                            @foreach (var method in Enum.GetValues<PaymentMethod>())
                            {
                                <MudSelectItem T="PaymentMethod" Value="@(method)">
                                    <MudChip T="InvoiceStatus"
                                             Size="Size.Small"
                                             Color="Color.Info">
                                        @Localization.GetString(method.ToString())
                                    </MudChip>
                                </MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>

                    <MudItem xs="12" md="4">
                        <MudNumericField T="decimal"
                                         @bind-Value="_amount"
                                         Label="@Localization.GetString("Amount")"
                                         Variant="Variant.Outlined"
                                         Required="true"
                                         RequiredError="@Localization.GetString("PleaseEnterAmount")"
                                         Min="0.01m"
                                         Max="@(_selectedInvoice?.AmountDue ?? 999999999)"
                                         Format="N2"
                                         TextUpdateSuppression="false"
                                         Adornment="Adornment.Start"
                                         AdornmentText="MKD" />
                    </MudItem>

                    <MudItem xs="12" md="4">
                        <MudDatePicker @key="_currentCultureKey"
                                       @bind-Date="_paymentDate"
                                       Label="@Localization.GetString("PaymentDate")"
                                       Variant="Variant.Outlined"
                                       Required="true"
                                       RequiredError="@Localization.GetString("PaymentDateRequired")" />
                    </MudItem>

                    <MudItem xs="12">
                        <MudTextField T="string"
                                      @bind-Value="_notes"
                                      Label="@Localization.GetString("Notes")"
                                      Variant="Variant.Outlined"
                                      Lines="3"
                                      Placeholder="@Localization.GetString("EnterNotes")" />
                    </MudItem>
                </MudGrid>
            </MudCardContent>
        </MudCard>
        <!-- Actions -->
        <MudItem xs="12">
            <div class="d-flex justify-end gap-2">
                <MudButton Variant="Variant.Outlined"
                           OnClick="@(() => Navigation.NavigateTo("/payments"))">
                    @Localization.GetString("Cancel")
                </MudButton>
                <MudButton Variant="Variant.Filled"
                           Color="Color.Primary"
                           OnClick="HandleSubmit"
                           Disabled="@(!_isValid || _saving)">
                    @if (_saving)
                    {
                        <MudProgressCircular Class="mr-2" Size="Size.Small" Indeterminate="true" />
                        @Localization.GetString("Save")
                    }
                    else
                    {
                        @Localization.GetString("RecordPayment")
                    }
                </MudButton>
            </div>
        </MudItem>
    </MudForm>
}

@code {
    [Parameter]
    [SupplyParameterFromQuery(Name = "invoiceId")]
    public Guid? PreSelectedInvoiceId { get; set; }

    private bool _loadingInvoices = true;
    private bool _invoiceReadonly = false;
    private bool _saving = false;
    private string _currentCultureKey = CultureInfo.CurrentCulture.Name;
    private MudForm _form = null!;
    private bool _isValid;
    private List<InvoiceDto> _unpaidInvoices = new();
    private InvoiceDto? _selectedInvoice;
    private readonly CreatePaymentDto _createDto = new();

    private Guid? _selectedInvoiceId;
    private DateTime? _paymentDate = DateTime.UtcNow;
    private decimal _amount = 0;
    private PaymentMethod _paymentMethod = PaymentMethod.BankTransfer;
    private string? _referenceNumber;
    private string? _notes;
    private string? _recordedBy;

    protected override async Task OnInitializedAsync()
    {
        Localization.OnLanguageChanged += OnLanguageChanged;
        await LoadUnpaidInvoices();

        if (PreSelectedInvoiceId.HasValue)
        {
            _selectedInvoiceId = PreSelectedInvoiceId.Value;
            _invoiceReadonly = true;
            await OnInvoiceSelected();
        }
    }

    private async void OnLanguageChanged()
    {
        _currentCultureKey = CultureInfo.CurrentCulture.Name;
        await InvokeAsync(StateHasChanged);
    }

    private async Task LoadUnpaidInvoices()
    {
        _loadingInvoices = true;

        try
        {
            IEnumerable<InvoiceDto> allInvoices = await InvoiceService.GetAllInvoicesAsync();
            _unpaidInvoices = allInvoices
                .Where(i => i.Status != InvoiceStatus.Paid &&
                            i.Status != InvoiceStatus.Cancelled &&
                            i.AmountDue > 0)
                .OrderByDescending(i => i.DueDate)
                .ToList();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading invoices: {ex.Message}");
            Snackbar.Add("Error loading invoices", Severity.Error);
        }
        finally
        {
            _loadingInvoices = false;
        }
    }

    private async Task OnInvoiceSelected()
    {
        if (_selectedInvoiceId.HasValue)
        {
            _selectedInvoice = _unpaidInvoices.FirstOrDefault(i => i.Id == _selectedInvoiceId.Value);
            if (_selectedInvoice != null)
            {
                _amount = _selectedInvoice.AmountDue;
            }
        }
        else
        {
            _selectedInvoice = null;
            _amount = 0;
        }

        await InvokeAsync(StateHasChanged);
    }

    private async Task HandleSubmit()
    {
        if (!_selectedInvoiceId.HasValue)
        {
            Snackbar.Add(Localization.GetString("PleaseSelectInvoice"), Severity.Warning);
            return;
        }

        if (_amount <= 0)
        {
            Snackbar.Add(Localization.GetString("PleaseEnterAmount"), Severity.Warning);
            return;
        }

        if (_selectedInvoice != null && _amount > _selectedInvoice.AmountDue)
        {
            Snackbar.Add(Localization.GetString("PaymentExceedsBalance"), Severity.Warning);
            return;
        }

        _saving = true;

        try
        {
            _createDto.InvoiceId = _selectedInvoiceId.Value;
            _createDto.PaymentDate = _paymentDate ?? DateTime.UtcNow;
            _createDto.Amount = _amount;
            _createDto.PaymentMethod = _paymentMethod;
            _createDto.ReferenceNumber = _referenceNumber;
            _createDto.Notes = _notes;
            _createDto.RecordedBy = _recordedBy;

            PaymentDto created = await PaymentService.CreatePaymentAsync(_createDto);

            Snackbar.Add(Localization.GetString("PaymentCreated"), Severity.Success);
            Navigation.NavigateTo($"/invoices/{_selectedInvoiceId}");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error creating payment: {ex.Message}");
            Snackbar.Add(Localization.GetString("ErrorCreatingPayment"), Severity.Error);
        }
        finally
        {
            _saving = false;
        }
    }

    public void Dispose()
    {
        Localization.OnLanguageChanged -= OnLanguageChanged;
    }
}