@page "/payments/edit/{Id:guid}"
@implements IDisposable
@using System.Globalization
@using WarehouseInvoiceSystem.Application.DTOs.Invoice
@using WarehouseInvoiceSystem.Application.DTOs.Payment
@using WarehouseInvoiceSystem.Application.Interfaces
@inject IPaymentService PaymentService
@inject IInvoiceService InvoiceService
@inject ILocalizationService Localization
@inject NavigationManager Navigation
@inject ISnackbar Snackbar

<PageTitle>@Localization.GetString("EditPayment") - @Localization.GetString("WarehouseInvoiceSystem")</PageTitle>

<div class="d-flex justify-space-between align-center mb-4">
    <MudText Typo="Typo.h4">@Localization.GetString("EditPayment")</MudText>
    <MudButton StartIcon="@Icons.Material.Filled.ArrowBack" 
               Variant="Variant.Text"
               Href="@($"/payments/{Id}")">
        @Localization.GetString("BackToPayments")
    </MudButton>
</div>

@if (_loading)
{
    <MudProgressLinear Color="Color.Primary" Indeterminate="true" />
}
else if (_payment == null)
{
    <MudAlert Severity="Severity.Error">@Localization.GetString("ErrorLoadingPayment")</MudAlert>
}
else
{
    <MudForm @ref="_form" @bind-IsValid="@_isValid">
        <MudCard Elevation="2" Class="mb-4">
            <MudCardHeader>
                <CardHeaderContent>
                    <MudText Typo="Typo.h6">@Localization.GetString("PaymentDetails")</MudText>
                </CardHeaderContent>
            </MudCardHeader>
            <MudCardContent>
                <MudGrid>
                    <MudItem xs="12">
                        <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">
                            <MudText Typo="Typo.body2">
                                <strong>@Localization.GetString("InvoiceNumber"):</strong> 
                                <MudLink Href="@($"/invoices/{_payment.InvoiceId}")">@_payment.InvoiceNumber</MudLink>
                            </MudText>
                            @if (_invoice != null)
                            {
                                <MudText Typo="Typo.body2" Class="mt-2">
                                    <strong>@Localization.GetString("RemainingBalance"):</strong> @_remainingBalance.ToString("C")
                                </MudText>
                            }
                        </MudAlert>
                    </MudItem>

                    <MudItem xs="12" md="6">
                        <MudDatePicker @key="_currentCultureKey"
                                       @bind-Date="_paymentDate"
                                       Label="@Localization.GetString("PaymentDate")"
                                       Variant="Variant.Outlined"
                                       Required="true"
                                       RequiredError="@Localization.GetString("PaymentDateRequired")" />
                    </MudItem>

                    <MudItem xs="12" md="6">
                        <MudNumericField T="decimal"
                                         @bind-Value="_amount"
                                         Label="@Localization.GetString("Amount")"
                                         Variant="Variant.Outlined"
                                         Required="true"
                                         RequiredError="@Localization.GetString("PleaseEnterAmount")"
                                         Min="0.01m"
                                         Max="@_maxAmount"
                                         Format="N2"
                                         TextUpdateSuppression="false"
                                         Adornment="Adornment.Start"
                                         AdornmentText="MKD" />
                    </MudItem>

                    <MudItem xs="12" md="6">
                        <MudSelect T="PaymentMethod"
                                   @bind-Value="_paymentMethod"
                                   Label="@Localization.GetString("PaymentMethod")"
                                   Variant="Variant.Outlined"
                                   Required="true"
                                   RequiredError="@Localization.GetString("PleaseSelectPaymentMethod")"
                                   AnchorOrigin="Origin.BottomLeft">
                            @foreach (var method in Enum.GetValues<PaymentMethod>())
                            {
                                <MudSelectItem T="PaymentMethod" Value="@(method)">
                                    <MudChip T="InvoiceStatus"
                                             Size="Size.Small"
                                             Color="Color.Info">
                                        @Localization.GetString(method.ToString())
                                    </MudChip>
                                </MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>

                    <MudItem xs="12" md="6">
                        <MudTextField T="string"
                                      @bind-Value="_referenceNumber"
                                      Label="@Localization.GetString("ReferenceNumber")"
                                      Variant="Variant.Outlined"
                                      Placeholder="@Localization.GetString("EnterReferenceNumber")" />
                    </MudItem>

                    <MudItem xs="12">
                        <MudTextField T="string"
                                      @bind-Value="_notes"
                                      Label="@Localization.GetString("Notes")"
                                      Variant="Variant.Outlined"
                                      Lines="3"
                                      Placeholder="@Localization.GetString("EnterNotes")" />
                    </MudItem>
                </MudGrid>
            </MudCardContent>
        </MudCard>
        <!-- Actions -->
        <MudItem xs="12">
            <div class="d-flex justify-end gap-2">
                <MudButton Variant="Variant.Outlined"
                           OnClick="@(() => Navigation.NavigateTo($"/payments/{Id}"))">
                    @Localization.GetString("Cancel")
                </MudButton>
                <MudButton Variant="Variant.Filled"
                           Color="Color.Primary"
                           OnClick="HandleSubmit"
                           Disabled="@(!_isValid || _saving)">
                    @if (_saving)
                    {
                        <MudProgressCircular Class="mr-2" Size="Size.Small" Indeterminate="true" />
                        @Localization.GetString("Save")
                    }
                    else
                    {
                        @Localization.GetString("Update")
                    }
                </MudButton>
            </div>
            </MudItem>
    </MudForm>
}

@code {
    [Parameter]
    public Guid Id { get; set; }

    private bool _loading = true;
    private bool _saving = false;
    private string _currentCultureKey = CultureInfo.CurrentCulture.Name;
    private MudForm _form = null!;
    private bool _isValid;
    private PaymentDto? _payment;
    private InvoiceDto? _invoice;
    private readonly UpdatePaymentDto _updateDto = new();

    private DateTime? _paymentDate;
    private decimal _amount = 0;
    private PaymentMethod _paymentMethod = PaymentMethod.BankTransfer;
    private string? _referenceNumber;
    private string? _notes;

    private decimal _remainingBalance = 0;
    private decimal _maxAmount = 0;

    protected override async Task OnInitializedAsync()
    {
        Localization.OnLanguageChanged += OnLanguageChanged;
        await LoadPayment();
        await LoadInvoice();
        CalculateMaxAmount();
    }

    private async void OnLanguageChanged()
    {
        _currentCultureKey = CultureInfo.CurrentCulture.Name;
        await InvokeAsync(StateHasChanged);
    }

    private async Task LoadPayment()
    {
        _loading = true;
        
        try
        {
            _payment = await PaymentService.GetPaymentByIdAsync(Id);
            
            if (_payment != null)
            {
                _paymentDate = _payment.PaymentDate;
                _amount = _payment.Amount;
                _paymentMethod = _payment.PaymentMethod;
                _referenceNumber = _payment.ReferenceNumber;
                _notes = _payment.Notes;
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading payment: {ex.Message}");
            Snackbar.Add(Localization.GetString("ErrorLoadingPayment"), Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task LoadInvoice()
    {
        try
        {
            if (_payment != null)
            {
                _invoice = await InvoiceService.GetInvoiceByIdAsync(_payment.InvoiceId);
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading invoice: {ex.Message}");
        }
    }

    private void CalculateMaxAmount()
    {
        if (_invoice != null && _payment != null)
        {
            _remainingBalance = _invoice.AmountDue + _payment.Amount;
            _maxAmount = _remainingBalance;
        }
    }

    private async Task HandleSubmit()
    {
        if (_amount <= 0)
        {
            Snackbar.Add(Localization.GetString("PleaseEnterAmount"), Severity.Warning);
            return;
        }

        if (_amount > _maxAmount)
        {
            Snackbar.Add(Localization.GetString("PaymentExceedsBalance"), Severity.Warning);
            return;
        }

        _saving = true;

        try
        {
            _updateDto.PaymentDate = _paymentDate ?? DateTime.UtcNow;
            _updateDto.Amount = _amount;
            _updateDto.PaymentMethod = _paymentMethod;
            _updateDto.ReferenceNumber = _referenceNumber;
            _updateDto.Notes = _notes;

            PaymentDto updated = await PaymentService.UpdatePaymentAsync(Id, _updateDto);
            
            Snackbar.Add(Localization.GetString("PaymentUpdated"), Severity.Success);
            Navigation.NavigateTo($"/payments/{Id}");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error updating payment: {ex.Message}");
            Snackbar.Add(Localization.GetString("ErrorUpdatingPayment"), Severity.Error);
        }
        finally
        {
            _saving = false;
        }
    }

    public void Dispose()
    {
        Localization.OnLanguageChanged -= OnLanguageChanged;
    }
}