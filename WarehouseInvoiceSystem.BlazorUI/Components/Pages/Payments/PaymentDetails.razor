@page "/payments/{Id:guid}"
@inherits PageBase
@using WarehouseInvoiceSystem.Application.DTOs.Invoice
@using WarehouseInvoiceSystem.Application.DTOs.Payment
@inject IPaymentService PaymentService
@inject IInvoiceService InvoiceService

<PageTitle>@Localization.GetString("PaymentDetails") - @Localization.GetString("InvoiceSystem")</PageTitle>

@if (_loading)
{
    <MudProgressLinear Color="Color.Primary" Indeterminate="true" />
}
else if (_payment == null)
{
    <MudAlert Severity="Severity.Error">@Localization.GetString("ErrorLoadingPayment")</MudAlert>
}
else
{
    <WisDetailHeader BackHref="/payments"
                     BackLabel="@Localization.GetString("Payments")"
                     PrimaryAction="@_primaryAction"
                     Actions="@_actions" />

    <MudCard Elevation="2">
        <MudCardContent Class="pa-6">

            <!-- wis-contact-row: left col (amount + pills) | divider | right col (notes) -->
            <div class="wis-contact-row mb-4">

                <div class="wis-contact-row-left">
                    <!-- Amount + chip -->
                    <div class="mb-3">
                        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="wis-section-label">@Localization.GetString("PaymentAmount")</MudText>
                        <div class="d-flex align-center gap-3">
                            <MudText Typo="Typo.h3" Color="Color.Success">@_payment.Amount.ToString("C")</MudText>
                            <MudChip T="string"
                                     Size="Size.Small"
                                     Color="@GetPaymentMethodColor(_payment.PaymentMethod)"
                                     Variant="Variant.Filled">
                                @GetPaymentMethodText(_payment.PaymentMethod)
                            </MudChip>
                        </div>
                    </div>

                    <!-- Detail pills -->
                    <div class="wis-detail-contact">
                        <div class="wis-detail-contact-item">
                            <MudIcon Icon="@Icons.Material.Filled.CalendarToday" Size="Size.Small" Color="Color.Secondary" />
                            <MudText Typo="Typo.body2">@_payment.PaymentDate.ToString("dd MMM yyyy")</MudText>
                        </div>
                        @if (!string.IsNullOrWhiteSpace(_payment.ReferenceNumber))
                        {
                            <div class="wis-detail-contact-item">
                                <MudIcon Icon="@Icons.Material.Filled.Tag" Size="Size.Small" Color="Color.Secondary" />
                                <MudText Typo="Typo.body2">@_payment.ReferenceNumber</MudText>
                            </div>
                        }
                        @if (!string.IsNullOrWhiteSpace(_payment.RecordedBy))
                        {
                            <div class="wis-detail-contact-item">
                                <MudIcon Icon="@Icons.Material.Filled.Person" Size="Size.Small" Color="Color.Secondary" />
                                <MudText Typo="Typo.body2">@_payment.RecordedBy</MudText>
                            </div>
                        }
                        <div class="wis-detail-contact-item">
                            <MudIcon Icon="@Icons.Material.Filled.Schedule" Size="Size.Small" Color="Color.Secondary" />
                            <MudText Typo="Typo.body2" Color="Color.Secondary">@_payment.CreatedAt.ToString("dd MMM yyyy HH:mm")</MudText>
                        </div>
                    </div>
                </div>

                <div class="wis-contact-row-divider"></div>
                <div class="wis-contact-row-right">
                    @if (_notesEditMode)
                    {
                        <div class="d-flex align-center gap-1 mb-0">
                            <MudIcon Icon="@Icons.Material.Filled.Notes" Size="Size.Small" Color="Color.Secondary" />
                            <MudText Typo="Typo.caption" Color="Color.Secondary" Class="wis-section-label flex-grow-1" Style="margin-bottom:0">@Localization.GetString("Notes")</MudText>
                            <MudIconButton Icon="@Icons.Material.Filled.Close"
                                           Size="Size.Small"
                                           Title="@Localization.GetString("Cancel")"
                                           OnClick="CancelNotesEdit"
                                           Disabled="@_notesSaving" />
                            <MudIconButton Icon="@Icons.Material.Filled.Check"
                                           Size="Size.Small"
                                           Color="Color.Primary"
                                           Title="@Localization.GetString("Save")"
                                           OnClick="SaveNotes"
                                           Disabled="@_notesSaving" />
                        </div>
                        <MudTextField @bind-Value="_notesEditValue"
                                      Variant="Variant.Outlined"
                                      FullWidth="true"
                                      Margin="Margin.Dense"
                                      Class="mt-0 wis-notes-input" />
                    }
                    else
                    {
                        <div class="d-flex align-center gap-1 mb-0">
                            <MudIcon Icon="@Icons.Material.Filled.Notes" Size="Size.Small" Color="Color.Secondary" />
                            <MudText Typo="Typo.caption" Color="Color.Secondary" Class="wis-section-label flex-grow-1" Style="margin-bottom:0">@Localization.GetString("Notes")</MudText>
                            <MudIconButton Icon="@(string.IsNullOrWhiteSpace(_payment.Notes) ? Icons.Material.Filled.Add : Icons.Material.Filled.Edit)"
                                           Size="Size.Small"
                                           Title="@Localization.GetString("Edit")"
                                           OnClick="@(() => StartNotesEdit(_payment?.Notes))" />
                        </div>
                        <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mt-0" Style="line-height: 1.6;">
                            @(string.IsNullOrWhiteSpace(_payment.Notes) ? "—" : _payment.Notes)
                        </MudText>
                    }
                </div>

            </div>

            <MudDivider Class="mb-6" />

            <!-- Related Invoice section - full width -->
            <div class="d-flex justify-space-between align-center mb-4">
                <MudText Typo="Typo.subtitle1" Class="wis-section-label">@Localization.GetString("RelatedInvoice")</MudText>
                <WisSplitButton PrimaryAction="@_invoiceAction" />
            </div>

            @if (_loadingInvoice)
            {
                <MudProgressLinear Color="Color.Primary" Indeterminate="true" Size="Size.Small" />
            }
            else if (_invoice != null)
            {
                <MudGrid Class="wis-detail-stats" Spacing="4">
                    <MudItem xs="12" sm="3">
                        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="wis-section-label">@Localization.GetString("Company")</MudText>
                        <MudText Typo="Typo.body1">@_invoice.CompanyName</MudText>
                    </MudItem>
                    <MudItem xs="12" sm="2">
                        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="wis-section-label">@Localization.GetString("InvoiceAmount")</MudText>
                        <div class="wis-stat-value">@_invoice.TotalAmount.ToString("C")</div>
                    </MudItem>
                    <MudItem xs="12" sm="2">
                        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="wis-section-label">@Localization.GetString("AlreadyPaid")</MudText>
                        <div class="wis-stat-value mud-success-text">@_invoice.AmountPaid.ToString("C")</div>
                    </MudItem>
                    <MudItem xs="12" sm="2">
                        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="wis-section-label">@Localization.GetString("AmountDue")</MudText>
                        <div class="wis-stat-value @(_invoice.AmountDue > 0 ? "mud-warning-text" : "mud-success-text")">
                            @_invoice.AmountDue.ToString("C")
                        </div>
                    </MudItem>
                    <MudItem xs="12" sm="2">
                        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="wis-section-label">@Localization.GetString("Status")</MudText>
                        <div>
                            <MudChip T="string"
                                     Size="Size.Small"
                                     Color="@GetInvoiceStatusColor(_invoice.Status)"
                                     Variant="Variant.Outlined">
                                @GetInvoiceStatusText(_invoice.Status)
                            </MudChip>
                        </div>
                    </MudItem>
                </MudGrid>
            }

        </MudCardContent>
    </MudCard>
}

@code {
    [Parameter]
    public Guid Id { get; set; }

    private bool _loadingInvoice = true;
    private PaymentDto? _payment;
    private InvoiceDto? _invoice;


    private WisDetailActionItem? _primaryAction;
    private List<WisDetailActionItem> _actions = [];
    private WisDetailActionItem? _invoiceAction;

    protected override async Task OnInitializedAsync()
    {
        await base.OnInitializedAsync();
        await LoadPayment();
        await LoadInvoice();
        BuildActions();
    }

    protected override async Task OnParametersSetAsync()
    {
        await LoadPayment();
        await LoadInvoice();
        BuildActions();
    }

    protected override async void OnLanguageChanged()
    {
        BuildActions();
        await InvokeAsync(StateHasChanged);
    }

    private async Task LoadPayment() =>
        await SafeLoadAsync(async () =>
        {
            _payment = await PaymentService.GetPaymentByIdAsync(Id, CancellationToken.None);
        }, "ErrorLoadingPayment");

    private async Task LoadInvoice()
    {
        _loadingInvoice = true;
        try
        {
            if (_payment != null)
                _invoice = await InvoiceService.GetInvoiceByIdAsync(_payment.InvoiceId, CancellationToken.None);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading invoice: {ex.Message}");
        }
        finally
        {
            _loadingInvoice = false;
        }
    }

    private void BuildActions()
    {
        if (_payment is null) return;

        _primaryAction = _act.Primary(Icons.Material.Filled.Edit, Localization.GetString("Edit"), OpenEditDialog);

        _actions =
        [
            _act.Error(Icons.Material.Filled.Delete, Localization.GetString("Delete"), DeletePayment),
        ];

        _invoiceAction = _act.Secondary(Icons.Material.Filled.RequestQuote, _payment.InvoiceNumber, () => Navigation.NavigateTo($"/invoices/{_payment.InvoiceId}"));
    }

    private async Task OpenEditDialog()
    {
        if (_payment is null) return;

        UpdatePaymentDto? dto = await WisDialog.ShowFormAsync<PaymentDialog, UpdatePaymentDto>(
            Localization.GetString("EditPayment"),
            p => p.Add(x => x.Payment, _payment));

        if (dto is null) return;

        try
        {
            await PaymentService.UpdatePaymentAsync(Id, dto);
            Snackbar.Add(Localization.GetString("PaymentUpdated"), Severity.Success);
            await LoadPayment();
            await LoadInvoice();
            BuildActions();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error updating payment: {ex.Message}");
            Snackbar.Add(Localization.GetString("ErrorUpdatingPayment"), Severity.Error);
        }
    }

    private async Task DeletePayment()
    {
        bool confirmed = await WisDialog.ConfirmAsync(
            Localization.GetString("ConfirmDelete"),
            Localization.GetString("DeletePaymentConfirm"),
            Localization.GetString("Yes"),
            Localization.GetString("No"));

        if (!confirmed) return;

        try
        {
            bool deleted = await PaymentService.DeletePaymentAsync(Id);
            if (deleted)
            {
                Snackbar.Add(Localization.GetString("PaymentDeleted"), Severity.Success);
                Navigation.NavigateTo("/payments");
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error deleting payment: {ex.Message}");
            Snackbar.Add(Localization.GetString("ErrorDeletingPayment"), Severity.Error);
        }
    }

    // ── Inline notes editing ──────────────────────────────────────────────────

    private async Task SaveNotes()
    {
        if (_payment is null) return;
        await SaveNotesAsync(async notes =>
        {
            await PaymentService.UpdateNotesAsync(Id, notes, CancellationToken.None);
            _payment.Notes = notes;
        }, "ErrorUpdatingPayment");
    }

}
