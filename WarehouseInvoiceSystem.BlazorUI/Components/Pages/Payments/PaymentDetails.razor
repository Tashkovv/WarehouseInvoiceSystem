@page "/payments/{Id:guid}"
@implements IDisposable
@using WarehouseInvoiceSystem.Application.DTOs.Invoice
@using WarehouseInvoiceSystem.Application.DTOs.Payment
@using WarehouseInvoiceSystem.Application.Interfaces
@inject IPaymentService PaymentService
@inject IInvoiceService InvoiceService
@inject ILocalizationService Localization
@inject NavigationManager Navigation
@inject IDialogService DialogService
@inject ISnackbar Snackbar

<PageTitle>@Localization.GetString("PaymentDetails") - @Localization.GetString("InvoiceSystem")</PageTitle>

@if (_loading)
{
    <MudProgressLinear Color="Color.Primary" Indeterminate="true" />
}
else if (_payment == null)
{
    <MudAlert Severity="Severity.Error">@Localization.GetString("ErrorLoadingPayment")</MudAlert>
}
else
{
    <div class="d-flex justify-space-between align-center mb-4">
        <div>
            <MudButton StartIcon="@Icons.Material.Filled.ArrowBack"
                       Variant="Variant.Text"
                       Href="/payments">
                @Localization.GetString("BackToPayments")
            </MudButton>
        </div>
        <div>
            <MudButton StartIcon="@Icons.Material.Filled.Edit"
                       Color="Color.Primary"
                       Variant="Variant.Filled"
                       Class="mr-2"
                       Href="@($"/payments/edit/{Id}")">
                @Localization.GetString("Edit")
            </MudButton>
            <MudButton StartIcon="@Icons.Material.Filled.Delete"
                       Color="Color.Error"
                       Variant="Variant.Outlined"
                       OnClick="DeletePayment">
                @Localization.GetString("Delete")
            </MudButton>
        </div>
    </div>

    <MudGrid>
        <!-- Payment Header - Single Card -->
        <MudItem xs="12">
            <MudCard Elevation="2">
                <MudCardContent Class="pa-6">
                    <MudGrid Spacing="4">
                        <!-- Left: Amount + Method + Invoice Link -->
                        <MudItem xs="12" md="6">
                            <MudStack Spacing="2">
                                <MudText Typo="Typo.caption" Color="Color.Secondary">@Localization.GetString("PaymentAmount")</MudText>
                                <MudText Typo="Typo.h3" Color="Color.Success" Class="mb-0">
                                    @_payment.Amount.ToString("C")
                                </MudText>

                                <MudDivider Class="my-2" />

                                <div class="d-flex align-center">
                                    <MudIcon Icon="@Icons.Material.Filled.Payment" Size="Size.Small" Class="mr-2" Color="Color.Info" />
                                    <MudChip T="string" Size="Size.Small" Color="Color.Info">
                                        @GetPaymentMethodText(_payment.PaymentMethod)
                                    </MudChip>
                                </div>

                                <div class="d-flex align-center">
                                    <MudIcon Icon="@Icons.Material.Filled.Receipt" Size="Size.Small" Class="mr-2" Color="Color.Secondary" />
                                    <div>
                                        <MudText Typo="Typo.caption" Color="Color.Secondary">@Localization.GetString("InvoiceNumber")</MudText>
                                        <MudText Typo="Typo.body1" Class="font-weight-medium">
                                            @_payment.InvoiceNumber
                                        </MudText>
                                    </div>
                                </div>
                            </MudStack>
                        </MudItem>

                        <!-- Divider (visible on medium+ screens) -->
                        <MudHidden Breakpoint="Breakpoint.SmAndDown">
                            <MudItem md="1" Class="d-flex align-center justify-center">
                                <MudDivider Vertical="true" />
                            </MudItem>
                        </MudHidden>

                        <!-- Right: Payment Details + Dates -->
                        <MudItem xs="12" md="5">
                            <MudStack Spacing="3">
                                <!-- Payment Date -->
                                <div>
                                    <div class="d-flex align-center mb-1">
                                        <MudIcon Icon="@Icons.Material.Filled.CalendarToday" Size="Size.Small" Class="mr-1" Color="Color.Secondary" />
                                        <MudText Typo="Typo.caption" Color="Color.Secondary">@Localization.GetString("PaymentDate")</MudText>
                                    </div>
                                    <MudText Typo="Typo.h6" Class="mb-0">
                                        @_payment.PaymentDate.ToString("dd MMM yyyy")
                                    </MudText>
                                </div>

                                <!-- Reference Number (if exists) -->
                                @if (!string.IsNullOrWhiteSpace(_payment.ReferenceNumber))
                                {
                                    <div>
                                        <div class="d-flex align-center mb-1">
                                            <MudIcon Icon="@Icons.Material.Filled.Tag" Size="Size.Small" Class="mr-1" Color="Color.Secondary" />
                                            <MudText Typo="Typo.caption" Color="Color.Secondary">@Localization.GetString("ReferenceNumber")</MudText>
                                        </div>
                                        <MudText Typo="Typo.body1" Class="font-weight-medium">
                                            @_payment.ReferenceNumber
                                        </MudText>
                                    </div>
                                }

                                <!-- Recorded By (if exists) -->
                                @if (!string.IsNullOrWhiteSpace(_payment.RecordedBy))
                                {
                                    <div>
                                        <div class="d-flex align-center mb-1">
                                            <MudIcon Icon="@Icons.Material.Filled.Person" Size="Size.Small" Class="mr-1" Color="Color.Secondary" />
                                            <MudText Typo="Typo.caption" Color="Color.Secondary">@Localization.GetString("RecordedBy")</MudText>
                                        </div>
                                        <MudText Typo="Typo.body1">@_payment.RecordedBy</MudText>
                                    </div>
                                }

                                <!-- Created At -->
                                <div>
                                    <div class="d-flex align-center mb-1">
                                        <MudIcon Icon="@Icons.Material.Filled.Schedule" Size="Size.Small" Class="mr-1" Color="Color.Secondary" />
                                        <MudText Typo="Typo.caption" Color="Color.Secondary">@Localization.GetString("CreatedAt")</MudText>
                                    </div>
                                    <MudText Typo="Typo.body2">
                                        @_payment.CreatedAt.ToString("dd MMM yyyy HH:mm")
                                    </MudText>
                                </div>
                            </MudStack>
                        </MudItem>
                    </MudGrid>

                    <!-- Notes Section (Full Width) -->
                    @if (!string.IsNullOrWhiteSpace(_payment.Notes))
                    {
                        <MudDivider Class="my-4" />
                        <div class="d-flex align-start">
                            <MudIcon Icon="@Icons.Material.Filled.Notes" Size="Size.Small" Class="mr-2 mt-1" Color="Color.Secondary" />
                            <div style="flex: 1;">
                                <MudText Typo="Typo.caption" Color="Color.Dark" Class="mb-1">@Localization.GetString("Notes")</MudText>
                                <MudText Typo="Typo.body2" Color="Color.Secondary" Style="line-height: 1.6;">
                                    @_payment.Notes
                                </MudText>
                            </div>
                        </div>
                    }
                </MudCardContent>
            </MudCard>
        </MudItem>

        <!-- Related Invoice Summary (Simplified) -->
        <MudItem xs="12">
            <MudCard Elevation="2">
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudText Typo="Typo.h6">@Localization.GetString("RelatedInvoice")</MudText>
                    </CardHeaderContent>
                    <CardHeaderActions>
                        <MudButton Size="Size.Small"
                                   Variant="Variant.Text"
                                   Color="Color.Primary"
                                   Href="@($"/invoices/{_payment.InvoiceId}")"
                                   EndIcon="@Icons.Material.Filled.ArrowForward">
                            @Localization.GetString("ViewInvoice")
                        </MudButton>
                    </CardHeaderActions>
                </MudCardHeader>
                <MudCardContent Class="pa-4">
                    @if (_loadingInvoice)
                    {
                        <MudProgressLinear Color="Color.Primary" Indeterminate="true" />
                    }
                    else if (_invoice != null)
                    {
                        <MudGrid Spacing="3">
                            <!-- Company -->
                            <MudItem xs="12" sm="6" md="3">
                                <div class="d-flex align-center">
                                    <MudIcon Icon="@Icons.Material.Filled.Business" Size="Size.Small" Class="mr-2" Color="Color.Primary" />
                                    <div>
                                        <MudText Typo="Typo.caption" Color="Color.Secondary">@Localization.GetString("Company")</MudText>
                                        <MudText Typo="Typo.body1" Class="font-weight-medium">@_invoice.CompanyName</MudText>
                                    </div>
                                </div>
                            </MudItem>

                            <!-- Invoice Amount -->
                            <MudItem xs="12" sm="6" md="2">
                                <div class="d-flex align-center">
                                    <MudIcon Icon="@Icons.Material.Filled.Receipt" Size="Size.Small" Class="mr-2" Color="Color.Secondary" />
                                    <div>
                                        <MudText Typo="Typo.caption" Color="Color.Secondary">@Localization.GetString("InvoiceAmount")</MudText>
                                        <MudText Typo="Typo.body1" Class="font-weight-bold">@_invoice.TotalAmount.ToString("C")</MudText>
                                    </div>
                                </div>
                            </MudItem>

                            <!-- Already Paid -->
                            <MudItem xs="12" sm="6" md="2">
                                <div class="d-flex align-center">
                                    <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Size="Size.Small" Class="mr-2" Color="Color.Success" />
                                    <div>
                                        <MudText Typo="Typo.caption" Color="Color.Secondary">@Localization.GetString("AlreadyPaid")</MudText>
                                        <MudText Typo="Typo.body1" Class="font-weight-bold" Color="Color.Success">@_invoice.AmountPaid.ToString("C")</MudText>
                                    </div>
                                </div>
                            </MudItem>

                            <!-- Amount Due -->
                            <MudItem xs="12" sm="6" md="2">
                                <div class="d-flex align-center">
                                    <MudIcon Icon="@Icons.Material.Filled.Warning" Size="Size.Small" Class="mr-2" Color="@(_invoice.AmountDue > 0 ? Color.Warning : Color.Success)" />
                                    <div>
                                        <MudText Typo="Typo.caption" Color="Color.Secondary">@Localization.GetString("AmountDue")</MudText>
                                        <MudText Typo="Typo.body1" Class="font-weight-bold" Color="@(_invoice.AmountDue > 0 ? Color.Warning : Color.Success)">
                                            @_invoice.AmountDue.ToString("C")
                                        </MudText>
                                    </div>
                                </div>
                            </MudItem>

                            <!-- Status -->
                            <MudItem xs="12" sm="6" md="1">
                                <div class="d-flex align-center">
                                    <MudIcon Icon="@Icons.Material.Filled.Info" Size="Size.Small" Class="mr-2" Color="Color.Secondary" />
                                    <div>
                                        <MudText Typo="Typo.caption" Color="Color.Secondary">@Localization.GetString("Status")</MudText>
                                        <MudChip T="string" Size="Size.Small" Color="GetStatusColor(_invoice.Status)">
                                            @GetStatusText(_invoice.Status)
                                        </MudChip>
                                    </div>
                                </div>
                            </MudItem>
                        </MudGrid>
                    }
                </MudCardContent>
            </MudCard>
        </MudItem>
    </MudGrid>
}

@code {
    [Parameter]
    public Guid Id { get; set; }

    private bool _loading = true;
    private bool _loadingInvoice = true;
    private PaymentDto? _payment;
    private InvoiceDto? _invoice;

    protected override async Task OnInitializedAsync()
    {
        Localization.OnLanguageChanged += OnLanguageChanged;
        await LoadPayment();
        await LoadInvoice();
    }

    protected override async Task OnParametersSetAsync()
    {
        await LoadPayment();
        await LoadInvoice();
    }

    private async void OnLanguageChanged()
    {
        await InvokeAsync(StateHasChanged);
    }

    private async Task LoadPayment()
    {
        _loading = true;

        try
        {
            _payment = await PaymentService.GetPaymentByIdAsync(Id);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading payment: {ex.Message}");
            Snackbar.Add(Localization.GetString("ErrorLoadingPayment"), Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task LoadInvoice()
    {
        _loadingInvoice = true;

        try
        {
            if (_payment != null)
            {
                _invoice = await InvoiceService.GetInvoiceByIdAsync(_payment.InvoiceId);
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading invoice: {ex.Message}");
        }
        finally
        {
            _loadingInvoice = false;
        }
    }

    private string GetPaymentMethodText(PaymentMethod method)
    {
        return method switch
        {
            PaymentMethod.Cash => Localization.GetString("Cash"),
            PaymentMethod.Check => Localization.GetString("Check"),
            PaymentMethod.BankTransfer => Localization.GetString("BankTransfer"),
            PaymentMethod.CreditCard => Localization.GetString("CreditCard"),
            PaymentMethod.DebitCard => Localization.GetString("DebitCard"),
            PaymentMethod.Other => Localization.GetString("Other"),
            _ => method.ToString()
        };
    }

    private Color GetStatusColor(InvoiceStatus status)
    {
        return status switch
        {
            InvoiceStatus.Draft => Color.Default,
            InvoiceStatus.Sent => Color.Info,
            InvoiceStatus.PartiallyPaid => Color.Warning,
            InvoiceStatus.Paid => Color.Success,
            InvoiceStatus.Overdue => Color.Error,
            InvoiceStatus.Cancelled => Color.Default,
            _ => Color.Default
        };
    }

    private string GetStatusText(InvoiceStatus status)
    {
        return status switch
        {
            InvoiceStatus.Draft => Localization.GetString("Draft"),
            InvoiceStatus.Sent => Localization.GetString("Sent"),
            InvoiceStatus.PartiallyPaid => Localization.GetString("PartiallyPaid"),
            InvoiceStatus.Paid => Localization.GetString("PaidStatus"),
            InvoiceStatus.Overdue => Localization.GetString("OverdueStatus"),
            InvoiceStatus.Cancelled => Localization.GetString("Cancelled"),
            _ => status.ToString()
        };
    }

    private async Task DeletePayment()
    {
        bool? result = await DialogService.ShowMessageBoxAsync(
            new MessageBoxOptions
            {
                Title = Localization.GetString("ConfirmDelete"),
                Message = Localization.GetString("DeletePaymentConfirm"),
                YesText = Localization.GetString("Yes"),
                CancelText = Localization.GetString("No")
            });

        if (result == true)
        {
            try
            {
                bool deleted = await PaymentService.DeletePaymentAsync(Id);
                if (deleted)
                {
                    Snackbar.Add(Localization.GetString("PaymentDeleted"), Severity.Success);
                    Navigation.NavigateTo("/payments");
                }
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Error deleting payment: {ex.Message}");
                Snackbar.Add(Localization.GetString("ErrorDeletingPayment"), Severity.Error);
            }
        }
    }

    public void Dispose()
    {
        Localization.OnLanguageChanged -= OnLanguageChanged;
    }
}