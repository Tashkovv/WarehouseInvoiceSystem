@page "/payments"
@implements IDisposable
@using WarehouseInvoiceSystem.Application.Interfaces
@using WarehouseInvoiceSystem.Application.DTOs.Payment
@inject IPaymentService PaymentService
@inject ILocalizationService Localization
@inject NavigationManager Navigation
@inject IDialogService DialogService
@inject ISnackbar Snackbar

<PageTitle>@Localization.GetString("Payments") - @Localization.GetString("InvoiceSystem")</PageTitle>

<MudText Typo="Typo.h4" Class="mb-6">@Localization.GetString("Payments")</MudText>

<MudCard Elevation="2" Class="mb-4">
    <MudCardContent>
        <MudGrid>
            <MudItem xs="12" sm="6" md="3">
                <MudButton StartIcon="@Icons.Material.Filled.Add"
                           Color="Color.Primary"
                           Variant="Variant.Filled"
                           FullWidth="true"
                           Href="/payments/create">
                    @Localization.GetString("RecordPayment")
                </MudButton>
            </MudItem>
            <MudItem xs="12" sm="6" md="9">
                <MudTextField T="string"
                              Value="_searchString"
                              ValueChanged="OnSearch"
                              Placeholder="@Localization.GetString("Search")"
                              Adornment="Adornment.Start"
                              AdornmentIcon="@Icons.Material.Filled.Search"
                              IconSize="Size.Medium"
                              Immediate="true"
                              DebounceInterval="300"
                              Class="mt-0" />
            </MudItem>
        </MudGrid>

        <!-- Filter Toggle Button -->
        <div class="mt-4">
            <MudButton StartIcon="@(_showFilters? Icons.Material.Filled.ExpandLess : Icons.Material.Filled.ExpandMore)"
                       Variant="Variant.Text"
                       Color="Color.Primary"
                       OnClick="@(() => _showFilters = !_showFilters)">
                @Localization.GetString("AdvancedFilters")
                @if (_hasActiveFilters)
                {
                    <MudChip T="int" Size="Size.Small" Class="ml-2">@_activeFilterCount</MudChip>
                }
            </MudButton>
        </div>

        <!-- Filters Panel (Collapsible) -->
        @if (_showFilters)
        {
            <MudDivider Class="my-4" />
            <MudGrid>
                <!-- Payment Method Filter -->
                <MudItem xs="12" sm="6" md="3" Class="d-flex align-end">
                    <MudSelect T="PaymentMethod ?"
                               Value="_filterMethod"
                               Label="@Localization.GetString("PaymentMethod")"
                               Clearable="true"
                               Dense="true"
                               ValueChanged="@((PaymentMethod? val) => { _filterMethod = val; ResetPaginationAndApplyFilters(); })">
                        @foreach (var method in Enum.GetValues<PaymentMethod>())
                        {
                            <MudSelectItem T="PaymentMethod ?" Value="@(method)">
                                <MudChip T="string"
                                         Size="Size.Small"
                                         Color="Color.Info">
                                    @Localization.GetString(method.ToString())
                                </MudChip>
                            </MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>

                <!-- Payment Date Range Filter -->
                <MudItem xs="12" sm="6" md="3">
                    <MudText Typo="Typo.body2" Class="mb-2">@Localization.GetString("PaymentDate")</MudText>
                    <MudStack Row="true" Spacing="1">
                        <MudDatePicker Date="_filterPaymentDateFrom"
                                       Label="@Localization.GetString("From")"
                                       Dense="true"
                                       DateChanged="@((DateTime? val) => { _filterPaymentDateFrom = val; ResetPaginationAndApplyFilters(); })" />
                        <MudDatePicker Date="_filterPaymentDateTo"
                                       Label="@Localization.GetString("To")"
                                       Dense="true"
                                       DateChanged="@((DateTime? val) => { _filterPaymentDateTo = val; ResetPaginationAndApplyFilters(); })" />
                    </MudStack>
                </MudItem>

                <!-- Amount Range Filter -->
                <MudItem xs="12" sm="6" md="3">
                    <MudText Typo="Typo.body2" Class="mb-2">@Localization.GetString("AmountRange")</MudText>
                    <MudStack Row="true" Spacing="1">
                        <MudNumericField T="decimal?"
                                         Value="_filterAmountMin"
                                         Label="@Localization.GetString("Min")"
                                         HideSpinButtons="true"
                                         Dense="true"
                                         ValueChanged="@((decimal? val) => { _filterAmountMin = val; ResetPaginationAndApplyFilters(); })" />
                        <MudNumericField T="decimal?"
                                         Value="_filterAmountMax"
                                         Label="@Localization.GetString("Max")"
                                         HideSpinButtons="true"
                                         Dense="true"
                                         ValueChanged="@((decimal? val) => { _filterAmountMax = val; ResetPaginationAndApplyFilters(); })" />
                    </MudStack>
                </MudItem>

                <!-- Clear Filters Button -->
                <MudItem xs="12" sm="6" md="3" Class="d-flex align-end">
                    <MudButton StartIcon="@Icons.Material.Filled.FilterAltOff"
                               Variant="Variant.Outlined"
                               Color="Color.Default"
                               OnClick="ClearFilters"
                               Disabled="@(!_hasActiveFilters)">
                        @Localization.GetString("ClearFilters")
                    </MudButton>
                </MudItem>
            </MudGrid>
        }
    </MudCardContent>
</MudCard>

<MudCard Elevation="2" Class="mb-4">
    <MudCardContent Class="pa-0">
        @if (_loading)
        {
            <div class="pa-6">
                <MudProgressLinear Color="Color.Primary" Indeterminate="true" />
            </div>
        }
        else if (_filteredPayments == null || !_filteredPayments.Any())
        {
            <div class="pa-6 text-center">
                <MudText Color="Color.Secondary">@Localization.GetString("NoPaymentsFound")</MudText>
            </div>
        }
        else
        {
            <MudTable Items="_paginatedPayments"
                      Hover="true"
                      Breakpoint="Breakpoint.Sm"
                      Dense="false"
                      FixedHeader="true"
                      Height="710px"
                      Sort="@((SortDefinition<PaymentDto> sortDefinition) => HandleSort(sortDefinition))">
                <HeaderContent>
                    <MudTh><MudTableSortLabel SortBy="new Func<PaymentDto, object>(x => x.PaymentDate)">@Localization.GetString("PaymentDate")</MudTableSortLabel></MudTh>
                    <MudTh><MudTableSortLabel SortBy="new Func<PaymentDto, object>(x => x.InvoiceNumber)">@Localization.GetString("InvoiceNumber")</MudTableSortLabel></MudTh>
                    <MudTh><MudTableSortLabel SortBy="new Func<PaymentDto, object>(x => x.Amount)">@Localization.GetString("Amount")</MudTableSortLabel></MudTh>
                    <MudTh>@Localization.GetString("PaymentMethod")</MudTh>
                    <MudTh><MudTableSortLabel SortBy="new Func<PaymentDto, object>(x => x.ReferenceNumber ?? string.Empty)">@Localization.GetString("ReferenceNumber")</MudTableSortLabel></MudTh>
                    <MudTh>@Localization.GetString("RecordedBy")</MudTh>
                    <MudTh>@Localization.GetString("Actions")</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="@Localization.GetString("PaymentDate")">
                        @context.PaymentDate.ToString("MMM dd, yyyy")
                    </MudTd>
                    <MudTd DataLabel="@Localization.GetString("InvoiceNumber")">
                        <MudLink Href="@($"/invoices/{context.InvoiceId}")" Typo="Typo.body2" Class="font-weight-medium">
                            @context.InvoiceNumber
                        </MudLink>
                    </MudTd>
                    <MudTd DataLabel="@Localization.GetString("Amount")">
                        <MudText Typo="Typo.body2" Class="font-weight-medium" Color="Color.Success">
                            @context.Amount.ToString("C")
                        </MudText>
                    </MudTd>
                    <MudTd DataLabel="@Localization.GetString("PaymentMethod")">
                        <MudChip T="string" Size="Size.Small" Color="Color.Info">
                            @GetPaymentMethodText(context.PaymentMethod)
                        </MudChip>
                    </MudTd>
                    <MudTd DataLabel="@Localization.GetString("ReferenceNumber")">
                        @context.ReferenceNumber
                    </MudTd>
                    <MudTd DataLabel="@Localization.GetString("RecordedBy")">
                        @context.RecordedBy
                    </MudTd>
                    <MudTd DataLabel="@Localization.GetString("Actions")">
                        <MudMenu Icon="@Icons.Material.Filled.MoreVert" Size="Size.Small">
                            <MudMenuItem Icon="@Icons.Material.Filled.Visibility"
                                         OnClick="@(() => ViewPayment(context.Id))">
                                @Localization.GetString("View")
                            </MudMenuItem>
                            <MudMenuItem Icon="@Icons.Material.Filled.Edit"
                                         OnClick="@(() => EditPayment(context.Id))">
                                @Localization.GetString("Edit")
                            </MudMenuItem>
                            <MudDivider />
                            <MudMenuItem Icon="@Icons.Material.Filled.Delete"
                                         IconColor="Color.Error"
                                         OnClick="@(() => DeletePayment(context.Id))">
                                @Localization.GetString("Delete")
                            </MudMenuItem>
                        </MudMenu>
                    </MudTd>
                </RowTemplate>
            </MudTable>

            <!-- Pagination Controls -->
            <MudDivider />
            <MudCardContent Class="pa-4">
                <MudGrid>
                    <!-- Left Side: Page Navigation -->
                    <MudItem xs="12" sm="6">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                            <MudButton Variant="Variant.Outlined"
                                       Size="Size.Small"
                                       OnClick="PreviousPage"
                                       Disabled="@(_currentPage == 1)">
                                @Localization.GetString("Previous")
                            </MudButton>

                            <MudText Typo="Typo.body2">
                                @Localization.GetString("Page") @_currentPage @Localization.GetString("Of") @_totalPages
                            </MudText>

                            <MudButton Variant="Variant.Outlined"
                                       Size="Size.Small"
                                       OnClick="NextPage"
                                       Disabled="@(_currentPage == _totalPages)">
                                @Localization.GetString("Next")
                            </MudButton>
                        </MudStack>
                    </MudItem>

                    <!-- Right Side: Items Per Page & Stats -->
                    <MudItem xs="12" sm="6" Class="d-flex justify-end align-center">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1" Class="ml-auto">
                            <MudText Typo="Typo.body2">
                                @Localization.GetString("ItemsPerPage")
                            </MudText>

                            <MudSelect T="int"
                                       Value="_itemsPerPage"
                                       Dense="true"
                                       Variant="Variant.Outlined"
                                       Style="width: 100px;"
                                       ValueChanged="@((int val) => OnItemsPerPageChanged(val))">
                                <MudSelectItem Value="10">10</MudSelectItem>
                                <MudSelectItem Value="25">25</MudSelectItem>
                                <MudSelectItem Value="50">50</MudSelectItem>
                                <MudSelectItem Value="100">100</MudSelectItem>
                            </MudSelect>

                            <MudText Typo="Typo.body2" Color="Color.Secondary">
                                (@_totalPayments @Localization.GetString("Total"))
                            </MudText>
                        </MudStack>
                    </MudItem>
                </MudGrid>
            </MudCardContent>
        }
    </MudCardContent>
</MudCard>

@code {
    private bool _loading = true;
    private bool _showFilters = false;
    private List<PaymentDto> _allPayments = new();
    private List<PaymentDto> _filteredPayments = new();
    private List<PaymentDto> _paginatedPayments = [];
    private string _searchString = "";

    // Pagination variables
    private int _currentPage = 1;
    private int _itemsPerPage = 10;
    private int _totalPayments = 0;
    private int _totalPages = 1;

    // Sorting variables
    private string _sortBy = "CreatedAt";
    private bool _sortAscending = false;

    // Filter variables
    private PaymentMethod? _filterMethod;
    private decimal? _filterAmountMin;
    private decimal? _filterAmountMax;
    private DateTime? _filterPaymentDateFrom;
    private DateTime? _filterPaymentDateTo;

    private bool _hasActiveFilters =>
        _filterMethod.HasValue ||
        _filterAmountMin.HasValue ||
        _filterAmountMax.HasValue ||
        _filterPaymentDateFrom.HasValue ||
        _filterPaymentDateTo.HasValue;

    private int _activeFilterCount =>
        (_filterMethod.HasValue ? 1 : 0) +
        (_filterAmountMin.HasValue || _filterAmountMax.HasValue ? 1 : 0) +
        (_filterPaymentDateFrom.HasValue || _filterPaymentDateTo.HasValue ? 1 : 0);

    protected override async Task OnInitializedAsync()
    {
        Localization.OnLanguageChanged += OnLanguageChanged;
        await LoadPayments();
    }

    private async void OnLanguageChanged()
    {
        await InvokeAsync(StateHasChanged);
    }

    private async Task LoadPayments()
    {
        _loading = true;

        try
        {
            IEnumerable<PaymentDto> payments = await PaymentService.GetAllPaymentsAsync();
            _allPayments = payments.ToList();
            ApplyFilters();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading payments: {ex.Message}");
            Snackbar.Add(Localization.GetString("ErrorLoadingPayment"), Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    private void ApplyFilters()
    {
        IEnumerable<PaymentDto> filtered = _allPayments;

        // Apply Method filter
        if (_filterMethod.HasValue)
        {
            filtered = filtered.Where(i => i.PaymentMethod == _filterMethod.Value);
        }

        // Apply Amount Range filter
        if (_filterAmountMin.HasValue)
        {
            filtered = filtered.Where(i => i.Amount >= _filterAmountMin.Value);
        }

        if (_filterAmountMax.HasValue)
        {
            filtered = filtered.Where(i => i.Amount <= _filterAmountMax.Value);
        }

        // Apply Payment Date Range filter
        if (_filterPaymentDateFrom.HasValue)
        {
            filtered = filtered.Where(i => i.PaymentDate.Date >= _filterPaymentDateFrom.Value.Date);
        }

        if (_filterPaymentDateTo.HasValue)
        {
            filtered = filtered.Where(i => i.PaymentDate.Date <= _filterPaymentDateTo.Value.Date);
        }

        // Apply Search filter
        if (!string.IsNullOrWhiteSpace(_searchString))
        {
            string search = _searchString.ToLower();
            filtered = filtered.Where(p =>
                p.InvoiceNumber.ToLower().Contains(search) ||
                (p.ReferenceNumber?.ToLower().Contains(search) ?? false) ||
                (p.RecordedBy?.ToLower().Contains(search) ?? false) ||
                p.Amount.ToString().Contains(search));
        }

        // Apply sorting
        filtered = _sortAscending
            ? filtered.OrderBy(GetSortProperty)
            : filtered.OrderByDescending(GetSortProperty);

        _filteredPayments = filtered.ToList();
        _totalPayments = _filteredPayments.Count;

        // Calculate pagination
        UpdatePagination();
    }

    private void UpdatePagination()
    {
        // Calculate total pages
        _totalPages = (int)Math.Ceiling((double)_totalPayments / _itemsPerPage);

        // Ensure current page is valid
        if (_currentPage > _totalPages && _totalPages > 0)
        {
            _currentPage = _totalPages;
        }

        // Get paginated items
        int skipCount = (_currentPage - 1) * _itemsPerPage;
        _paginatedPayments = _filteredPayments
            .Skip(skipCount)
            .Take(_itemsPerPage)
            .ToList();
    }

    private void ResetPaginationAndApplyFilters()
    {
        _currentPage = 1;
        ApplyFilters();
    }

    private object GetSortProperty(PaymentDto payment) => _sortBy switch
    {
        "PaymentDate" => payment.PaymentDate,
        "InvoiceNumber" => payment.InvoiceNumber,
        "Amount" => payment.Amount,
        "ReferenceNumber" => payment.ReferenceNumber ?? string.Empty,
        _ => payment.CreatedAt
    };


    private void HandleSort(SortDefinition<PaymentDto> sortDefinition)
    {
        if (sortDefinition == null || string.IsNullOrEmpty(sortDefinition.SortBy))
            return;

        _sortBy = sortDefinition.SortBy;
        _sortAscending = !sortDefinition.Descending;
        ApplyFilters();
    }

    private async Task OnSearch(string text)
    {
        _searchString = text;
        ApplyFilters();
        await InvokeAsync(StateHasChanged);
    }

    private void ClearFilters()
    {
        _filterMethod = null;
        _filterAmountMin = null;
        _filterAmountMax = null;
        _filterPaymentDateFrom = null;
        _filterPaymentDateTo = null;
        ResetPaginationAndApplyFilters();
    }

    // Pagination methods
    private void PreviousPage()
    {
        if (_currentPage > 1)
        {
            _currentPage--;
            UpdatePagination();
        }
    }

    private void NextPage()
    {
        if (_currentPage < _totalPages)
        {
            _currentPage++;
            UpdatePagination();
        }
    }

    private void OnItemsPerPageChanged(int newItemsPerPage)
    {
        _itemsPerPage = newItemsPerPage;
        _currentPage = 1;
        UpdatePagination();
    }

    private string GetPaymentMethodText(PaymentMethod method)
    {
        return method switch
        {
            PaymentMethod.Cash => Localization.GetString("Cash"),
            PaymentMethod.Check => Localization.GetString("Check"),
            PaymentMethod.BankTransfer => Localization.GetString("BankTransfer"),
            PaymentMethod.CreditCard => Localization.GetString("CreditCard"),
            PaymentMethod.DebitCard => Localization.GetString("DebitCard"),
            PaymentMethod.Other => Localization.GetString("Other"),
            _ => method.ToString()
        };
    }

    private void ViewPayment(int id)
    {
        Navigation.NavigateTo($"/payments/{id}");
    }

    private void EditPayment(int id)
    {
        Navigation.NavigateTo($"/payments/edit/{id}");
    }

    private async Task DeletePayment(int id)
    {
        bool? result = await DialogService.ShowMessageBox(
            Localization.GetString("ConfirmDelete"),
            Localization.GetString("DeletePaymentConfirm"),
            yesText: Localization.GetString("Yes"),
            cancelText: Localization.GetString("No"));

        if (result == true)
        {
            try
            {
                bool deleted = await PaymentService.DeletePaymentAsync(id);
                if (deleted)
                {
                    Snackbar.Add(Localization.GetString("PaymentDeleted"), Severity.Success);
                    await LoadPayments();
                }
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Error deleting payment: {ex.Message}");
                Snackbar.Add(Localization.GetString("ErrorDeletingPayment"), Severity.Error);
            }
        }
    }

    public void Dispose()
    {
        Localization.OnLanguageChanged -= OnLanguageChanged;
    }
}