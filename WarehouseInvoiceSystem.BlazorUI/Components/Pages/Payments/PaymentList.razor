@page "/payments"
@implements IDisposable
@using WarehouseInvoiceSystem.Application.DTOs.Payment
@using WarehouseInvoiceSystem.Domain.Enums
@using WarehouseInvoiceSystem.Domain.Queries
@using WarehouseInvoiceSystem.Domain.Queries.Common
@inject IPaymentService PaymentService
@inject ILocalizationService Localization
@inject NavigationManager Navigation
@inject IDialogService DialogService
@inject WisDialogService WisDialog
@inject ISnackbar Snackbar

<PageTitle>@Localization.GetString("Payments") - @Localization.GetString("InvoiceSystem")</PageTitle>

<div class="wis-page-header">
    <MudText Typo="Typo.h3" Class="wis-page-title">
        @Localization.GetString("Payments")
    </MudText>
</div>

<WisGridToolbar CreateAction="OpenCreateDialog"
                CreateLabel="@Localization.GetString("Payment")"
                SearchValue="@_searchString"
                SearchValueChanged="OnSearch"
                HasAnyActiveFilter="@(_filterMethod.HasValue || _activeAdvancedFilterCount > 0)"
                OnClearAll="ClearAllFilters"
                ActiveAdvancedFilterCount="@_activeAdvancedFilterCount">
    <Filters>
        <FilterPopoverList TValue="PaymentMethod?"
                           Label="@Localization.GetString("PaymentMethod")"
                           Items="_methodFilterItems"
                           Mode="FilterSelectionMode.Single"
                           SelectedValue="_filterMethod"
                           SelectedValueChanged="OnMethodFilterChanged" />
    </Filters>
    <AdvancedFilters>
        <div class="d-flex align-center flex-wrap gap-3">

            <WisDateRangeFilter @ref="_dateRangeFilter"
                                Label="@Localization.GetString("PaymentDate")"
                                DateRange="_filterDateRange"
                                DateRangeChanged="OnDateRangeChanged"
                                DatePreset="_filterDatePreset"
                                DatePresetChanged="OnDatePresetChanged"
                                OnChanged="ReloadGrid"
                                MaxDate="DateTime.Today" />

            <WisAmountRangeFilter @ref="_amountRangeFilter"
                                  Label="@Localization.GetString("AmountRange")"
                                  AmountMin="_filterAmountMin"
                                  AmountMinChanged="OnAmountMinChanged"
                                  AmountMax="_filterAmountMax"
                                  AmountMaxChanged="OnAmountMaxChanged"
                                  AmountPreset="@_filterAmountPreset"
                                  AmountPresetChanged="OnAmountPresetChanged"
                                  OnChanged="ReloadGrid" />

        </div>
    </AdvancedFilters>
</WisGridToolbar>

<MudCard Elevation="2" Class="mb-4">
    <MudCardContent Class="pa-0">
        <MudDataGrid T="PaymentDto"
                     @ref="_grid"
                     ServerData="LoadServerData"
                     RowClick="OnRowClick"
                     RowClassFunc="GetRowClass"
                     ReadOnly="true"
                     Hover="true"
                     FixedHeader="true"
                     Height="100%"
                     Filterable="false"
                     ShowColumnOptions="false"
                     ColumnResizeMode="ResizeMode.Column"
                     SortMode="SortMode.Single"
                     Class="wis-data-grid">
            <Columns>

                <PropertyColumn Property="x => x.PaymentDate"
                                Title="@Localization.GetString("PaymentDate")"
                                Sortable="true"
                                IsEditable="false">
                    <CellTemplate>
                        @context.Item.PaymentDate.ToString("dd MMM yyyy")
                    </CellTemplate>
                </PropertyColumn>

                <PropertyColumn Property="x => x.InvoiceNumber"
                                Title="@Localization.GetString("InvoiceNumber")"
                                Sortable="true"
                                IsEditable="false">
                    <CellTemplate>
                        <MudLink Href="@($"/invoices/{context.Item.InvoiceId}")"
                                 Typo="Typo.body2"
                                 Class="wis-cell-mono"
                                 @onclick:stopPropagation="true">
                            @context.Item.InvoiceNumber
                        </MudLink>
                    </CellTemplate>
                </PropertyColumn>

                <PropertyColumn Property="x => x.Amount"
                                Title="@Localization.GetString("Amount")"
                                Sortable="true"
                                IsEditable="false">
                    <CellTemplate>
                        <MudText Typo="Typo.body2" Class="wis-cell-amount-success">
                            @context.Item.Amount.ToString("C")
                        </MudText>
                    </CellTemplate>
                </PropertyColumn>

                <PropertyColumn Property="x => x.PaymentMethod"
                                Title="@Localization.GetString("PaymentMethod")"
                                Sortable="false"
                                IsEditable="false">
                    <CellTemplate>
                        <MudChip T="string" Size="Size.Small" Color="@GetMethodColor(context.Item.PaymentMethod)">
                            @GetMethodText(context.Item.PaymentMethod)
                        </MudChip>
                    </CellTemplate>
                </PropertyColumn>

                <PropertyColumn Property="x => x.ReferenceNumber"
                                Title="@Localization.GetString("ReferenceNumber")"
                                Sortable="false"
                                IsEditable="false" />

                <PropertyColumn Property="x => x.RecordedBy"
                                Title="@Localization.GetString("RecordedBy")"
                                Sortable="false"
                                IsEditable="false" />

                <TemplateColumn Sortable="false"
                                Filterable="false"
                                IsEditable="false"
                                HeaderClass="wis-col-actions-2"
                                CellClass="wis-col-actions-2">
                    <CellTemplate>
                        <MudStack Row="true" Spacing="0">
                            <MudIconButton Icon="@Icons.Material.Filled.Edit"
                                           Size="Size.Small"
                                           Color="Color.Primary"
                                           Title="@Localization.GetString("Edit")"
                                           OnClick="@(() => OpenEditDialog(context.Item))" />
                            <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                           Size="Size.Small"
                                           Color="Color.Error"
                                           Title="@Localization.GetString("Delete")"
                                           OnClick="@(() => DeletePayment(context.Item.Id))" />
                        </MudStack>
                    </CellTemplate>
                </TemplateColumn>

            </Columns>

            <NoRecordsContent>
                <WisNoRecordsContent Icon="@Icons.Material.Filled.Payment"
                                     Message="@Localization.GetString("NoPaymentsFound")" />
            </NoRecordsContent>

            <LoadingContent>
                <WisLoadingContent />
            </LoadingContent>

            <PagerContent>
                <WisPagerContent T="PaymentDto" />
            </PagerContent>

        </MudDataGrid>
    </MudCardContent>
</MudCard>

@code {
    private readonly CancellationTokenSource _cts = new();
    [Parameter]
    [SupplyParameterFromQuery(Name = "invoiceId")]
    public Guid? InvoiceIdParam { get; set; }

    private MudDataGrid<PaymentDto> _grid = null!;
    private string _searchString = string.Empty;

    // Quick filter
    private PaymentMethod? _filterMethod = null;

    // Advanced filters
    private DateRange _filterDateRange = new(null, null);
    private int? _filterDatePreset = null;
    private WisDateRangeFilter? _dateRangeFilter;
    private decimal? _filterAmountMin = null;
    private decimal? _filterAmountMax = null;
    private string? _filterAmountPreset = null;
    private WisAmountRangeFilter? _amountRangeFilter;

    private int _activeAdvancedFilterCount =>
        (_filterDateRange.Start != null || _filterDateRange.End != null ? 1 : 0) +
        (_filterAmountMin.HasValue || _filterAmountMax.HasValue ? 1 : 0);

    private List<FilterPopoverItem<PaymentMethod?>> _methodFilterItems = [];

    protected override void OnInitialized()
    {
        Localization.OnLanguageChanged += OnLanguageChanged;
        BuildFilterItems();
    }

    private void BuildFilterItems()
    {
        _methodFilterItems =
        [
            new() { Label = Localization.GetString("All"),          Value = null,                        Color = Color.Info   },
            new() { Label = Localization.GetString("Cash"),         Value = PaymentMethod.Cash,          Color = Color.Success   },
            new() { Label = Localization.GetString("BankTransfer"), Value = PaymentMethod.BankTransfer,  Color = Color.Primary   },
            new() { Label = Localization.GetString("CreditCard"),   Value = PaymentMethod.CreditCard,    Color = Color.Secondary },
            new() { Label = Localization.GetString("Other"),        Value = PaymentMethod.Other,         Color = Color.Default   },
        ];
    }

    private async void OnLanguageChanged()
    {
        BuildFilterItems();
        await InvokeAsync(StateHasChanged);
    }

    private async Task<GridData<PaymentDto>> LoadServerData(GridState<PaymentDto> state, CancellationToken ct)
    {
        string? sortBy = state.SortDefinitions.FirstOrDefault()?.SortBy;
        bool ascending = state.SortDefinitions.FirstOrDefault()?.Descending == false;

        GetPaymentsQuery query = new()
        {
            Search = _searchString,
            InvoiceId = InvoiceIdParam,
            PaymentMethod = _filterMethod,
            DateFrom = _filterDateRange.Start,
            DateTo = _filterDateRange.End,
            AmountMin = _filterAmountMin,
            AmountMax = _filterAmountMax,
            Page = state.Page + 1,
            PageSize = state.PageSize,
            SortBy = sortBy,
            SortAscending = ascending,
        };

        PagedResult<PaymentDto> result = await PaymentService.GetPagedAsync(query, ct);

        return new GridData<PaymentDto>
        {
            Items = result.Items,
            TotalItems = result.TotalCount
        };
    }

    private async Task OnSearch(string text)
    {
        _searchString = text;
        await _grid.ReloadServerData();
    }

    private async Task OnMethodFilterChanged(PaymentMethod? value)
    {
        _filterMethod = value;
        await _grid.ReloadServerData();
    }

    private async Task ReloadGrid() => await _grid.ReloadServerData();

    private Task OnDatePresetChanged(int? days)
    {
        _filterDatePreset = days;
        return Task.CompletedTask;
    }

    private Task OnDateRangeChanged(DateRange range)
    {
        _filterDateRange = range;
        return Task.CompletedTask;
    }

    private Task OnAmountMinChanged(decimal? value)
    {
        _filterAmountMin = value;
        return Task.CompletedTask;
    }

    private Task OnAmountMaxChanged(decimal? value)
    {
        _filterAmountMax = value;
        return Task.CompletedTask;
    }

    private Task OnAmountPresetChanged(string? key)
    {
        _filterAmountPreset = key;
        return Task.CompletedTask;
    }

    private async Task ClearAllFilters()
    {
        _filterMethod = null;
        _filterAmountMin = null;
        _filterAmountMax = null;
        _filterAmountPreset = null;
        _filterDateRange = new(null, null);
        _filterDatePreset = null;

        if (_dateRangeFilter is not null)
            await _dateRangeFilter.ClearAsync();
        if (_amountRangeFilter is not null)
            await _amountRangeFilter.ClearAsync();

        await _grid.ReloadServerData();
    }

    private void OnRowClick(DataGridRowClickEventArgs<PaymentDto> args)
    {
        Navigation.NavigateTo($"/payments/{args.Item.Id}");
    }

    private async Task OpenCreateDialog()
    {
        DialogParameters<PaymentDialog> parameters = new();
        if (InvoiceIdParam.HasValue)
            parameters.Add(x => x.PreSelectedInvoiceId, InvoiceIdParam);

        DialogOptions options = new()
        {
            MaxWidth = MaxWidth.Medium,
            FullWidth = true,
            CloseOnEscapeKey = true
        };

        IDialogReference dialog = await DialogService.ShowAsync<PaymentDialog>(
            Localization.GetString("RecordPayment"), parameters, options);

        DialogResult? result = await dialog.Result;

        if (result is { Canceled: false, Data: CreatePaymentDto dto })
        {
            try
            {
                await PaymentService.CreatePaymentAsync(dto);
                Snackbar.Add(Localization.GetString("PaymentCreated"), Severity.Success);
                await _grid.ReloadServerData();
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Error creating payment: {ex.Message}");
                Snackbar.Add(Localization.GetString("ErrorCreatingPayment"), Severity.Error);
            }
        }
    }

    private async Task OpenEditDialog(PaymentDto payment)
    {
        DialogParameters<PaymentDialog> parameters = new();
        parameters.Add(x => x.Payment, payment);

        DialogOptions options = new()
        {
            MaxWidth = MaxWidth.Medium,
            FullWidth = true,
            CloseOnEscapeKey = true
        };

        IDialogReference dialog = await DialogService.ShowAsync<PaymentDialog>(
            Localization.GetString("EditPayment"), parameters, options);

        DialogResult? result = await dialog.Result;

        if (result is { Canceled: false, Data: UpdatePaymentDto dto })
        {
            try
            {
                await PaymentService.UpdatePaymentAsync(payment.Id, dto);
                Snackbar.Add(Localization.GetString("PaymentUpdated"), Severity.Success);
                await _grid.ReloadServerData();
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Error updating payment: {ex.Message}");
                Snackbar.Add(Localization.GetString("ErrorUpdatingPayment"), Severity.Error);
            }
        }
    }

    private async Task DeletePayment(Guid id)
    {
        bool result = await WisDialog.ConfirmAsync(
            Localization.GetString("ConfirmDelete"),
            Localization.GetString("DeletePaymentConfirm"),
            Localization.GetString("Yes"),
            Localization.GetString("No"));

        if (result)
        {
            try
            {
                bool deleted = await PaymentService.DeletePaymentAsync(id);
                if (deleted)
                {
                    Snackbar.Add(Localization.GetString("PaymentDeleted"), Severity.Success);
                    await _grid.ReloadServerData();
                }
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Error deleting payment: {ex.Message}");
                Snackbar.Add(Localization.GetString("ErrorDeletingPayment"), Severity.Error);
            }
        }
    }

    private string GetRowClass(PaymentDto item, int index) => item.PaymentMethod switch
    {
        PaymentMethod.Cash => "row-status-success",
        PaymentMethod.BankTransfer => "row-status-primary",
        PaymentMethod.CreditCard => "row-status-secondary",
        PaymentMethod.Other => "row-status-default",
        _ => "row-status-default"
    };

    private string GetMethodText(PaymentMethod method) => method switch
    {
        PaymentMethod.Cash => Localization.GetString("Cash"),
        PaymentMethod.BankTransfer => Localization.GetString("BankTransfer"),
        PaymentMethod.CreditCard => Localization.GetString("CreditCard"),
        PaymentMethod.Other => Localization.GetString("Other"),
        _ => method.ToString()
    };

    private Color GetMethodColor(PaymentMethod method) => method switch
    {
        PaymentMethod.Cash => Color.Success,
        PaymentMethod.BankTransfer => Color.Primary,
        PaymentMethod.CreditCard => Color.Secondary,
        PaymentMethod.Other => Color.Default,
        _ => Color.Default
    };

    public void Dispose()
    {
        _cts.Cancel();
        _cts.Dispose();
        Localization.OnLanguageChanged -= OnLanguageChanged;
    }
}
