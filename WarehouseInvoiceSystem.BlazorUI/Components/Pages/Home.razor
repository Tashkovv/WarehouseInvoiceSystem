@page "/"
@implements IDisposable
@using WarehouseInvoiceSystem.Application.Interfaces
@using WarehouseInvoiceSystem.Application.DTOs.Company
@using WarehouseInvoiceSystem.Application.DTOs.Individual
@using WarehouseInvoiceSystem.Application.DTOs.Invoice
@using WarehouseInvoiceSystem.Application.DTOs.PurchaseNote
@using WarehouseInvoiceSystem.Application.DTOs.Product
@using WarehouseInvoiceSystem.BlazorUI.Components.Pages.Individuals
@inject ICompanyService CompanyService
@inject IIndividualService IndividualService
@inject IInvoiceService InvoiceService
@inject IPurchaseNoteService PurchaseNoteService
@inject IProductService ProductService
@inject IInventoryService InventoryService
@inject ILocalizationService Localization

<PageTitle>@Localization.GetString("Home") - @Localization.GetString("InvoiceSystem")</PageTitle>

<MudText Typo="Typo.h4" Class="mb-6">@Localization.GetString("Overview")</MudText>

@if (_loading)
{
    <MudProgressLinear Color="Color.Primary" Indeterminate="true" />
}
else
{
    <MudGrid>
        <!-- First Row: Partners and Documents -->
        <MudItem xs="12" md="6">
            <MudText Typo="Typo.h6" Class="mb-4 d-flex align-center">
                <MudIcon Icon="@Icons.Material.Filled.Groups" Class="mr-2" />
                @Localization.GetString("Partners")
            </MudText>

            <MudGrid Justify="Justify.Center" Spacing="3">
                <MudItem xs="12" sm="6">
                    <DashboardCard Title="@Localization.GetString("TotalCompanies")"
                                   Value="@_totalCompanies.ToString()"
                                   Subtitle="@($"{Localization.GetString("Active")}: {_activeCompanies}")"
                                   Icon="@Icons.Material.Filled.Business"
                                   IconColor="Color.Primary"
                                   Link="/partners-dashboard" />
                </MudItem>

                <MudItem xs="12" sm="6">
                    <DashboardCard Title="@Localization.GetString("TotalIndividuals")"
                                   Value="@_totalIndividuals.ToString()"
                                   Subtitle="@($"{Localization.GetString("Active")}: {_activeIndividuals}")"
                                   Icon="@Icons.Material.Filled.Person"
                                   IconColor="Color.Success"
                                   Link="/partners-dashboard" />
                </MudItem>
            </MudGrid>
        </MudItem>

        <MudItem xs="12" md="6">
            <MudText Typo="Typo.h6" Class="mb-4 d-flex align-center">
                <MudIcon Icon="@Icons.Material.Filled.Description" Class="mr-2" />
                @Localization.GetString("Documents")
            </MudText>
            <MudGrid Justify="Justify.Center" Spacing="3">
                <MudItem xs="12" sm="6">
                    <DashboardCard Title="@Localization.GetString("PurchaseNotesToday")"
                                   Value="@_purchaseNotesToday.ToString()"
                                   Subtitle="@_purchaseAmountToday.ToString("C")"
                                   Icon="@Icons.Material.Filled.Receipt"
                                   IconColor="Color.Info"
                                   Link="/documents-dashboard" />
                </MudItem>

                <MudItem xs="12" sm="6">
                    <DashboardCard Title="@Localization.GetString("InvoicesIssuedToday")"
                                   Value="@_invoicesToday.ToString()"
                                   Subtitle="@_invoiceAmountToday.ToString("C")"
                                   Icon="@Icons.Material.Filled.RequestQuote"
                                   IconColor="Color.Warning"
                                   Link="/documents-dashboard" />
                </MudItem>
            </MudGrid>
        </MudItem>

        <!-- Second Row: Inventory (Centered) -->
        <MudItem xs="12" Class="d-flex justify-center mt-4">
            <div style="max-width: 800px; width: 100%;">
                <MudText Typo="Typo.h6" Class="mb-4 text-center d-flex align-center">
                    <MudIcon Icon="@Icons.Material.Filled.Inventory" Class="mr-2" />
                    @Localization.GetString("Inventory")
                </MudText>

                <MudGrid Justify="Justify.Center" Spacing="3">
                    <MudItem xs="12" sm="6">
                        <DashboardCard Title="@Localization.GetString("TotalProducts")"
                                       Value="@_totalProducts.ToString()"
                                       Subtitle="@($"{Localization.GetString("Active")}: {_activeProducts}")"
                                       Icon="@Icons.Material.Filled.Inventory2"
                                       IconColor="Color.Tertiary"
                                       Link="/inventory-dashboard" />
                    </MudItem>

                    <MudItem xs="12" sm="6">
                        <DashboardCard Title="@Localization.GetString("AlertsAndWarnings")"
                                       Value="@_lowStockCount.ToString()"
                                       Subtitle="@Localization.GetString("ProductsBelowMinimum")"
                                       Icon="@Icons.Material.Filled.Warning"
                                       IconColor="Color.Error"
                                       Link="/inventory-dashboard" />
                    </MudItem>
                </MudGrid>
            </div>
        </MudItem>
    </MudGrid>
}

@code {
    private bool _loading = true;

    // Partners
    private int _totalCompanies = 0;
    private int _activeCompanies = 0;
    private int _totalIndividuals = 0;
    private int _activeIndividuals = 0;

    // Documents
    private int _purchaseNotesToday = 0;
    private decimal _purchaseAmountToday = 0;
    private int _invoicesToday = 0;
    private decimal _invoiceAmountToday = 0;

    // Inventory
    private int _totalProducts = 0;
    private int _activeProducts = 0;
    private int _lowStockCount = 0;

    protected override async Task OnInitializedAsync()
    {
        Localization.OnLanguageChanged += OnLanguageChanged;
        await LoadDashboardData();
    }

    private async void OnLanguageChanged()
    {
        await InvokeAsync(StateHasChanged);
    }

    private async Task LoadDashboardData()
    {
        _loading = true;

        try
        {
            // Load Companies
            IEnumerable<CompanyDto> companies = await CompanyService.GetAllCompaniesAsync();
            _totalCompanies = companies.Count();
            _activeCompanies = companies.Count(c => c.IsActive);

            // Load Individuals
            IEnumerable<IndividualDto> individuals = await IndividualService.GetAllIndividualsAsync();
            _totalIndividuals = individuals.Count();
            _activeIndividuals = individuals.Count(i => i.IsActive);

            // Load Purchase Notes
            IEnumerable<PurchaseNoteDto> allPurchaseNotes = await PurchaseNoteService.GetAllPurchaseNotesAsync();
            var todayPurchaseNotes = allPurchaseNotes.Where(pn => pn.PurchaseDate.Date == DateTime.Today);
            _purchaseNotesToday = todayPurchaseNotes.Count();
            _purchaseAmountToday = todayPurchaseNotes.Sum(pn => pn.TotalAmount);

            // Load Invoices
            IEnumerable<InvoiceDto> allInvoices = await InvoiceService.GetAllInvoicesAsync();
            var todayInvoices = allInvoices.Where(i => i.IssueDate.Date == DateTime.Today);
            _invoicesToday = todayInvoices.Count();
            _invoiceAmountToday = todayInvoices.Sum(i => i.TotalAmount);

            // Load Products
            IEnumerable<ProductDto> products = await ProductService.GetAllProductsAsync();
            _totalProducts = products.Count();
            _activeProducts = products.Count(p => p.IsActive);

            // Low stock count (placeholder - we'll implement this properly later)
            _lowStockCount = (await InventoryService.GetLowStockItemsAsync()).Count(); // TODO: Implement GetLowStockItemsAsync
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading dashboard data: {ex.Message}");
        }
        finally
        {
            _loading = false;
        }
    }

    public void Dispose()
    {
        Localization.OnLanguageChanged -= OnLanguageChanged;
    }
}