@page "/"
@inherits PageBase
@using WarehouseInvoiceSystem.Application.DTOs.Invoice
@using WarehouseInvoiceSystem.Application.DTOs.PurchaseNote
@using WarehouseInvoiceSystem.Application.DTOs.StockLevel
@using WarehouseInvoiceSystem.Application.DTOs.Individual
@using WarehouseInvoiceSystem.Application.DTOs.Product
@using WarehouseInvoiceSystem.Application.DTOs.Company
@using WarehouseInvoiceSystem.Application.DTOs.Warehouse
@using WarehouseInvoiceSystem.Domain.Queries
@using WarehouseInvoiceSystem.Domain.Queries.Common
@using WarehouseInvoiceSystem.Domain.Queries.Results
@inject IInvoiceService InvoiceService
@inject IPurchaseNoteService PurchaseNoteService
@inject IPaymentService PaymentService
@inject IInventoryService InventoryService
@inject IIndividualService IndividualService
@inject ICompanyService CompanyService
@inject IWarehouseService WarehouseService
@inject IProductService ProductService

<PageTitle>@Localization.GetString("Overview") - @Localization.GetString("InvoiceSystem")</PageTitle>

<MudText Typo="Typo.h4" Class="mb-6">@Localization.GetString("Overview")</MudText>

@if (_loading)
{
    <MudProgressLinear Color="Color.Primary" Indeterminate="true" />
}
else
{
    <MudGrid>

        <!-- ── Quick Actions ── -->
        <MudItem xs="12">
            <MudPaper Elevation="2" Class="pa-4 rounded-lg" Style="background-color: rgba(var(--mud-palette-secondary-rgb), 0.07);">
                <div class="d-flex flex-wrap gap-3 justify-space-between">
                    <WisButton Action="@(new WisDetailActionItem { Icon = Icons.Material.Filled.Business, Label = Localization.GetString("NewCompany"), Color = Color.Success, OnClick = EventCallback.Factory.Create(this, async () => await OpenNewCompanyDialog()) })" ButtonSize="Size.Large" />
                    <WisButton Action="@(new WisDetailActionItem { Icon = Icons.Material.Filled.Person, Label = Localization.GetString("NewIndividual"), Color = Color.Dark, OnClick = EventCallback.Factory.Create(this, async () => await OpenNewIndividualDialog()) })" ButtonSize="Size.Large" />
                    <WisButton Action="@NavAction(Icons.Material.Filled.RequestQuote, Localization.GetString("NewInvoice"), "/invoices/create", Color.Primary)" ButtonSize="Size.Large" />
                    <WisButton Action="@NavAction(Icons.Material.Filled.Receipt, Localization.GetString("NewPurchaseNote"), "/purchase-notes/create", Color.Info)" ButtonSize="Size.Large" />
                    <WisButton Action="@(new WisDetailActionItem { Icon = Icons.Material.Filled.Payment, Label = Localization.GetString("NewPayment"), Color = Color.Success, OnClick = EventCallback.Factory.Create(this, async () => await OpenNewPaymentDialog()) })" ButtonSize="Size.Large" />
                    <WisButton Action="@(new WisDetailActionItem { Icon = Icons.Material.Filled.Inventory2, Label = Localization.GetString("NewProduct"), Color = Color.Warning, OnClick = EventCallback.Factory.Create(this, async () => await OpenNewProductDialog()) })" ButtonSize="Size.Large" />
                    <WisButton Action="@(new WisDetailActionItem { Icon = Icons.Material.Filled.Inventory2, Label = Localization.GetString("AdjustStock"), Color = Color.Secondary, OnClick = EventCallback.Factory.Create(this, async () => await OpenAdjustStockDialog()) })" ButtonSize="Size.Large" />
                </div>
            </MudPaper>
        </MudItem>

        <!-- ── Row 1: Today's Pulse ── -->
        <MudItem xs="12">
            <MudText Typo="Typo.h6" Class="mb-4">@Localization.GetString("TodaysActivity")</MudText>
        </MudItem>

        <MudItem xs="12" sm="6" md="3">
            <DashboardCard Title="@Localization.GetString("InvoicesIssuedToday")"
                           Value="@_dayIssueSummary.ReceivableCount.ToString()"
                           Subtitle="@_dayIssueSummary.ReceivableAmount.ToString("C")"
                           Icon="@Icons.Material.Filled.RequestQuote"
                           IconColor="Color.Default" />
        </MudItem>

        <MudItem xs="12" sm="6" md="3">
            <DashboardCard Title="@Localization.GetString("PurchaseNotesToday")"
                           Value="@_dayPurchaseNoteSummary.Count.ToString()"
                           Subtitle="@_dayPurchaseNoteSummary.Amount.ToString("C")"
                           Icon="@Icons.Material.Filled.Receipt"
                           IconColor="Color.Default" />
        </MudItem>

        <MudItem xs="12" sm="6" md="3">
            <DashboardCard Title="@Localization.GetString("RecentPayments")"
                           Value="@_dayPaymentSummary.TotalCount.ToString()"
                           Subtitle="@_dayPaymentSummary.TotalAmount.ToString("C")"
                           Icon="@Icons.Material.Filled.Payments"
                           IconColor="Color.Default" />
        </MudItem>

        <MudItem xs="12" sm="6" md="3">
            <DashboardCard Title="@Localization.GetString("Profit")"
                           Value="@_profitToday.ToString("C")"
                           Icon="@Icons.Material.Filled.TrendingUp"
                           IconColor="@(_profitToday >= 0 ? Color.Success : Color.Error)" />
        </MudItem>

        <!-- ── Row 2: Financial Health ── -->
        <MudItem xs="12" Class="mt-6">
            <MudText Typo="Typo.h6" Class="mb-4">@Localization.GetString("FinancialHealth")</MudText>
        </MudItem>

        <MudItem xs="12" sm="6" md="4">
            <DashboardCard Title="@Localization.GetString("TotalReceivables")"
                           Value="@_invoicePosition.ReceivableAmount.ToString("C")"
                           Subtitle="@($"{_invoicePosition.ReceivableCount} {Localization.GetString("Invoices")}")"
                           Icon="@Icons.Material.Filled.AccountBalanceWallet"
                           IconColor="Color.Primary" />
        </MudItem>

        <MudItem xs="12" sm="6" md="4">
            <DashboardCard Title="@Localization.GetString("TotalPayables")"
                           Value="@_totalPayables.ToString("C")"
                           Subtitle="@($"{_invoicePosition.PayableCount} {Localization.GetString("Invoices")} · {_purchaseNotePosition.unpaidCount} {Localization.GetString("PurchaseNotes")}")"
                           Icon="@Icons.Material.Filled.AccountBalance"
                           IconColor="Color.Default" />
        </MudItem>

        <MudItem xs="12" sm="6" md="4">
            <DashboardCard Title="@Localization.GetString("OverdueInvoices")"
                           Value="@_invoicePosition.OverdueReceivableCount.ToString()"
                           Subtitle="@_invoicePosition.OverdueReceivableAmount.ToString("C")"
                           Icon="@Icons.Material.Filled.Warning"
                           IconColor="@(_invoicePosition.OverdueReceivableCount > 0 ? Color.Error : Color.Success)" />
        </MudItem>

        <!-- ── Row 3: Warehouse Health ── -->
        <MudItem xs="12" Class="mt-6">
            <div class="d-flex align-center flex-wrap gap-3 mb-4">
                <MudText Typo="Typo.h6">@Localization.GetString("WarehouseHealth")</MudText>
                <WisAutocompleteFilter TValue="Guid"
                                       Label="@Localization.GetString("AllWarehouses")"
                                       AllLabel="@Localization.GetString("AllWarehouses")"
                                       Icon="@Icons.Material.Filled.Warehouse"
                                       LoadItems="LoadWarehouseItems"
                                       SelectedValue="@(_filterWarehouseId ?? default)"
                                       SelectedValueChanged="OnWarehouseFilterChanged"
                                       MinWidth="180px" />
            </div>
        </MudItem>

        <MudItem xs="12" sm="6" md="3">
            <DashboardCard Title="@Localization.GetString("TotalProducts")"
                           Value="@_stockSummary.TotalProducts.ToString()"
                           Subtitle="@($"{_stockSummary.InStockCount} {Localization.GetString("InStock")}")"
                           Icon="@Icons.Material.Filled.Inventory2"
                           IconColor="Color.Default" />
        </MudItem>

        <MudItem xs="12" sm="6" md="3">
            <DashboardCard Title="@Localization.GetString("TotalStockValue")"
                           Value="@_stockSummary.TotalStockValue.ToString("C")"
                           Subtitle="@_stockValueSubtitle"
                           Icon="@Icons.Material.Filled.Warehouse"
                           IconColor="Color.Default" />
        </MudItem>

        <MudItem xs="12" sm="6" md="3">
            <DashboardCard Title="@Localization.GetString("LowStock")"
                           Value="@_stockSummary.LowStockCount.ToString()"
                           Subtitle="@Localization.GetString("ProductsBelowMinimum")"
                           Icon="@Icons.Material.Filled.TrendingDown"
                           IconColor="@(_stockSummary.LowStockCount > 0 ? Color.Warning : Color.Default)" />
        </MudItem>

        <MudItem xs="12" sm="6" md="3">
            <DashboardCard Title="@Localization.GetString("OutOfStock")"
                           Value="@_stockSummary.OutOfStockCount.ToString()"
                           Icon="@Icons.Material.Filled.RemoveShoppingCart"
                           IconColor="@(_stockSummary.OutOfStockCount > 0 ? Color.Error : Color.Success)" />
        </MudItem>

        <!-- ── Row 4: Attention Needed ── -->
        @if (_overdueInvoices.Any() || _unpaidPurchaseNotes.Any() || _stockAlerts.Any())
        {
            <MudItem xs="12" Class="mt-6">
                <MudText Typo="Typo.h6" Class="mb-4">@Localization.GetString("AttentionNeeded")</MudText>
            </MudItem>

            <MudItem xs="12">
                <MudCard Elevation="2">
                    <MudTabs Elevation="0" Rounded="false" ApplyEffectsToContainer="true" PanelClass="pa-0" Color="Color.Default">

                        @if (_overdueInvoices.Any())
                        {
                            <MudTabPanel Text="@Localization.GetString("OverdueInvoices")"
                                         Icon="@Icons.Material.Filled.Warning"
                                         BadgeData="@_overdueInvoices.Count()"
                                         BadgeColor="Color.Error"
                                         Class="mr-5">
                                <MudTable Items="@_overdueInvoices.Take(10)"
                                          Hover="true"
                                          Dense="true"
                                          Elevation="0"
                                          T="InvoiceDto"
                                          Class="wis-secondary-list"
                                          RowClassFunc="@((i, n) => "row-status-error table-row-clickable")"
                                          OnRowClick="@((TableRowClickEventArgs<InvoiceDto> args) => Navigation.NavigateTo($"/invoices/{args.Item!.Id}"))">
                                    <HeaderContent>
                                        <MudTh>@Localization.GetString("InvoiceNumber")</MudTh>
                                        <MudTh>@Localization.GetString("Company")</MudTh>
                                        <MudTh Class="text-right">@Localization.GetString("DaysOverdue")</MudTh>
                                        <MudTh>@Localization.GetString("DueDate")</MudTh>
                                        <MudTh Class="text-right">@Localization.GetString("AmountDue")</MudTh>
                                    </HeaderContent>
                                    <RowTemplate>
                                        <MudTd DataLabel="@Localization.GetString("InvoiceNumber")">
                                            <MudText Typo="Typo.body2" Class="font-weight-medium">@context.InvoiceNumber</MudText>
                                        </MudTd>
                                        <MudTd DataLabel="@Localization.GetString("Company")">
                                            <MudText Typo="Typo.body2" Color="Color.Secondary">@context.CompanyName</MudText>
                                        </MudTd>
                                        <MudTd DataLabel="@Localization.GetString("DaysOverdue")" Class="text-right">
                                            <MudChip T="string" Size="Size.Small" Color="Color.Error" Variant="Variant.Outlined">
                                                @((DateTime.Today - context.DueDate).Days) @Localization.GetString("Days")
                                            </MudChip>
                                        </MudTd>
                                        <MudTd DataLabel="@Localization.GetString("DueDate")">
                                            <MudText Typo="Typo.body2" Color="Color.Secondary">
                                                @context.DueDate.ToString("dd MMM yyyy")
                                            </MudText>
                                        </MudTd>
                                        <MudTd DataLabel="@Localization.GetString("AmountDue")" Class="text-right">
                                            <MudText Typo="Typo.body2" Class="font-weight-bold" Color="Color.Error">
                                                @context.AmountDue.ToString("C")
                                            </MudText>
                                        </MudTd>
                                    </RowTemplate>
                                </MudTable>
                                <MudCardActions Class="pa-4">
                                    <WisButton Action="@NavAction(Icons.Material.Filled.List, Localization.GetString("Invoices"), "/invoices", Color.Secondary)" />
                                </MudCardActions>
                            </MudTabPanel>
                        }

                        @if (_unpaidPurchaseNotes.Any())
                        {
                            <MudTabPanel Text="@Localization.GetString("UnpaidPurchaseNotes")"
                                         Icon="@Icons.Material.Filled.Receipt"
                                         BadgeData="@_unpaidPurchaseNotes.Count()"
                                         BadgeColor="Color.Warning"
                                         Class="mr-5">
                                <MudTable Items="@_unpaidPurchaseNotes.Take(10)"
                                          Hover="true"
                                          Dense="true"
                                          Elevation="0"
                                          T="PurchaseNoteDto"
                                          Class="wis-secondary-list"
                                          RowClassFunc="@((pn, n) => "row-status-warning table-row-clickable")"
                                          OnRowClick="@((TableRowClickEventArgs<PurchaseNoteDto> args) => Navigation.NavigateTo($"/purchase-notes/{args.Item!.Id}"))">
                                    <HeaderContent>
                                        <MudTh>@Localization.GetString("NoteNumber")</MudTh>
                                        <MudTh>@Localization.GetString("Individual")</MudTh>
                                        <MudTh>@Localization.GetString("Status")</MudTh>
                                        <MudTh>@Localization.GetString("Date")</MudTh>
                                        <MudTh Class="text-right">@Localization.GetString("Amount")</MudTh>
                                    </HeaderContent>
                                    <RowTemplate>
                                        <MudTd DataLabel="@Localization.GetString("NoteNumber")">
                                            <MudText Typo="Typo.body2" Class="font-weight-medium">@context.NoteNumber</MudText>
                                        </MudTd>
                                        <MudTd DataLabel="@Localization.GetString("Individual")">
                                            <MudText Typo="Typo.body2" Color="Color.Secondary">@context.IndividualFullName</MudText>
                                        </MudTd>
                                        <MudTd DataLabel="@Localization.GetString("Status")">
                                            <MudChip T="string" Size="Size.Small" Color="@GetPurchaseNoteStatusColor(context.Status)" Variant="Variant.Outlined">
                                                @GetPurchaseNoteStatusText(context.Status)
                                            </MudChip>
                                        </MudTd>
                                        <MudTd DataLabel="@Localization.GetString("Date")">
                                            <MudText Typo="Typo.body2" Color="Color.Secondary">
                                                @context.PurchaseDate.ToString("dd MMM yyyy")
                                            </MudText>
                                        </MudTd>
                                        <MudTd DataLabel="@Localization.GetString("Amount")" Class="text-right">
                                            <MudText Typo="Typo.body2" Class="font-weight-bold">@context.TotalAmount.ToString("C")</MudText>
                                        </MudTd>
                                    </RowTemplate>
                                </MudTable>
                                <MudCardActions Class="pa-4">
                                    <WisButton Action="@NavAction(Icons.Material.Filled.List, Localization.GetString("PurchaseNotes"), "/purchase-notes", Color.Secondary)" />
                                </MudCardActions>
                            </MudTabPanel>
                        }

                        @if (_stockAlerts.Any())
                        {
                            <MudTabPanel Text="@Localization.GetString("AlertsAndWarnings")"
                                         Icon="@Icons.Material.Filled.Inventory"
                                         BadgeData="@_stockAlerts.Count()"
                                         BadgeColor="Color.Error"
                                         Class="mr-5">
                                <MudTable Items="@_stockAlerts.Take(10)"
                                          Hover="true"
                                          Dense="true"
                                          Elevation="0"
                                          T="StockLevelDto"
                                          Class="wis-secondary-list"
                                          RowClassFunc="@((sl, n) => (sl.Quantity == 0 ? "row-status-error" : "row-status-warning") + " table-row-clickable")"
                                          OnRowClick="@((TableRowClickEventArgs<StockLevelDto> args) => Navigation.NavigateTo($"/products/{args.Item!.ProductId}"))">
                                    <HeaderContent>
                                        <MudTh>@Localization.GetString("Product")</MudTh>
                                        <MudTh>@Localization.GetString("Warehouse")</MudTh>
                                        <MudTh Class="text-right">@Localization.GetString("Quantity")</MudTh>
                                        <MudTh>@Localization.GetString("Status")</MudTh>
                                        <MudTh Class="text-right">@Localization.GetString("MinimumQuantity")</MudTh>
                                    </HeaderContent>
                                    <RowTemplate>
                                        <MudTd DataLabel="@Localization.GetString("Product")">
                                            <MudText Typo="Typo.body2" Class="font-weight-medium">@context.ProductCode — @context.ProductName</MudText>
                                        </MudTd>
                                        <MudTd DataLabel="@Localization.GetString("Warehouse")">
                                            <MudText Typo="Typo.body2" Color="Color.Secondary">@context.WarehouseName</MudText>
                                        </MudTd>
                                        <MudTd DataLabel="@Localization.GetString("Quantity")" Class="text-right">
                                            <MudText Typo="Typo.body2" Class="font-weight-bold"
                                                     Color="@(context.Quantity == 0 ? Color.Error : Color.Warning)">
                                                @context.Quantity.ToString("N2") @context.ProductUnit
                                            </MudText>
                                        </MudTd>
                                        <MudTd DataLabel="@Localization.GetString("Status")">
                                            @if (context.Quantity == 0)
                                            {
                                                <MudChip T="string" Size="Size.Small" Color="Color.Error" Variant="Variant.Outlined">
                                                    @Localization.GetString("OutOfStock")
                                                </MudChip>
                                            }
                                            else
                                            {
                                                <MudChip T="string" Size="Size.Small" Color="Color.Warning" Variant="Variant.Outlined">
                                                    @Localization.GetString("LowStock")
                                                </MudChip>
                                            }
                                        </MudTd>
                                        <MudTd DataLabel="@Localization.GetString("MinimumQuantity")" Class="text-right">
                                            <MudText Typo="Typo.body2" Color="Color.Secondary">
                                                @if (context.MinimumQuantity.HasValue)
                                                {
                                                    @($"{context.MinimumQuantity.Value.ToString("N2")} {context.ProductUnit}")
                                                }
                                                else
                                                {
                                                    <text>—</text>
                                                }
                                            </MudText>
                                        </MudTd>
                                    </RowTemplate>
                                </MudTable>
                                <MudCardActions Class="pa-4">
                                    <WisButton Action="@NavAction(Icons.Material.Filled.List, Localization.GetString("Inventory"), "/inventory", Color.Secondary)" />
                                </MudCardActions>
                            </MudTabPanel>
                        }

                    </MudTabs>
                </MudCard>
            </MudItem>
        }

    </MudGrid>
}

@code {
    // ── State ──────────────────────────────────────────────────────────────────

    private DayIssueSummaryResult _dayIssueSummary = new();
    private DayPaymentSummaryResult _dayPaymentSummary = new();
    private DayPurchaseNoteSummaryResult _dayPurchaseNoteSummary = new();
    private InvoiceOutstandingResult _invoicePosition = new();
    private (int unpaidCount, decimal unpaidAmount) _purchaseNotePosition;
    private WarehouseStockSummaryResult _stockSummary = new();
    private List<InvoiceDto> _overdueInvoices = [];
    private List<PurchaseNoteDto> _unpaidPurchaseNotes = [];
    private List<StockLevelDto> _stockAlerts = [];
    private Guid? _filterWarehouseId;
    private string? _selectedWarehouseName;

    // ── Computed display values ─────────────────────────────────────────────────

    private decimal _profitToday =>
        _dayPaymentSummary.ReceivedAmount - _dayPaymentSummary.PaidOutAmount - _dayPurchaseNoteSummary.Amount;

    private decimal _totalPayables =>
        _invoicePosition.PayableAmount + _purchaseNotePosition.unpaidAmount;

    private string _stockValueSubtitle =>
        _filterWarehouseId.HasValue
            ? _selectedWarehouseName ?? string.Empty
            : $"{_stockSummary.WarehouseCount} {Localization.GetString("Warehouses")}";

    // ── Lifecycle ──────────────────────────────────────────────────────────────

    protected override async Task OnInitializedAsync()
    {
        await base.OnInitializedAsync();
        await LoadData();
    }

    private async Task LoadData()
    {
        _loading = true;

        try
        {
            DateTime today = DateTime.Today;

            await Task.WhenAll(
                InvoiceService.GetDayIssueSummaryAsync(today, _cts.Token)
                    .ContinueWith(t => _dayIssueSummary = t.Result),
                PaymentService.GetDayPaymentSummaryAsync(today, _cts.Token)
                    .ContinueWith(t => _dayPaymentSummary = t.Result),
                PurchaseNoteService.GetDayPaidSummaryAsync(today, _cts.Token)
                    .ContinueWith(t => _dayPurchaseNoteSummary = t.Result),
                InvoiceService.GetOutstandingPositionAsync(_cts.Token)
                    .ContinueWith(t => _invoicePosition = t.Result),
                PurchaseNoteService.GetOutstandingPositionAsync(_cts.Token)
                    .ContinueWith(t => _purchaseNotePosition = t.Result),
                LoadWarehouseData()
            );
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading home data: {ex.Message}");
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task LoadWarehouseData()
    {
        await Task.WhenAll(
            InventoryService.GetWarehouseStockSummaryAsync(_filterWarehouseId, _cts.Token)
                .ContinueWith(t => _stockSummary = t.Result),
            InvoiceService.GetTopOverdueReceivablesAsync(_filterWarehouseId, 10, _cts.Token)
                .ContinueWith(t => _overdueInvoices = t.Result.ToList()),
            PurchaseNoteService.GetTopUnpaidAsync(_filterWarehouseId, 10, _cts.Token)
                .ContinueWith(t => _unpaidPurchaseNotes = t.Result.ToList()),
            InventoryService.GetStockAlertsAsync(_filterWarehouseId, 10, _cts.Token)
                .ContinueWith(t => _stockAlerts = t.Result.ToList())
        );
    }

    private async Task<PagedResult<WisAutocompleteItem<Guid>>> LoadWarehouseItems(
        string search, int page, CancellationToken ct)
    {
        PagedResult<WarehouseDto> result = await WarehouseService.GetPagedAsync(new GetWarehousesQuery
        {
            Search = search,
            Page = page,
            PageSize = 10,
            SortBy = "Name",
            SortAscending = true,
            IsActive = true
        }, ct);

        return new PagedResult<WisAutocompleteItem<Guid>>
        {
            Items = result.Items.Select(w => new WisAutocompleteItem<Guid>
            {
                Label = w.Name + (w.IsDefault ? $" ({Localization.GetString("Default")})" : ""),
                Value = w.Id
            }).ToList(),
            TotalCount = result.TotalCount,
            Page = result.Page,
            PageSize = result.PageSize
        };
    }

    private async Task OnWarehouseFilterChanged(Guid value)
    {
        _filterWarehouseId = value == default ? null : value;
        if (_filterWarehouseId.HasValue)
        {
            WarehouseDto? wh = await WarehouseService.GetWarehouseByIdAsync(_filterWarehouseId.Value, _cts.Token);
            _selectedWarehouseName = wh?.Name;
        }
        else
        {
            _selectedWarehouseName = null;
        }
        await LoadWarehouseData();
    }

    private async Task OpenAdjustStockDialog()
    {
        if (await WisDialog.ShowFormAsync<AdjustStockDialog, bool>(
                Localization.GetString("AdjustStock"), MaxWidth.Small) == true)
        {
            await LoadWarehouseData();
            StateHasChanged();
        }
    }

    private async Task OpenNewPaymentDialog()
    {
        try
        {
            bool created = await WisDialog.ShowPaymentDialogAsync();
            if (created)
                Snackbar.Add(Localization.GetString("PaymentCreated"), Severity.Success);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error creating payment: {ex.Message}");
            Snackbar.Add(Localization.GetString("ErrorCreatingPayment"), Severity.Error);
        }
    }

    private async Task OpenNewProductDialog()
    {
        ProductDto? dto = await WisDialog.ShowFormAsync<ProductDialog, ProductDto>(
            Localization.GetString("CreateProduct"), MaxWidth.Small);

        if (dto is null) return;

        try
        {
            await ProductService.CreateProductAsync(new CreateProductDto
            {
                Code = dto.Code,
                Name = dto.Name,
                Description = dto.Description,
                Unit = dto.Unit,
                DefaultPrice = dto.DefaultPrice,
                IsActive = dto.IsActive
            });
            Snackbar.Add(Localization.GetString("ProductCreated"), Severity.Success);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error creating product: {ex.Message}");
            Snackbar.Add(Localization.GetString("ErrorCreatingProduct"), Severity.Error);
        }
    }

    private async Task OpenNewCompanyDialog()
    {
        CompanyDto? dto = await WisDialog.ShowFormAsync<CompanyDialog, CompanyDto>(
            Localization.GetString("CreateCompany"));

        if (dto is null) return;

        try
        {
            await CompanyService.CreateCompanyAsync(new CreateCompanyDto
            {
                Name = dto.Name,
                Type = dto.Type,
                ContactPerson = dto.ContactPerson,
                Email = dto.Email,
                Phone = dto.Phone,
                Address = dto.Address,
                TaxId = dto.TaxId,
                PaymentTermsDays = dto.PaymentTermsDays,
                CreditLimit = dto.CreditLimit
            });
            Snackbar.Add(Localization.GetString("CompanyCreated"), Severity.Success);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error creating company: {ex.Message}");
            Snackbar.Add(Localization.GetString("ErrorCreatingCompany"), Severity.Error);
        }
    }

    private async Task OpenNewIndividualDialog()
    {
        IndividualDto? dto = await WisDialog.ShowFormAsync<IndividualDialog, IndividualDto>(
            Localization.GetString("CreateIndividual"));

        if (dto is null) return;

        try
        {
            await IndividualService.CreateIndividualAsync(new CreateIndividualDto
            {
                FirstName = dto.FirstName,
                LastName = dto.LastName,
                IdentificationNumber = dto.IdentificationNumber,
                Phone = dto.Phone,
                Email = dto.Email,
                Address = dto.Address,
                IsActive = dto.IsActive
            });
            Snackbar.Add(Localization.GetString("IndividualCreated"), Severity.Success);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error creating individual: {ex.Message}");
            Snackbar.Add(Localization.GetString("ErrorCreatingIndividual"), Severity.Error);
        }
    }

}
