@page "/individuals"
@implements IDisposable
@using WarehouseInvoiceSystem.Application.Interfaces
@using WarehouseInvoiceSystem.Application.DTOs.Individual
@inject IIndividualService IndividualService
@inject ILocalizationService Localization
@inject NavigationManager Navigation
@inject IDialogService DialogService
@inject ISnackbar Snackbar

<PageTitle>@Localization.GetString("Individuals") - @Localization.GetString("WarehouseInvoiceSystem")</PageTitle>

<MudText Typo="Typo.h4" Class="mb-6">@Localization.GetString("Individuals")</MudText>

<MudCard Elevation="2" Class="mb-4">
    <MudCardContent>
        <MudGrid>
            <MudItem xs="12" sm="6" md="3">
                <MudButton StartIcon="@Icons.Material.Filled.Add"
                           Color="Color.Primary"
                           Variant="Variant.Filled"
                           FullWidth="true"
                           Href="/individuals/create">
                    @Localization.GetString("CreateIndividual")
                </MudButton>
            </MudItem>
            <MudItem xs="12" sm="6" md="9">
                <MudTextField T="string"
                              Value="_searchString"
                              ValueChanged="OnSearch"
                              Placeholder="@Localization.GetString("Search")"
                              Adornment="Adornment.Start"
                              AdornmentIcon="@Icons.Material.Filled.Search"
                              IconSize="Size.Medium"
                              Immediate="true"
                              DebounceInterval="300"
                              Class="mt-0" />
            </MudItem>
        </MudGrid>

        <MudTabs Elevation="0"
                 Rounded="true"
                 Class="mt-4"
                 ActivePanelIndex="_activeTabIndex"
                 ActivePanelIndexChanged="OnTabChanged">
            <MudTabPanel Text="@Localization.GetString("AllIndividuals")" Icon="@Icons.Material.Filled.List" />
            <MudTabPanel Text="@Localization.GetString("ActiveIndividuals")" Icon="@Icons.Material.Filled.CheckCircle" />
            <MudTabPanel Text="@Localization.GetString("InactiveIndividuals")" Icon="@Icons.Material.Filled.Block" />
        </MudTabs>
    </MudCardContent>
</MudCard>

<MudCard Elevation="2" Class="mb-4">
    <MudCardContent Class="pa-0">
        @if (_loading)
        {
            <div class="pa-6">
                <MudProgressLinear Color="Color.Primary" Indeterminate="true" />
            </div>
        }
        else if (_filteredIndividuals == null || !_filteredIndividuals.Any())
        {
            <div class="pa-6 text-center">
                <MudText Color="Color.Secondary">@Localization.GetString("NoIndividualsFound")</MudText>
            </div>
        }
        else
        {
            <MudTable Items="_paginatedIndividuals"
                      Hover="true"
                      Breakpoint="Breakpoint.Sm"
                      Dense="false"
                      FixedHeader="true"
                      Height="600px"
                      Sort="@((SortDefinition<IndividualDto> sortDefinition) => HandleSort(sortDefinition))">
                <HeaderContent>
                    <MudTh><MudTableSortLabel SortBy="new Func<IndividualDto, object>(x => x.LastName)">@Localization.GetString("LastName")</MudTableSortLabel></MudTh>
                    <MudTh><MudTableSortLabel SortBy="new Func<IndividualDto, object>(x => x.FirstName)">@Localization.GetString("FirstName")</MudTableSortLabel></MudTh>
                    <MudTh><MudTableSortLabel SortBy="new Func<IndividualDto, object>(x => x.IdentificationNumber)">@Localization.GetString("IdentificationNumber")</MudTableSortLabel></MudTh>
                    <MudTh>@Localization.GetString("Phone")</MudTh>
                    <MudTh>@Localization.GetString("Status")</MudTh>
                    <MudTh>@Localization.GetString("Actions")</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="@Localization.GetString("LastName")">
                        <MudText Typo="Typo.body2" Class="font-weight-medium">
                            @context.LastName
                        </MudText>
                    </MudTd>
                    <MudTd DataLabel="@Localization.GetString("FirstName")">
                        @context.FirstName
                    </MudTd>
                    <MudTd DataLabel="@Localization.GetString("IdentificationNumber")">
                        @context.IdentificationNumber
                    </MudTd>
                    <MudTd DataLabel="@Localization.GetString("Phone")">
                        @context.Phone
                    </MudTd>
                    <MudTd DataLabel="@Localization.GetString("Status")">
                        <MudChip T="string"
                                 Size="Size.Small"
                                 Color="@(context.IsActive ? Color.Success : Color.Default)">
                            @(context.IsActive? Localization.GetString("ActiveIndividual") : Localization.GetString("InactiveIndividual"))
                        </MudChip>
                    </MudTd>
                    <MudTd DataLabel="@Localization.GetString("Actions")">
                        <MudMenu Icon="@Icons.Material.Filled.MoreVert" Size="Size.Small">
                            <MudMenuItem Icon="@Icons.Material.Filled.Edit"
                                         OnClick="@(() => EditIndividual(context.Id))">
                                @Localization.GetString("Edit")
                            </MudMenuItem>
                            <MudMenuItem Icon="@Icons.Material.Filled.Receipt"
                                         OnClick="@(() => ViewPurchaseNotes(context.Id))">
                                @Localization.GetString("PurchaseNotes")
                            </MudMenuItem>
                            <MudDivider />
                            <MudMenuItem Icon="@Icons.Material.Filled.Delete"
                                         IconColor="Color.Error"
                                         OnClick="@(() => DeleteIndividual(context.Id))">
                                @Localization.GetString("Delete")
                            </MudMenuItem>
                        </MudMenu>
                    </MudTd>
                </RowTemplate>
            </MudTable>

            <!-- Pagination Controls -->
            <MudDivider />
            <MudCardContent Class="pa-4">
                <MudGrid>
                    <MudItem xs="12" sm="6">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                            <MudButton Variant="Variant.Outlined"
                                       Size="Size.Small"
                                       OnClick="PreviousPage"
                                       Disabled="@(_currentPage == 1)">
                                @Localization.GetString("Previous")
                            </MudButton>

                            <MudText Typo="Typo.body2">
                                @Localization.GetString("Page") @_currentPage @Localization.GetString("Of") @_totalPages
                            </MudText>

                            <MudButton Variant="Variant.Outlined"
                                       Size="Size.Small"
                                       OnClick="NextPage"
                                       Disabled="@(_currentPage == _totalPages)">
                                @Localization.GetString("Next")
                            </MudButton>
                        </MudStack>
                    </MudItem>

                    <MudItem xs="12" sm="6" Class="d-flex justify-end align-center">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1" Class="ml-auto">
                            <MudText Typo="Typo.body2">
                                @Localization.GetString("ItemsPerPage")
                            </MudText>

                            <MudSelect T="int"
                                       Value="_itemsPerPage"
                                       Dense="true"
                                       Variant="Variant.Outlined"
                                       Style="width: 100px;"
                                       ValueChanged="@((int val) => OnItemsPerPageChanged(val))">
                                <MudSelectItem Value="10">10</MudSelectItem>
                                <MudSelectItem Value="25">25</MudSelectItem>
                                <MudSelectItem Value="50">50</MudSelectItem>
                                <MudSelectItem Value="100">100</MudSelectItem>
                            </MudSelect>

                            <MudText Typo="Typo.body2" Color="Color.Secondary">
                                (@_totalIndividuals @Localization.GetString("Total"))
                            </MudText>
                        </MudStack>
                    </MudItem>
                </MudGrid>
            </MudCardContent>
        }
    </MudCardContent>
</MudCard>

@code {
    private bool _loading = true;
    private List<IndividualDto> _allIndividuals = [];
    private List<IndividualDto> _filteredIndividuals = [];
    private List<IndividualDto> _paginatedIndividuals = [];
    private string _searchString = "";
    private int _activeTabIndex = 0;

    private int _currentPage = 1;
    private int _itemsPerPage = 10;
    private int _totalIndividuals = 0;
    private int _totalPages = 1;

    private string _sortBy = "CreatedAt";
    private bool _sortAscending = false;

    protected override async Task OnInitializedAsync()
    {
        Localization.OnLanguageChanged += OnLanguageChanged;
        await LoadIndividuals();
    }

    private async void OnLanguageChanged()
    {
        await InvokeAsync(StateHasChanged);
    }

    private async Task LoadIndividuals()
    {
        _loading = true;

        try
        {
            IEnumerable<IndividualDto> individuals = await IndividualService.GetAllIndividualsAsync();
            _allIndividuals = individuals.ToList();
            ApplyFilters();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading individuals: {ex.Message}");
            Snackbar.Add(Localization.GetString("ErrorLoadingIndividuals"), Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    private void ApplyFilters()
    {
        IEnumerable<IndividualDto> filtered = _allIndividuals;

        filtered = _activeTabIndex switch
        {
            1 => filtered.Where(i => i.IsActive),
            2 => filtered.Where(i => !i.IsActive),
            _ => filtered
        };

        if (!string.IsNullOrWhiteSpace(_searchString))
        {
            string search = _searchString.ToLower();
            filtered = filtered.Where(i =>
                i.FirstName.ToLower().Contains(search) ||
                i.LastName.ToLower().Contains(search) ||
                i.IdentificationNumber.Contains(search) ||
                (i.Phone?.ToLower().Contains(search) ?? false));
        }

        filtered = _sortAscending
            ? filtered.OrderBy(GetSortProperty)
            : filtered.OrderByDescending(GetSortProperty);

        _filteredIndividuals = filtered.ToList();
        _totalIndividuals = _filteredIndividuals.Count;

        UpdatePagination();
    }

    private void UpdatePagination()
    {
        _totalPages = (int)Math.Ceiling((double)_totalIndividuals / _itemsPerPage);

        if (_currentPage > _totalPages && _totalPages > 0)
        {
            _currentPage = _totalPages;
        }

        int skipCount = (_currentPage - 1) * _itemsPerPage;
        _paginatedIndividuals = _filteredIndividuals
            .Skip(skipCount)
            .Take(_itemsPerPage)
            .ToList();
    }

    private void ResetPaginationAndApplyFilters()
    {
        _currentPage = 1;
        ApplyFilters();
    }

    private object GetSortProperty(IndividualDto individual) => _sortBy switch
    {
        "FirstName" => individual.FirstName,
        "LastName" => individual.LastName,
        "IdentificationNumber" => individual.IdentificationNumber,
        _ => individual.CreatedAt
    };

    private void HandleSort(SortDefinition<IndividualDto> sortDefinition)
    {
        if (sortDefinition == null || string.IsNullOrEmpty(sortDefinition.SortBy))
            return;

        _sortBy = sortDefinition.SortBy;
        _sortAscending = !sortDefinition.Descending;
        ApplyFilters();
    }

    private async Task OnSearch(string text)
    {
        _searchString = text;
        ResetPaginationAndApplyFilters();
        await InvokeAsync(StateHasChanged);
    }

    private async Task OnTabChanged(int index)
    {
        _activeTabIndex = index;
        ResetPaginationAndApplyFilters();
        await InvokeAsync(StateHasChanged);
    }

    private void EditIndividual(Guid id)
    {
        Navigation.NavigateTo($"/individuals/edit/{id}");
    }

    private void ViewPurchaseNotes(Guid id)
    {
        Navigation.NavigateTo($"/purchase-notes?individualId={id}");
    }

    private async Task DeleteIndividual(Guid id)
    {
        bool? result = await DialogService.ShowMessageBox(
            Localization.GetString("ConfirmDelete"),
            Localization.GetString("DeleteIndividualConfirm"),
            yesText: Localization.GetString("Yes"),
            cancelText: Localization.GetString("No"));

        if (result == true)
        {
            try
            {
                bool deleted = await IndividualService.DeleteIndividualAsync(id);
                if (deleted)
                {
                    Snackbar.Add(Localization.GetString("IndividualDeleted"), Severity.Success);
                    await LoadIndividuals();
                }
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Error deleting individual: {ex.Message}");
                Snackbar.Add(Localization.GetString("ErrorDeletingIndividual"), Severity.Error);
            }
        }
    }

    private void PreviousPage()
    {
        if (_currentPage > 1)
        {
            _currentPage--;
            UpdatePagination();
        }
    }

    private void NextPage()
    {
        if (_currentPage < _totalPages)
        {
            _currentPage++;
            UpdatePagination();
        }
    }

    private void OnItemsPerPageChanged(int newItemsPerPage)
    {
        _itemsPerPage = newItemsPerPage;
        _currentPage = 1;
        UpdatePagination();
    }

    public void Dispose()
    {
        Localization.OnLanguageChanged -= OnLanguageChanged;
    }
}