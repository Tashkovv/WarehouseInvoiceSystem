@page "/individuals"
@inherits PageBase
@using WarehouseInvoiceSystem.Application.DTOs.Individual
@using WarehouseInvoiceSystem.Domain.Queries
@using WarehouseInvoiceSystem.Domain.Queries.Common
@inject IIndividualService IndividualService

<PageTitle>@Localization.GetString("Individuals") - @Localization.GetString("InvoiceSystem")</PageTitle>

<div class="wis-page-header">
    <MudText Typo="Typo.h3" Class="wis-page-title">
        @Localization.GetString("Individuals")
    </MudText>
</div>

<WisGridToolbar CreateAction="OpenCreateDialog"
                CreateLabel="@Localization.GetString("Individual")"
                SearchValue="@_searchString"
                SearchValueChanged="OnSearch"
                HasAnyActiveFilter="@(_filterIsActive.HasValue)"
                OnClearAll="ClearAllFilters">
    <Filters>
        <FilterPopoverList TValue="bool?"
                           Label="@Localization.GetString("Status")"
                           Items="_statusFilterItems"
                           Mode="FilterSelectionMode.Single"
                           SelectedValue="_filterIsActive"
                           FilterVariant="Variant.Outlined"
                           SelectedValueChanged="OnStatusFilterChanged" />
    </Filters>
</WisGridToolbar>

<MudCard Elevation="2" Class="mb-4">
    <MudCardContent Class="pa-0">
        <MudDataGrid T="IndividualDto"
                     @ref="_grid"
                     ServerData="LoadServerData"
                     RowClick="OnRowClick"
                     RowClassFunc="GetRowClass"
                     ReadOnly="true"
                     Hover="true"
                     FixedHeader="true"
                     Height="100%"
                     Filterable="false"
                     ShowColumnOptions="false"
                     ColumnResizeMode="ResizeMode.Column"
                     SortMode="SortMode.Single"
                     Class="wis-data-grid">
            <Columns>

                <TemplateColumn Sortable="false"
                                Filterable="false"
                                IsEditable="false"
                                HeaderClass="wis-col-actions-1"
                                CellClass="wis-col-actions-1">
                    <CellTemplate>
                        <MudStack Row="true" Justify="Justify.Center" AlignItems="AlignItems.Center">
                            <WisSplitButton Actions="@BuildRowActions(context.Item)"
                                            AnchorOrigin="Origin.BottomLeft"
                                            TransformOrigin="Origin.TopLeft"
                                            HideLabel="true" />
                        </MudStack>
                    </CellTemplate>
                </TemplateColumn>

                <PropertyColumn Property="x => x.FullName"
                                Title="@Localization.GetString("FullName")"
                                Sortable="true"
                                IsEditable="false"
                                CellClass="wis-cell-primary" />

                <PropertyColumn Property="x => x.IdentificationNumber"
                                Title="@Localization.GetString("IdentificationNumber")"
                                Sortable="true"
                                IsEditable="false"
                                CellClass="wis-cell-mono" />

                <PropertyColumn Property="x => x.Phone"
                                Title="@Localization.GetString("Phone")"
                                Sortable="false"
                                IsEditable="false" />

                <PropertyColumn Property="x => x.Email"
                                Title="@Localization.GetString("Email")"
                                Sortable="false"
                                IsEditable="false" />

                <PropertyColumn Property="x => x.IsActive"
                                Title="@Localization.GetString("Status")"
                                Sortable="false"
                                IsEditable="false">
                    <CellTemplate>
                        <MudChip T="string"
                                 Size="Size.Small"
                                 Variant="Variant.Outlined"
                                 Color="@(context.Item.IsActive ? Color.Success : Color.Default)">
                            @(context.Item.IsActive ? Localization.GetString("ActiveIndividual")
                                                        : Localization.GetString("InactiveIndividual"))
                        </MudChip>
                    </CellTemplate>
                </PropertyColumn>

            </Columns>

            <NoRecordsContent>
                <WisNoRecordsContent Icon="@Icons.Material.Filled.Person"
                                     Message="@Localization.GetString("NoIndividualsFound")" />
            </NoRecordsContent>

            <LoadingContent>
                <WisLoadingContent />
            </LoadingContent>

            <PagerContent>
                <WisPagerContent T="IndividualDto" />
            </PagerContent>

        </MudDataGrid>
    </MudCardContent>
</MudCard>

@code {
    private MudDataGrid<IndividualDto> _grid = null!;
    private string _searchString = string.Empty;
    private bool? _filterIsActive = null;

    private List<FilterPopoverItem<bool?>> _statusFilterItems = [];

    protected override void OnInitialized()
    {
        base.OnInitialized();
        BuildFilterItems();
    }

    private void BuildFilterItems()
    {
        _statusFilterItems =
        [
            new() { Label = Localization.GetString("All"),                Value = null,  Color = Color.Info },
            new() { Label = Localization.GetString("ActiveIndividual"),   Value = true,  Color = Color.Success },
            new() { Label = Localization.GetString("InactiveIndividual"), Value = false, Color = Color.Default },
        ];
    }

    protected override async void OnLanguageChanged()
    {
        BuildFilterItems();
        await InvokeAsync(StateHasChanged);
    }

    private async Task<GridData<IndividualDto>> LoadServerData(GridState<IndividualDto> state, CancellationToken ct)
    {
        string? sortBy = state.SortDefinitions.FirstOrDefault()?.SortBy;
        bool ascending = state.SortDefinitions.FirstOrDefault()?.Descending == false;

        GetIndividualsQuery query = new()
        {
            Search = _searchString,
            IsActive = _filterIsActive,
            Page = state.Page + 1,
            PageSize = state.PageSize,
            SortBy = sortBy,
            SortAscending = ascending,
        };

        PagedResult<IndividualDto> result = await IndividualService.GetPagedAsync(query, ct);

        return new GridData<IndividualDto>
        {
            Items = result.Items,
            TotalItems = result.TotalCount
        };
    }

    private string GetRowClass(IndividualDto item, int index) =>
        item.IsActive ? "row-status-success" : "row-status-default";

    private async Task OnSearch(string text)
    {
        _searchString = text;
        await _grid.ReloadServerData();
    }

    private async Task OnStatusFilterChanged(bool? value)
    {
        _filterIsActive = value;
        await _grid.ReloadServerData();
    }

    private async Task ClearAllFilters()
    {
        _filterIsActive = null;
        await _grid.ReloadServerData();
    }

    private async void OnRowClick(DataGridRowClickEventArgs<IndividualDto> args)
    {
        if (args.MouseEventArgs.Detail == 2)
            Navigation.NavigateTo($"/individuals/{args.Item.Id}");
    }

    private async Task OpenCreateDialog()
    {
        IndividualDto? dto = await WisDialog.ShowFormAsync<IndividualDialog, IndividualDto>(
            Localization.GetString("CreateIndividual"));

        if (dto is null) return;

        try
        {
            CreateIndividualDto createDto = new()
            {
                FirstName = dto.FirstName,
                LastName = dto.LastName,
                IdentificationNumber = dto.IdentificationNumber,
                Phone = dto.Phone,
                Email = dto.Email,
                Address = dto.Address,
                IsActive = dto.IsActive,
            };

            await IndividualService.CreateIndividualAsync(createDto);
            Snackbar.Add(Localization.GetString("IndividualCreated"), Severity.Success);
            await _grid.ReloadServerData();
        }
        catch (InvalidOperationException ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error creating individual: {ex.Message}");
            Snackbar.Add(Localization.GetString("ErrorCreatingIndividual"), Severity.Error);
        }
    }

    private async Task OpenEditDialog(IndividualDto individual)
    {
        IndividualDto? dto = await WisDialog.ShowFormAsync<IndividualDialog, IndividualDto>(
            Localization.GetString("EditIndividual"),
            p => p.Add(x => x.Individual, individual));

        if (dto is null) return;

        try
        {
            UpdateIndividualDto updateDto = new()
            {
                FirstName = dto.FirstName,
                LastName = dto.LastName,
                IdentificationNumber = dto.IdentificationNumber,
                Phone = dto.Phone,
                Email = dto.Email,
                Address = dto.Address,
                IsActive = dto.IsActive,
            };

            await IndividualService.UpdateIndividualAsync(dto.Id, updateDto);
            Snackbar.Add(Localization.GetString("IndividualUpdated"), Severity.Success);
            await _grid.ReloadServerData();
        }
        catch (InvalidOperationException ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error updating individual: {ex.Message}");
            Snackbar.Add(Localization.GetString("ErrorUpdatingIndividual"), Severity.Error);
        }
    }

    private List<WisDetailActionItem> BuildRowActions(IndividualDto item) =>
    [
        new WisDetailActionItem
        {
            Icon    = Icons.Material.Filled.Edit,
            Label   = Localization.GetString("Edit"),
            OnClick = EventCallback.Factory.Create(this, () => OpenEditDialog(item))
        },
        new WisDetailActionItem
        {
            Icon    = Icons.Material.Filled.Receipt,
            Label   = Localization.GetString("PurchaseNotes"),
            Color   = Color.Secondary,
            OnClick = EventCallback.Factory.Create(this, () => Navigation.NavigateTo($"/purchase-notes?individualId={item.Id}"))
        },
        new WisDetailActionItem
        {
            Icon            = Icons.Material.Filled.PowerSettingsNew,
            Label           = item.IsActive ? Localization.GetString("Deactivate") : Localization.GetString("Activate"),
            Color           = item.IsActive ? Color.Warning : Color.Success,
            IsDividerBefore = true,
            OnClick         = EventCallback.Factory.Create(this, () => SetActiveStatus(item, !item.IsActive))
        },
    ];

    private async Task SetActiveStatus(IndividualDto individual, bool isActive)
    {
        if (!isActive)
        {
            bool confirmed = await WisDialog.ConfirmAsync(
                Localization.GetString("DeactivateIndividual"),
                Localization.GetString("DeactivateIndividualConfirm"),
                Localization.GetString("Deactivate"),
                Localization.GetString("Back"));
            if (!confirmed) return;
        }

        try
        {
            await IndividualService.SetActiveStatusAsync(individual.Id, isActive);
            string key = isActive ? "IndividualActivated" : "IndividualDeactivated";
            Snackbar.Add(Localization.GetString(key), Severity.Success);
            await _grid.ReloadServerData();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error updating individual status: {ex.Message}");
            Snackbar.Add(Localization.GetString("ErrorUpdatingIndividual"), Severity.Error);
        }
    }

}
