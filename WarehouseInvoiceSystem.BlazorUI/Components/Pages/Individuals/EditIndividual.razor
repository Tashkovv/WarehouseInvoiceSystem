@page "/individuals/edit/{Id:guid}"
@using WarehouseInvoiceSystem.Application.Interfaces
@using WarehouseInvoiceSystem.Application.DTOs.Individual
@inject IIndividualService IndividualService
@inject ILocalizationService Localization
@inject NavigationManager Navigation
@inject ISnackbar Snackbar

<PageTitle>@Localization.GetString("EditIndividual") - @Localization.GetString("InvoiceSystem")</PageTitle>

@if (_loading)
{
    <MudProgressLinear Color="Color.Primary" Indeterminate="true" />
}
else if (_model == null)
{
    <MudAlert Severity="Severity.Error">@Localization.GetString("IndividualNotFound")</MudAlert>
}
else
{
    <MudText Typo="Typo.h4" Class="mb-6">@Localization.GetString("EditIndividual")</MudText>

    <MudCard Elevation="2" Class="mb-4">
        <MudCardContent>
            <MudForm @ref="_form" @bind-IsValid="@_isValid">
                <MudGrid>
                    <MudItem xs="12" md="6">
                        <MudTextField @bind-Value="_model.FirstName"
                                      Label="@Localization.GetString("FirstName")"
                                      Required="true"
                                      RequiredError="@Localization.GetString("FirstNameRequired")"
                                      Variant="Variant.Outlined"
                                      MaxLength="100" />
                    </MudItem>

                    <MudItem xs="12" md="6">
                        <MudTextField @bind-Value="_model.LastName"
                                      Label="@Localization.GetString("LastName")"
                                      Required="true"
                                      RequiredError="@Localization.GetString("LastNameRequired")"
                                      Variant="Variant.Outlined"
                                      MaxLength="100" />
                    </MudItem>

                    <MudItem xs="12" md="6">
                        <MudTextField @bind-Value="_model.IdentificationNumber"
                                      Label="@Localization.GetString("IdentificationNumber")"
                                      Required="true"
                                      RequiredError="@Localization.GetString("IdentificationNumberRequired")"
                                      Variant="Variant.Outlined"
                                      MaxLength="50" />
                    </MudItem>

                    <MudItem xs="12" md="6">
                        <MudTextField @bind-Value="_model.Phone"
                                      Label="@Localization.GetString("Phone")"
                                      Variant="Variant.Outlined"
                                      MaxLength="50" />
                    </MudItem>

                    <MudItem xs="12" md="6">
                        <MudTextField @bind-Value="_model.Email"
                                      Label="@Localization.GetString("Email")"
                                      Variant="Variant.Outlined"
                                      InputType="InputType.Email"
                                      MaxLength="100" />
                    </MudItem>

                    <MudItem xs="12" md="6">
                        <MudTextField @bind-Value="_model.Address"
                                      Label="@Localization.GetString("Address")"
                                      Variant="Variant.Outlined"
                                      MaxLength="500" />
                    </MudItem>

                    <MudItem xs="12">
                        <MudSwitch @bind-Value="_model.IsActive"
                                   Label="@Localization.GetString("ActiveIndividual")"
                                   Color="Color.Success" />
                    </MudItem>
                </MudGrid>
            </MudForm>
        </MudCardContent>
    </MudCard>
    <!-- Actions -->
    <MudItem xs="12">
        <div class="d-flex justify-end gap-2">
            <MudButton Variant="Variant.Outlined"
                       OnClick="Cancel"
                       Disabled="@_saving">
                @Localization.GetString("Cancel")
            </MudButton>
            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       OnClick="SaveIndividual"
                       Disabled="@(!_isValid || _saving)">
                @if (_saving)
                {
                    <MudProgressCircular Class="ms-n1" Size="Size.Small" Indeterminate="true" />
                    <MudText Class="ms-2">@Localization.GetString("Saving")</MudText>
                }
                else
                {
                    @Localization.GetString("Save")
                }
            </MudButton>
        </div>
    </MudItem>
}

@code {
    [Parameter] public Guid Id { get; set; }

    private MudForm _form = null!;
    private bool _isValid;
    private bool _loading = true;
    private bool _saving;
    private UpdateIndividualDto? _model;

    protected override async Task OnInitializedAsync()
    {
        Localization.OnLanguageChanged += OnLanguageChanged;
        await LoadIndividual();
    }

    private async void OnLanguageChanged()
    {
        await InvokeAsync(StateHasChanged);
    }

    private async Task LoadIndividual()
    {
        _loading = true;

        try
        {
            IndividualDto? individual = await IndividualService.GetIndividualByIdAsync(Id);
            if (individual != null)
            {
                _model = new UpdateIndividualDto
                {
                    FirstName = individual.FirstName,
                    LastName = individual.LastName,
                    IdentificationNumber = individual.IdentificationNumber,
                    Address = individual.Address,
                    Phone = individual.Phone,
                    Email = individual.Email,
                    IsActive = individual.IsActive
                };
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading individual: {ex.Message}");
            Snackbar.Add(Localization.GetString("ErrorLoadingIndividual"), Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task SaveIndividual()
    {
        await _form.ValidateAsync();
        if (!_isValid || _model == null) return;

        _saving = true;

        try
        {
            await IndividualService.UpdateIndividualAsync(Id, _model);
            Snackbar.Add(Localization.GetString("IndividualUpdated"), Severity.Success);
            Navigation.NavigateTo("/individuals");
        }
        catch (InvalidOperationException ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error updating individual: {ex.Message}");
            Snackbar.Add(Localization.GetString("ErrorUpdatingIndividual"), Severity.Error);
        }
        finally
        {
            _saving = false;
        }
    }

    private void Cancel()
    {
        Navigation.NavigateTo("/individuals");
    }
}