@page "/individuals/{Id:guid}"
@inherits PageBase
@using WarehouseInvoiceSystem.Application.DTOs.Individual
@using WarehouseInvoiceSystem.Domain.Enums
@inject IIndividualService IndividualService

<PageTitle>@Localization.GetString("IndividualDetails") - @Localization.GetString("InvoiceSystem")</PageTitle>

@if (_loading)
{
    <MudProgressLinear Color="Color.Primary" Indeterminate="true" />
}
else if (_individual == null)
{
    <MudAlert Severity="Severity.Error">@Localization.GetString("IndividualNotFound")</MudAlert>
}
else
{
    <WisDetailHeader BackHref="/individuals"
                     BackLabel="@Localization.GetString("Individuals")"
                     PrimaryAction="@_primaryAction"
                     Actions="@_actions" />

    <MudGrid>
        <!-- Individual Header Card -->
        <MudItem xs="12">
            <MudCard Elevation="2">
                <MudCardContent Class="pa-4">

                    <!-- Row 1: Name + status chip -->
                    <div class="wis-detail-identity mb-3">
                        <MudText Typo="Typo.h4" Class="font-weight-bold mb-0">@_individual.FullName</MudText>
                        <MudChip T="string" Size="Size.Small"
                                 Color="@(_individual.IsActive ? Color.Success : Color.Default)">
                            @(_individual.IsActive? Localization.GetString("ActiveIndividual") : Localization.GetString("InactiveIndividual"))
                        </MudChip>
                    </div>

                    <!-- Row 2: Contact pills -->
                    <div class="wis-detail-contact mb-4">
                        <div class="wis-detail-contact-item">
                            <MudIcon Icon="@Icons.Material.Filled.Badge" Size="Size.Small" Color="Color.Secondary" />
                            <MudText Typo="Typo.body2" Color="Color.Secondary">@_individual.IdentificationNumber</MudText>
                        </div>
                        @if (!string.IsNullOrWhiteSpace(_individual.Phone))
                        {
                            <div class="wis-detail-contact-item">
                                <MudIcon Icon="@Icons.Material.Filled.Phone" Size="Size.Small" Color="Color.Secondary" />
                                <MudText Typo="Typo.body2">@_individual.Phone</MudText>
                            </div>
                        }
                        @if (!string.IsNullOrWhiteSpace(_individual.Email))
                        {
                            <div class="wis-detail-contact-item">
                                <MudIcon Icon="@Icons.Material.Filled.Email" Size="Size.Small" Color="Color.Secondary" />
                                <MudText Typo="Typo.body2">@_individual.Email</MudText>
                            </div>
                        }
                        @if (!string.IsNullOrWhiteSpace(_individual.BankAccount))
                        {
                            <div class="wis-detail-contact-item">
                                <MudIcon Icon="@Icons.Material.Outlined.AccountBalance" Size="Size.Small" Color="Color.Secondary" />
                                <MudText Typo="Typo.body2">@_individual.BankAccount</MudText>
                            </div>
                        }
                        @if (!string.IsNullOrWhiteSpace(_individual.Address))
                        {
                            <div class="wis-detail-contact-item">
                                <MudIcon Icon="@Icons.Material.Filled.LocationOn" Size="Size.Small" Color="Color.Secondary" />
                                <MudText Typo="Typo.body2">@_individual.Address</MudText>
                            </div>
                        }
                    </div>

                    @if (_analytics.TotalPurchaseNotes > 0 || _analytics.CancelledCount > 0)
                    {
                        <MudDivider Class="mb-6" />

                        <!-- Row 3: Stats across full width -->
                        <MudGrid Spacing="4" Class="wis-detail-stats">

                            <!-- Total Purchases -->
                            <MudItem xs="2">
                                <MudText Typo="Typo.caption" Color="Color.Secondary" Class="wis-section-label">@Localization.GetString("TotalPurchases")</MudText>
                                <div class="wis-stat-value mud-info-text">@_analytics.TotalAmount.ToString("C")</div>
                                <MudText Typo="Typo.body2" Color="Color.Secondary">@_analytics.TotalPurchaseNotes @Localization.GetString("PurchaseNotes")</MudText>
                            </MudItem>

                            <!-- Paid -->
                            <MudItem xs="2">
                                <MudText Typo="Typo.caption" Color="Color.Secondary" Class="wis-section-label">@Localization.GetString("Paid")</MudText>
                                <div class="wis-stat-value mud-success-text">@_analytics.PaidAmount.ToString("C")</div>
                                <MudText Typo="Typo.body2" Color="Color.Secondary">@_analytics.PaidCount @Localization.GetString("PurchaseNotes")</MudText>
                            </MudItem>

                            <!-- Unpaid -->
                            <MudItem xs="2">
                                <MudText Typo="Typo.caption" Color="Color.Secondary" Class="wis-section-label">@Localization.GetString("Unpaid")</MudText>
                                @if (_analytics.UnpaidCount > 0)
                                {
                                    <div class="wis-stat-value mud-warning-text">@_analytics.UnpaidAmount.ToString("C")</div>
                                    <MudText Typo="Typo.body2" Color="Color.Warning">@_analytics.UnpaidCount @Localization.GetString("PurchaseNotes")</MudText>
                                }
                                else
                                {
                                    <div class="wis-stat-value mud-success-text">—</div>
                                    <MudText Typo="Typo.body2" Color="Color.Success">✓ @Localization.GetString("AllPurchasesPaid")</MudText>
                                }
                            </MudItem>

                            <!-- Cancelled -->
                            @if (_analytics.CancelledCount > 0)
                            {
                                <MudItem xs="2">
                                    <MudText Typo="Typo.caption" Color="Color.Secondary" Class="wis-section-label">@Localization.GetString("Cancelled")</MudText>
                                    <div class="wis-stat-value mud-error-text" style="text-decoration: line-through;">@_analytics.CancelledAmount.ToString("C")</div>
                                    <MudText Typo="Typo.body2" Color="Color.Error">@_analytics.CancelledCount @Localization.GetString("PurchaseNotes")</MudText>
                                </MudItem>
                            }

                            <!-- Purchase History: dates + most purchased side by side -->
                            <MudItem xs="4">
                                <MudText Typo="Typo.caption" Color="Color.Secondary" Class="wis-section-label mb-2">@Localization.GetString("PurchaseHistory")</MudText>
                                <div class="wis-detail-history">
                                    <div class="wis-detail-history-dates">
                                        <div>
                                            <MudText Typo="Typo.caption" Color="Color.Secondary">@Localization.GetString("FirstPurchase")</MudText>
                                            <MudText Typo="Typo.body1" Class="font-weight-medium">@(_analytics.FirstPurchaseDate?.ToString("dd MMM yyyy") ?? "—")</MudText>
                                        </div>
                                        <div>
                                            <MudText Typo="Typo.caption" Color="Color.Secondary">@Localization.GetString("LastPurchase")</MudText>
                                            <MudText Typo="Typo.body1" Class="font-weight-medium">@(_analytics.LastPurchaseDate?.ToString("dd MMM yyyy") ?? "—")</MudText>
                                        </div>
                                    </div>
                                    @if (!string.IsNullOrEmpty(_analytics.MostPurchasedProduct))
                                    {
                                        <div class="wis-detail-history-product">
                                            <MudIcon Icon="@Icons.Material.Filled.Star" Size="Size.Small" Color="Color.Warning" />
                                            <div class="wis-detail-history-product-text">
                                                <MudText Typo="Typo.caption" Color="Color.Secondary">@Localization.GetString("MostPurchasedProduct")</MudText>
                                                <MudText Typo="Typo.body2" Class="wis-capitalize font-weight-medium wis-truncate">@_analytics.MostPurchasedProduct</MudText>
                                                <MudText Typo="Typo.body2" Color="Color.Secondary">@_analytics.MostPurchasedProductQuantity.ToString("N2") @_analytics.MostPurchasedProductUnit</MudText>
                                            </div>
                                        </div>
                                    }
                                </div>
                            </MudItem>

                        </MudGrid>
                    }

                </MudCardContent>
            </MudCard>
        </MudItem>

        <!-- Recent Purchase Notes -->
        <MudItem xs="12">
            <MudCard Elevation="2">
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudText Typo="Typo.h6">@Localization.GetString("RecentPurchaseNotes")</MudText>
                    </CardHeaderContent>
                    <CardHeaderActions>
                        <WisSplitButton PrimaryAction="@_purchaseNotesAction" />
                    </CardHeaderActions>
                </MudCardHeader>
                <MudCardContent Class="pa-0">
                    @if (_analytics.RecentPurchaseNotes.Any())
                    {
                        <MudTable Items="_analytics.RecentPurchaseNotes"
                                  Hover="true"
                                  Dense="false"
                                  Elevation="0"
                                  T="RecentPurchaseNoteDto"
                                  Class="wis-secondary-list"
                                  OnRowClick="@ViewPurchaseNote">
                            <HeaderContent>
                                <MudTh>@Localization.GetString("Number")</MudTh>
                                <MudTh>@Localization.GetString("Status")</MudTh>
                                <MudTh>@Localization.GetString("Date")</MudTh>
                                <MudTh Class="text-right">@Localization.GetString("Amount")</MudTh>
                            </HeaderContent>
                            <RowTemplate>
                                <MudTd DataLabel="@Localization.GetString("Number")">
                                    <MudText Typo="Typo.body2" Class="font-weight-medium">@context.NoteNumber</MudText>
                                </MudTd>
                                <MudTd DataLabel="@Localization.GetString("Status")">
                                    <MudChip T="string" Size="Size.Small" Color="@GetPurchaseNoteStatusColor(context.Status)" Variant="Variant.Outlined">@GetPurchaseNoteStatusText(context.Status)</MudChip>
                                </MudTd>
                                <MudTd DataLabel="@Localization.GetString("Date")">
                                    <MudText Typo="Typo.body2">@context.PurchaseDate.ToString("dd MMM yyyy")</MudText>
                                </MudTd>
                                <MudTd DataLabel="@Localization.GetString("Amount")" Class="text-right">
                                    <MudText Typo="Typo.body2" Class="font-weight-bold">@context.TotalAmount.ToString("C")</MudText>
                                </MudTd>
                            </RowTemplate>
                        </MudTable>
                    }
                    else
                    {
                        <div class="pa-6 text-center d-flex align-center">
                            <MudIcon Icon="@Icons.Material.Filled.Receipt"
                                     Size="Size.Large"
                                     Color="Color.Secondary"
                                     Class="mr-2" />
                            <MudText Typo="Typo.body1" Color="Color.Secondary">@Localization.GetString("NoPurchaseNotesFound")</MudText>
                        </div>
                    }
                </MudCardContent>
            </MudCard>
        </MudItem>
    </MudGrid>
}

@code {
    [Parameter] public Guid Id { get; set; }

    private IndividualDto? _individual;
    private IndividualAnalyticsDto _analytics = new();

    private WisDetailActionItem? _primaryAction;
    private List<WisDetailActionItem> _actions = [];
    private WisDetailActionItem? _purchaseNotesAction;

    protected override async Task OnInitializedAsync()
    {
        await base.OnInitializedAsync();
        await LoadIndividual();
    }

    protected override async void OnLanguageChanged()
    {
        BuildActions();
        await InvokeAsync(StateHasChanged);
    }

    private async Task LoadIndividual() =>
        await SafeLoadAsync(async () =>
        {
            _individual = await IndividualService.GetIndividualByIdAsync(Id, CancellationToken.None);
            if (_individual != null)
            {
                _analytics = await IndividualService.GetIndividualAnalyticsAsync(Id, CancellationToken.None);
                BuildActions();
            }
        }, "ErrorLoadingIndividual");

    private void BuildActions()
    {
        if (_individual is null) return;

        _primaryAction = _act.Primary(Icons.Material.Filled.Edit, Localization.GetString("Edit"), OpenEditDialog);

        _actions =
        [
            _individual.IsActive
                ? _act.Warning(Icons.Material.Filled.PowerSettingsNew, Localization.GetString("Deactivate"), ToggleActiveStatus)
                : _act.Success(Icons.Material.Filled.PowerSettingsNew,  Localization.GetString("Activate"),   ToggleActiveStatus),
        ];

        _purchaseNotesAction = _act.Secondary(Icons.Material.Filled.Receipt, Localization.GetString("PurchaseNotes"), () => Navigation.NavigateTo($"/purchase-notes?individualId={Id}"));
    }

    private async Task OpenEditDialog()
    {
        if (_individual is null) return;
        if (await WisDialog.ShowFormAsync<IndividualDialog, bool>(
                Localization.GetString("EditIndividual"),
                p => p.Add(x => x.Individual, _individual)) == true)
            await LoadIndividual();
    }

    private void ViewPurchaseNote(TableRowClickEventArgs<RecentPurchaseNoteDto> args)
    {
        Navigation.NavigateTo($"/purchase-notes/{args.Item!.Id}");
    }

    private async Task ToggleActiveStatus()
    {
        if (_individual is null) return;

        if (_individual.IsActive)
            await DeactivateIndividual();
        else
            await ActivateIndividual();
    }

    private async Task DeactivateIndividual()
    {
        string message = _analytics.UnpaidCount > 0
            ? string.Format(Localization.GetString("DeactivateIndividualWithOpenNotes"), _analytics.UnpaidCount)
            : Localization.GetString("DeactivateIndividualConfirm");

        await ConfirmAndExecuteAsync(
            Localization.GetString("DeactivateIndividual"), message,
            async () => { await IndividualService.SetActiveStatusAsync(Id, false); await LoadIndividual(); },
            "IndividualDeactivated", "ErrorDeactivatingIndividual",
            Localization.GetString("Deactivate"), Localization.GetString("Cancel"));
    }

    private async Task ActivateIndividual()
    {
        try
        {
            await IndividualService.SetActiveStatusAsync(Id, true);
            Snackbar.Add(Localization.GetString("IndividualActivated"), Severity.Success);
            await LoadIndividual();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error activating individual: {ex.Message}");
            Snackbar.Add(Localization.GetString("ErrorActivatingIndividual"), Severity.Error);
        }
    }

}
