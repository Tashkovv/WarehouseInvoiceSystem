@page "/individuals/{Id:guid}"
@implements IDisposable
@using WarehouseInvoiceSystem.Application.Interfaces
@using WarehouseInvoiceSystem.Application.DTOs.Individual
@using WarehouseInvoiceSystem.Domain.Enums
@inject IIndividualService IndividualService
@inject ILocalizationService Localization
@inject NavigationManager Navigation
@inject IDialogService DialogService
@inject ISnackbar Snackbar

<PageTitle>@Localization.GetString("IndividualDetails") - @Localization.GetString("InvoiceSystem")</PageTitle>

@if (_loading)
{
    <MudProgressLinear Color="Color.Primary" Indeterminate="true" />
}
else if (_individual == null)
{
    <MudAlert Severity="Severity.Error">@Localization.GetString("IndividualNotFound")</MudAlert>
}
else
{
    <div class="d-flex justify-space-between align-center mb-4">
        <div>
            <MudButton StartIcon="@Icons.Material.Filled.ArrowBack"
                       Variant="Variant.Text"
                       Href="/individuals">
                @Localization.GetString("BackToIndividuals")
            </MudButton>
        </div>
        <div>
            <MudButton StartIcon="@Icons.Material.Filled.Edit"
                       Color="Color.Primary"
                       Variant="Variant.Filled"
                       Class="mr-2"
                       Href="@($"/individuals/edit/{Id}")">
                @Localization.GetString("Edit")
            </MudButton>
            <MudButton StartIcon="@Icons.Material.Filled.Delete"
                       Color="Color.Error"
                       Variant="Variant.Outlined"
                       OnClick="DeleteIndividual">
                @Localization.GetString("Delete")
            </MudButton>
        </div>
    </div>

    <MudGrid>
        <!-- Individual Header - Single Card -->
        <MudItem xs="12">
            <MudCard Elevation="2">
                <MudCardContent Class="pa-6">
                    <MudGrid Spacing="4">
                        <!-- Left: Name + ID + Status + Contact -->
                        <MudItem xs="12" md="6">
                            <MudStack Spacing="2">
                                <div class="d-flex align-center gap-3">
                                    <MudText Typo="Typo.h4" Class="mb-0">@_individual.FullName</MudText>
                                    <MudChip T="string" Size="Size.Small" Color="@(_individual.IsActive? Color.Success: Color.Default)">
                                        @(_individual.IsActive? Localization.GetString("ActiveIndividual") : Localization.GetString("InactiveIndividual"))
                                    </MudChip>
                                </div>

                                <div class="d-flex align-center">
                                    <MudIcon Icon="@Icons.Material.Filled.Badge" Size="Size.Small" Class="mr-2" Color="Color.Secondary" />
                                    <MudText Typo="Typo.body2" Color="Color.Secondary">
                                        @Localization.GetString("IdentificationNumber"): <strong>@_individual.IdentificationNumber</strong>
                                    </MudText>
                                </div>

                                @if (!string.IsNullOrWhiteSpace(_individual.Phone) ||
                                                            !string.IsNullOrWhiteSpace(_individual.Email) ||
                                                            !string.IsNullOrWhiteSpace(_individual.Address))
                                {
                                    <MudDivider Class="my-2" />

                                    <MudStack Spacing="1">
                                        @if (!string.IsNullOrWhiteSpace(_individual.Phone))
                                        {
                                            <div class="d-flex align-center">
                                                <MudIcon Icon="@Icons.Material.Filled.Phone" Size="Size.Small" Class="mr-2" Color="Color.Secondary" />
                                                <MudText Typo="Typo.body2"><strong>@_individual.Phone</strong></MudText>
                                            </div>
                                        }

                                        @if (!string.IsNullOrWhiteSpace(_individual.Email))
                                        {
                                            <div class="d-flex align-center">
                                                <MudIcon Icon="@Icons.Material.Filled.Email" Size="Size.Small" Class="mr-2" Color="Color.Secondary" />
                                                <MudText Typo="Typo.body2"><strong>@_individual.Email</strong></MudText>
                                            </div>
                                        }

                                        @if (!string.IsNullOrWhiteSpace(_individual.Address))
                                        {
                                            <div class="d-flex align-center">
                                                <MudIcon Icon="@Icons.Material.Filled.LocationOn" Size="Size.Small" Class="mr-2" Color="Color.Secondary" />
                                                <MudText Typo="Typo.body2">@_individual.Address</MudText>
                                            </div>
                                        }
                                    </MudStack>
                                }
                            </MudStack>
                        </MudItem>

                        <!-- Divider (visible on medium+ screens) -->
                        <MudHidden Breakpoint="Breakpoint.SmAndDown">
                            <MudItem md="1" Class="d-flex align-center justify-center">
                                <MudDivider Vertical="true" />
                            </MudItem>
                        </MudHidden>

                        <!-- Right: Payment Summary + Purchase History -->
                        <MudItem xs="12" md="5">
                            <MudStack Spacing="3">
                                <!-- Payment Overview -->
                                <div>
                                    <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-2">@Localization.GetString("PaymentOverview")</MudText>

                                    <MudStack Row="true" Spacing="3" Class="mb-2">
                                        <div style="flex: 1;">
                                            <MudText Typo="Typo.caption" Color="Color.Secondary">@Localization.GetString("TotalPurchases")</MudText>
                                            <MudText Typo="Typo.h6" Color="Color.Info">
                                                @_analytics.TotalAmount.ToString("C")
                                            </MudText>
                                            <MudText Typo="Typo.caption" Color="Color.Secondary">
                                                @_analytics.TotalPurchaseNotes @Localization.GetString("PurchaseNotes")
                                            </MudText>
                                        </div>

                                        <div style="flex: 1;">
                                            <MudText Typo="Typo.caption" Color="Color.Secondary">@Localization.GetString("Paid")</MudText>
                                            <MudText Typo="Typo.h6" Color="Color.Success">
                                                @_analytics.PaidAmount.ToString("C")
                                            </MudText>
                                            <MudText Typo="Typo.caption" Color="Color.Secondary">
                                                @_analytics.PaidCount @Localization.GetString("PurchaseNotes")
                                            </MudText>
                                        </div>
                                    </MudStack>

                                    @if (_analytics.UnpaidCount > 0)
                                    {
                                        <MudAlert Severity="Severity.Warning" Dense="true" NoIcon="false" Class="pa-2">
                                            <MudText Typo="Typo.caption">@Localization.GetString("Unpaid")</MudText>
                                            <MudText Typo="Typo.h6">
                                                @_analytics.UnpaidAmount.ToString("C")
                                                <MudText Typo="Typo.caption" Inline="true" Class="ml-2">
                                                    (@_analytics.UnpaidCount @Localization.GetString("PurchaseNotes"))
                                                </MudText>
                                            </MudText>
                                        </MudAlert>
                                    }
                                    else
                                    {
                                        <MudAlert Severity="Severity.Success" Dense="true" NoIcon="false" Class="pa-2">
                                            <MudText Typo="Typo.body2">@Localization.GetString("AllPurchasesPaid")</MudText>
                                        </MudAlert>
                                    }
                                </div>

                                <MudDivider />

                                <!-- Purchase History -->
                                <div>
                                    <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-2">@Localization.GetString("PurchaseHistory")</MudText>

                                    <MudStack Spacing="2">
                                        <MudStack Row="true" Spacing="4">
                                            <div style="flex: 1;">
                                                <div class="d-flex align-center mb-1">
                                                    <MudIcon Icon="@Icons.Material.Filled.FirstPage" Size="Size.Small" Class="mr-1" Color="Color.Secondary" />
                                                    <MudText Typo="Typo.caption" Color="Color.Secondary">@Localization.GetString("FirstPurchase")</MudText>
                                                </div>
                                                <MudText Typo="Typo.body1" Class="font-weight-medium">
                                                    @(_analytics.FirstPurchaseDate?.ToString("dd MMM yyyy") ?? "-")
                                                </MudText>
                                            </div>

                                            <div style="flex: 1;">
                                                <div class="d-flex align-center mb-1">
                                                    <MudIcon Icon="@Icons.Material.Filled.Today" Size="Size.Small" Class="mr-1" Color="Color.Secondary" />
                                                    <MudText Typo="Typo.caption" Color="Color.Secondary">@Localization.GetString("LastPurchase")</MudText>
                                                </div>
                                                <MudText Typo="Typo.body1" Class="font-weight-medium">
                                                    @(_analytics.LastPurchaseDate?.ToString("dd MMM yyyy") ?? "-")
                                                </MudText>
                                            </div>
                                        </MudStack>

                                        @if (!string.IsNullOrEmpty(_analytics.MostPurchasedProduct))
                                        {
                                            <div>
                                                <div class="d-flex align-center mb-1">
                                                    <MudIcon Icon="@Icons.Material.Filled.Star" Size="Size.Small" Class="mr-1" Color="Color.Warning" />
                                                    <MudText Typo="Typo.caption" Color="Color.Secondary">@Localization.GetString("MostPurchasedProduct")</MudText>
                                                </div>
                                                <MudText Typo="Typo.body1" Class="font-weight-medium">
                                                    @_analytics.MostPurchasedProduct
                                                </MudText>
                                                <MudText Typo="Typo.caption" Color="Color.Secondary">
                                                    @_analytics.MostPurchasedProductQuantity.ToString("N2") @_analytics.MostPurchasedProductUnit
                                                </MudText>
                                            </div>
                                        }
                                    </MudStack>
                                </div>
                            </MudStack>
                        </MudItem>
                    </MudGrid>
                </MudCardContent>
            </MudCard>
        </MudItem>

        <!-- Recent Purchase Notes -->
        <MudItem xs="12">
            <MudCard Elevation="2">
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudText Typo="Typo.h6">@Localization.GetString("RecentPurchaseNotes")</MudText>
                    </CardHeaderContent>
                    <CardHeaderActions>
                        <MudButton Href="@($"/purchase-notes?individualId={Id}")"
                                   Color="Color.Primary"
                                   Variant="Variant.Text"
                                   Size="Size.Small"
                                   EndIcon="@Icons.Material.Filled.ArrowForward">
                            @Localization.GetString("ViewAllPurchaseNotes")
                        </MudButton>
                    </CardHeaderActions>
                </MudCardHeader>
                <MudCardContent Class="pa-0">
                    @if (_analytics.RecentPurchaseNotes.Any())
                    {
                        <MudTable Items="_analytics.RecentPurchaseNotes"
                                  Hover="true"
                                  Dense="true"
                                  Elevation="0"
                                  T="RecentPurchaseNoteDto"
                                  RowClass="table-row-clickable"
                                  OnRowClick="@((TableRowClickEventArgs<RecentPurchaseNoteDto> args) => ViewPurchaseNote(args))">
                            <HeaderContent>
                                <MudTh>@Localization.GetString("NoteNumber")</MudTh>
                                <MudTh>@Localization.GetString("Date")</MudTh>
                                <MudTh Style="text-align: right;">@Localization.GetString("Amount")</MudTh>
                                <MudTh>@Localization.GetString("Status")</MudTh>
                            </HeaderContent>
                            <RowTemplate>
                                <MudTd DataLabel="@Localization.GetString("NoteNumber")">
                                    <MudText Typo="Typo.body2" Class="font-weight-medium">@context.NoteNumber</MudText>
                                </MudTd>
                                <MudTd DataLabel="@Localization.GetString("Date")">
                                    @context.PurchaseDate.ToString("dd MMM yyyy")
                                </MudTd>
                                <MudTd DataLabel="@Localization.GetString("Amount")" Style="text-align: right;">
                                    <MudText Typo="Typo.body2" Class="font-weight-bold">
                                        @context.TotalAmount.ToString("C")
                                    </MudText>
                                </MudTd>
                                <MudTd DataLabel="@Localization.GetString("Status")">
                                    @if (context.Status == PurchaseNoteStatus.Paid.ToString())
                                    {
                                        <MudChip T="string" Size="Size.Small" Color="Color.Success">@Localization.GetString("Paid")</MudChip>
                                    }
                                    else if (context.Status == PurchaseNoteStatus.Completed.ToString())
                                    {
                                        <MudChip T="string" Size="Size.Small" Color="Color.Info">@Localization.GetString("Completed")</MudChip>
                                    }
                                    else
                                    {
                                        <MudChip T="string" Size="Size.Small" Color="Color.Default">@Localization.GetString("Draft")</MudChip>
                                    }
                                </MudTd>
                            </RowTemplate>
                        </MudTable>
                    }
                    else
                    {
                        <div class="pa-6 text-center">
                            <MudIcon Icon="@Icons.Material.Filled.Receipt"
                                     Size="Size.Large"
                                     Color="Color.Secondary"
                                     Class="mb-2" />
                            <MudText Color="Color.Secondary">@Localization.GetString("NoPurchaseNotesFound")</MudText>
                        </div>
                    }
                </MudCardContent>
            </MudCard>
        </MudItem>
    </MudGrid>

    <style>
        .gap-3 {
            gap: 12px;
        }
    </style>
}

@code {
    [Parameter] public Guid Id { get; set; }

    private bool _loading = true;
    private IndividualDto? _individual;
    private IndividualAnalyticsDto _analytics = new();

    protected override async Task OnInitializedAsync()
    {
        Localization.OnLanguageChanged += OnLanguageChanged;
        await LoadIndividual();
    }

    private async void OnLanguageChanged()
    {
        await InvokeAsync(StateHasChanged);
    }

    private async Task LoadIndividual()
    {
        _loading = true;

        try
        {
            _individual = await IndividualService.GetIndividualByIdAsync(Id);
            if (_individual != null)
            {
                _analytics = await IndividualService.GetIndividualAnalyticsAsync(Id);
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading individual: {ex.Message}");
            Snackbar.Add(Localization.GetString("ErrorLoadingIndividual"), Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    private void ViewPurchaseNote(TableRowClickEventArgs<RecentPurchaseNoteDto> args)
    {
        if (args.MouseEventArgs.Detail == 2)
        {
            Navigation.NavigateTo($"/purchase-notes/{args.Item!.Id}");
        }
    }

    private void EditIndividual()
    {
        Navigation.NavigateTo($"/individuals/edit/{Id}");
    }

    private async Task DeleteIndividual()
    {
        bool? result = await DialogService.ShowMessageBoxAsync(
            new MessageBoxOptions
            {
                Title = Localization.GetString("ConfirmDelete"),
                Message = Localization.GetString("DeleteIndividualConfirm"),
                YesText = Localization.GetString("Yes"),
                CancelText = Localization.GetString("No")
            });

        if (result == true)
        {
            try
            {
                bool deleted = await IndividualService.DeleteIndividualAsync(Id);
                if (deleted)
                {
                    Snackbar.Add(Localization.GetString("IndividualDeleted"), Severity.Success);
                    Navigation.NavigateTo("/individuals");
                }
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Error deleting individual: {ex.Message}");
                Snackbar.Add(Localization.GetString("ErrorDeletingIndividual"), Severity.Error);
            }
        }
    }

    public void Dispose()
    {
        Localization.OnLanguageChanged -= OnLanguageChanged;
    }
}