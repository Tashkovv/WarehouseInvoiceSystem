@page "/purchase-notes/create"
@attribute [Authorize]
@inherits PageBase
@using WarehouseInvoiceSystem.Application.DTOs.PurchaseNote
@using WarehouseInvoiceSystem.Application.DTOs.Individual
@using WarehouseInvoiceSystem.Application.DTOs.Product
@using WarehouseInvoiceSystem.Application.DTOs.Warehouse
@using WarehouseInvoiceSystem.Domain.Queries
@using WarehouseInvoiceSystem.Domain.Queries.Common
@inject IPurchaseNoteService PurchaseNoteService
@inject IIndividualService IndividualService
@inject IProductService ProductService
@inject IWarehouseService WarehouseService

<PageTitle>@Localization.GetString("CreatePurchaseNote") - @Localization.GetString("InvoiceSystem")</PageTitle>

<WisDetailHeader BackHref="/purchase-notes" BackLabel="@Localization.GetString("PurchaseNotes")" />

@if (_loading)
{
    <MudProgressLinear Color="Color.Primary" Indeterminate="true" />
}
else
{
    <MudCard Elevation="2" Class="mb-4">
        <MudCardHeader>
            <CardHeaderContent>
                <MudText Typo="Typo.h6">@Localization.GetString("PurchaseNoteInformation")</MudText>
            </CardHeaderContent>
        </MudCardHeader>
        <MudCardContent>
            <MudForm @ref="_form" @bind-IsValid="@_isValid">
                <MudGrid>
                    <!-- Individual Selection -->
                    <MudItem xs="12" md="4">
                        <MudAutocomplete T="IndividualDto"
                        Label="@Localization.GetString("Individual")"
                        @bind-Value="_selectedIndividual"
                        SearchFunc="@SearchIndividuals"
                        ToStringFunc="@(i => i?.FullName ?? "")"
                        Required="true"
                        RequiredError="@Localization.GetString("IndividualRequired")"
                        ResetValueOnEmptyText="true"
                        CoerceText="false"
                        Variant="Variant.Outlined"
                        Clearable="true">
                            <ItemTemplate Context="individual">
                                <MudText Typo="Typo.body2">
                                    <strong>@individual.FullName</strong>
                                </MudText>
                                <MudText Typo="Typo.caption" Color="Color.Secondary">
                                    @individual.IdentificationNumber
                                </MudText>
                            </ItemTemplate>
                        </MudAutocomplete>
                    </MudItem>

                    <!-- Warehouse Selection -->
                    <MudItem xs="12" md="4">
                        <MudAutocomplete T="WarehouseDto"
                        Label="@Localization.GetString("Warehouse")"
                        @bind-Value="_selectedWarehouse"
                        SearchFunc="@SearchWarehouses"
                        ToStringFunc="@(w => w?.Name ?? "")"
                        ResetValueOnEmptyText="true"
                        Variant="Variant.Outlined"
                        Required="true"
                        RequiredError="@Localization.GetString("WarehouseRequired")"
                        CoerceText="false"
                        Clearable="true">
                        </MudAutocomplete>
                    </MudItem>

                    <!-- Purchase Date -->
                    <MudItem xs="12" md="4">
                        <MudDatePicker @bind-Date="_purchaseDate"
                        Label="@Localization.GetString("PurchaseDate")"
                        Variant="Variant.Outlined"
                        Required="true"
                        RequiredError="@Localization.GetString("PurchaseDateRequired")" />
                    </MudItem>

                    <!-- Notes -->
                    <MudItem xs="12" md="10">
                        <MudTextField @bind-Value="_notes"
                        Label="@Localization.GetString("Notes")"
                        Variant="Variant.Outlined"
                        Lines="1"
                        MaxLength="1000" />
                    </MudItem>

                    <!-- Mark as Paid Checkbox -->
                    <MudItem xs="12" md="2" Class="d-flex align-center">
                        <MudSwitch @bind-Value="_markAsPaid"
                        Label="@Localization.GetString("MarkAsPaidQuestion")"
                        Color="Color.Success"
                        Class="mt-4" />
                    </MudItem>
                </MudGrid>

                <!-- Line Items -->
                <MudDivider Class="my-4" />
                <div class="d-flex justify-space-between align-center mb-2">
                    <MudText Typo="Typo.h6">@Localization.GetString("Products")</MudText>
                    <WisButton Action="@_addLineItemAction" />
                </div>

                <MudTable Items="_lineItems" Dense="true" Hover="true" Elevation="0" Class="mb-2" Style="table-layout: fixed; width: 100%" ContainerStyle="overflow: hidden">
                    <HeaderContent>
                        <MudTh>@Localization.GetString("Product")</MudTh>
                        <MudTh Style="width:13%" Class="text-right">@Localization.GetString("GrossQuantity")</MudTh>
                        <MudTh Style="width:10%" Class="text-right">@Localization.GetString("KaloPercentage")</MudTh>
                        <MudTh Style="width:13%" Class="text-right">@Localization.GetString("NetQuantity")</MudTh>
                        <MudTh Style="width:15%" Class="text-right">@Localization.GetString("UnitPrice")</MudTh>
                        <MudTh Style="width:15%" Class="text-right">@Localization.GetString("Amount")</MudTh>
                        <MudTh Style="width:48px"></MudTh>
                    </HeaderContent>
                    <RowTemplate Context="item">
                        <MudTd>
                            <MudAutocomplete T="ProductDto"
                            Value="item.SelectedProduct"
                            SearchFunc="@SearchProducts"
                            ToStringFunc="@(p => p != null ? $"{p.Code} - {p.Name}" : "")"
                            ValueChanged="@((ProductDto p) => OnProductSelected(item, p))"
                            ResetValueOnEmptyText="true"
                            CoerceText="false"
                            Variant="Variant.Text"
                            Clearable="true"
                            Placeholder="@Localization.GetString("SelectProduct")"
                            FullWidth="true">
                                <ItemTemplate Context="product">
                                    <MudText Typo="Typo.body2">
                                        <strong>@product.Code</strong> - @product.Name
                                    </MudText>
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">
                                        @product.Unit | @product.CostPrice.ToString("C")
                                    </MudText>
                                </ItemTemplate>
                            </MudAutocomplete>
                        </MudTd>
                        <MudTd Class="text-right">
                            <MudNumericField T="decimal"
                            @bind-Value="item.GrossQuantity"
                            @bind-Value:after="() => RecalculateNet(item)"
                            Variant="Variant.Text"
                            Format="N0"
                            Min="0m"
                            Class="text-right"
                            Adornment="Adornment.End"
                            AdornmentText="@(item.SelectedProduct?.Unit ?? "")" />
                        </MudTd>
                        <MudTd Class="text-right">
                            <MudNumericField T="decimal"
                            @bind-Value="item.KaloPercentage"
                            @bind-Value:after="() => RecalculateNet(item)"
                            Variant="Variant.Text"
                            Format="N2"
                            Min="0m"
                            Max="100m"
                            Class="text-right"
                            Adornment="Adornment.End"
                            AdornmentText="%" />
                        </MudTd>
                        <MudTd Class="text-right">
                            <MudText Typo="Typo.body2" Class="font-weight-medium tabular-numbers text-right">
                                @Math.Round(item.Quantity, 0, MidpointRounding.AwayFromZero).ToString("N0") @(item.SelectedProduct?.Unit ?? "")
                            </MudText>
                        </MudTd>
                        <MudTd Class="text-right">
                            <MudNumericField @bind-Value="item.UnitPrice"
                            @bind-Value:after="CalculateTotals"
                            Variant="Variant.Text"
                            Format="N2"
                            Min="0m"
                            Class="text-right"
                            Adornment="Adornment.End"
                            AdornmentText="@Localization.CurrencySymbol" />
                        </MudTd>
                        <MudTd Class="text-right">
                            <MudText Typo="Typo.body2" Class="font-weight-medium tabular-numbers text-right">
                                @(Math.Round(item.Quantity * item.UnitPrice, 0, MidpointRounding.AwayFromZero).ToString("C0"))
                            </MudText>
                        </MudTd>
                        <MudTd>
                            <MudIconButton Icon="@Icons.Material.Filled.Delete"
                            Color="Color.Error"
                            Variant="Variant.Outlined"
                            Size="Size.Small"
                            OnClick="@(() => RemoveLineItem(item))" />
                        </MudTd>
                    </RowTemplate>
                    <NoRecordsContent>
                        <MudText Typo="Typo.body2" Color="Color.Secondary" Class="pa-4">
                            @Localization.GetString("AddLineItems")
                        </MudText>
                    </NoRecordsContent>
                </MudTable>

                <!-- Totals -->
                <MudDivider Class="my-3" />
                <div class="d-flex justify-end gap-4 px-2 pb-1">
                    <div class="d-flex align-center gap-2">
                        <MudText Typo="Typo.body2" Color="Color.Secondary">@Localization.GetString("Total"):</MudText>
                        <MudText Typo="Typo.h6" Color="Color.Primary" Class="font-weight-bold tabular-numbers">@Math.Round(_total, 0, MidpointRounding.AwayFromZero).ToString("C0")</MudText>
                    </div>
                </div>
            </MudForm>
        </MudCardContent>
    </MudCard>
    <!-- Actions -->
    <MudItem xs="12">
        <div class="d-flex justify-space-between wis-page-actions">
            <WisButton Action="@_cancelAction" />
            <WisSplitButton PrimaryAction="@_saveAction" Actions="@_saveDropdownActions" />
        </div>
    </MudItem>
}
@code {
    [Parameter, SupplyParameterFromQuery(Name = "copyFrom")] public Guid? CopyFrom { get; set; }

    private MudForm _form = null!;
    private bool _isValid;
    private bool _saving;

    private WisDetailActionItem _cancelAction => new()
    {
        Label = Localization.GetString("Cancel"),
        Color = Color.Secondary,
        OnClick = EventCallback.Factory.Create(this, Cancel)
    };

    private WisDetailActionItem _saveAction => new()
    {
        Label = Localization.GetString("Save"),
        Color = Color.Primary,
        Disabled = !_isValid || _saving || !_lineItems.Any(),
        OnClick = EventCallback.Factory.Create(this, () => SaveNote(false))
    };

    private List<WisDetailActionItem> _saveDropdownActions => new()
    {
        new WisDetailActionItem
        {
            Icon = Icons.Material.Filled.AddCircleOutline,
            Label = Localization.GetString("SaveAndNew"),
            Color = Color.Success,
            Disabled = !_isValid || _saving || !_lineItems.Any(),
            OnClick = EventCallback.Factory.Create(this, SaveAndNew)
        }
    };

    private WisDetailActionItem _addLineItemAction => new()
    {
        Icon = Icons.Material.Filled.Add,
        Label = Localization.GetString("AddProduct"),
        Color = Color.Info,
        OnClick = EventCallback.Factory.Create(this, AddLineItem)
    };

    private IndividualDto? _selectedIndividual;
    private WarehouseDto? _selectedWarehouse;
    private DateTime? _purchaseDate = DateTime.Today;
    private bool _markAsPaid = false;
    private string? _notes;
    private decimal _total = 0;

    private List<LineItemModel> _lineItems = [];

    protected override async Task OnInitializedAsync()
    {
        await base.OnInitializedAsync();
        if (CopyFrom.HasValue)
            await PrefillFromPurchaseNote(CopyFrom.Value);
        else
        {
            await LoadDefaultWarehouse();
            AddLineItem();
        }
    }

    private async Task LoadDefaultWarehouse()
    {
        _loading = true;
        try
        {
            _selectedWarehouse = await WarehouseService.GetDefaultWarehouseAsync(_cts.Token);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading default warehouse: {ex.Message}");
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task PrefillFromPurchaseNote(Guid sourceId)
    {
        _loading = true;
        try
        {
            PurchaseNoteDto? source = await PurchaseNoteService.GetPurchaseNoteByIdAsync(sourceId, _cts.Token);
            if (source == null)
            {
                await LoadDefaultWarehouse();
                AddLineItem();
                return;
            }

            _selectedIndividual = await IndividualService.GetIndividualByIdAsync(source.IndividualId, _cts.Token);

            _selectedWarehouse = await WarehouseService.GetWarehouseByIdAsync(source.WarehouseId, _cts.Token);

            _purchaseDate = DateTime.Today;
            _notes = source.Notes;

            foreach (PurchaseNoteLineDto li in source.LineItems)
            {
                ProductDto? product = await ProductService.GetProductByIdAsync(li.ProductId, _cts.Token);
                if (product != null)
                {
                    _lineItems.Add(new LineItemModel
                    {
                        SelectedProduct = product,
                        Description = li.Description,
                        GrossQuantity = li.GrossQuantity,
                        KaloPercentage = li.KaloPercentage,
                        Quantity = li.Quantity,
                        UnitPrice = li.UnitPrice
                    });
                }
            }

            CalculateTotals();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error prefilling from purchase note: {ex.Message}");
            Snackbar.Add(Localization.GetString("ErrorLoadingPurchaseNote"), Severity.Error);
            AddLineItem();
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task<IEnumerable<IndividualDto>> SearchIndividuals(string value, CancellationToken ct)
    {
        GetIndividualsQuery query = new() { PageSize = 10, IsActive = true };
        if (!string.IsNullOrWhiteSpace(value)) query.Search = value;
        PagedResult<IndividualDto> result = await IndividualService.GetPagedAsync(query, ct);
        return result.Items;
    }

    private async Task<IEnumerable<ProductDto>> SearchProducts(string value, CancellationToken ct)
    {
        GetProductsQuery query = new() { PageSize = 10, IsActive = true };
        if (!string.IsNullOrWhiteSpace(value)) query.Search = value;
        PagedResult<ProductDto> result = await ProductService.GetPagedAsync(query, ct);
        return result.Items;
    }

    private async Task<IEnumerable<WarehouseDto>> SearchWarehouses(string value, CancellationToken ct)
    {
        GetWarehousesQuery query = new() { PageSize = 10, IsActive = true };
        if (!string.IsNullOrWhiteSpace(value)) query.Search = value;
        PagedResult<WarehouseDto> result = await WarehouseService.GetPagedAsync(query, ct);
        return result.Items;
    }

    private void OnProductSelected(LineItemModel item, ProductDto? product)
    {
        if (product != null)
        {
            item.SelectedProduct = product;
            item.Description = product.Name;
            item.UnitPrice = product.CostPrice;
            CalculateTotals();
        }
    }

    private void AddLineItem()
    {
        _lineItems.Add(new LineItemModel());
    }

    private void RemoveLineItem(LineItemModel item)
    {
        _lineItems.Remove(item);
        CalculateTotals();
    }

    private void RecalculateNet(LineItemModel item)
    {
        item.Quantity = Math.Round(item.GrossQuantity - (item.GrossQuantity * item.KaloPercentage / 100m), 2);
        CalculateTotals();
    }

    private void CalculateTotals()
    {
        _total = _lineItems.Sum(li => li.Quantity * li.UnitPrice);
        StateHasChanged();
    }

    private async Task SaveNote(bool saveAndNew = false)
    {
        await _form.ValidateAsync();
        if (!_isValid) return;

        _saving = true;

        try
        {
            CreatePurchaseNoteDto dto = new()
            {
                IndividualId = _selectedIndividual!.Id,
                WarehouseId = _selectedWarehouse!.Id,
                PurchaseDate = _purchaseDate?.Date ?? DateTime.Today,
                MarkAsPaid = _markAsPaid,
                Notes = _notes,
                LineItems = _lineItems
                    .Where(li => li.SelectedProduct != null)
                    .Select(li => new CreatePurchaseNoteLineDto
                    {
                        ProductId = li.SelectedProduct!.Id,
                        Description = li.Description,
                        GrossQuantity = li.GrossQuantity,
                        KaloPercentage = li.KaloPercentage,
                        Quantity = li.Quantity,
                        UnitPrice = li.UnitPrice
                    }).ToList()
            };

            await PurchaseNoteService.CreatePurchaseNoteAsync(dto);
            Snackbar.Add(Localization.GetString("PurchaseNoteCreated"), Severity.Success);

            if (saveAndNew)
            {
                _selectedIndividual = null;
                _purchaseDate = DateTime.Today;
                _notes = null;
                _lineItems.Clear();
                _total = 0;
                _selectedWarehouse = await WarehouseService.GetDefaultWarehouseAsync(_cts.Token);
                AddLineItem();
            }
            else
            {
                Navigation.NavigateTo("/purchase-notes");
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error creating purchase note: {ex.Message}");
            Snackbar.Add(Localization.GetString("ErrorCreatingPurchaseNote"), Severity.Error);
        }
        finally
        {
            _saving = false;
        }
    }

    private async Task SaveAndNew()
    {
        await SaveNote(saveAndNew: true);
    }

    private void Cancel()
    {
        Navigation.NavigateTo("/purchase-notes");
    }

    private class LineItemModel
    {
        public ProductDto? SelectedProduct { get; set; }
        public string Description { get; set; } = string.Empty;
        public decimal GrossQuantity { get; set; }
        public decimal KaloPercentage { get; set; }
        public decimal Quantity { get; set; }
        public decimal UnitPrice { get; set; }
    }
}
