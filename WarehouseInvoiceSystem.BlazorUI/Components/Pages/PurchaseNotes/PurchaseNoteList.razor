@page "/purchase-notes"
@implements IDisposable
@using WarehouseInvoiceSystem.Application.Interfaces
@using WarehouseInvoiceSystem.Application.DTOs.PurchaseNote
@using WarehouseInvoiceSystem.Domain.Enums
@inject IPurchaseNoteService PurchaseNoteService
@inject ILocalizationService Localization
@inject NavigationManager Navigation
@inject IDialogService DialogService
@inject ISnackbar Snackbar

<PageTitle>@Localization.GetString("PurchaseNotes") - @Localization.GetString("InvoiceSystem")</PageTitle>

<MudText Typo="Typo.h4" Class="mb-6">@Localization.GetString("PurchaseNotes")</MudText>

<MudCard Elevation="2" Class="mb-4">
    <MudCardContent>
        <MudGrid>
            <MudItem xs="12" sm="6" md="3">
                <MudButton StartIcon="@Icons.Material.Filled.Add"
                           Color="Color.Primary"
                           Variant="Variant.Filled"
                           FullWidth="true"
                           Href="/purchase-notes/create">
                    @Localization.GetString("CreatePurchaseNote")
                </MudButton>
            </MudItem>
            <MudItem xs="12" sm="6" md="9">
                <MudTextField T="string"
                              Value="_searchString"
                              ValueChanged="OnSearch"
                              Placeholder="@Localization.GetString("Search")"
                              Adornment="Adornment.Start"
                              AdornmentIcon="@Icons.Material.Filled.Search"
                              IconSize="Size.Medium"
                              Immediate="true"
                              DebounceInterval="300"
                              Class="mt-0" />
            </MudItem>
        </MudGrid>

        <MudTabs Elevation="0"
                 Rounded="true"
                 Class="mt-4"
                 ActivePanelIndex="_activeTabIndex"
                 ActivePanelIndexChanged="OnTabChanged">
            <MudTabPanel Text="@Localization.GetString("AllPurchaseNotes")" Icon="@Icons.Material.Filled.List" />
            <MudTabPanel Text="@Localization.GetString("Draft")" Icon="@Icons.Material.Filled.Edit" />
            <MudTabPanel Text="@Localization.GetString("Completed")" Icon="@Icons.Material.Filled.CheckCircle" />
            <MudTabPanel Text="@Localization.GetString("Paid")" Icon="@Icons.Material.Filled.Payment" />
        </MudTabs>
    </MudCardContent>
</MudCard>

<MudCard Elevation="2" Class="mb-4">
    <MudCardContent Class="pa-0">
        @if (_loading)
        {
            <div class="pa-6">
                <MudProgressLinear Color="Color.Primary" Indeterminate="true" />
            </div>
        }
        else if (_filteredNotes == null || !_filteredNotes.Any())
        {
            <div class="pa-6 text-center">
                <MudText Color="Color.Secondary">@Localization.GetString("NoPurchaseNotesFound")</MudText>
            </div>
        }
        else
        {
            <MudTable Items="_paginatedNotes"
                      Hover="true"
                      Breakpoint="Breakpoint.Sm"
                      Dense="false"
                      FixedHeader="true"
                      RowClass="table-row-clickable"
                      OnRowClick="@((TableRowClickEventArgs<PurchaseNoteDto> args) => OnRowClick(args))"
                      Height="600px"
                      Sort="@((SortDefinition<PurchaseNoteDto> sortDefinition) => HandleSort(sortDefinition))">
                <HeaderContent>
                    <MudTh><MudTableSortLabel SortBy="new Func<PurchaseNoteDto, object>(x => x.NoteNumber)">@Localization.GetString("NoteNumber")</MudTableSortLabel></MudTh>
                    <MudTh><MudTableSortLabel SortBy="new Func<PurchaseNoteDto, object>(x => x.IndividualFullName)">@Localization.GetString("Individual")</MudTableSortLabel></MudTh>
                    <MudTh><MudTableSortLabel SortBy="new Func<PurchaseNoteDto, object>(x => x.PurchaseDate)">@Localization.GetString("PurchaseDate")</MudTableSortLabel></MudTh>
                    <MudTh><MudTableSortLabel SortBy="new Func<PurchaseNoteDto, object>(x => x.TotalAmount)">@Localization.GetString("Total")</MudTableSortLabel></MudTh>
                    <MudTh>@Localization.GetString("Status")</MudTh>
                    <MudTh>@Localization.GetString("Actions")</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="@Localization.GetString("NoteNumber")">
                        <MudText Typo="Typo.body2" Class="font-weight-medium">
                            @context.NoteNumber
                        </MudText>
                    </MudTd>
                    <MudTd DataLabel="@Localization.GetString("Individual")">
                        <MudText>@context.IndividualFullName</MudText>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">
                            @context.IndividualIdentificationNumber
                        </MudText>
                    </MudTd>
                    <MudTd DataLabel="@Localization.GetString("PurchaseDate")">
                        @context.PurchaseDate.ToString("dd MMM yyyy")
                    </MudTd>
                    <MudTd DataLabel="@Localization.GetString("Total")">
                        <MudText Typo="Typo.body2" Class="font-weight-medium">
                            @context.TotalAmount.ToString("C")
                        </MudText>
                    </MudTd>
                    <MudTd DataLabel="@Localization.GetString("Status")">
                        <MudChip T="string"
                                 Size="Size.Small"
                                 Color="GetStatusColor(context.Status)">
                            @GetStatusText(context.Status)
                        </MudChip>
                    </MudTd>
                    <MudTd DataLabel="@Localization.GetString("Actions")">
                        <MudMenu Icon="@Icons.Material.Filled.MoreVert" Size="Size.Small">
                            <MudMenuItem Icon="@Icons.Material.Filled.Edit"
                                         OnClick="@(() => EditNote(context.Id))">
                                @Localization.GetString("Edit")
                            </MudMenuItem>
                            @if (context.Status != PurchaseNoteStatus.Paid)
                            {
                                <MudMenuItem Icon="@Icons.Material.Filled.Payment"
                                             OnClick="@(() => MarkAsPaid(context.Id))">
                                    @Localization.GetString("MarkAsPaid")
                                </MudMenuItem>
                            }
                            <MudDivider />
                            <MudMenuItem Icon="@Icons.Material.Filled.Delete"
                                         IconColor="Color.Error"
                                         OnClick="@(() => DeleteNote(context.Id))">
                                @Localization.GetString("Delete")
                            </MudMenuItem>
                        </MudMenu>
                    </MudTd>
                </RowTemplate>
            </MudTable>

            <!-- Pagination Controls -->
            <MudDivider />
            <MudCardContent Class="pa-4">
                <MudGrid>
                    <MudItem xs="12" sm="6">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                            <MudButton Variant="Variant.Outlined"
                                       Size="Size.Small"
                                       OnClick="PreviousPage"
                                       Disabled="@(_currentPage == 1)">
                                @Localization.GetString("Previous")
                            </MudButton>

                            <MudText Typo="Typo.body2">
                                @Localization.GetString("Page") @_currentPage @Localization.GetString("Of") @_totalPages
                            </MudText>

                            <MudButton Variant="Variant.Outlined"
                                       Size="Size.Small"
                                       OnClick="NextPage"
                                       Disabled="@(_currentPage == _totalPages)">
                                @Localization.GetString("Next")
                            </MudButton>
                        </MudStack>
                    </MudItem>

                    <MudItem xs="12" sm="6" Class="d-flex justify-end align-center">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1" Class="ml-auto">
                            <MudText Typo="Typo.body2">
                                @Localization.GetString("ItemsPerPage")
                            </MudText>

                            <MudSelect T="int"
                                       Value="_itemsPerPage"
                                       Dense="true"
                                       Variant="Variant.Outlined"
                                       Style="width: 100px;"
                                       ValueChanged="@((int val) => OnItemsPerPageChanged(val))">
                                <MudSelectItem Value="10">10</MudSelectItem>
                                <MudSelectItem Value="25">25</MudSelectItem>
                                <MudSelectItem Value="50">50</MudSelectItem>
                                <MudSelectItem Value="100">100</MudSelectItem>
                            </MudSelect>

                            <MudText Typo="Typo.body2" Color="Color.Secondary">
                                (@_totalNotes @Localization.GetString("Total"))
                            </MudText>
                        </MudStack>
                    </MudItem>
                </MudGrid>
            </MudCardContent>
        }
    </MudCardContent>
</MudCard>

@code {
    private bool _loading = true;
    private List<PurchaseNoteDto> _allNotes = [];
    private List<PurchaseNoteDto> _filteredNotes = [];
    private List<PurchaseNoteDto> _paginatedNotes = [];
    private string _searchString = "";
    private int _activeTabIndex = 0;

    private int _currentPage = 1;
    private int _itemsPerPage = 25;
    private int _totalNotes = 0;
    private int _totalPages = 1;

    private string _sortBy = "PurchaseDate";
    private bool _sortAscending = false;

    protected override async Task OnInitializedAsync()
    {
        Localization.OnLanguageChanged += OnLanguageChanged;
        await LoadNotes();
    }

    private async void OnLanguageChanged()
    {
        await InvokeAsync(StateHasChanged);
    }

    private async Task LoadNotes()
    {
        _loading = true;

        try
        {
            // Use status-scoped call when a specific tab is selected
            IEnumerable<PurchaseNoteDto> notes = _activeTabIndex switch
            {
                1 => await PurchaseNoteService.GetPurchaseNotesByStatusAsync(PurchaseNoteStatus.Draft),
                2 => await PurchaseNoteService.GetPurchaseNotesByStatusAsync(PurchaseNoteStatus.Completed),
                3 => await PurchaseNoteService.GetPurchaseNotesByStatusAsync(PurchaseNoteStatus.Paid),
                _ => await PurchaseNoteService.GetAllPurchaseNotesAsync()
            };

            _allNotes = notes.ToList();
            ApplyFilters();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading purchase notes: {ex.Message}");
            Snackbar.Add(Localization.GetString("ErrorLoadingPurchaseNotes"), Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    private void ApplyFilters()
    {
        IEnumerable<PurchaseNoteDto> filtered = _allNotes;

        filtered = _activeTabIndex switch
        {
            1 => filtered.Where(n => n.Status == PurchaseNoteStatus.Draft),
            2 => filtered.Where(n => n.Status == PurchaseNoteStatus.Completed),
            3 => filtered.Where(n => n.Status == PurchaseNoteStatus.Paid),
            _ => filtered
        };

        if (!string.IsNullOrWhiteSpace(_searchString))
        {
            string search = _searchString.ToLower();
            filtered = filtered.Where(n =>
                n.NoteNumber.ToLower().Contains(search) ||
                n.IndividualFullName.ToLower().Contains(search) ||
                n.IndividualIdentificationNumber.Contains(search));
        }

        filtered = _sortAscending
            ? filtered.OrderBy(GetSortProperty)
            : filtered.OrderByDescending(GetSortProperty);

        _filteredNotes = filtered.ToList();
        _totalNotes = _filteredNotes.Count;

        UpdatePagination();
    }

    private void UpdatePagination()
    {
        _totalPages = (int)Math.Ceiling((double)_totalNotes / _itemsPerPage);

        if (_currentPage > _totalPages && _totalPages > 0)
        {
            _currentPage = _totalPages;
        }

        int skipCount = (_currentPage - 1) * _itemsPerPage;
        _paginatedNotes = _filteredNotes
            .Skip(skipCount)
            .Take(_itemsPerPage)
            .ToList();
    }

    private void ResetPaginationAndApplyFilters()
    {
        _currentPage = 1;
        ApplyFilters();
    }

    private object GetSortProperty(PurchaseNoteDto note) => _sortBy switch
    {
        "NoteNumber" => note.NoteNumber,
        "IndividualFullName" => note.IndividualFullName,
        "PurchaseDate" => note.PurchaseDate,
        "TotalAmount" => note.TotalAmount,
        _ => note.CreatedAt
    };

    private void HandleSort(SortDefinition<PurchaseNoteDto> sortDefinition)
    {
        if (sortDefinition == null || string.IsNullOrEmpty(sortDefinition.SortBy))
            return;

        _sortBy = sortDefinition.SortBy;
        _sortAscending = !sortDefinition.Descending;
        ApplyFilters();
    }

    private async Task OnSearch(string text)
    {
        _searchString = text;
        ResetPaginationAndApplyFilters();
        await InvokeAsync(StateHasChanged);
    }

    private async Task OnTabChanged(int index)
    {
        _activeTabIndex = index;
        ResetPaginationAndApplyFilters();
        await InvokeAsync(StateHasChanged);
    }

    private Color GetStatusColor(PurchaseNoteStatus status)
    {
        return status switch
        {
            PurchaseNoteStatus.Draft => Color.Default,
            PurchaseNoteStatus.Completed => Color.Info,
            PurchaseNoteStatus.Paid => Color.Success,
            _ => Color.Default
        };
    }

    private string GetStatusText(PurchaseNoteStatus status)
    {
        return status switch
        {
            PurchaseNoteStatus.Draft => Localization.GetString("Draft"),
            PurchaseNoteStatus.Completed => Localization.GetString("Completed"),
            PurchaseNoteStatus.Paid => Localization.GetString("Paid"),
            _ => status.ToString()
        };
    }

    private void ViewNote(Guid id)
    {
        Navigation.NavigateTo($"/purchase-notes/{id}");
    }

    private void EditNote(Guid id)
    {
        Navigation.NavigateTo($"/purchase-notes/edit/{id}");
    }

    private async Task MarkAsPaid(Guid id)
    {
        try
        {
            PurchaseNoteDto updated = await PurchaseNoteService.MarkAsPaidAsync(id);
            Snackbar.Add(Localization.GetString("PurchaseNoteMarkedPaid"), Severity.Success);

            // Update local state instead of full reload
            int index = _allNotes.FindIndex(n => n.Id == id);
            if (index >= 0)
                _allNotes[index] = updated;

            ApplyFilters();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error marking as paid: {ex.Message}");
            Snackbar.Add(Localization.GetString("ErrorUpdatingPurchaseNote"), Severity.Error);
        }
    }

    private async Task DeleteNote(Guid id)
    {
        bool? result = await DialogService.ShowMessageBox(
            Localization.GetString("ConfirmDelete"),
            Localization.GetString("DeletePurchaseNoteConfirm"),
            yesText: Localization.GetString("Yes"),
            cancelText: Localization.GetString("No"));

        if (result == true)
        {
            try
            {
                bool deleted = await PurchaseNoteService.DeletePurchaseNoteAsync(id);
                if (deleted)
                {
                    Snackbar.Add(Localization.GetString("PurchaseNoteDeleted"), Severity.Success);

                    // Remove from local list instead of full reload
                    _allNotes.RemoveAll(n => n.Id == id);
                    ApplyFilters();
                }
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Error deleting purchase note: {ex.Message}");
                Snackbar.Add(Localization.GetString("ErrorDeletingPurchaseNote"), Severity.Error);
            }
        }
    }

    private void PreviousPage()
    {
        if (_currentPage > 1)
        {
            _currentPage--;
            UpdatePagination();
        }
    }

    private void NextPage()
    {
        if (_currentPage < _totalPages)
        {
            _currentPage++;
            UpdatePagination();
        }
    }

    private void OnRowClick(TableRowClickEventArgs<PurchaseNoteDto> args)
    {
        if (args.MouseEventArgs.Detail == 2)
        {
            ViewNote(args.Item!.Id);
        }
    }

    private void OnItemsPerPageChanged(int newItemsPerPage)
    {
        _itemsPerPage = newItemsPerPage;
        _currentPage = 1;
        UpdatePagination();
    }

    public void Dispose()
    {
        Localization.OnLanguageChanged -= OnLanguageChanged;
    }
}