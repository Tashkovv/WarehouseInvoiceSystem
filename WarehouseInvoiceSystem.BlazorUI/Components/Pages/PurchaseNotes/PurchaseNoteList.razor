@page "/purchase-notes"
@implements IDisposable
@using WarehouseInvoiceSystem.Application.DTOs.PurchaseNote
@using WarehouseInvoiceSystem.Application.DTOs.Individual
@using WarehouseInvoiceSystem.Domain.Enums
@using WarehouseInvoiceSystem.Domain.Queries
@using WarehouseInvoiceSystem.Domain.Queries.Common
@inject IPurchaseNoteService PurchaseNoteService
@inject IIndividualService IndividualService
@inject ILocalizationService Localization
@inject NavigationManager Navigation
@inject WisDialogService WisDialog
@inject ISnackbar Snackbar

<PageTitle>@Localization.GetString("PurchaseNotes") - @Localization.GetString("InvoiceSystem")</PageTitle>

<div class="wis-page-header">
    <MudText Typo="Typo.h3" Class="wis-page-title">
        @Localization.GetString("PurchaseNotes")
    </MudText>
</div>

<WisGridToolbar CreateAction="@(() => Navigation.NavigateTo("/purchase-notes/create"))"
                CreateLabel="@Localization.GetString("PurchaseNote")"
                SearchValue="@_searchString"
                SearchValueChanged="OnSearch"
                HasAnyActiveFilter="@(_filterStatus.HasValue || _activeAdvancedFilterCount > 0)"
                OnClearAll="ClearAllFilters"
                ActiveAdvancedFilterCount="@_activeAdvancedFilterCount">
    <Filters>
        <FilterPopoverList TValue="PurchaseNoteStatus?"
                           Label="@Localization.GetString("Status")"
                           Items="_statusFilterItems"
                           Mode="FilterSelectionMode.Single"
                           SelectedValue="_filterStatus"
                           SelectedValueChanged="OnStatusFilterChanged" />
    </Filters>
    <AdvancedFilters>
        <div class="d-flex align-center flex-wrap gap-3">

            <WisAutocompleteFilter TValue="Guid"
                                   Label="@Localization.GetString("Individual")"
                                   AllLabel="@Localization.GetString("AllIndividuals")"
                                   Icon="@Icons.Material.Filled.Person"
                                   LoadItems="LoadIndividualItems"
                                   SelectedValue="@(_filterIndividualId ?? default)"
                                   SelectedValueChanged="OnIndividualFilterChanged"
                                   InitialLabel="@_filterIndividualInitialLabel"
                                   MinWidth="200px" />

            <WisDateRangeFilter @ref="_dateRangeFilter"
                                Label="@Localization.GetString("PurchaseDate")"
                                DateRange="_filterDateRange"
                                DateRangeChanged="OnDateRangeChanged"
                                OnChanged="ReloadGrid"
                                DatePreset="_filterDatePreset"
                                DatePresetChanged="OnDatePresetChanged"
                                MaxDate="DateTime.Today" />

            <WisAmountRangeFilter @ref="_amountRangeFilter"
                                  Label="@Localization.GetString("AmountRange")"
                                  AmountMin="_filterAmountMin"
                                  AmountMinChanged="OnAmountMinChanged"
                                  AmountMax="_filterAmountMax"
                                  AmountMaxChanged="OnAmountMaxChanged"
                                  AmountPreset="@_filterAmountPreset"
                                  AmountPresetChanged="OnAmountPresetChanged"
                                  OnChanged="ReloadGrid" />

        </div>
    </AdvancedFilters>
</WisGridToolbar>

<MudCard Elevation="2" Class="mb-4">
    <MudCardContent Class="pa-0">
        <MudDataGrid T="PurchaseNoteDto"
                     @ref="_grid"
                     ServerData="LoadServerData"
                     RowClick="OnRowClick"
                     RowClassFunc="GetRowClass"
                     ReadOnly="true"
                     Hover="true"
                     FixedHeader="true"
                     Height="100%"
                     Filterable="false"
                     ShowColumnOptions="false"
                     ColumnResizeMode="ResizeMode.Column"
                     SortMode="SortMode.Single"
                     Class="wis-data-grid">
            <Columns>

                <PropertyColumn Property="x => x.NoteNumber"
                                Title="@Localization.GetString("Number")"
                                Sortable="true"
                                IsEditable="false"
                                CellClass="wis-cell-mono" />

                <PropertyColumn Property="x => x.IndividualFullName"
                                Title="@Localization.GetString("Individual")"
                                Sortable="true"
                                IsEditable="false">
                    <CellTemplate>
                        <MudText Typo="Typo.body2" Class="wis-cell-primary">
                            @context.Item.IndividualFullName
                        </MudText>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">
                            @context.Item.IndividualIdentificationNumber
                        </MudText>
                    </CellTemplate>
                </PropertyColumn>

                <PropertyColumn Property="x => x.PurchaseDate"
                                Title="@Localization.GetString("PurchaseDate")"
                                Sortable="true"
                                IsEditable="false">
                    <CellTemplate>
                        @context.Item.PurchaseDate.ToString("dd MMM yyyy")
                    </CellTemplate>
                </PropertyColumn>

                <PropertyColumn Property="x => x.WarehouseName"
                                Title="@Localization.GetString("Warehouse")"
                                Sortable="false"
                                IsEditable="false">
                    <CellTemplate>
                        @(context.Item.WarehouseName ?? "—")
                    </CellTemplate>
                </PropertyColumn>

                <PropertyColumn Property="x => x.TotalAmount"
                                Title="@Localization.GetString("Total")"
                                Sortable="true"
                                IsEditable="false">
                    <CellTemplate>
                        <MudText Typo="Typo.body2" Class="wis-cell-amount">
                            @context.Item.TotalAmount.ToString("C")
                        </MudText>
                    </CellTemplate>
                </PropertyColumn>

                <PropertyColumn Property="x => x.Status"
                                Title="@Localization.GetString("Status")"
                                Sortable="true"
                                IsEditable="false">
                    <CellTemplate>
                        <MudChip T="string"
                                 Size="Size.Small"
                                 Color="@GetStatusColor(context.Item.Status)">
                            @GetStatusText(context.Item.Status)
                        </MudChip>
                    </CellTemplate>
                </PropertyColumn>

                <TemplateColumn Sortable="false"
                                Filterable="false"
                                IsEditable="false"
                                HeaderClass="wis-col-actions-2"
                                CellClass="wis-col-actions-2">
                    <CellTemplate>
                        <MudStack Row="true" Spacing="0">
                            <MudIconButton Icon="@Icons.Material.Filled.Edit"
                                           Size="Size.Small"
                                           Color="Color.Primary"
                                           Title="@Localization.GetString("Edit")"
                                           Disabled="@(context.Item.Status == PurchaseNoteStatus.Paid || context.Item.Status == PurchaseNoteStatus.Cancelled)"
                                           OnClick="@(() => Navigation.NavigateTo($"/purchase-notes/edit/{context.Item.Id}"))" />
                            @if (context.Item.Status == PurchaseNoteStatus.Draft)
                            {
                                <MudIconButton Icon="@Icons.Material.Filled.MoveToInbox"
                                               Size="Size.Small"
                                               Color="Color.Warning"
                                               Title="@Localization.GetString("ReceiveGoods")"
                                               OnClick="@(() => ReceiveGoods(context.Item))" />
                            }
                            else if (context.Item.Status == PurchaseNoteStatus.Pending)
                            {
                                <MudIconButton Icon="@Icons.Material.Filled.Payment"
                                               Size="Size.Small"
                                               Color="Color.Success"
                                               Title="@Localization.GetString("MarkAsPaid")"
                                               OnClick="@(() => MarkAsPaid(context.Item))" />
                            }
                        </MudStack>
                    </CellTemplate>
                </TemplateColumn>

            </Columns>

            <NoRecordsContent>
                <WisNoRecordsContent Icon="@Icons.Material.Filled.Receipt"
                                     Message="@Localization.GetString("NoPurchaseNotesFound")" />
            </NoRecordsContent>

            <LoadingContent>
                <WisLoadingContent />
            </LoadingContent>

            <PagerContent>
                <WisPagerContent T="PurchaseNoteDto" />
            </PagerContent>

        </MudDataGrid>
    </MudCardContent>
</MudCard>

@code {
    private readonly CancellationTokenSource _cts = new();
    [Parameter]
    [SupplyParameterFromQuery(Name = "individualId")]
    public Guid? IndividualIdParam { get; set; }

    private MudDataGrid<PurchaseNoteDto> _grid = null!;
    private string _searchString = string.Empty;

    // Quick filter
    private PurchaseNoteStatus? _filterStatus = null;

    // Advanced filters
    private Guid? _filterIndividualId = null;
    private string? _filterIndividualInitialLabel = null;
    private DateRange _filterDateRange = new(null, null);
    private int? _filterDatePreset = null;
    private WisDateRangeFilter? _dateRangeFilter;
    private decimal? _filterAmountMin = null;
    private decimal? _filterAmountMax = null;
    private string? _filterAmountPreset = null;
    private WisAmountRangeFilter? _amountRangeFilter;

    private int _activeAdvancedFilterCount =>
        (_filterIndividualId.HasValue ? 1 : 0) +
        (_filterDateRange.Start != null || _filterDateRange.End != null ? 1 : 0) +
        (_filterAmountMin.HasValue || _filterAmountMax.HasValue ? 1 : 0);

    private List<FilterPopoverItem<PurchaseNoteStatus?>> _statusFilterItems = [];

    protected override async Task OnInitializedAsync()
    {
        Localization.OnLanguageChanged += OnLanguageChanged;
        BuildFilterItems();

        // Set IndividualId filter from ?individualId= query param
        if (IndividualIdParam.HasValue)
        {
            _filterIndividualId = IndividualIdParam.Value;
            try
            {
                IndividualDto? match = await IndividualService.GetIndividualByIdAsync(IndividualIdParam.Value, _cts.Token);
                if (match is not null)
                    _filterIndividualInitialLabel = match.FullName;
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Error resolving individual param: {ex.Message}");
            }
        }
    }

    private void BuildFilterItems()
    {
        _statusFilterItems =
        [
            new() { Label = Localization.GetString("All"),             Value = null,                         Color = Color.Info },
            new() { Label = Localization.GetString("Draft"),           Value = PurchaseNoteStatus.Draft,     Color = Color.Default },
            new() { Label = Localization.GetString("PendingStatus"),   Value = PurchaseNoteStatus.Pending,   Color = Color.Warning },
            new() { Label = Localization.GetString("PaidStatus"),      Value = PurchaseNoteStatus.Paid,      Color = Color.Success },
            new() { Label = Localization.GetString("CancelledStatus"), Value = PurchaseNoteStatus.Cancelled, Color = Color.Error   },
        ];
    }

    private async void OnLanguageChanged()
    {
        BuildFilterItems();
        await InvokeAsync(StateHasChanged);
    }

    private async Task<GridData<PurchaseNoteDto>> LoadServerData(GridState<PurchaseNoteDto> state, CancellationToken ct)
    {
        string? sortBy = state.SortDefinitions.FirstOrDefault()?.SortBy;
        bool ascending = state.SortDefinitions.FirstOrDefault()?.Descending == false;

        GetPurchaseNotesQuery query = new()
        {
            Search = _searchString,
            Status = _filterStatus,
            IndividualId = _filterIndividualId,
            DateFrom = _filterDateRange.Start,
            DateTo = _filterDateRange.End,
            AmountMin = _filterAmountMin,
            AmountMax = _filterAmountMax,
            Page = state.Page + 1,
            PageSize = state.PageSize,
            SortBy = sortBy,
            SortAscending = ascending,
        };

        PagedResult<PurchaseNoteDto> result = await PurchaseNoteService.GetPagedAsync(query, ct);

        return new GridData<PurchaseNoteDto>
        {
            Items = result.Items,
            TotalItems = result.TotalCount
        };
    }

    private async Task OnSearch(string text)
    {
        _searchString = text;
        await _grid.ReloadServerData();
    }

    private async Task OnStatusFilterChanged(PurchaseNoteStatus? value)
    {
        _filterStatus = value;
        await _grid.ReloadServerData();
    }

    private async Task ReloadGrid() => await _grid.ReloadServerData();

    private async Task<PagedResult<WisAutocompleteItem<Guid>>> LoadIndividualItems(
        string search, int page, CancellationToken ct)
    {
        PagedResult<IndividualDto> result = await IndividualService.GetPagedAsync(new GetIndividualsQuery
        {
            Search = search,
            Page = page,
            PageSize = 10,
            SortBy = "LastName",
            SortAscending = true,
            IsActive = true
        }, ct);

        return new PagedResult<WisAutocompleteItem<Guid>>
        {
            Items = result.Items.Select(i => new WisAutocompleteItem<Guid>
            {
                Label = i.FullName,
                SubLabel = i.IdentificationNumber,
                Value = i.Id
            }).ToList(),
            TotalCount = result.TotalCount,
            Page = result.Page,
            PageSize = result.PageSize
        };
    }

    private async Task OnIndividualFilterChanged(Guid value)
    {
        _filterIndividualId = value == default ? null : value;
        await _grid.ReloadServerData();
    }

    private Task OnDatePresetChanged(int? days)
    {
        _filterDatePreset = days;
        return Task.CompletedTask;
    }

    private Task OnDateRangeChanged(DateRange range)
    {
        _filterDateRange = range;
        return Task.CompletedTask;
    }

    private Task OnAmountMinChanged(decimal? value)
    {
        _filterAmountMin = value;
        return Task.CompletedTask;
    }

    private Task OnAmountMaxChanged(decimal? value)
    {
        _filterAmountMax = value;
        return Task.CompletedTask;
    }

    private Task OnAmountPresetChanged(string? key)
    {
        _filterAmountPreset = key;
        return Task.CompletedTask;
    }

    private async Task ClearAllFilters()
    {
        _filterStatus = null;
        _filterIndividualId = null;
        _filterIndividualInitialLabel = null;
        _filterAmountMin = null;
        _filterAmountMax = null;
        _filterAmountPreset = null;
        _filterDateRange = new(null, null);
        _filterDatePreset = null;

        if (_dateRangeFilter is not null)
            await _dateRangeFilter.ClearAsync();
        if (_amountRangeFilter is not null)
            await _amountRangeFilter.ClearAsync();

        await _grid.ReloadServerData();
    }

    private void OnRowClick(DataGridRowClickEventArgs<PurchaseNoteDto> args)
    {
        if (args.MouseEventArgs.Detail == 2)
            Navigation.NavigateTo($"/purchase-notes/{args.Item.Id}");
    }

    private async Task ReceiveGoods(PurchaseNoteDto note)
    {
        bool confirm = await WisDialog.ConfirmAsync(
            Localization.GetString("ReceiveGoods"),
            $"{note.NoteNumber} — {note.IndividualFullName}",
            Localization.GetString("ReceiveGoods"),
            Localization.GetString("Cancel"));

        if (confirm)
        {
            try
            {
                await PurchaseNoteService.ReceiveAsync(note.Id);
                Snackbar.Add(Localization.GetString("PurchaseNoteReceived"), Severity.Success);
                await _grid.ReloadServerData();
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Error receiving purchase note: {ex.Message}");
                Snackbar.Add(Localization.GetString("ErrorUpdatingPurchaseNote"), Severity.Error);
            }
        }
    }

    private async Task MarkAsPaid(PurchaseNoteDto note)
    {
        bool confirm = await WisDialog.ConfirmAsync(
            Localization.GetString("MarkAsPaidQuestion"),
            $"{note.NoteNumber} — {note.IndividualFullName}",
            Localization.GetString("MarkAsPaid"),
            Localization.GetString("Cancel"));

        if (confirm == true)
        {
            try
            {
                await PurchaseNoteService.MarkAsPaidAsync(note.Id);
                Snackbar.Add(Localization.GetString("PurchaseNoteMarkedPaid"), Severity.Success);
                await _grid.ReloadServerData();
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Error marking as paid: {ex.Message}");
                Snackbar.Add(Localization.GetString("ErrorUpdatingPurchaseNote"), Severity.Error);
            }
        }
    }

    private string GetRowClass(PurchaseNoteDto item, int index) => item.Status switch
    {
        PurchaseNoteStatus.Draft => "row-status-default",
        PurchaseNoteStatus.Pending => "row-status-warning",
        PurchaseNoteStatus.Paid => "row-status-success",
        PurchaseNoteStatus.Cancelled => "row-status-default",
        _ => string.Empty
    };

    private Color GetStatusColor(PurchaseNoteStatus status) => status switch
    {
        PurchaseNoteStatus.Draft => Color.Default,
        PurchaseNoteStatus.Pending => Color.Warning,
        PurchaseNoteStatus.Paid => Color.Success,
        PurchaseNoteStatus.Cancelled => Color.Error,
        _ => Color.Default
    };

    private string GetStatusText(PurchaseNoteStatus status) => status switch
    {
        PurchaseNoteStatus.Draft => Localization.GetString("Draft"),
        PurchaseNoteStatus.Pending => Localization.GetString("PendingStatus"),
        PurchaseNoteStatus.Paid => Localization.GetString("PaidStatus"),
        PurchaseNoteStatus.Cancelled => Localization.GetString("CancelledStatus"),
        _ => status.ToString()
    };

    public void Dispose()
    {
        _cts.Cancel();
        _cts.Dispose();
        Localization.OnLanguageChanged -= OnLanguageChanged;
    }
}
