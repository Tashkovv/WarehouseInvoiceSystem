@page "/purchase-notes"
@inherits PageBase
@using WarehouseInvoiceSystem.Application.DTOs.PurchaseNote
@using WarehouseInvoiceSystem.Application.DTOs.Individual
@using WarehouseInvoiceSystem.Domain.Enums
@using WarehouseInvoiceSystem.Domain.Queries
@using WarehouseInvoiceSystem.Domain.Queries.Common
@using WarehouseInvoiceSystem.Application.Models
@inject IPurchaseNoteService PurchaseNoteService
@inject IIndividualService IndividualService
@inject IExcelExportService ExcelExportService

<PageTitle>@Localization.GetString("PurchaseNotes") - @Localization.GetString("InvoiceSystem")</PageTitle>

<div class="wis-page-header">
    <MudText Typo="Typo.h3" Class="wis-page-title">
        @Localization.GetString("PurchaseNotes")
    </MudText>
</div>

<WisGridToolbar CreateAction="@(() => Navigation.NavigateTo("/purchase-notes/create"))"
                CreateLabel="@Localization.GetString("PurchaseNote")"
                CreateActions="@_createActions"
                SearchValue="@_searchString"
                SearchValueChanged="OnSearch"
                HasAnyActiveFilter="@(_filterStatus.HasValue || _activeAdvancedFilterCount > 0)"
                OnClearAll="ClearAllFilters"
                ActiveAdvancedFilterCount="@_activeAdvancedFilterCount">
    <Filters>
        <FilterPopoverList TValue="PurchaseNoteStatus?"
                           Label="@Localization.GetString("Status")"
                           Items="_statusFilterItems"
                           Mode="FilterSelectionMode.Single"
                           SelectedValue="_filterStatus"
                           SelectedValueChanged="OnStatusFilterChanged" />
    </Filters>
    <AdvancedFilters>
        <div class="d-flex align-center flex-wrap gap-3">

            <WisAutocompleteFilter TValue="Guid"
                                   Label="@Localization.GetString("Individual")"
                                   AllLabel="@Localization.GetString("AllIndividuals")"
                                   Icon="@Icons.Material.Filled.Person"
                                   LoadItems="LoadIndividualItems"
                                   SelectedValue="@(_filterIndividualId ?? default)"
                                   SelectedValueChanged="OnIndividualFilterChanged"
                                   InitialLabel="@_filterIndividualInitialLabel"
                                   MinWidth="200px" />

            <WisDateRangeFilter @ref="_dateRangeFilter"
                                Label="@Localization.GetString("PurchaseDate")"
                                DateRange="_filterDateRange"
                                DateRangeChanged="OnDateRangeChanged"
                                OnChanged="ReloadGrid"
                                DatePreset="_filterDatePreset"
                                DatePresetChanged="OnDatePresetChanged"
                                MaxDate="DateTime.Today" />

            <WisAmountRangeFilter @ref="_amountRangeFilter"
                                  Label="@Localization.GetString("AmountRange")"
                                  AmountMin="_filterAmountMin"
                                  AmountMinChanged="OnAmountMinChanged"
                                  AmountMax="_filterAmountMax"
                                  AmountMaxChanged="OnAmountMaxChanged"
                                  AmountPreset="@_filterAmountPreset"
                                  AmountPresetChanged="OnAmountPresetChanged"
                                  OnChanged="ReloadGrid" />

        </div>
    </AdvancedFilters>
</WisGridToolbar>

<MudCard Elevation="2" Class="mb-4">
    <MudCardContent Class="pa-0">
        <MudDataGrid T="PurchaseNoteDto"
                     @ref="_grid"
                     ServerData="LoadServerData"
                     RowClick="OnRowClick"
                     RowClassFunc="GetRowClass"
                     ReadOnly="true"
                     Hover="true"
                     FixedHeader="true"
                     Height="100%"
                     Filterable="false"
                     ShowColumnOptions="false"
                     ColumnResizeMode="ResizeMode.Column"
                     SortMode="SortMode.Single"
                     Class="wis-data-grid">
            <Columns>

                <TemplateColumn Sortable="false"
                                Filterable="false"
                                HeaderClass="wis-col-actions-1"
                                CellClass="wis-col-actions-1">
                    <CellTemplate>
                        <MudStack Row="true" Justify="Justify.Center" AlignItems="AlignItems.Center">
                            <WisSplitButton Actions="@BuildRowActions(context.Item)"
                                            AnchorOrigin="Origin.BottomLeft"
                                            TransformOrigin="Origin.TopLeft"
                                            HideLabel="true" />
                        </MudStack>
                    </CellTemplate>
                </TemplateColumn>

                <PropertyColumn Property="x => x.NoteNumber"
                                Title="@Localization.GetString("Number")"
                                Sortable="true"
                                CellClass="wis-cell-mono" />

                <PropertyColumn Property="x => x.IndividualFullName"
                                Title="@Localization.GetString("Individual")"
                                Sortable="true"
>
                    <CellTemplate>
                        <MudText Typo="Typo.body2" Class="wis-cell-primary">
                            @context.Item.IndividualFullName
                        </MudText>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">
                            @context.Item.IndividualIdentificationNumber
                        </MudText>
                    </CellTemplate>
                </PropertyColumn>

                <PropertyColumn Property="x => x.Status"
                                Title="@Localization.GetString("Status")"
                                Sortable="true"
>
                    <CellTemplate>
                        <MudChip T="string"
                                 Size="Size.Small"
                                 Color="@GetPurchaseNoteStatusColor(context.Item.Status)">
                            @GetPurchaseNoteStatusText(context.Item.Status)
                        </MudChip>
                    </CellTemplate>
                </PropertyColumn>

                <PropertyColumn Property="x => x.PurchaseDate"
                                Title="@Localization.GetString("PurchaseDate")"
                                Sortable="true"
>
                    <CellTemplate>
                        @context.Item.PurchaseDate.ToString("dd MMM yyyy")
                    </CellTemplate>
                </PropertyColumn>

                <PropertyColumn Property="x => x.WarehouseName"
                                Title="@Localization.GetString("Warehouse")"
                                Sortable="false"
>
                    <CellTemplate>
                        @context.Item.WarehouseName
                    </CellTemplate>
                </PropertyColumn>

                <PropertyColumn Property="x => x.TotalAmount"
                                Title="@Localization.GetString("Total")"
                                Sortable="true"
                                HeaderClass="text-right"
                                CellClass="text-right"
>
                    <CellTemplate>
                        <MudText Typo="Typo.body2" Class="wis-cell-amount">
                            @context.Item.TotalAmount.ToString("C")
                        </MudText>
                    </CellTemplate>
                </PropertyColumn>

            </Columns>

            <NoRecordsContent>
                <WisNoRecordsContent Icon="@Icons.Material.Filled.Receipt"
                                     Message="@Localization.GetString("NoPurchaseNotesFound")" />
            </NoRecordsContent>

            <LoadingContent>
                <WisLoadingContent />
            </LoadingContent>

            <PagerContent>
                <WisPagerContent T="PurchaseNoteDto" />
            </PagerContent>

        </MudDataGrid>
    </MudCardContent>
</MudCard>

@code {
    [Parameter]
    [SupplyParameterFromQuery(Name = "individualId")]
    public string? IndividualIdParam { get; set; }

    [Parameter]
    [SupplyParameterFromQuery(Name = "purchaseDateFrom")]
    public string? PurchaseDateFromParam { get; set; }

    [Parameter]
    [SupplyParameterFromQuery(Name = "purchaseDateTo")]
    public string? PurchaseDateToParam { get; set; }

    [Parameter]
    [SupplyParameterFromQuery(Name = "status")]
    public string? StatusParam { get; set; }

    private MudDataGrid<PurchaseNoteDto> _grid = null!;
    private string _searchString = string.Empty;
    private bool _exporting = false;
    private bool _exportingRow = false;
    private List<WisDetailActionItem>? _createActions;

    // Quick filter
    private PurchaseNoteStatus? _filterStatus = null;

    // Advanced filters
    private Guid? _filterIndividualId = null;
    private string? _filterIndividualInitialLabel = null;
    private DateRange _filterDateRange = new(null, null);
    private int? _filterDatePreset = null;
    private WisDateRangeFilter? _dateRangeFilter;
    private decimal? _filterAmountMin = null;
    private decimal? _filterAmountMax = null;
    private string? _filterAmountPreset = null;
    private WisAmountRangeFilter? _amountRangeFilter;

    private int _activeAdvancedFilterCount =>
        (_filterIndividualId.HasValue ? 1 : 0) +
        (_filterDateRange.Start != null || _filterDateRange.End != null ? 1 : 0) +
        (_filterAmountMin.HasValue || _filterAmountMax.HasValue ? 1 : 0);

    private List<FilterPopoverItem<PurchaseNoteStatus?>> _statusFilterItems = [];

    protected override async Task OnInitializedAsync()
    {
        await base.OnInitializedAsync();
        BuildFilterItems();
        BuildCreateActions();
        ApplyQueryParams();

        // Set IndividualId filter from query param so filter button shows active state
        if (_filterIndividualId.HasValue)
        {
            try
            {
                IndividualDto? individual = await IndividualService.GetIndividualByIdAsync(_filterIndividualId.Value, CancellationToken.None);
                if (individual is not null)
                    _filterIndividualInitialLabel = individual.FullName;
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Error resolving individual param: {ex.Message}");
            }
        }
    }

    private void ApplyQueryParams()
    {
        if (!string.IsNullOrWhiteSpace(StatusParam) &&
            Enum.TryParse<PurchaseNoteStatus>(StatusParam, ignoreCase: true, out PurchaseNoteStatus parsedStatus))
        {
            _filterStatus = parsedStatus;
        }

        if (!string.IsNullOrWhiteSpace(IndividualIdParam) &&
            Guid.TryParse(IndividualIdParam, out Guid individualId))
        {
            _filterIndividualId = individualId;
        }

        if (!string.IsNullOrWhiteSpace(PurchaseDateFromParam) &&
            DateTime.TryParse(PurchaseDateFromParam, out DateTime purchaseDateFrom))
        {
            _filterDateRange = new DateRange(purchaseDateFrom, _filterDateRange.End);
        }

        if (!string.IsNullOrWhiteSpace(PurchaseDateToParam) &&
            DateTime.TryParse(PurchaseDateToParam, out DateTime purchaseDateTo))
        {
            _filterDateRange = new DateRange(_filterDateRange.Start, purchaseDateTo);
        }
    }

    private void BuildFilterItems()
    {
        _statusFilterItems =
        [
            new() { Label = Localization.GetString("All"),             Value = null,                         Color = Color.Info },
            new() { Label = Localization.GetString("Draft"),           Value = PurchaseNoteStatus.Draft,     Color = Color.Default },
            new() { Label = Localization.GetString("PendingStatus"),   Value = PurchaseNoteStatus.Pending,   Color = Color.Warning },
            new() { Label = Localization.GetString("PaidStatus"),      Value = PurchaseNoteStatus.Paid,      Color = Color.Success },
            new() { Label = Localization.GetString("CancelledStatus"), Value = PurchaseNoteStatus.Cancelled, Color = Color.Error   },
        ];
    }

    protected override async void OnLanguageChanged()
    {
        BuildFilterItems();
        await InvokeAsync(StateHasChanged);
    }

    private async Task<GridData<PurchaseNoteDto>> LoadServerData(GridState<PurchaseNoteDto> state, CancellationToken ct)
    {
        string? sortBy = state.SortDefinitions.FirstOrDefault()?.SortBy;
        bool ascending = state.SortDefinitions.FirstOrDefault()?.Descending == false;

        GetPurchaseNotesQuery query = new()
        {
            Search = _searchString,
            Status = _filterStatus,
            IndividualId = _filterIndividualId,
            DateFrom = _filterDateRange.Start,
            DateTo = _filterDateRange.End,
            AmountMin = _filterAmountMin,
            AmountMax = _filterAmountMax,
            Page = state.Page + 1,
            PageSize = state.PageSize,
            SortBy = sortBy,
            SortAscending = ascending,
        };

        PagedResult<PurchaseNoteDto> result = await PurchaseNoteService.GetPagedAsync(query, ct);

        return new GridData<PurchaseNoteDto>
        {
            Items = result.Items,
            TotalItems = result.TotalCount
        };
    }

    private async Task OnSearch(string text)
    {
        _searchString = text;
        await _grid.ReloadServerData();
    }

    private async Task OnStatusFilterChanged(PurchaseNoteStatus? value)
    {
        _filterStatus = value;
        await _grid.ReloadServerData();
    }

    private async Task ReloadGrid() => await _grid.ReloadServerData();

    private async Task<PagedResult<WisAutocompleteItem<Guid>>> LoadIndividualItems(
        string search, int page, CancellationToken ct)
    {
        PagedResult<IndividualDto> result = await IndividualService.GetPagedAsync(new GetIndividualsQuery
        {
            Search = search,
            Page = page,
            PageSize = 10,
            SortBy = "LastName",
            SortAscending = true,
            IsActive = true
        }, ct);

        return new PagedResult<WisAutocompleteItem<Guid>>
        {
            Items = result.Items.Select(i => new WisAutocompleteItem<Guid>
            {
                Label = i.FullName,
                SubLabel = i.IdentificationNumber,
                Value = i.Id
            }).ToList(),
            TotalCount = result.TotalCount,
            Page = result.Page,
            PageSize = result.PageSize
        };
    }

    private async Task OnIndividualFilterChanged(Guid value)
    {
        _filterIndividualId = value == default ? null : value;
        await _grid.ReloadServerData();
    }

    private Task OnDatePresetChanged(int? days)
    {
        _filterDatePreset = days;
        return Task.CompletedTask;
    }

    private Task OnDateRangeChanged(DateRange range)
    {
        _filterDateRange = range;
        return Task.CompletedTask;
    }

    private Task OnAmountMinChanged(decimal? value)
    {
        _filterAmountMin = value;
        return Task.CompletedTask;
    }

    private Task OnAmountMaxChanged(decimal? value)
    {
        _filterAmountMax = value;
        return Task.CompletedTask;
    }

    private Task OnAmountPresetChanged(string? key)
    {
        _filterAmountPreset = key;
        return Task.CompletedTask;
    }

    private async Task ClearAllFilters()
    {
        _filterStatus = null;
        _filterIndividualId = null;
        _filterIndividualInitialLabel = null;
        _filterAmountMin = null;
        _filterAmountMax = null;
        _filterAmountPreset = null;
        _filterDateRange = new(null, null);
        _filterDatePreset = null;

        if (_dateRangeFilter is not null)
            await _dateRangeFilter.ClearAsync();
        if (_amountRangeFilter is not null)
            await _amountRangeFilter.ClearAsync();

        await _grid.ReloadServerData();
    }

    private void OnRowClick(DataGridRowClickEventArgs<PurchaseNoteDto> args)
    {
        if (args.MouseEventArgs.Detail == 2)
            Navigation.NavigateTo($"/purchase-notes/{args.Item.Id}");
    }

    private async Task ReceiveGoods(PurchaseNoteDto note) =>
        await ConfirmAndExecuteAsync(
            Localization.GetString("ReceiveGoods"),
            $"{note.NoteNumber} — {note.IndividualFullName}",
            async () => { await PurchaseNoteService.ReceiveAsync(note.Id); await _grid.ReloadServerData(); },
            "PurchaseNoteReceived", "ErrorUpdatingPurchaseNote",
            Localization.GetString("ReceiveGoods"), Localization.GetString("Cancel"));

    private async Task MarkAsPaid(PurchaseNoteDto note) =>
        await ConfirmAndExecuteAsync(
            Localization.GetString("MarkAsPaidQuestion"),
            $"{note.NoteNumber} — {note.IndividualFullName}",
            async () => { await PurchaseNoteService.MarkAsPaidAsync(note.Id); await _grid.ReloadServerData(); },
            "PurchaseNoteMarkedPaid", "ErrorUpdatingPurchaseNote",
            Localization.GetString("MarkAsPaid"), Localization.GetString("Cancel"));

    private async Task DeleteNote(PurchaseNoteDto note) =>
        await ConfirmAndExecuteAsync(
            Localization.GetString("ConfirmDelete"),
            Localization.GetString("DeletePurchaseNoteConfirm"),
            async () => { await PurchaseNoteService.DeletePurchaseNoteAsync(note.Id); await _grid.ReloadServerData(); },
            "PurchaseNoteDeleted", "ErrorUpdatingPurchaseNote",
            Localization.GetString("Delete"), Localization.GetString("Back"));

    private string GetRowClass(PurchaseNoteDto item, int index) => item.Status switch
    {
        PurchaseNoteStatus.Draft => "row-status-default",
        PurchaseNoteStatus.Pending => "row-status-warning",
        PurchaseNoteStatus.Paid => "row-status-success",
        PurchaseNoteStatus.Cancelled => "row-status-error",
        _ => string.Empty
    };

    private List<WisDetailActionItem> BuildRowActions(PurchaseNoteDto item)
    {
        bool isDraft     = item.Status == PurchaseNoteStatus.Draft;
        bool isPending   = item.Status == PurchaseNoteStatus.Pending;
        bool isPaid      = item.Status == PurchaseNoteStatus.Paid;
        bool isCancelled = item.Status == PurchaseNoteStatus.Cancelled;
        bool canPay      = isPending;
        bool canRevert   = isPending;
        bool canCancel   = !isPaid && !isCancelled;

        List<WisDetailActionItem> actions = [];

        if (isDraft)
        {
            actions.Add(new WisDetailActionItem
            {
                Icon    = Icons.Material.Filled.MoveToInbox,
                Label   = Localization.GetString("ReceiveGoods"),
                Color   = Color.Warning,
                OnClick = EventCallback.Factory.Create(this, () => ReceiveGoods(item))
            });
        }

        if (canPay)
        {
            actions.Add(new WisDetailActionItem
            {
                Icon    = Icons.Material.Filled.Payment,
                Label   = Localization.GetString("MarkAsPaid"),
                Color   = Color.Success,
                OnClick = EventCallback.Factory.Create(this, () => MarkAsPaid(item))
            });
        }

        if (isDraft)
        {
            actions.Add(new WisDetailActionItem
            {
                Icon    = Icons.Material.Filled.Edit,
                Label   = Localization.GetString("Edit"),
                OnClick = EventCallback.Factory.Create(this, () => Navigation.NavigateTo($"/purchase-notes/edit/{item.Id}"))
            });
        }

        actions.Add(new WisDetailActionItem
        {
            Icon     = Icons.Material.Filled.Print,
            Label    = Localization.GetString("Export"),
            Disabled = _exportingRow,
            OnClick  = EventCallback.Factory.Create(this, () => ExportNoteRow(item))
        });

        actions.Add(new WisDetailActionItem
        {
            Icon    = Icons.Material.Filled.ContentCopy,
            Label   = Localization.GetString("Copy"),
            OnClick = EventCallback.Factory.Create(this, () => Navigation.NavigateTo($"/purchase-notes/create?copyFrom={item.Id}"))
        });

        if (canRevert)
        {
            actions.Add(new WisDetailActionItem
            {
                Icon    = Icons.Material.Filled.Undo,
                Label   = Localization.GetString("Draft"),
                OnClick = EventCallback.Factory.Create(this, () => RevertToDraftFromList(item))
            });
        }

        if (isCancelled)
        {
            actions.Add(new WisDetailActionItem
            {
                Icon            = Icons.Material.Filled.Delete,
                Label           = Localization.GetString("Delete"),
                Color           = Color.Error,
                IsDividerBefore = true,
                OnClick         = EventCallback.Factory.Create(this, () => DeleteNote(item))
            });
        }
        else if (canCancel)
        {
            actions.Add(new WisDetailActionItem
            {
                Icon            = Icons.Material.Filled.Cancel,
                Label           = Localization.GetString("Cancel"),
                Color           = Color.Error,
                IsDividerBefore = true,
                OnClick         = EventCallback.Factory.Create(this, () => CancelNote(item))
            });
        }

        return actions;
    }

    private async Task CancelNote(PurchaseNoteDto note)
    {
        string message = note.Status == PurchaseNoteStatus.Pending
            ? Localization.GetString("CancelPendingNoteConfirm")
            : Localization.GetString("CancelDraftNoteConfirm");

        await ConfirmAndExecuteAsync(
            Localization.GetString("CancelPurchaseNote"), message,
            async () => { await PurchaseNoteService.CancelAsync(note.Id); await _grid.ReloadServerData(); },
            "PurchaseNoteCancelled", "ErrorUpdatingPurchaseNote",
            Localization.GetString("Cancel"), Localization.GetString("Back"));
    }

    private async Task RevertToDraftFromList(PurchaseNoteDto note) =>
        await ConfirmAndExecuteAsync(
            Localization.GetString("RevertToDraft"),
            Localization.GetString("RevertToDraftConfirm"),
            async () => { await PurchaseNoteService.RevertToDraftAsync(note.Id); await _grid.ReloadServerData(); },
            "PurchaseNoteRevertedToDraft", "ErrorUpdatingPurchaseNote",
            Localization.GetString("RevertToDraft"), Localization.GetString("Back"));

    private void BuildCreateActions()
    {
        _createActions =
        [
            new WisDetailActionItem
            {
                Icon = Icons.Material.Filled.Print,
                Label = Localization.GetString("Export"),
                Disabled = _exporting,
                OnClick = EventCallback.Factory.Create(this, PerformExport)
            }
        ];
    }

    private async Task PerformExport()
    {
        _exporting = true;
        StateHasChanged();

        try
        {
            GetPurchaseNotesQuery exportQuery = new()
            {
                Search = _searchString,
                Status = _filterStatus,
                IndividualId = _filterIndividualId,
                DateFrom = _filterDateRange.Start,
                DateTo = _filterDateRange.End,
                AmountMin = _filterAmountMin,
                AmountMax = _filterAmountMax,
            };

            IEnumerable<PurchaseNoteDto> notes = await PurchaseNoteService.GetAllFilteredAsync(exportQuery, CancellationToken.None);

            byte[] fileBytes = await ExcelExportService.ExportListToExcelAsync(
                notes,
                ExportColumnDefinitions.PurchaseNoteColumns(Localization),
                new ExportListOptions(Localization.GetString("PurchaseNotes")));

            string fileName = $"{Localization.GetString("PurchaseNotes")}_{DateTime.UtcNow:yyyyMMdd}.xlsx";
            await DownloadFileAsync(fileBytes, fileName);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error exporting purchase notes: {ex.Message}");
            Snackbar.Add(Localization.GetString("ExportError"), Severity.Error);
        }
        finally
        {
            _exporting = false;
            StateHasChanged();
        }
    }

    private async Task ExportNoteRow(PurchaseNoteDto item)
    {
        _exportingRow = true;
        try
        {
            PurchaseNoteDto? fullNote = await PurchaseNoteService.GetPurchaseNoteByIdAsync(item.Id, CancellationToken.None);
            if (fullNote is null) return;

            byte[] fileBytes = await ExcelExportService.ExportPurchaseNoteForPrintingAsync(fullNote);
            string fileName = $"{Localization.GetString("PurchaseNote")}_{fullNote.NoteNumber}_{DateTime.UtcNow:yyyyMMdd}.xlsx";
            await DownloadFileAsync(fileBytes, fileName);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error exporting purchase note: {ex.Message}");
            Snackbar.Add(Localization.GetString("ExportError"), Severity.Error);
        }
        finally
        {
            _exportingRow = false;
        }
    }

}
