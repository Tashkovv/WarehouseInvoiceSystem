@page "/purchase-notes/{Id:guid}"
@implements IDisposable
@using WarehouseInvoiceSystem.Application.DTOs.PurchaseNote
@using WarehouseInvoiceSystem.Domain.Enums
@inject IPurchaseNoteService PurchaseNoteService
@inject ILocalizationService Localization
@inject NavigationManager Navigation
@inject WisDialogService WisDialog
@inject ISnackbar Snackbar

<PageTitle>@Localization.GetString("PurchaseNoteDetails") - @Localization.GetString("InvoiceSystem")</PageTitle>

@if (_loading)
{
    <MudProgressLinear Color="Color.Primary" Indeterminate="true" />
}
else if (_note == null)
{
    <MudAlert Severity="Severity.Error">@Localization.GetString("PurchaseNoteNotFound")</MudAlert>
}
else
{
    <WisDetailHeader BackHref="/purchase-notes"
                     BackLabel="@Localization.GetString("PurchaseNotes")"
                     PrimaryAction="@_primaryAction"
                     Actions="@_actions" />

    <MudGrid>

        @* ── Header card ── *@
        <MudItem xs="12">
            <MudCard Elevation="2">
                <MudCardContent Class="pa-4">

                    @* Top section: identity + pills (left 6) | notes (right 6) *@
                    <div class="wis-contact-row mb-4">
                        <div class="wis-contact-row-left">

                            @* Row 1: note number + status chip *@
                            <div class="wis-detail-identity mb-3">
                                <MudText Typo="Typo.h4" Class="font-weight-bold mb-0" Style="font-family: monospace;">
                                    @_note.NoteNumber
                                </MudText>
                                <MudChip T="string" Size="Size.Small" Color="@GetStatusColor(_note.Status)">
                                    @GetStatusText(_note.Status)
                                </MudChip>
                            </div>

                            @* Row 2: individual + warehouse contact pills *@
                            <div class="wis-detail-contact">
                                <div class="wis-detail-contact-item">
                                    <MudIcon Icon="@Icons.Material.Filled.Person" Size="Size.Small" Color="Color.Secondary" />
                                    <MudText Typo="Typo.body2" Style="font-weight: 500;">@_note.IndividualFullName</MudText>
                                </div>
                                <div class="wis-detail-contact-item">
                                    <MudIcon Icon="@Icons.Material.Filled.Badge" Size="Size.Small" Color="Color.Secondary" />
                                    <MudText Typo="Typo.body2" Color="Color.Secondary">@_note.IndividualIdentificationNumber</MudText>
                                </div>
                                @if (!string.IsNullOrEmpty(_note.WarehouseName))
                                {
                                    <div class="wis-detail-contact-item">
                                        <MudIcon Icon="@Icons.Material.Filled.Warehouse" Size="Size.Small" Color="Color.Secondary" />
                                        <MudText Typo="Typo.body2">@_note.WarehouseName</MudText>
                                    </div>
                                }
                            </div>

                        </div>

                        @if (!string.IsNullOrWhiteSpace(_note.Notes))
                        {
                            <div class="wis-contact-row-divider"></div>
                            <div class="wis-contact-row-right">
                                <div class="d-flex align-start gap-2">
                                    <MudIcon Icon="@Icons.Material.Filled.Notes" Size="Size.Small" Color="Color.Secondary" Class="mt-1" />
                                    <div>
                                        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="wis-section-label">@Localization.GetString("Notes")</MudText>
                                        <MudText Typo="Typo.body2" Color="Color.Secondary" Style="line-height: 1.6;">@_note.Notes</MudText>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>

                    <MudDivider Class="mb-4" />

                    @* Stats row: full width *@
                    <MudGrid Spacing="4" Class="wis-detail-stats">

                        <MudItem xs="3">
                            <MudText Typo="Typo.caption" Color="Color.Secondary" Class="wis-section-label">@Localization.GetString("Total")</MudText>
                            <div class="wis-stat-value mud-info-text">@_note.TotalAmount.ToString("C")</div>
                            <MudText Typo="Typo.body2" Color="Color.Secondary">@_note.LineItems.Count @Localization.GetString("Products")</MudText>
                        </MudItem>

                        <MudItem xs="3">
                            <MudText Typo="Typo.caption" Color="Color.Secondary" Class="wis-section-label">@Localization.GetString("PurchaseDate")</MudText>
                            <div class="wis-stat-value">@_note.PurchaseDate.ToString("dd MMM yyyy")</div>
                        </MudItem>

                        @if (_note.PaidDate.HasValue)
                        {
                            <MudItem xs="3">
                                <MudText Typo="Typo.caption" Color="Color.Secondary" Class="wis-section-label">@Localization.GetString("PaidDate")</MudText>
                                <div class="wis-stat-value mud-success-text">@_note.PaidDate.Value.ToString("dd MMM yyyy")</div>
                            </MudItem>
                        }

                    </MudGrid>

                </MudCardContent>
            </MudCard>
        </MudItem>

        @* ── Line items ── *@
        <MudItem xs="12">
            <MudCard Elevation="2">
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudText Typo="Typo.h6">@Localization.GetString("Products")</MudText>
                    </CardHeaderContent>
                </MudCardHeader>
                <MudCardContent Class="pa-0">
                    <MudTable Items="_note.LineItems"
                              Hover="true"
                              Elevation="0"
                              Class="wis-secondary-list">
                        <HeaderContent>
                            <MudTh>@Localization.GetString("Product")</MudTh>
                            <MudTh>@Localization.GetString("Description")</MudTh>
                            <MudTh Style="text-align: right;">@Localization.GetString("Quantity")</MudTh>
                            <MudTh Style="text-align: right;">@Localization.GetString("UnitPrice")</MudTh>
                            <MudTh Style="text-align: right;">@Localization.GetString("Amount")</MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd DataLabel="@Localization.GetString("Product")">
                                <MudText Typo="Typo.body2">@context.ProductCode - @context.ProductName</MudText>
                            </MudTd>
                            <MudTd DataLabel="@Localization.GetString("Description")">
                                <MudText Typo="Typo.body2">
                                    @(string.IsNullOrEmpty(context.Description) ? "—" : context.Description)
                                </MudText>
                            </MudTd>
                            <MudTd DataLabel="@Localization.GetString("Quantity")" Style="text-align: right;">
                                <MudText Typo="Typo.body2" Style="font-weight: 500;">
                                    @context.Quantity.ToString("N2") @context.ProductUnit
                                </MudText>
                            </MudTd>
                            <MudTd DataLabel="@Localization.GetString("UnitPrice")" Style="text-align: right;">
                                <MudText Typo="Typo.body2">@context.UnitPrice.ToString("C")</MudText>
                            </MudTd>
                            <MudTd DataLabel="@Localization.GetString("Amount")" Style="text-align: right;">
                                <MudText Typo="Typo.body2" Color="Color.Primary">@context.Amount.ToString("C")</MudText>
                            </MudTd>
                        </RowTemplate>
                    </MudTable>

                </MudCardContent>
            </MudCard>
        </MudItem>

    </MudGrid>
}

@code {
    private readonly CancellationTokenSource _cts = new();
    [Parameter] public Guid Id { get; set; }

    private bool _loading = true;
    private PurchaseNoteDto? _note;
    private WisDetailActionItem? _primaryAction;
    private List<WisDetailActionItem> _actions = [];
    private WisActionItem _act = null!;

    protected override async Task OnInitializedAsync()
    {
        _act = new WisActionItem(this);
        Localization.OnLanguageChanged += OnLanguageChanged;
        await LoadNote();
    }

    private async void OnLanguageChanged() => await InvokeAsync(() =>
    {
        BuildActions();
        StateHasChanged();
    });

    private async Task LoadNote()
    {
        _loading = true;
        try
        {
            _note = await PurchaseNoteService.GetPurchaseNoteByIdAsync(Id, _cts.Token);
            BuildActions();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading purchase note: {ex.Message}");
            Snackbar.Add(Localization.GetString("ErrorLoadingPurchaseNote"), Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    private void BuildActions()
    {
        if (_note == null) return;

        _primaryAction = null;
        _actions = [];

        switch (_note.Status)
        {
            case PurchaseNoteStatus.Draft:
                _primaryAction = _act.Warning(Icons.Material.Filled.MoveToInbox, Localization.GetString("ReceiveGoods"), ReceiveGoods);
                _actions =
                [
                    _act.Primary(Icons.Material.Filled.Edit,   Localization.GetString("Edit"),   GoToEdit),
                    _act.Error(Icons.Material.Filled.Cancel,   Localization.GetString("Cancel"), CancelNote, dividerBefore: true),
                ];
                break;

            case PurchaseNoteStatus.Pending:
                _primaryAction = _act.Success(Icons.Material.Filled.Payment, Localization.GetString("MarkAsPaid"), MarkAsPaid);
                _actions =
                [
                    _act.Primary(Icons.Material.Filled.Edit,   Localization.GetString("Edit"),   GoToEdit),
                    _act.Primary(Icons.Material.Filled.Undo,   Localization.GetString("Draft"),  RevertToDraft),
                    _act.Error(Icons.Material.Filled.Cancel,   Localization.GetString("Cancel"), CancelNote, dividerBefore: true),
                ];
                break;

            case PurchaseNoteStatus.Paid:
                // No actions available for a paid note
                break;

            case PurchaseNoteStatus.Cancelled:
                _primaryAction = _act.Error(Icons.Material.Filled.Delete, Localization.GetString("Delete"), DeleteNote);
                break;
        }
    }

    // ── Actions ───────────────────────────────────────────────────────────────

    private void GoToEdit() => Navigation.NavigateTo($"/purchase-notes/edit/{Id}"); // kept as void; _act.Primary accepts Action overload

    private async Task ReceiveGoods()
    {
        // No confirm — straightforward "goods arrived" action
        try
        {
            await PurchaseNoteService.ReceiveAsync(Id);
            Snackbar.Add(Localization.GetString("PurchaseNoteReceived"), Severity.Success);
            await LoadNote();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error receiving goods: {ex.Message}");
            Snackbar.Add(Localization.GetString("ErrorUpdatingPurchaseNote"), Severity.Error);
        }
    }

    private async Task MarkAsPaid()
    {
        try
        {
            await PurchaseNoteService.MarkAsPaidAsync(Id);
            Snackbar.Add(Localization.GetString("PurchaseNoteMarkedPaid"), Severity.Success);
            await LoadNote();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error marking as paid: {ex.Message}");
            Snackbar.Add(Localization.GetString("ErrorUpdatingPurchaseNote"), Severity.Error);
        }
    }

    private async Task RevertToDraft()
    {
        bool confirmed = await WisDialog.ConfirmAsync(
            Localization.GetString("RevertToDraft"),
            Localization.GetString("RevertToDraftConfirm"),
            Localization.GetString("Revert"),
            Localization.GetString("Cancel"));

        if (!confirmed) return;

        try
        {
            await PurchaseNoteService.RevertToDraftAsync(Id);
            Snackbar.Add(Localization.GetString("PurchaseNoteRevertedToDraft"), Severity.Success);
            await LoadNote();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error reverting to draft: {ex.Message}");
            Snackbar.Add(Localization.GetString("ErrorUpdatingPurchaseNote"), Severity.Error);
        }
    }

    private async Task DeleteNote()
    {
        bool confirmed = await WisDialog.ConfirmAsync(
            Localization.GetString("ConfirmDelete"),
            Localization.GetString("DeletePurchaseNoteConfirm"),
            Localization.GetString("Delete"),
            Localization.GetString("Back"));

        if (!confirmed) return;

        try
        {
            await PurchaseNoteService.DeletePurchaseNoteAsync(Id);
            Snackbar.Add(Localization.GetString("PurchaseNoteDeleted"), Severity.Success);
            Navigation.NavigateTo("/purchase-notes");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error deleting purchase note: {ex.Message}");
            Snackbar.Add(Localization.GetString("ErrorUpdatingPurchaseNote"), Severity.Error);
        }
    }

    private async Task CancelNote()
    {
        string message = _note!.Status == PurchaseNoteStatus.Pending
            ? Localization.GetString("CancelPendingNoteConfirm")
            : Localization.GetString("CancelDraftNoteConfirm");

        bool confirmed = await WisDialog.ConfirmAsync(
            Localization.GetString("CancelPurchaseNote"),
            message,
            Localization.GetString("Cancel"),
            Localization.GetString("Back"));

        if (!confirmed) return;

        try
        {
            await PurchaseNoteService.CancelAsync(Id);
            Snackbar.Add(Localization.GetString("PurchaseNoteCancelled"), Severity.Success);
            await LoadNote();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error cancelling purchase note: {ex.Message}");
            Snackbar.Add(Localization.GetString("ErrorUpdatingPurchaseNote"), Severity.Error);
        }
    }

    // ── Helpers ───────────────────────────────────────────────────────────────

    private Color GetStatusColor(PurchaseNoteStatus status) => status switch
    {
        PurchaseNoteStatus.Draft => Color.Default,
        PurchaseNoteStatus.Pending => Color.Warning,
        PurchaseNoteStatus.Paid => Color.Success,
        PurchaseNoteStatus.Cancelled => Color.Error,
        _ => Color.Default
    };

    private string GetStatusText(PurchaseNoteStatus status) => status switch
    {
        PurchaseNoteStatus.Draft => Localization.GetString("Draft"),
        PurchaseNoteStatus.Pending => Localization.GetString("PendingStatus"),
        PurchaseNoteStatus.Paid => Localization.GetString("PaidStatus"),
        PurchaseNoteStatus.Cancelled => Localization.GetString("CancelledStatus"),
        _ => status.ToString()
    };

    public void Dispose()
    {
        _cts.Cancel();
        _cts.Dispose();
        Localization.OnLanguageChanged -= OnLanguageChanged;
    }
}
