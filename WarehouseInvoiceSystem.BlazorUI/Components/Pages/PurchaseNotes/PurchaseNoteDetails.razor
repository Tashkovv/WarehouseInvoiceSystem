@page "/purchase-notes/{Id:guid}"
@attribute [Authorize]
@inherits PageBase
@using WarehouseInvoiceSystem.Application.DTOs.Individual
@using WarehouseInvoiceSystem.Application.DTOs.PurchaseNote
@using WarehouseInvoiceSystem.Application.DTOs.Warehouse
@using WarehouseInvoiceSystem.Domain.Enums
@using WarehouseInvoiceSystem.Domain.Queries
@using WarehouseInvoiceSystem.Domain.Queries.Common
@inject IPurchaseNoteService PurchaseNoteService
@inject IWarehouseService WarehouseService
@inject IIndividualService IndividualService
@inject IExcelExportService ExcelExportService

<PageTitle>@Localization.GetString("PurchaseNoteDetails") - @Localization.GetString("InvoiceSystem")</PageTitle>

@if (_loading)
{
    <MudProgressLinear Color="Color.Primary" Indeterminate="true" />
}
else if (_note == null)
{
    <MudAlert Severity="Severity.Error">@Localization.GetString("PurchaseNoteNotFound")</MudAlert>
}
else
{
    <WisDetailHeader BackHref="/purchase-notes"
                     BackLabel="@Localization.GetString("PurchaseNotes")"
                     PrimaryAction="@_primaryAction"
                     Actions="@_actions" />

    @if (_note.Status == PurchaseNoteStatus.Draft && _note.LineItems.Count == 0)
    {
        <MudAlert Severity="Severity.Info" Class="mb-3">@Localization.GetString("AddItemsBeforeReceiveGoods")</MudAlert>
    }

    <MudGrid>

        @* ── Header card ── *@
        <MudItem xs="12">
            <MudCard Elevation="2">
                <MudCardContent Class="pa-4">

                    <div class="wis-contact-row mb-4">
                        <div class="wis-contact-row-left">

                            @* Note number + status *@
                            <div class="wis-detail-identity mb-3">
                                <MudText Typo="Typo.h4" Class="font-weight-bold mb-0" Style="font-family: monospace;">
                                    @_note.NoteNumber
                                </MudText>
                                <MudChip T="string" Size="Size.Small" Color="@GetPurchaseNoteStatusColor(_note.Status)">
                                    @GetPurchaseNoteStatusText(_note.Status)
                                </MudChip>
                            </div>

                            <div class="wis-detail-contact">

                                @* ── Individual (display only) ── *@
                                <div class="wis-detail-contact-item">
                                    <MudIcon Icon="@Icons.Material.Filled.Person" Size="Size.Small" Color="Color.Secondary" />
                                    <MudText Typo="Typo.body2" Style="font-weight:500">@_note.IndividualFullName</MudText>
                                </div>
                                <div class="wis-detail-contact-item">
                                    <MudIcon Icon="@Icons.Material.Filled.Badge" Size="Size.Small" Color="Color.Secondary" />
                                    <MudText Typo="Typo.body2" Color="Color.Secondary">@_note.IndividualIdentificationNumber</MudText>
                                </div>

                                @* ── Warehouse ── *@
                                @if (_warehouseEditing)
                                {
                                    <div class="wis-detail-contact-item">
                                        <MudIcon Icon="@Icons.Material.Filled.Warehouse" Size="Size.Small" Color="Color.Secondary" Style="flex-shrink:0" />
                                        <div style="flex:1;min-width:0;">
                                            <WisSelect T="WarehouseDto" Items="_warehouses" Value="_warehouseEdit"
                                                       ValueChanged="@(w => _warehouseEdit = w)"
                                                       ToStringFunc="@(w => w?.Name ?? "")"
                                                       Label="@Localization.GetString("Warehouse")" FullWidth="true" />
                                        </div>
                                        <MudIconButton Icon="@Icons.Material.Filled.Close" Size="Size.Small" OnClick="CancelWarehouseEdit" Disabled="@_warehouseSaving" />
                                        <MudIconButton Icon="@Icons.Material.Filled.Check" Size="Size.Small" Color="Color.Primary" OnClick="SaveWarehouse" Disabled="@(_warehouseSaving || _warehouseEdit == null)" />
                                    </div>
                                }
                                else
                                {
                                    <div class="wis-detail-contact-item">
                                        <MudIcon Icon="@Icons.Material.Filled.Warehouse" Size="Size.Small" Color="Color.Secondary" />
                                        <MudText Typo="Typo.body2">@_note.WarehouseName</MudText>
                                        @if (_note.Status == PurchaseNoteStatus.Draft)
                                        {
                                            <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small" OnClick="StartWarehouseEdit" />
                                        }
                                    </div>
                                }

                            </div>
                        </div>

                        <div class="wis-contact-row-divider"></div>

                        @* ── Notes ── *@
                        <div class="wis-contact-row-right">
                            @if (_notesEditMode)
                            {
                                <div class="d-flex align-center gap-1 mb-0">
                                    <MudIcon Icon="@Icons.Material.Filled.Notes" Size="Size.Small" Color="Color.Secondary" />
                                    <MudText Typo="Typo.caption" Color="Color.Secondary" Class="wis-section-label flex-grow-1" Style="margin-bottom:0">@Localization.GetString("Notes")</MudText>
                                    <MudIconButton Icon="@Icons.Material.Filled.Close" Size="Size.Small" OnClick="CancelNotesEdit" Disabled="@_notesSaving" />
                                    <MudIconButton Icon="@Icons.Material.Filled.Check" Size="Size.Small" Color="Color.Primary" OnClick="SaveNotes" Disabled="@_notesSaving" />
                                </div>
                                <WisInput @bind-Value="_notesEditValue" CssClass="mt-2" />
                            }
                            else
                            {
                                <div class="d-flex align-center gap-1 mb-0">
                                    <MudIcon Icon="@Icons.Material.Filled.Notes" Size="Size.Small" Color="Color.Secondary" />
                                    <MudText Typo="Typo.caption" Color="Color.Secondary" Class="wis-section-label flex-grow-1" Style="margin-bottom:0">@Localization.GetString("Notes")</MudText>
                                    <MudIconButton Icon="@(string.IsNullOrWhiteSpace(_note.Notes) ? Icons.Material.Filled.Add : Icons.Material.Filled.Edit)"
                                                   Size="Size.Small"
                                                   OnClick="@(() => StartNotesEdit(_note?.Notes))" />
                                </div>
                                <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mt-0" Style="line-height:1.6;">
                                    @(string.IsNullOrWhiteSpace(_note.Notes) ? "—" : _note.Notes)
                                </MudText>
                            }
                        </div>
                    </div>

                    <MudDivider Class="mb-4" />

                    @* Stats row *@
                    <MudGrid Spacing="4" Class="wis-detail-stats">

                        <MudItem xs="3">
                            <MudText Typo="Typo.caption" Color="Color.Secondary" Class="wis-section-label">@Localization.GetString("Total")</MudText>
                            <div class="wis-stat-value mud-primary-text">@_note.TotalAmount.ToString("C")</div>
                            <MudText Typo="Typo.body2" Color="Color.Secondary">@_note.LineItems.Count @Localization.GetString("Products")</MudText>
                        </MudItem>

                        <MudItem xs="3">
                            @* ── Purchase Date inline edit ── *@
                            <MudText Typo="Typo.caption" Color="Color.Secondary" Class="wis-section-label">@Localization.GetString("PurchaseDate")</MudText>
                            @if (_purchaseDateEditing)
                            {
                                <div class="d-flex align-center gap-0">
                                    <div style="width:232px">
                                        <WisDateInput Date="@_purchaseDateEdit"
                                                      DateChanged="@(d => _purchaseDateEdit = d)"
                                                      Label="" />
                                    </div>
                                    <MudIconButton Icon="@Icons.Material.Filled.Close" Size="Size.Small" OnClick="CancelPurchaseDateEdit" Disabled="@_purchaseDateSaving" />
                                    <MudIconButton Icon="@Icons.Material.Filled.Check" Size="Size.Small" Color="Color.Primary" OnClick="SavePurchaseDate" Disabled="@(_purchaseDateSaving || _purchaseDateEdit == null)" />
                                </div>
                            }
                            else
                            {
                                <div class="d-flex align-center gap-1">
                                    <div class="wis-stat-value">@_note.PurchaseDate.ToString("dd MMM yyyy")</div>
                                    @if (_note.Status == PurchaseNoteStatus.Draft)
                                    {
                                        <MudIconButton Icon="@Icons.Material.Filled.EditCalendar" Size="Size.Small" OnClick="StartPurchaseDateEdit" />
                                    }
                                </div>
                            }
                        </MudItem>

                        @if (_note.PaidDate.HasValue)
                        {
                            <MudItem xs="3">
                                <MudText Typo="Typo.caption" Color="Color.Secondary" Class="wis-section-label">@Localization.GetString("PaidDate")</MudText>
                                <div class="wis-stat-value mud-success-text">@_note.PaidDate.Value.ToString("dd MMM yyyy")</div>
                            </MudItem>
                        }

                    </MudGrid>

                </MudCardContent>
            </MudCard>
        </MudItem>

        @* ── Products card ── *@
        <MudItem xs="12">
            <MudCard Elevation="2">
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudText Typo="Typo.h6">@Localization.GetString("Products")</MudText>
                    </CardHeaderContent>
                    <CardHeaderActions>
                        @if (_lineItemsEditing)
                        {
                            <MudIconButton Icon="@Icons.Material.Filled.Close"
                                           Size="Size.Small"
                                           OnClick="CancelLineItemsEdit"
                                           Disabled="@_lineItemsSaving" />
                            <MudIconButton Icon="@Icons.Material.Filled.Check"
                                           Size="Size.Small"
                                           Color="Color.Primary"
                                           OnClick="SaveLineItems"
                                           Disabled="@_lineItemsSaving" />
                        }
                        else if (_note.Status == PurchaseNoteStatus.Draft)
                        {
                            <MudIconButton Icon="@Icons.Material.Filled.Edit"
                                           Size="Size.Small"
                                           OnClick="StartLineItemsEdit" />
                        }
                    </CardHeaderActions>
                </MudCardHeader>
                <MudCardContent Class="pa-0">
                    <PurchaseNoteLineItemsEditor Items="_lineItemsModels"
                                                 ItemsChanged="@(items => _lineItemsModels = items)"
                                                 ReadOnly="@(!_lineItemsEditing)" />
                </MudCardContent>
            </MudCard>
        </MudItem>

    </MudGrid>
}

@code {
    [Parameter] public Guid Id { get; set; }

    private PurchaseNoteDto? _note;
    private WisDetailActionItem? _primaryAction;
    private List<WisDetailActionItem> _actions = [];

    // ── Individual inline edit ─────────────────────────────────────────────────
    private bool _individualEditing, _individualSaving;
    private Guid? _individualEdit;

    // ── Warehouse inline edit ──────────────────────────────────────────────────
    private bool _warehouseEditing, _warehouseSaving;
    private WarehouseDto? _warehouseEdit;
    private List<WarehouseDto> _warehouses = [];

    // ── Purchase date inline edit ──────────────────────────────────────────────
    private bool _purchaseDateEditing, _purchaseDateSaving;
    private DateTime? _purchaseDateEdit;

    // ── Line items edit ────────────────────────────────────────────────────────
    private bool _lineItemsEditing, _lineItemsSaving;
    private List<PurchaseNoteLineItemEditorModel> _lineItemsModels = [];

    protected override async Task OnInitializedAsync()
    {
        await base.OnInitializedAsync();
        await Task.WhenAll(LoadNote(), LoadWarehouses());
    }

    protected override async void OnLanguageChanged() => await InvokeAsync(() =>
    {
        BuildActions();
        StateHasChanged();
    });

    private async Task LoadWarehouses()
    {
        try
        {
            PagedResult<WarehouseDto> result = await WarehouseService.GetPagedAsync(
                new GetWarehousesQuery { Page = 1, PageSize = 100, IsActive = true, SortBy = "Name", SortAscending = true },
                _cts.Token);
            _warehouses = [.. result.Items];
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading warehouses: {ex.Message}");
        }
    }

    private async Task LoadNote() =>
        await SafeLoadAsync(async () =>
        {
            _note = await PurchaseNoteService.GetPurchaseNoteByIdAsync(Id, CancellationToken.None);
            if (_note is not null)
                BuildLineItemModels();
            BuildActions();
        }, "ErrorLoadingPurchaseNote");

    private void BuildLineItemModels()
    {
        if (_note is null) return;
        _lineItemsModels = [.. _note.LineItems.Select(li => new PurchaseNoteLineItemEditorModel
        {
            Id = li.Id,
            SelectedProduct = new Application.DTOs.Product.ProductDto
            {
                Id = li.ProductId,
                Code = li.ProductCode,
                Name = li.ProductName,
                Unit = li.ProductUnit,
                CostPrice = li.UnitPrice,
                SellingPrice = 0,
                IsActive = true
            },
            Description = li.Description,
            GrossQuantity = li.GrossQuantity,
            KaloPercentage = li.KaloPercentage,
            UnitPrice = li.UnitPrice
        })];
    }

    private void BuildActions()
    {
        if (_note == null) return;

        _primaryAction = null;
        _actions = [];

        WisDetailActionItem exportAction = _act.Primary(Icons.Material.Filled.Print, Localization.GetString("Export"), ExportForPrinting);
        WisDetailActionItem copyAction = _act.Secondary(Icons.Material.Filled.ContentCopy, Localization.GetString("Copy"), CopyNote);

        switch (_note.Status)
        {
            case PurchaseNoteStatus.Draft:
                _primaryAction = _act.Warning(Icons.Material.Filled.MoveToInbox, Localization.GetString("ReceiveGoods"), ReceiveGoods,
                    disabled: _note.LineItems.Count == 0);
                _actions =
                [
                    exportAction,
                    copyAction,
                    _act.Error(Icons.Material.Filled.Cancel, Localization.GetString("Cancel"), CancelNote, dividerBefore: true),
                ];
                break;

            case PurchaseNoteStatus.Pending:
                _primaryAction = _act.Success(Icons.Material.Filled.Payment, Localization.GetString("MarkAsPaid"), MarkAsPaid);
                _actions =
                [
                    exportAction,
                    copyAction,
                    _act.Primary(Icons.Material.Filled.Undo, Localization.GetString("Draft"), RevertToDraft),
                    _act.Error(Icons.Material.Filled.Cancel, Localization.GetString("Cancel"), CancelNote, dividerBefore: true),
                ];
                break;

            case PurchaseNoteStatus.Paid:
                _primaryAction = exportAction;
                _actions = [copyAction];
                break;

            case PurchaseNoteStatus.Cancelled:
                _primaryAction = _act.Error(Icons.Material.Filled.Delete, Localization.GetString("Delete"), DeleteNote);
                _actions = [exportAction, copyAction];
                break;
        }
    }

    // ── Individual edit ────────────────────────────────────────────────────────

    private void StartIndividualEdit()
    {
        _individualEdit = _note?.IndividualId;
        _individualEditing = true;
    }

    private void CancelIndividualEdit()
    {
        _individualEditing = false;
        _individualEdit = null;
    }

    private async Task SaveIndividual()
    {
        if (_note is null || _individualEdit is null) return;
        _individualSaving = true;
        try
        {
            await PurchaseNoteService.UpdateIndividualAsync(Id, _individualEdit.Value);
            _individualEditing = false;
            _individualEdit = null;
            await LoadNote();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error updating individual: {ex.Message}");
            Snackbar.Add(Localization.GetString("ErrorUpdatingPurchaseNote"), Severity.Error);
        }
        finally { _individualSaving = false; }
    }

    private async Task<PagedResult<WisAutocompleteItem<Guid>>> LoadIndividualItems(
        string search, int page, CancellationToken ct)
    {
        PagedResult<IndividualDto> result = await IndividualService.GetPagedAsync(
            new GetIndividualsQuery { Search = search, Page = page, PageSize = 10, IsActive = true }, ct);
        return new PagedResult<WisAutocompleteItem<Guid>>
        {
            Items = result.Items.Select(i => new WisAutocompleteItem<Guid>
            {
                Value = i.Id,
                Label = i.FullName,
                SubLabel = i.IdentificationNumber
            }).ToList(),
            Page = result.Page,
            PageSize = result.PageSize,
            TotalCount = result.TotalCount
        };
    }

    // ── Warehouse edit ─────────────────────────────────────────────────────────

    private void StartWarehouseEdit()
    {
        _warehouseEdit = _warehouses.FirstOrDefault(w => w.Id == _note?.WarehouseId);
        _warehouseEditing = true;
    }

    private void CancelWarehouseEdit()
    {
        _warehouseEditing = false;
        _warehouseEdit = null;
    }

    private async Task SaveWarehouse()
    {
        if (_note is null || _warehouseEdit is null) return;
        _warehouseSaving = true;
        try
        {
            await PurchaseNoteService.UpdateWarehouseAsync(Id, _warehouseEdit.Id);
            _warehouseEditing = false;
            _warehouseEdit = null;
            await LoadNote();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error updating warehouse: {ex.Message}");
            Snackbar.Add(Localization.GetString("ErrorUpdatingPurchaseNote"), Severity.Error);
        }
        finally { _warehouseSaving = false; }
    }

    // ── Purchase date edit ─────────────────────────────────────────────────────

    private void StartPurchaseDateEdit()
    {
        _purchaseDateEdit = _note?.PurchaseDate;
        _purchaseDateEditing = true;
    }

    private void CancelPurchaseDateEdit()
    {
        _purchaseDateEditing = false;
        _purchaseDateEdit = null;
    }

    private async Task SavePurchaseDate()
    {
        if (_note is null || _purchaseDateEdit is null) return;
        _purchaseDateSaving = true;
        try
        {
            await PurchaseNoteService.UpdatePurchaseDateAsync(Id, _purchaseDateEdit.Value);
            _purchaseDateEditing = false;
            _purchaseDateEdit = null;
            await LoadNote();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error updating purchase date: {ex.Message}");
            Snackbar.Add(Localization.GetString("ErrorUpdatingPurchaseNote"), Severity.Error);
        }
        finally { _purchaseDateSaving = false; }
    }

    // ── Line items edit ────────────────────────────────────────────────────────

    private void StartLineItemsEdit() => _lineItemsEditing = true;

    private void CancelLineItemsEdit()
    {
        _lineItemsEditing = false;
        BuildLineItemModels();
    }

    private async Task SaveLineItems()
    {
        if (_note is null) return;
        _lineItemsSaving = true;
        try
        {
            UpdatePurchaseNoteDto dto = new()
            {
                IndividualId = _note.IndividualId,
                WarehouseId = _note.WarehouseId,
                PurchaseDate = _note.PurchaseDate,
                Notes = _note.Notes,
                LineItems = [.. _lineItemsModels
                    .Where(li => li.SelectedProduct != null)
                    .Select(li => new UpdatePurchaseNoteLineDto
                    {
                        Id = li.Id,
                        ProductId = li.SelectedProduct!.Id,
                        Description = li.Description,
                        GrossQuantity = li.GrossQuantity,
                        KaloPercentage = li.KaloPercentage,
                        Quantity = li.Quantity,
                        UnitPrice = li.UnitPrice
                    })]
            };

            await PurchaseNoteService.UpdatePurchaseNoteAsync(Id, dto);
            _lineItemsEditing = false;
            await LoadNote();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error updating line items: {ex.Message}");
            Snackbar.Add(Localization.GetString("ErrorUpdatingPurchaseNote"), Severity.Error);
        }
        finally { _lineItemsSaving = false; }
    }

    // ── Notes ──────────────────────────────────────────────────────────────────

    private async Task SaveNotes()
    {
        if (_note is null) return;
        await SaveNotesAsync(async notes =>
        {
            await PurchaseNoteService.UpdateNotesAsync(Id, notes, CancellationToken.None);
            _note.Notes = notes;
        }, "ErrorUpdatingPurchaseNote");
    }

    // ── Status actions ─────────────────────────────────────────────────────────

    private async Task ExportForPrinting()
    {
        try
        {
            byte[] fileBytes = await ExcelExportService.ExportPurchaseNoteForPrintingAsync(_note!);
            string fileName = $"{Localization.GetString("PurchaseNote")}_{_note?.NoteNumber}_{DateTime.UtcNow:yyyyMMdd}.xlsx";
            await DownloadFileAsync(fileBytes, fileName);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error exporting purchase note: {ex.Message}");
            Snackbar.Add(Localization.GetString("ExportError"), Severity.Error);
        }
    }

    private async Task CopyNote()
    {
        try
        {
            Guid newId = await PurchaseNoteService.DuplicatePurchaseNoteAsync(Id);
            Navigation.NavigateTo($"/purchase-notes/{newId}");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error copying purchase note: {ex.Message}");
            Snackbar.Add(Localization.GetString("ErrorCreatingPurchaseNote"), Severity.Error);
        }
    }

    private async Task ReceiveGoods()
    {
        try
        {
            await PurchaseNoteService.ReceiveAsync(Id);
            Snackbar.Add(Localization.GetString("PurchaseNoteReceived"), Severity.Success);
            await LoadNote();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error receiving goods: {ex.Message}");
            Snackbar.Add(Localization.GetString("ErrorUpdatingPurchaseNote"), Severity.Error);
        }
    }

    private async Task MarkAsPaid()
    {
        try
        {
            await PurchaseNoteService.MarkAsPaidAsync(Id);
            Snackbar.Add(Localization.GetString("PurchaseNoteMarkedPaid"), Severity.Success);
            await LoadNote();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error marking as paid: {ex.Message}");
            Snackbar.Add(Localization.GetString("ErrorUpdatingPurchaseNote"), Severity.Error);
        }
    }

    private async Task RevertToDraft() =>
        await ConfirmAndExecuteAsync(
            Localization.GetString("RevertToDraft"),
            Localization.GetString("RevertToDraftConfirm"),
            async () => { await PurchaseNoteService.RevertToDraftAsync(Id); await LoadNote(); },
            "PurchaseNoteRevertedToDraft", "ErrorUpdatingPurchaseNote",
            Localization.GetString("Revert"), Localization.GetString("Cancel"));

    private async Task DeleteNote() =>
        await ConfirmAndExecuteAsync(
            Localization.GetString("ConfirmDelete"),
            Localization.GetString("DeletePurchaseNoteConfirm"),
            async () => { await PurchaseNoteService.DeletePurchaseNoteAsync(Id); Navigation.NavigateTo("/purchase-notes"); },
            "PurchaseNoteDeleted", "ErrorUpdatingPurchaseNote",
            Localization.GetString("Delete"), Localization.GetString("Back"));

    private async Task CancelNote()
    {
        string message = _note!.Status == PurchaseNoteStatus.Pending
            ? Localization.GetString("CancelPendingNoteConfirm")
            : Localization.GetString("CancelDraftNoteConfirm");

        await ConfirmAndExecuteAsync(
            Localization.GetString("CancelPurchaseNote"), message,
            async () => { await PurchaseNoteService.CancelAsync(Id); await LoadNote(); },
            "PurchaseNoteCancelled", "ErrorUpdatingPurchaseNote",
            Localization.GetString("Cancel"), Localization.GetString("Back"));
    }
}
