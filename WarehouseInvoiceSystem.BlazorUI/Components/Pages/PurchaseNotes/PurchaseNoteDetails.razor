@page "/purchase-notes/{Id:guid}"
@using WarehouseInvoiceSystem.Application.Interfaces
@using WarehouseInvoiceSystem.Application.DTOs.PurchaseNote
@using WarehouseInvoiceSystem.Domain.Enums
@inject IPurchaseNoteService PurchaseNoteService
@inject ILocalizationService Localization
@inject NavigationManager Navigation
@inject IDialogService DialogService
@inject ISnackbar Snackbar

<PageTitle>@Localization.GetString("PurchaseNoteDetails") - @Localization.GetString("InvoiceSystem")</PageTitle>

@if (_loading)
{
    <MudProgressLinear Color="Color.Primary" Indeterminate="true" />
}
else if (_model == null)
{
    <MudAlert Severity="Severity.Error">@Localization.GetString("PurchaseNoteNotFound")</MudAlert>
}
else
{
    <div class="d-flex justify-space-between align-center mb-4">
        <div>
            <MudButton StartIcon="@Icons.Material.Filled.ArrowBack" 
                       Variant="Variant.Text"
                       Href="/purchase-notes">
                @Localization.GetString("BackToPurchaseNotes")
            </MudButton>
        </div>
        <div>
            @if (_model.Status != PurchaseNoteStatus.Paid)
            {
                <MudButton Variant="Variant.Filled"
                           Color="Color.Success"
                           StartIcon="@Icons.Material.Filled.Payment"
                           OnClick="MarkAsPaid">
                    @Localization.GetString("MarkAsPaid")
                </MudButton>
            }
            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       StartIcon="@Icons.Material.Filled.Edit"
                       OnClick="EditNote"
                       Class="ml-2">
                @Localization.GetString("Edit")
            </MudButton>
            <MudButton Variant="Variant.Outlined"
                       Color="Color.Error"
                       StartIcon="@Icons.Material.Filled.Delete"
                       OnClick="DeleteNote"
                       Class="ml-2">
                @Localization.GetString("Delete")
            </MudButton>
        </div>
    </div>
    <MudGrid>
        <!-- Purchase Note Header - Single Card -->
        <MudItem xs="12">
            <MudCard Elevation="2">
                <MudCardContent Class="pa-6">
                    <MudGrid Spacing="4">
                        <!-- Left: Note Number + Status + Individual -->
                        <MudItem xs="12" md="6">
                            <MudStack Spacing="2">
                                <div class="d-flex align-center gap-3">
                                    <MudText Typo="Typo.h4" Class="mb-0">@_model.NoteNumber</MudText>
                                    <MudChip T="string" Size="Size.Small" Color="GetStatusColor(_model.Status)">
                                        @GetStatusText(_model.Status)
                                    </MudChip>
                                </div>

                                <MudDivider Class="my-2" />

                                <div class="d-flex align-center">
                                    <MudIcon Icon="@Icons.Material.Filled.Person" Size="Size.Small" Class="mr-2" Color="Color.Secondary" />
                                    <MudText Typo="Typo.h6" Class="mb-0">@_model.IndividualFullName</MudText>
                                </div>

                                <div class="d-flex align-center">
                                    <MudIcon Icon="@Icons.Material.Filled.Badge" Size="Size.Small" Class="mr-2" Color="Color.Secondary" />
                                    <MudText Typo="Typo.body2" Color="Color.Secondary">
                                        @Localization.GetString("IdentificationNumber"): <strong>@_model.IndividualIdentificationNumber</strong>
                                    </MudText>
                                </div>
                            </MudStack>
                        </MudItem>

                        <!-- Divider (visible on medium+ screens) -->
                        <MudHidden Breakpoint="Breakpoint.SmAndDown">
                            <MudItem md="1" Class="d-flex align-center justify-center">
                                <MudDivider Vertical="true" />
                            </MudItem>
                        </MudHidden>

                        <!-- Right: Amount + Dates + Warehouse -->
                        <MudItem xs="12" md="5">
                            <MudStack Spacing="3">
                                <!-- Total Amount -->
                                <div>
                                    <MudText Typo="Typo.h3" Color="Color.Primary" Class="mb-0">
                                        @_model.TotalAmount.ToString("C")
                                    </MudText>
                                </div>

                                <MudDivider />

                                <!-- Purchase Date & Warehouse -->
                                <MudStack Row="true" Spacing="4">
                                    <div style="flex: 1;">
                                        <div class="d-flex align-center mb-1">
                                            <MudIcon Icon="@Icons.Material.Filled.CalendarToday" Size="Size.Small" Class="mr-1" Color="Color.Secondary" />
                                            <MudText Typo="Typo.caption" Color="Color.Secondary">@Localization.GetString("PurchaseDate")</MudText>
                                        </div>
                                        <MudText Typo="Typo.body1" Class="font-weight-medium">
                                            @_model.PurchaseDate.ToString("dd MMM yyyy")
                                        </MudText>
                                    </div>

                                    @if (!string.IsNullOrEmpty(_model.WarehouseName))
                                    {
                                        <div style="flex: 1;">
                                            <div class="d-flex align-center mb-1">
                                                <MudIcon Icon="@Icons.Material.Filled.Warehouse" Size="Size.Small" Class="mr-1" Color="Color.Secondary" />
                                                <MudText Typo="Typo.caption" Color="Color.Secondary">@Localization.GetString("Warehouse")</MudText>
                                            </div>
                                            <MudText Typo="Typo.body1" Class="font-weight-medium">
                                                @_model.WarehouseName
                                            </MudText>
                                        </div>
                                    }
                                </MudStack>

                                <!-- Paid Date (if exists) -->
                                @if (_model.PaidDate.HasValue)
                                {
                                    <div>
                                        <div class="d-flex align-center mb-1">
                                            <MudIcon Icon="@Icons.Material.Filled.Payment" Size="Size.Small" Class="mr-1" Color="Color.Success" />
                                            <MudText Typo="Typo.caption" Color="Color.Secondary">@Localization.GetString("PaidDate")</MudText>
                                        </div>
                                        <MudText Typo="Typo.body1" Class="font-weight-medium" Color="Color.Success">
                                            @_model.PaidDate.Value.ToString("dd MMM yyyy")
                                        </MudText>
                                    </div>
                                }
                            </MudStack>
                        </MudItem>
                    </MudGrid>

                    <!-- Notes Section (Full Width) - if you have notes field -->
                    @if (!string.IsNullOrWhiteSpace(_model.Notes))
                    {
                        <MudDivider Class="my-4" />
                        <div class="d-flex align-start">
                            <MudIcon Icon="@Icons.Material.Filled.Notes" Size="Size.Small" Class="mr-2 mt-1" Color="Color.Secondary" />
                            <div style="flex: 1;">
                                <MudText Typo="Typo.caption" Color="Color.Dark" Class="mb-1">@Localization.GetString("Notes")</MudText>
                                <MudText Typo="Typo.body2" Color="Color.Secondary" Style="line-height: 1.6;">
                                    @_model.Notes
                                </MudText>
                            </div>
                        </div>
                    }
                </MudCardContent>
            </MudCard>
        </MudItem>

        <!-- Line Items -->
        <MudItem xs="12">
            <MudCard Elevation="2">
                <MudCardHeader>
                    <CardHeaderContent>
                        <div class="d-flex align-center gap-3">
                            <MudText Typo="Typo.h6">@Localization.GetString("Products")</MudText>
                        </div>
                    </CardHeaderContent>
                </MudCardHeader>
                <MudCardContent Class="pa-0">
                    <MudTable Items="_model.LineItems"
                              Hover="true"
                              Breakpoint="Breakpoint.Sm"
                              Elevation="0">
                        <HeaderContent>
                            <MudTh>@Localization.GetString("Product")</MudTh>
                            <MudTh>@Localization.GetString("Description")</MudTh>
                            <MudTh Style="text-align: right;">@Localization.GetString("Quantity")</MudTh>
                            <MudTh Style="text-align: right;">@Localization.GetString("UnitPrice")</MudTh>
                            <MudTh Style="text-align: right;">@Localization.GetString("Amount")</MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd DataLabel="@Localization.GetString("Product")">
                                <MudText Typo="Typo.body2" Class="font-weight-medium">@context.ProductCode</MudText>
                                <MudText Typo="Typo.body2" Color="Color.Dark">@context.ProductName</MudText>
                            </MudTd>
                            <MudTd DataLabel="@Localization.GetString("Description")">
                                <MudText Typo="Typo.body2" Color="Color.Dark">
                                    @(string.IsNullOrEmpty(context.Description) ? "-" : context.Description)
                                </MudText>
                            </MudTd>
                            <MudTd DataLabel="@Localization.GetString("Quantity")" Style="text-align: right;">
                                <MudText Typo="Typo.body2" Class="font-weight-medium">
                                    @context.Quantity.ToString("N2")
                                    <MudText Typo="Typo.body2" Color="Color.Dark" Inline="true">
                                        @context.ProductUnit
                                    </MudText>
                                </MudText>
                            </MudTd>
                            <MudTd DataLabel="@Localization.GetString("UnitPrice")" Style="text-align: right;">
                                <MudText Typo="Typo.body2" Color="Color.Dark">
                                    @context.UnitPrice.ToString("C")
                                </MudText>
                            </MudTd>
                            <MudTd DataLabel="@Localization.GetString("Amount")" Style="text-align: right;">
                                <MudText Typo="Typo.body2" Class="font-weight-bold" Color="Color.Primary">
                                    @context.Amount.ToString("C")
                                </MudText>
                            </MudTd>
                        </RowTemplate>
                    </MudTable>

                    <MudDivider />

                    <!-- Totals Section -->
                    <div class="d-flex justify-end pa-4">
                        <MudStack Spacing="1" Style="min-width: 300px;">
                            <div class="d-flex justify-space-between align-center">
                                <MudText Typo="Typo.body2" Color="Color.Secondary">
                                    @_model.LineItems.Count @Localization.GetString("Items")
                                </MudText>
                            </div>
                            <MudDivider Class="my-1" />
                            <div class="d-flex justify-space-between align-center">
                                <MudText Typo="Typo.h6" Class="font-weight-bold">@Localization.GetString("Total")</MudText>
                                <MudText Typo="Typo.h5" Class="font-weight-bold" Color="Color.Primary">
                                    @_model.TotalAmount.ToString("C")
                                </MudText>
                            </div>
                        </MudStack>
                    </div>
                </MudCardContent>
            </MudCard>
        </MudItem>
    </MudGrid>
}

@code {
    [Parameter] public Guid Id { get; set; }

    private bool _loading = true;
    private PurchaseNoteDto? _model;

    protected override async Task OnInitializedAsync()
    {
        Localization.OnLanguageChanged += OnLanguageChanged;
        await LoadPurchaseNote();
    }

    private async void OnLanguageChanged()
    {
        await InvokeAsync(StateHasChanged);
    }

    private async Task LoadPurchaseNote()
    {
        _loading = true;

        try
        {
            _model = await PurchaseNoteService.GetPurchaseNoteByIdAsync(Id);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading purchase note: {ex.Message}");
            Snackbar.Add(Localization.GetString("ErrorLoadingPurchaseNote"), Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    private Color GetStatusColor(PurchaseNoteStatus status)
    {
        return status switch
        {
            PurchaseNoteStatus.Draft => Color.Default,
            PurchaseNoteStatus.Completed => Color.Info,
            PurchaseNoteStatus.Paid => Color.Success,
            _ => Color.Default
        };
    }

    private string GetStatusText(PurchaseNoteStatus status)
    {
        return status switch
        {
            PurchaseNoteStatus.Draft => Localization.GetString("Draft"),
            PurchaseNoteStatus.Completed => Localization.GetString("Completed"),
            PurchaseNoteStatus.Paid => Localization.GetString("Paid"),
            _ => status.ToString()
        };
    }

    private void EditNote()
    {
        Navigation.NavigateTo($"/purchase-notes/edit/{Id}");
    }

    private async Task MarkAsPaid()
    {
        try
        {
            await PurchaseNoteService.MarkAsPaidAsync(Id);
            Snackbar.Add(Localization.GetString("PurchaseNoteMarkedPaid"), Severity.Success);
            await LoadPurchaseNote();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error marking note as paid: {ex.Message}");
            Snackbar.Add(Localization.GetString("ErrorUpdatingPurchaseNote"), Severity.Error);
        }
    }

    private async Task DeleteNote()
    {
        var parameters = new DialogParameters
        {
            { "Title", Localization.GetString("ConfirmDelete") },
            { "Message", Localization.GetString("DeletePurchaseNoteConfirm") },
            { "YesText", Localization.GetString("Yes") },
            { "NoText", Localization.GetString("No") }
        };

        bool? result = await DialogService.ShowMessageBoxAsync(
            new MessageBoxOptions
            {
                Title = Localization.GetString("ConfirmDelete"),
                Message = Localization.GetString("DeletePurchaseNoteConfirm"),
                YesText = Localization.GetString("Yes"),
                CancelText = Localization.GetString("No")
            });

        if (result == true)
        {
            try
            {
                bool deleted = await PurchaseNoteService.DeletePurchaseNoteAsync(Id);
                if (deleted)
                {
                    Snackbar.Add(Localization.GetString("PurchaseNoteDeleted"), Severity.Success);
                    Navigation.NavigateTo("/purchase-notes");
                }
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Error deleting purchase note: {ex.Message}");
                Snackbar.Add(Localization.GetString("ErrorDeletingPurchaseNote"), Severity.Error);
            }
        }
    }
}