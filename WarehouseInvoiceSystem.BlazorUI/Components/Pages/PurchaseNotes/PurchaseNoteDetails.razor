@page "/purchase-notes/{Id:guid}"
@attribute [Authorize]
@inherits PageBase
@using WarehouseInvoiceSystem.Application.DTOs.PurchaseNote
@using WarehouseInvoiceSystem.Domain.Enums
@inject IPurchaseNoteService PurchaseNoteService
@inject IExcelExportService ExcelExportService

<PageTitle>@Localization.GetString("PurchaseNoteDetails") - @Localization.GetString("InvoiceSystem")</PageTitle>

@if (_loading)
{
    <MudProgressLinear Color="Color.Primary" Indeterminate="true" />
}
else if (_note == null)
{
    <MudAlert Severity="Severity.Error">@Localization.GetString("PurchaseNoteNotFound")</MudAlert>
}
else
{
    <WisDetailHeader BackHref="/purchase-notes"
                     BackLabel="@Localization.GetString("PurchaseNotes")"
                     PrimaryAction="@_primaryAction"
                     Actions="@_actions" />

    <MudGrid>

        @* ── Header card ── *@
        <MudItem xs="12">
            <MudCard Elevation="2">
                <MudCardContent Class="pa-4">

                    @* Top section: identity + pills (left 6) | notes (right 6) *@
                    <div class="wis-contact-row mb-4">
                        <div class="wis-contact-row-left">

                            @* Row 1: note number + status chip *@
                            <div class="wis-detail-identity mb-3">
                                <MudText Typo="Typo.h4" Class="font-weight-bold mb-0" Style="font-family: monospace;">
                                    @_note.NoteNumber
                                </MudText>
                                <MudChip T="string" Size="Size.Small" Color="@GetPurchaseNoteStatusColor(_note.Status)">
                                    @GetPurchaseNoteStatusText(_note.Status)
                                </MudChip>
                            </div>

                            @* Row 2: individual + warehouse contact pills *@
                            <div class="wis-detail-contact">
                                <div class="wis-detail-contact-item">
                                    <MudIcon Icon="@Icons.Material.Filled.Person" Size="Size.Small" Color="Color.Secondary" />
                                    <MudText Typo="Typo.body2" Style="font-weight: 500;">@_note.IndividualFullName</MudText>
                                </div>
                                <div class="wis-detail-contact-item">
                                    <MudIcon Icon="@Icons.Material.Filled.Badge" Size="Size.Small" Color="Color.Secondary" />
                                    <MudText Typo="Typo.body2" Color="Color.Secondary">@_note.IndividualIdentificationNumber</MudText>
                                </div>
                                <div class="wis-detail-contact-item">
                                    <MudIcon Icon="@Icons.Material.Filled.Warehouse" Size="Size.Small" Color="Color.Secondary" />
                                    <MudText Typo="Typo.body2">@_note.WarehouseName</MudText>
                                </div>
                            </div>

                        </div>

                        <div class="wis-contact-row-divider"></div>
                        <div class="wis-contact-row-right">
                            @if (_notesEditMode)
                            {
                                <div class="d-flex align-center gap-1 mb-0">
                                    <MudIcon Icon="@Icons.Material.Filled.Notes" Size="Size.Small" Color="Color.Secondary" />
                                    <MudText Typo="Typo.caption" Color="Color.Secondary" Class="wis-section-label flex-grow-1" Style="margin-bottom:0">@Localization.GetString("Notes")</MudText>
                                    <MudIconButton Icon="@Icons.Material.Filled.Close"
                                                   Size="Size.Small"

                                                   OnClick="CancelNotesEdit"
                                                   Disabled="@_notesSaving" />
                                    <MudIconButton Icon="@Icons.Material.Filled.Check"
                                                   Size="Size.Small"
                                                   Color="Color.Primary"

                                                   OnClick="SaveNotes"
                                                   Disabled="@_notesSaving" />
                                </div>
                                <WisInput @bind-Value="_notesEditValue"
                                          CssClass="mt-2" />
                            }
                            else
                            {
                                <div class="d-flex align-center gap-1 mb-0">
                                    <MudIcon Icon="@Icons.Material.Filled.Notes" Size="Size.Small" Color="Color.Secondary" />
                                    <MudText Typo="Typo.caption" Color="Color.Secondary" Class="wis-section-label flex-grow-1" Style="margin-bottom:0">@Localization.GetString("Notes")</MudText>
                                    <MudIconButton Icon="@(string.IsNullOrWhiteSpace(_note.Notes) ? Icons.Material.Filled.Add : Icons.Material.Filled.Edit)"
                                                   Size="Size.Small"

                                                   OnClick="@(() => StartNotesEdit(_note?.Notes))" />
                                </div>
                                <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mt-0" Style="line-height: 1.6;">
                                    @(string.IsNullOrWhiteSpace(_note.Notes) ? "—" : _note.Notes)
                                </MudText>
                            }
                        </div>
                    </div>

                    <MudDivider Class="mb-4" />

                    @* Stats row: full width *@
                    <MudGrid Spacing="4" Class="wis-detail-stats">

                        <MudItem xs="3">
                            <MudText Typo="Typo.caption" Color="Color.Secondary" Class="wis-section-label">@Localization.GetString("Total")</MudText>
                            <div class="wis-stat-value mud-info-text">@_note.TotalAmount.ToString("C")</div>
                            <MudText Typo="Typo.body2" Color="Color.Secondary">@_note.LineItems.Count @Localization.GetString("Products")</MudText>
                        </MudItem>

                        <MudItem xs="3">
                            <MudText Typo="Typo.caption" Color="Color.Secondary" Class="wis-section-label">@Localization.GetString("PurchaseDate")</MudText>
                            <div class="wis-stat-value">@_note.PurchaseDate.ToString("dd MMM yyyy")</div>
                        </MudItem>

                        @if (_note.PaidDate.HasValue)
                        {
                            <MudItem xs="3">
                                <MudText Typo="Typo.caption" Color="Color.Secondary" Class="wis-section-label">@Localization.GetString("PaidDate")</MudText>
                                <div class="wis-stat-value mud-success-text">@_note.PaidDate.Value.ToString("dd MMM yyyy")</div>
                            </MudItem>
                        }

                    </MudGrid>

                </MudCardContent>
            </MudCard>
        </MudItem>

        @* ── Line items ── *@
        <MudItem xs="12">
            <MudCard Elevation="2">
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudText Typo="Typo.h6">@Localization.GetString("Products")</MudText>
                    </CardHeaderContent>
                </MudCardHeader>
                <MudCardContent Class="pa-0">
                    <MudTable Items="_note.LineItems"
                              Hover="true"
                              Elevation="0"
                              Class="wis-secondary-list">
                        <HeaderContent>
                            <MudTh>@Localization.GetString("Product")</MudTh>
                            <MudTh>@Localization.GetString("Description")</MudTh>
                            <MudTh Class="text-right">@Localization.GetString("GrossQuantity")</MudTh>
                            <MudTh Class="text-right">@Localization.GetString("KaloPercentage")</MudTh>
                            <MudTh Class="text-right">@Localization.GetString("NetQuantity")</MudTh>
                            <MudTh Class="text-right">@Localization.GetString("UnitPrice")</MudTh>
                            <MudTh Class="text-right">@Localization.GetString("Amount")</MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd DataLabel="@Localization.GetString("Product")">
                                <MudText Typo="Typo.body2">@context.ProductCode - @context.ProductName</MudText>
                            </MudTd>
                            <MudTd DataLabel="@Localization.GetString("Description")">
                                <MudText Typo="Typo.body2">
                                    @(string.IsNullOrWhiteSpace(context.Description) ? "—" : context.Description)
                                </MudText>
                            </MudTd>
                            <MudTd DataLabel="@Localization.GetString("GrossQuantity")" Class="text-right">
                                <MudText Typo="Typo.body2">
                                    @context.GrossQuantity.ToString("N0") @context.ProductUnit
                                </MudText>
                            </MudTd>
                            <MudTd DataLabel="@Localization.GetString("KaloPercentage")" Class="text-right">
                                <MudText Typo="Typo.body2">@context.KaloPercentage.ToString("N0")%</MudText>
                            </MudTd>
                            <MudTd DataLabel="@Localization.GetString("NetQuantity")" Class="text-right">
                                <MudText Typo="Typo.body2" Style="font-weight: 500;">
                                    @context.Quantity.ToString("N0") @context.ProductUnit
                                </MudText>
                            </MudTd>
                            <MudTd DataLabel="@Localization.GetString("UnitPrice")" Class="text-right">
                                <MudText Typo="Typo.body2">@context.UnitPrice.ToString("C")</MudText>
                            </MudTd>
                            <MudTd DataLabel="@Localization.GetString("Amount")" Class="text-right">
                                <MudText Typo="Typo.body2" Color="Color.Primary">@context.Amount.ToString("C")</MudText>
                            </MudTd>
                        </RowTemplate>
                    </MudTable>

                </MudCardContent>
            </MudCard>
        </MudItem>

    </MudGrid>
}

@code {
    [Parameter] public Guid Id { get; set; }

    private PurchaseNoteDto? _note;
    private WisDetailActionItem? _primaryAction;
    private List<WisDetailActionItem> _actions = [];

    protected override async Task OnInitializedAsync()
    {
        await base.OnInitializedAsync();
        await LoadNote();
    }

    protected override async void OnLanguageChanged() => await InvokeAsync(() =>
    {
        BuildActions();
        StateHasChanged();
    });

    private async Task LoadNote() =>
        await SafeLoadAsync(async () =>
        {
            _note = await PurchaseNoteService.GetPurchaseNoteByIdAsync(Id, CancellationToken.None);
            BuildActions();
        }, "ErrorLoadingPurchaseNote");

    private void BuildActions()
    {
        if (_note == null) return;

        _primaryAction = null;
        _actions = [];

        WisDetailActionItem exportAction = _act.Primary(Icons.Material.Filled.Print, Localization.GetString("Export"), ExportForPrinting);
        WisDetailActionItem copyAction = _act.Secondary(Icons.Material.Filled.ContentCopy, Localization.GetString("Copy"), CopyNote);

        switch (_note.Status)
        {
            case PurchaseNoteStatus.Draft:
                _primaryAction = _act.Warning(Icons.Material.Filled.MoveToInbox, Localization.GetString("ReceiveGoods"), ReceiveGoods);
                _actions =
                [
                    _act.Primary(Icons.Material.Filled.Edit, Localization.GetString("Edit"),   GoToEdit),
                    exportAction,
                    copyAction,
                    _act.Error(Icons.Material.Filled.Cancel, Localization.GetString("Cancel"), CancelNote, dividerBefore: true),
            ];
                break;

            case PurchaseNoteStatus.Pending:
                _primaryAction = _act.Success(Icons.Material.Filled.Payment, Localization.GetString("MarkAsPaid"), MarkAsPaid);
                _actions =
                [
                    exportAction,
                    copyAction,
                    _act.Primary(Icons.Material.Filled.Undo, Localization.GetString("Draft"),  RevertToDraft),
                    _act.Error(Icons.Material.Filled.Cancel, Localization.GetString("Cancel"), CancelNote, dividerBefore: true),
            ];
                break;

            case PurchaseNoteStatus.Paid:
                _primaryAction = copyAction;
                _actions = [exportAction];
                break;

            case PurchaseNoteStatus.Cancelled:
                _primaryAction = _act.Error(Icons.Material.Filled.Delete, Localization.GetString("Delete"), DeleteNote);
                _actions =
                [
                    exportAction,
                    copyAction,
                ];
                break;
        }
    }

    // ── Actions ───────────────────────────────────────────────────────────────

    private void GoToEdit() => Navigation.NavigateTo($"/purchase-notes/edit/{Id}");
    private void CopyNote() => Navigation.NavigateTo($"/purchase-notes/create?copyFrom={Id}");

    private async Task ExportForPrinting()
    {
        try
        {
            byte[] fileBytes = await ExcelExportService.ExportPurchaseNoteForPrintingAsync(_note!);
            string fileName = $"{Localization.GetString("PurchaseNote")}_{_note?.NoteNumber}_{DateTime.UtcNow:yyyyMMdd}.xlsx";
            await DownloadFileAsync(fileBytes, fileName);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error exporting purchase note: {ex.Message}");
            Snackbar.Add(Localization.GetString("ExportError"), Severity.Error);
        }
    }

    private async Task ReceiveGoods()
    {
        // No confirm — straightforward "goods arrived" action
        try
        {
            await PurchaseNoteService.ReceiveAsync(Id);
            Snackbar.Add(Localization.GetString("PurchaseNoteReceived"), Severity.Success);
            await LoadNote();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error receiving goods: {ex.Message}");
            Snackbar.Add(Localization.GetString("ErrorUpdatingPurchaseNote"), Severity.Error);
        }
    }

    private async Task MarkAsPaid()
    {
        try
        {
            await PurchaseNoteService.MarkAsPaidAsync(Id);
            Snackbar.Add(Localization.GetString("PurchaseNoteMarkedPaid"), Severity.Success);
            await LoadNote();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error marking as paid: {ex.Message}");
            Snackbar.Add(Localization.GetString("ErrorUpdatingPurchaseNote"), Severity.Error);
        }
    }

    private async Task RevertToDraft() =>
        await ConfirmAndExecuteAsync(
            Localization.GetString("RevertToDraft"),
            Localization.GetString("RevertToDraftConfirm"),
            async () => { await PurchaseNoteService.RevertToDraftAsync(Id); await LoadNote(); },
            "PurchaseNoteRevertedToDraft", "ErrorUpdatingPurchaseNote",
            Localization.GetString("Revert"), Localization.GetString("Cancel"));

    private async Task DeleteNote() =>
        await ConfirmAndExecuteAsync(
            Localization.GetString("ConfirmDelete"),
            Localization.GetString("DeletePurchaseNoteConfirm"),
            async () => { await PurchaseNoteService.DeletePurchaseNoteAsync(Id); Navigation.NavigateTo("/purchase-notes"); },
            "PurchaseNoteDeleted", "ErrorUpdatingPurchaseNote",
            Localization.GetString("Delete"), Localization.GetString("Back"));

    private async Task CancelNote()
    {
        string message = _note!.Status == PurchaseNoteStatus.Pending
            ? Localization.GetString("CancelPendingNoteConfirm")
            : Localization.GetString("CancelDraftNoteConfirm");

        await ConfirmAndExecuteAsync(
            Localization.GetString("CancelPurchaseNote"), message,
            async () => { await PurchaseNoteService.CancelAsync(Id); await LoadNote(); },
            "PurchaseNoteCancelled", "ErrorUpdatingPurchaseNote",
            Localization.GetString("Cancel"), Localization.GetString("Back"));
    }

    // ── Inline notes editing ──────────────────────────────────────────────────

    private async Task SaveNotes()
    {
        if (_note is null) return;
        await SaveNotesAsync(async notes =>
        {
            await PurchaseNoteService.UpdateNotesAsync(Id, notes, CancellationToken.None);
            _note.Notes = notes;
        }, "ErrorUpdatingPurchaseNote");
    }

}
