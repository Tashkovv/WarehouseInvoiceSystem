@page "/purchase-notes/edit/{Id:guid}"
@inherits PageBase
@using WarehouseInvoiceSystem.Application.DTOs.PurchaseNote
@using WarehouseInvoiceSystem.Application.DTOs.Individual
@using WarehouseInvoiceSystem.Application.DTOs.Product
@using WarehouseInvoiceSystem.Application.DTOs.Warehouse
@using WarehouseInvoiceSystem.Domain.Enums
@using WarehouseInvoiceSystem.Domain.Queries
@using WarehouseInvoiceSystem.Domain.Queries.Common
@inject IPurchaseNoteService PurchaseNoteService
@inject IIndividualService IndividualService
@inject IProductService ProductService
@inject IWarehouseService WarehouseService

<PageTitle>@Localization.GetString("EditPurchaseNote") - @Localization.GetString("InvoiceSystem")</PageTitle>

<WisDetailHeader BackHref="/purchase-notes" BackLabel="@Localization.GetString("PurchaseNotes")" />

@if (_loading)
{
    <MudProgressLinear Color="Color.Primary" Indeterminate="true" />
}
else if (_model == null)
{
    <MudAlert Severity="Severity.Error">@Localization.GetString("PurchaseNoteNotFound")</MudAlert>
}
else if (_model.Status != PurchaseNoteStatus.Draft)
{
    <MudAlert Severity="Severity.Warning" Class="mb-4">
        @Localization.GetString("PurchaseNoteNotEditable")
    </MudAlert>
    <MudButton StartIcon="@Icons.Material.Filled.ArrowBack"
               Variant="Variant.Outlined"
               OnClick="@(() => Navigation.NavigateTo($"/purchase-notes/{Id}"))">
        @Localization.GetString("BackToPurchaseNote")
    </MudButton>
}
else
{
    <MudCard Elevation="2" Class="mb-4">
        <MudCardHeader>
            <CardHeaderContent>
                <MudText Typo="Typo.h6">@Localization.GetString("PurchaseNoteInformation")</MudText>
            </CardHeaderContent>
            <CardHeaderActions>
                <MudChip T="string" Size="Size.Medium">@_model.NoteNumber</MudChip>
            </CardHeaderActions>
        </MudCardHeader>
        <MudCardContent>
            <MudForm @ref="_form" @bind-IsValid="@_isValid">
                <MudGrid>
                    <!-- Individual Selection -->
                    <MudItem xs="12" md="4">
                        <MudAutocomplete T="IndividualDto"
                                         Label="@Localization.GetString("Individual")"
                                         @bind-Value="_selectedIndividual"
                                         SearchFunc="@SearchIndividuals"
                                         ToStringFunc="@(i => i?.FullName ?? "")"
                                         Required="true"
                                         RequiredError="@Localization.GetString("IndividualRequired")"
                                         ResetValueOnEmptyText="true"
                                         CoerceText="false"
                                         Variant="Variant.Outlined"
                                         Clearable="true">
                            <ItemTemplate Context="individual">
                                <MudText Typo="Typo.body2">
                                    <strong>@individual.FullName</strong>
                                </MudText>
                                <MudText Typo="Typo.caption" Color="Color.Secondary">
                                    @individual.IdentificationNumber
                                </MudText>
                            </ItemTemplate>
                        </MudAutocomplete>
                    </MudItem>

                    <!-- Warehouse Selection -->
                    <MudItem xs="12" md="4">
                        <MudAutocomplete T="WarehouseDto"
                                         Label="@Localization.GetString("Warehouse")"
                                         @bind-Value="_selectedWarehouse"
                                         SearchFunc="@SearchWarehouses"
                                         ToStringFunc="@(w => w?.Name ?? "")"
                                         ResetValueOnEmptyText="true"
                                         Variant="Variant.Outlined"
                                         RequiredError="@Localization.GetString("WarehouseRequired")"
                                         CoerceText="false"
                                         Required="true"
                                         Clearable="true">
                        </MudAutocomplete>
                    </MudItem>

                    <!-- Purchase Date -->
                    <MudItem xs="12" md="4">
                        <MudDatePicker @bind-Date="_purchaseDate"
                                       Label="@Localization.GetString("PurchaseDate")"
                                       Variant="Variant.Outlined"
                                       Required="true"
                                       RequiredError="@Localization.GetString("PurchaseDateRequired")" />
                    </MudItem>

                    <!-- Notes -->
                    <MudItem xs="12">
                        <MudTextField @bind-Value="_notes"
                                      Label="@Localization.GetString("Notes")"
                                      Variant="Variant.Outlined"
                                      Lines="1"
                                      MaxLength="1000" />
                    </MudItem>
                </MudGrid>

                <!-- Line Items -->
                <MudDivider Class="my-4" />
                <div class="d-flex justify-space-between align-center mb-2">
                    <MudText Typo="Typo.h6">@Localization.GetString("Products")</MudText>
                    <WisButton Action="@_addLineItemAction" />
                </div>

                <MudTable Items="_lineItems" Dense="true" Hover="true" Elevation="0" Class="mb-2" Style="table-layout: fixed; width: 100%" ContainerStyle="overflow: hidden">
                    <HeaderContent>
                        <MudTh>@Localization.GetString("Product")</MudTh>
                        <MudTh Style="width:21%" Class="text-right">@Localization.GetString("Quantity")</MudTh>
                        <MudTh Style="width:24%" Class="text-right">@Localization.GetString("UnitPrice")</MudTh>
                        <MudTh Style="width:25%" Class="text-right">@Localization.GetString("Amount")</MudTh>
                        <MudTh Style="width:48px"></MudTh>
                    </HeaderContent>
                    <RowTemplate Context="item">
                        <MudTd>
                            <MudAutocomplete T="ProductDto"
                                             Value="item.SelectedProduct"
                                             SearchFunc="@SearchProducts"
                                             ToStringFunc="@(p => p != null ? $"{p.Code} - {p.Name}" : "")"
                                             ValueChanged="@((ProductDto p) => OnProductSelected(item, p))"
                                             ResetValueOnEmptyText="true"
                                             CoerceText="false"
                                             Variant="Variant.Text"
                                             Clearable="true"
                                             Placeholder="@Localization.GetString("SelectProduct")"
                                             FullWidth="true">
                                <ItemTemplate Context="product">
                                    <MudText Typo="Typo.body2">
                                        <strong>@product.Code</strong> - @product.Name
                                    </MudText>
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">
                                        @product.Unit | @product.CostPrice.ToString("C")
                                    </MudText>
                                </ItemTemplate>
                            </MudAutocomplete>
                        </MudTd>
                        <MudTd Class="text-right">
                            <MudNumericField T="int"
                                             @bind-Value="item.Quantity"
                                             @bind-Value:after="CalculateTotals"
                                             Variant="Variant.Text"
                                             Min="1"
                                             Step="1"
                                             Class="text-right"
                                             Adornment="Adornment.End"
                                             AdornmentText="@(item.SelectedProduct?.Unit ?? "")" />
                        </MudTd>
                        <MudTd Class="text-right">
                            <MudNumericField @bind-Value="item.UnitPrice"
                                             @bind-Value:after="CalculateTotals"
                                             Variant="Variant.Text"
                                             Format="N2"
                                             Min="0m"
                                             TextUpdateSuppression="false"
                                             Class="text-right"
                                             Adornment="Adornment.End"
                                             AdornmentText="@Localization.CurrencySymbol" />
                        </MudTd>
                        <MudTd Class="text-right">
                            <MudText Typo="Typo.body2" Class="font-weight-medium tabular-numbers text-right">
                                @((item.Quantity * item.UnitPrice).ToString("C"))
                            </MudText>
                        </MudTd>
                        <MudTd>
                            <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                           Color="Color.Error"
                                           Size="Size.Small"
                                           Variant="Variant.Outlined"
                                           OnClick="@(() => RemoveLineItem(item))" />
                        </MudTd>
                    </RowTemplate>
                    <NoRecordsContent>
                        <MudText Typo="Typo.body2" Color="Color.Secondary" Class="pa-4">
                            @Localization.GetString("AddLineItems")
                        </MudText>
                    </NoRecordsContent>
                </MudTable>

                <!-- Totals -->
                <MudDivider Class="my-3" />
                <div class="d-flex justify-end gap-4 px-2 pb-1">
                    <div class="d-flex align-center gap-2">
                        <MudText Typo="Typo.body2" Color="Color.Secondary">@Localization.GetString("Total"):</MudText>
                        <MudText Typo="Typo.h6" Color="Color.Primary" Class="font-weight-bold tabular-numbers">@_total.ToString("C")</MudText>
                    </div>
                </div>
            </MudForm>
        </MudCardContent>
    </MudCard>
    <!-- Actions -->
    <MudItem xs="12">
        <div class="d-flex justify-space-between wis-page-actions">
            <WisDialogActions OnCancel="Cancel"
                              OnSave="SaveNote"
                              SaveDisabled="@(_saving || !_isValid || !_lineItems.Any())" />
        </div>
    </MudItem>
}

@code {
    [Parameter] public Guid Id { get; set; }

    private MudForm _form = null!;
    private bool _isValid;
    private bool _saving;
    private PurchaseNoteDto? _model;

    private WisDetailActionItem _addLineItemAction => new()
    {
        Icon = Icons.Material.Filled.Add,
        Label = Localization.GetString("AddProduct"),
        Color = Color.Info,
        OnClick = EventCallback.Factory.Create(this, AddLineItem)
    };

    private IndividualDto? _selectedIndividual;
    private WarehouseDto? _selectedWarehouse;
    private DateTime? _purchaseDate;
    private string? _notes;
    private decimal _total = 0;

    private List<LineItemModel> _lineItems = [];

    // Dirty tracking snapshot
    private FormSnapshot? _snapshot;

    protected override async Task OnInitializedAsync()
    {
        await base.OnInitializedAsync();
        await LoadPurchaseNote();
    }

    private async Task<IEnumerable<IndividualDto>> SearchIndividuals(string value, CancellationToken ct)
    {
        GetIndividualsQuery query = new() { PageSize = 10, IsActive = true };
        if (!string.IsNullOrWhiteSpace(value)) query.Search = value;
        PagedResult<IndividualDto> result = await IndividualService.GetPagedAsync(query, ct);
        return result.Items;
    }

    private async Task<IEnumerable<ProductDto>> SearchProducts(string value, CancellationToken ct)
    {
        GetProductsQuery query = new() { PageSize = 10, IsActive = true };
        if (!string.IsNullOrWhiteSpace(value)) query.Search = value;
        PagedResult<ProductDto> result = await ProductService.GetPagedAsync(query, ct);
        return result.Items;
    }

    private async Task<IEnumerable<WarehouseDto>> SearchWarehouses(string value, CancellationToken ct)
    {
        GetWarehousesQuery query = new() { PageSize = 10, IsActive = true };
        if (!string.IsNullOrWhiteSpace(value)) query.Search = value;
        PagedResult<WarehouseDto> result = await WarehouseService.GetPagedAsync(query, ct);
        return result.Items;
    }

    private async Task LoadPurchaseNote()
    {
        _loading = true;

        try
        {
            _model = await PurchaseNoteService.GetPurchaseNoteByIdAsync(Id);
            if (_model != null)
            {
                _purchaseDate = _model.PurchaseDate;
                _notes = _model.Notes;

                _selectedIndividual = await IndividualService.GetIndividualByIdAsync(_model.IndividualId, _cts.Token);

                _selectedWarehouse = await WarehouseService.GetWarehouseByIdAsync(_model.WarehouseId, _cts.Token);

                List<LineItemModel> lineItems = [];
                foreach (PurchaseNoteLineDto li in _model.LineItems)
                {
                    ProductDto? product = await ProductService.GetProductByIdAsync(li.ProductId);
                    lineItems.Add(new LineItemModel
                    {
                        Id = li.Id,
                        SelectedProduct = product!,
                        Description = li.Description,
                        Quantity = li.Quantity,
                        UnitPrice = li.UnitPrice
                    });
                }
                _lineItems = lineItems;

                CalculateTotals();
                _snapshot = CaptureSnapshot();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading purchase note: {ex.Message}");
            Snackbar.Add(Localization.GetString("ErrorLoadingPurchaseNote"), Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    private void OnProductSelected(LineItemModel item, ProductDto? product)
    {
        if (product != null)
        {
            item.SelectedProduct = product;
            item.Description = product.Name;
            item.UnitPrice = product.CostPrice;
            CalculateTotals();
        }
    }

    private void AddLineItem()
    {
        _lineItems.Add(new LineItemModel { Quantity = 1 });
    }

    private void RemoveLineItem(LineItemModel item)
    {
        _lineItems.Remove(item);
        CalculateTotals();
    }

    private void CalculateTotals()
    {
        _total = _lineItems.Sum(li => li.Quantity * li.UnitPrice);
        StateHasChanged();
    }

    private FormSnapshot CaptureSnapshot() => new(
        _selectedIndividual?.Id,
        _selectedWarehouse?.Id,
        _purchaseDate!.Value.Date,
        _notes,
        _lineItems.Select(i => new LineItemSnapshot(i.Id, i.SelectedProduct?.Id, i.Quantity, i.UnitPrice)).ToList()
    );

    private bool IsUnchanged()
    {
        if (_snapshot == null) return false;
        FormSnapshot current = CaptureSnapshot();
        return current.IndividualId == _snapshot.IndividualId
            && current.WarehouseId == _snapshot.WarehouseId
            && current.PurchaseDate!.Value.Date == _snapshot.PurchaseDate
            && current.Notes == _snapshot.Notes
            && current.LineItems.Count == _snapshot.LineItems.Count
            && current.LineItems.Zip(_snapshot.LineItems).All(pair =>
                pair.First.Id == pair.Second.Id
                && pair.First.ProductId == pair.Second.ProductId
                && pair.First.Quantity == pair.Second.Quantity
                && pair.First.UnitPrice == pair.Second.UnitPrice);
    }

    private async Task SaveNote()
    {
        await _form.ValidateAsync();
        if (!_isValid || _model == null) return;

        if (IsUnchanged())
        {
            Snackbar.Add(Localization.GetString("NoChanges"), Severity.Info);
            return;
        }

        _saving = true;

        try
        {
            UpdatePurchaseNoteDto dto = new()
            {
                IndividualId = _selectedIndividual!.Id,
                WarehouseId = _selectedWarehouse!.Id,
                PurchaseDate = _purchaseDate?.Date ?? DateTime.Today,
                Notes = _notes,
                LineItems = _lineItems
                    .Where(li => li.SelectedProduct != null)
                    .Select(li => new UpdatePurchaseNoteLineDto
                    {
                        Id = li.Id,
                        ProductId = li.SelectedProduct!.Id,
                        Description = li.Description,
                        Quantity = li.Quantity,
                        UnitPrice = li.UnitPrice
                    }).ToList()
            };

            await PurchaseNoteService.UpdatePurchaseNoteAsync(Id, dto);
            Snackbar.Add(Localization.GetString("PurchaseNoteUpdated"), Severity.Success);
            Navigation.NavigateTo($"/purchase-notes/{Id}");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error updating purchase note: {ex.Message}");
            Snackbar.Add(Localization.GetString("ErrorUpdatingPurchaseNote"), Severity.Error);
        }
        finally
        {
            _saving = false;
        }
    }

    private void Cancel()
    {
        Navigation.NavigateTo($"/purchase-notes/{Id}");
    }

    private sealed record FormSnapshot(
        Guid? IndividualId,
        Guid? WarehouseId,
        DateTime? PurchaseDate,
        string? Notes,
        IReadOnlyList<LineItemSnapshot> LineItems);

    private sealed record LineItemSnapshot(
        Guid Id,
        Guid? ProductId,
        int Quantity,
        decimal UnitPrice);

    private class LineItemModel
    {
        public Guid Id { get; set; }
        public ProductDto? SelectedProduct { get; set; }
        public string Description { get; set; } = string.Empty;
        public int Quantity { get; set; } = 1;
        public decimal UnitPrice { get; set; }
    }
}
