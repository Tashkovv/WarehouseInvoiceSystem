@page "/warehouses/{Id:guid}"
@attribute [Authorize]
@inherits PageBase
@using WarehouseInvoiceSystem.Application.DTOs.Warehouse
@using WarehouseInvoiceSystem.Application.DTOs.StockLevel
@using WarehouseInvoiceSystem.Application.Models
@using WarehouseInvoiceSystem.Domain.Queries
@inject IWarehouseService WarehouseService
@inject IInventoryService InventoryService
@inject IExcelExportService ExcelExportService

<PageTitle>@Localization.GetString("WarehouseDetails") - @Localization.GetString("InvoiceSystem")</PageTitle>

@if (_loading)
{
    <MudProgressLinear Color="Color.Primary" Indeterminate="true" />
}
else if (_warehouse == null)
{
    <MudAlert Severity="Severity.Error">@Localization.GetString("WarehouseNotFound")</MudAlert>
}
else
{
    <WisDetailHeader BackHref="/warehouses"
                     BackLabel="@Localization.GetString("Warehouses")"
                     PrimaryAction="@_primaryAction"
                     Actions="@_actions" />

    <MudGrid>

        @* ── Header card ── *@
        <MudItem xs="12">
            <MudCard Elevation="2">
                <MudCardContent Class="pa-4">

                    @* ── Identity row ── *@
                    <div class="wis-detail-identity mb-3">
                        <MudText Typo="Typo.h4" Class="font-weight-bold mb-0">@_warehouse.Name</MudText>
                        @if (_warehouse.IsDefault)
                        {
                            <MudChip T="string" Size="Size.Small" Color="Color.Info">
                                @Localization.GetString("Default")
                            </MudChip>
                        }
                        <MudChip T="string" Size="Size.Small"
                                 Color="@(_warehouse.IsActive ? Color.Success : Color.Default)">
                            @(_warehouse.IsActive ? Localization.GetString("ActiveWarehouse") : Localization.GetString("InactiveWarehouse"))
                        </MudChip>
                    </div>

                    @* ── Address ── *@
                    @if (!string.IsNullOrWhiteSpace(_warehouse.Address))
                    {
                        <div class="wis-detail-contact wis-product-meta-row">
                            <div class="wis-detail-contact-item">
                                <MudIcon Icon="@Icons.Material.Filled.LocationOn" Size="Size.Small" Color="Color.Secondary" />
                                <MudText Typo="Typo.body2" Color="Color.Secondary">@_warehouse.Address</MudText>
                            </div>
                        </div>
                    }


                </MudCardContent>
            </MudCard>
        </MudItem>

        @* ── Stock by Product ── *@
        <MudItem xs="12">
            <MudCard Elevation="2">
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudText Typo="Typo.h6">@Localization.GetString("StockByProduct")</MudText>
                    </CardHeaderContent>
                    <CardHeaderActions>
                        <div class="d-flex align-center gap-2 pr-2">
                            <MudChip T="string" Size="Size.Small" Color="Color.Default"
                                     Icon="@Icons.Material.Filled.Inventory2">
                                @_totalProducts @Localization.GetString("Products")
                            </MudChip>
                            @if (_lowStockCount > 0)
                            {
                                <MudChip T="string" Size="Size.Small" Color="Color.Warning"
                                         Icon="@Icons.Material.Filled.Warning">
                                    @_lowStockCount @Localization.GetString("LowStock")
                                </MudChip>
                            }
                            <WisButton Action="@(new WisDetailActionItem
                            {
                                Icon = Icons.Material.Filled.Print,
                                Label = Localization.GetString("Export"),
                                Disabled = _exportingStock,
                                OnClick = EventCallback.Factory.Create(this, ExportStock)
                            })" />
                        </div>
                    </CardHeaderActions>
                </MudCardHeader>
                <MudCardContent Class="pa-0">
                    @if (_totalProducts > 0)
                    {
                        <MudTable @ref="_stockTable"
                                  ServerData="LoadStockServerData"
                                  Hover="true"
                                  Elevation="0"
                                  RowsPerPage="10"
                                  Class="wis-secondary-list">
                            <HeaderContent>
                                <MudTh>@Localization.GetString("Product")</MudTh>
                                <MudTh Class="text-right">@Localization.GetString("Quantity")</MudTh>
                                <MudTh>@Localization.GetString("LastRestocked")</MudTh>
                                <MudTh Class="text-right">@Localization.GetString("MinimumQuantity")</MudTh>
                                <MudTh Class="text-right">@Localization.GetString("UnitPrice")</MudTh>
                                <MudTh Class="text-right">@Localization.GetString("TotalValue")</MudTh>
                                <MudTh />
                            </HeaderContent>
                            <RowTemplate>
                                <MudTd DataLabel="@Localization.GetString("Product")">
                                    <MudText Typo="Typo.body2">
                                        <span class="font-weight-medium">@context.ProductCode</span> - @context.ProductName
                                    </MudText>
                                </MudTd>
                                <MudTd DataLabel="@Localization.GetString("Quantity")" Class="text-right">
                                    <MudText Typo="Typo.body2"
                                             Color="@GetQuantityColor(context)">
                                        @context.Quantity.ToString("N0") @context.ProductUnit
                                    </MudText>
                                </MudTd>
                                <MudTd DataLabel="@Localization.GetString("LastRestocked")">
                                    <MudText Typo="Typo.body2">@(context.LastRestockedAt.ToString("dd MMM yyyy") ?? "—")</MudText>
                                </MudTd>
                                <MudTd DataLabel="@Localization.GetString("MinimumQuantity")" Class="text-right">
                                    <MudText Typo="Typo.body2">
                                        @if (context.MinimumQuantity.HasValue)
                                        {
                                            @($"{context.MinimumQuantity.Value.ToString("N0")} {context.ProductUnit}")
                                        }
                                        else
                                        {
                                            <text>—</text>
                                        }
                                    </MudText>
                                </MudTd>
                                <MudTd DataLabel="@Localization.GetString("UnitPrice")" Class="text-right">
                                    <MudText Typo="Typo.body2">@context.UnitPrice.ToString("C")</MudText>
                                </MudTd>
                                <MudTd DataLabel="@Localization.GetString("TotalValue")" Class="text-right">
                                    <MudText Typo="Typo.body2">@context.TotalValue.ToString("C")</MudText>
                                </MudTd>
                                <MudTd Style="text-align:center">
                                    <MudTooltip Text="@Localization.GetString("EditThresholds")">
                                        <MudIconButton Icon="@Icons.Material.Filled.Tune"
                                                       Size="Size.Small"
                                                       Color="Color.Primary"
                                                       OnClick="@(() => OpenSetThresholdsDialog(context))" />
                                    </MudTooltip>
                                </MudTd>
                            </RowTemplate>
                            <PagerContent>
                                <WisPagerContent T="StockLevelDto" Table="_stockTable" PageSizeOptions="[10, 25, 50]" />
                            </PagerContent>
                        </MudTable>
                    }
                    else
                    {
                        <div class="pa-6 text-center d-flex align-center">
                            <MudIcon Icon="@Icons.Material.Filled.Inventory2"
                                     Size="Size.Large"
                                     Color="Color.Secondary"
                                     Class="mr-2" />
                            <MudText Typo="Typo.body1" Color="Color.Secondary">@Localization.GetString("NoProductsInWarehouse")</MudText>
                        </div>
                    }
                </MudCardContent>
            </MudCard>
        </MudItem>

    </MudGrid>
}

@code {
    [Parameter] public Guid Id { get; set; }

    private WarehouseDto? _warehouse;
    private MudTable<StockLevelDto>? _stockTable;
    private int _totalProducts;
    private int _lowStockCount;

    private WisDetailActionItem? _primaryAction;
    private List<WisDetailActionItem> _actions = [];
    private bool _exportingStock = false;

    private static Color GetQuantityColor(StockLevelDto s)
    {
        if (s.Quantity == 0) return Color.Error;
        if (s.MinimumQuantity.HasValue && s.Quantity <= s.MinimumQuantity.Value) return Color.Warning;
        return Color.Default;
    }

    // ── Server data ─────────────────────────────────────────────────────────

    private async Task<TableData<StockLevelDto>> LoadStockServerData(TableState state, CancellationToken ct)
    {
        var result = await InventoryService.GetPagedStockAsync(new GetStockQuery
        {
            WarehouseId = Id,
            Page = state.Page + 1,
            PageSize = state.PageSize
        }, ct);

        return new TableData<StockLevelDto>
        {
            Items = result.Items,
            TotalItems = result.TotalCount
        };
    }

    // ── Lifecycle ─────────────────────────────────────────────────────────────

    protected override async Task OnInitializedAsync()
    {
        await base.OnInitializedAsync();
        await LoadWarehouse();
    }

    protected override async void OnLanguageChanged()
    {
        BuildActions();
        await InvokeAsync(StateHasChanged);
    }

    private async Task LoadWarehouse() =>
        await SafeLoadAsync(async () =>
        {
            _warehouse = await WarehouseService.GetWarehouseByIdAsync(Id, CancellationToken.None);
            if (_warehouse != null)
            {
                var allResult = await InventoryService.GetPagedStockAsync(
                    new GetStockQuery { WarehouseId = Id, Page = 1, PageSize = 1 }, CancellationToken.None);
                _totalProducts = allResult.TotalCount;

                var lowResult = await InventoryService.GetPagedStockAsync(
                    new GetStockQuery { WarehouseId = Id, IsLowStock = true, Page = 1, PageSize = 1 }, CancellationToken.None);
                _lowStockCount = lowResult.TotalCount;

                BuildActions();
            }
        }, "ErrorLoadingWarehouse");

    private void BuildActions()
    {
        if (_warehouse is null) return;

        _primaryAction = _act.Primary(Icons.Material.Filled.Edit, Localization.GetString("Edit"), OpenEditDialog);

        List<WisDetailActionItem> actions = [];

        if (!_warehouse.IsDefault && _warehouse.IsActive)
            actions.Add(_act.Secondary(Icons.Material.Filled.Star, Localization.GetString("Default"), SetAsDefault));

        if (_warehouse.IsActive)
        {
            bool cannotDeactivate = _warehouse.IsDefault || _totalProducts > 0;
            actions.Add(_act.Warning(Icons.Material.Filled.PowerSettingsNew, Localization.GetString("Deactivate"), () => SetActiveStatus(false),
                dividerBefore: actions.Count > 0,
                disabled: cannotDeactivate,
                disabledReason: cannotDeactivate ? Localization.GetString("DeactivateWarehouseDisabledTooltip") : null));
        }
        else
            actions.Add(_act.Success(Icons.Material.Filled.PowerSettingsNew, Localization.GetString("Activate"), () => SetActiveStatus(true),
                dividerBefore: actions.Count > 0));

        _actions = actions;
    }

    // ── Actions ───────────────────────────────────────────────────────────────

    private async Task OpenEditDialog()
    {
        if (_warehouse is null) return;
        if (await WisDialog.ShowFormAsync<WarehouseDialog, bool>(
                Localization.GetString("EditWarehouse"),
                p => p.Add(x => x.Warehouse, _warehouse),
                MaxWidth.Small) == true)
        {
            await LoadWarehouse();
            if (_stockTable is not null) await _stockTable.ReloadServerData();
        }
    }

    private async Task SetAsDefault()
    {
        try
        {
            await WarehouseService.SetDefaultWarehouseAsync(Id);
            Snackbar.Add(Localization.GetString("WarehouseSetAsDefault"), Severity.Success);
            await LoadWarehouse();
            if (_stockTable is not null) await _stockTable.ReloadServerData();
        }
        catch (Exception)
        {
            Snackbar.Add(Localization.GetString("ErrorSettingDefaultWarehouse"), Severity.Error);
        }
    }

    private async Task SetActiveStatus(bool isActive)
    {
        if (!isActive)
        {
            bool confirmed = await WisDialog.ConfirmAsync(
                Localization.GetString("ConfirmDeactivateWarehouse"),
                Localization.GetString("DeactivateWarehouseConfirm"),
                Localization.GetString("Yes"),
                Localization.GetString("No"));

            if (!confirmed) return;
        }

        try
        {
            await WarehouseService.SetActiveStatusAsync(Id, isActive);
            string key = isActive ? "WarehouseActivated" : "WarehouseDeactivated";
            Snackbar.Add(Localization.GetString(key), Severity.Success);
            await LoadWarehouse();
            if (_stockTable is not null) await _stockTable.ReloadServerData();
        }
        catch (Exception)
        {
            string errorKey = isActive ? "ErrorActivatingWarehouse" : "ErrorDeactivatingWarehouse";
            Snackbar.Add(Localization.GetString(errorKey), Severity.Error);
        }
    }

    private async Task OpenSetThresholdsDialog(StockLevelDto stockLevel)
    {
        if (await WisDialog.ShowFormAsync<SetThresholdsDialog, bool>(
                Localization.GetString("EditThresholds"),
                p => p.Add(x => x.StockLevel, stockLevel),
                MaxWidth.Small) == true)
        {
            await LoadWarehouse();
            if (_stockTable is not null) await _stockTable.ReloadServerData();
        }
    }

    private async Task ExportStock()
    {
        _exportingStock = true;
        StateHasChanged();

        try
        {
            var exportResult = await InventoryService.GetPagedStockAsync(
                new GetStockQuery { WarehouseId = Id, Page = 1, PageSize = int.MaxValue }, CancellationToken.None);

            byte[] fileBytes = await ExcelExportService.ExportListToExcelAsync(
                exportResult.Items,
                ExportColumnDefinitions.StockLevelColumns(Localization),
                new ExportListOptions(Localization.GetString("StockByProduct"),
                    $"{_warehouse!.Name} — {Localization.GetString("StockByProduct")}"));

            string fileName = $"{Localization.GetString("Stock")}_{_warehouse!.Name}_{DateTime.UtcNow:yyyyMMdd}.xlsx";
            await DownloadFileAsync(fileBytes, fileName);
        }
        catch (Exception)
        {
            Snackbar.Add(Localization.GetString("ExportError"), Severity.Error);
        }
        finally
        {
            _exportingStock = false;
            StateHasChanged();
        }
    }

}
