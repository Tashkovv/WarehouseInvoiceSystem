@page "/warehouses"
@implements IDisposable
@using WarehouseInvoiceSystem.Application.DTOs.Warehouse
@using WarehouseInvoiceSystem.Domain.Queries
@using WarehouseInvoiceSystem.Domain.Queries.Common
@inject IWarehouseService WarehouseService
@inject ILocalizationService Localization
@inject NavigationManager Navigation
@inject IDialogService DialogService
@inject WisDialogService WisDialog
@inject ISnackbar Snackbar

<PageTitle>@Localization.GetString("Warehouses") - @Localization.GetString("InvoiceSystem")</PageTitle>

<div class="wis-page-header">
    <MudText Typo="Typo.h3" Class="wis-page-title">
        @Localization.GetString("Warehouses")
    </MudText>
</div>

<WisGridToolbar CreateAction="OpenCreateDialog"
                CreateLabel="@Localization.GetString("Warehouse")"
                SearchValue="@_searchString"
                SearchValueChanged="OnSearch"
                HasAnyActiveFilter="@(_filterIsActive.HasValue)"
                OnClearAll="ClearAllFilters">
    <Filters>
        <FilterPopoverList TValue="bool?"
                           Label="@Localization.GetString("Status")"
                           Items="_statusFilterItems"
                           Mode="FilterSelectionMode.Single"
                           SelectedValue="_filterIsActive"
                           SelectedValueChanged="OnStatusFilterChanged" />
    </Filters>
</WisGridToolbar>

<MudCard Elevation="2" Class="mb-4">
    <MudCardContent Class="pa-0">
        <MudDataGrid T="WarehouseDto"
                     @ref="_grid"
                     ServerData="LoadServerData"
                     RowClassFunc="GetRowClass"
                     RowClick="OnRowClick"
                     ReadOnly="true"
                     Hover="true"
                     FixedHeader="true"
                     Height="100%"
                     Filterable="false"
                     ShowColumnOptions="false"
                     ColumnResizeMode="ResizeMode.Column"
                     SortMode="SortMode.Single"
                     Class="wis-data-grid">
            <Columns>

                <PropertyColumn Property="x => x.Name"
                                Title="@Localization.GetString("Name")"
                                Sortable="true"
                                IsEditable="false">
                    <CellTemplate>
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                            <MudText Typo="Typo.body2" Class="wis-cell-primary">
                                @context.Item.Name
                            </MudText>
                            @if (context.Item.IsDefault)
                            {
                                <MudChip T="string" Size="Size.Small" Color="Color.Info">
                                    @Localization.GetString("Default")
                                </MudChip>
                            }
                        </MudStack>
                    </CellTemplate>
                </PropertyColumn>

                <PropertyColumn Property="x => x.Address"
                                Title="@Localization.GetString("Address")"
                                Sortable="false"
                                IsEditable="false">
                    <CellTemplate>
                        @(context.Item.Address ?? "—")
                    </CellTemplate>
                </PropertyColumn>

                <PropertyColumn Property="x => x.IsActive"
                                Title="@Localization.GetString("Status")"
                                Sortable="false"
                                IsEditable="false">
                    <CellTemplate>
                        <MudChip T="string"
                                 Size="Size.Small"
                                 Color="@(context.Item.IsActive ? Color.Success : Color.Default)">
                            @(context.Item.IsActive ? Localization.GetString("ActiveWarehouse")
                                                        : Localization.GetString("InactiveWarehouse"))
                        </MudChip>
                    </CellTemplate>
                </PropertyColumn>

                <PropertyColumn Property="x => x.CreatedAt"
                                Title="@Localization.GetString("Created")"
                                Sortable="true"
                                IsEditable="false">
                    <CellTemplate>
                        @context.Item.CreatedAt.ToString("dd MMM yyyy")
                    </CellTemplate>
                </PropertyColumn>

                <TemplateColumn Sortable="false"
                                Filterable="false"
                                IsEditable="false"
                                HeaderClass="wis-col-actions-3"
                                CellClass="wis-col-actions-3">
                    <CellTemplate>
                        <MudStack Row="true" Spacing="0">
                            <MudIconButton Icon="@Icons.Material.Filled.Edit"
                                           Size="Size.Small"
                                           Color="Color.Primary"
                                           Title="@Localization.GetString("Edit")"
                                           OnClick="@(() => OpenEditDialog(context.Item))" />
                            <MudIconButton Icon="@Icons.Material.Filled.Star"
                                           Size="Size.Small"
                                           Color="@(context.Item.IsDefault ? Color.Info : Color.Default)"
                                           Title="@Localization.GetString("SetAsDefault")"
                                           Disabled="@(context.Item.IsDefault || !context.Item.IsActive)"
                                           OnClick="@(() => SetAsDefault(context.Item))" />
                            @if (context.Item.IsActive)
                            {
                                <MudIconButton Icon="@Icons.Material.Filled.PowerSettingsNew"
                                               Size="Size.Small"
                                               Color="Color.Warning"
                                               Title="@(context.Item.HasProducts ? Localization.GetString("DeactivateWarehouseDisabledTooltip")
                                                                                                                                                                       : Localization.GetString("Deactivate"))"
                                               Disabled="@(context.Item.IsDefault || context.Item.HasProducts)"
                                               OnClick="@(() => SetActiveStatus(context.Item, false))" />
                            }
                            else
                            {
                                <MudIconButton Icon="@Icons.Material.Filled.PowerSettingsNew"
                                               Size="Size.Small"
                                               Color="Color.Success"
                                               Title="@Localization.GetString("Activate")"
                                               OnClick="@(() => SetActiveStatus(context.Item, true))" />
                            }
                        </MudStack>
                    </CellTemplate>
                </TemplateColumn>

            </Columns>

            <NoRecordsContent>
                <WisNoRecordsContent Icon="@Icons.Material.Filled.Warehouse"
                                     Message="@Localization.GetString("NoWarehousesFound")" />
            </NoRecordsContent>

            <LoadingContent>
                <WisLoadingContent />
            </LoadingContent>

            <PagerContent>
                <WisPagerContent T="WarehouseDto" />
            </PagerContent>

        </MudDataGrid>
    </MudCardContent>
</MudCard>

@code {
    private readonly CancellationTokenSource _cts = new();
    private MudDataGrid<WarehouseDto> _grid = null!;
    private string _searchString = string.Empty;
    private bool? _filterIsActive = null;

    private List<FilterPopoverItem<bool?>> _statusFilterItems = [];

    protected override void OnInitialized()
    {
        Localization.OnLanguageChanged += OnLanguageChanged;
        BuildFilterItems();
    }

    private void BuildFilterItems()
    {
        _statusFilterItems =
        [
            new() { Label = Localization.GetString("All"),               Value = null,  Color = Color.Info },
            new() { Label = Localization.GetString("ActiveWarehouse"),   Value = true,  Color = Color.Success },
            new() { Label = Localization.GetString("InactiveWarehouse"), Value = false, Color = Color.Default },
    ];
    }

    private async void OnLanguageChanged()
    {
        BuildFilterItems();
        await InvokeAsync(StateHasChanged);
    }

    private async Task<GridData<WarehouseDto>> LoadServerData(GridState<WarehouseDto> state, CancellationToken ct)
    {
        string? sortBy = state.SortDefinitions.FirstOrDefault()?.SortBy;
        bool ascending = state.SortDefinitions.FirstOrDefault()?.Descending == false;

        GetWarehousesQuery query = new()
        {
            Search = _searchString,
            IsActive = _filterIsActive,
            Page = state.Page + 1,
            PageSize = state.PageSize,
            SortBy = sortBy,
            SortAscending = ascending,
        };

        PagedResult<WarehouseDto> result = await WarehouseService.GetPagedAsync(query, ct);

        return new GridData<WarehouseDto>
        {
            Items = result.Items,
            TotalItems = result.TotalCount
        };
    }

    private void OnRowClick(DataGridRowClickEventArgs<WarehouseDto> args)
    {
        if (args.MouseEventArgs.Detail == 2)
            Navigation.NavigateTo($"/warehouses/{args.Item!.Id}");
    }

    private string GetRowClass(WarehouseDto item, int index) =>
        item.IsActive
            ? (item.IsDefault ? "row-status-success" : string.Empty)
            : "row-status-default";

    private async Task OnSearch(string text)
    {
        _searchString = text;
        await _grid.ReloadServerData();
    }

    private async Task OnStatusFilterChanged(bool? value)
    {
        _filterIsActive = value;
        await _grid.ReloadServerData();
    }

    private async Task ClearAllFilters()
    {
        _filterIsActive = null;
        await _grid.ReloadServerData();
    }

    private async Task OpenCreateDialog()
    {
        DialogOptions options = new()
        {
            MaxWidth = MaxWidth.Small,
            FullWidth = true,
            CloseOnEscapeKey = true
        };

        IDialogReference dialog = await DialogService.ShowAsync<WarehouseDialog>(
            Localization.GetString("CreateWarehouse"), options);

        DialogResult? result = await dialog.Result;

        if (result is { Canceled: false, Data: CreateWarehouseDto dto })
        {
            try
            {
                await WarehouseService.CreateWarehouseAsync(dto);
                Snackbar.Add(Localization.GetString("WarehouseCreated"), Severity.Success);
                await _grid.ReloadServerData();
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Error creating warehouse: {ex.Message}");
                Snackbar.Add(Localization.GetString("ErrorCreatingWarehouse"), Severity.Error);
            }
        }
    }

    private async Task OpenEditDialog(WarehouseDto warehouse)
    {
        DialogParameters<WarehouseDialog> parameters = new();
        parameters.Add(x => x.Warehouse, warehouse);

        DialogOptions options = new()
        {
            MaxWidth = MaxWidth.Small,
            FullWidth = true,
            CloseOnEscapeKey = true
        };

        IDialogReference dialog = await DialogService.ShowAsync<WarehouseDialog>(
            Localization.GetString("EditWarehouse"), parameters, options);

        DialogResult? result = await dialog.Result;

        if (result is { Canceled: false, Data: UpdateWarehouseDto dto })
        {
            try
            {
                await WarehouseService.UpdateWarehouseAsync(warehouse.Id, dto);
                Snackbar.Add(Localization.GetString("WarehouseUpdated"), Severity.Success);
                await _grid.ReloadServerData();
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Error updating warehouse: {ex.Message}");
                Snackbar.Add(Localization.GetString("ErrorUpdatingWarehouse"), Severity.Error);
            }
        }
    }

    private async Task SetAsDefault(WarehouseDto warehouse)
    {
        try
        {
            await WarehouseService.SetDefaultWarehouseAsync(warehouse.Id);
            Snackbar.Add(Localization.GetString("WarehouseSetAsDefault"), Severity.Success);
            await _grid.ReloadServerData();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error setting default warehouse: {ex.Message}");
            Snackbar.Add(Localization.GetString("ErrorSettingDefaultWarehouse"), Severity.Error);
        }
    }

    private async Task SetActiveStatus(WarehouseDto warehouse, bool isActive)
    {
        bool confirmed = isActive;

        if (!isActive)
        {
            confirmed = await WisDialog.ConfirmAsync(
                Localization.GetString("ConfirmDeactivateWarehouse"),
                Localization.GetString("DeactivateWarehouseConfirm"),
                Localization.GetString("Yes"),
                Localization.GetString("No"));
        }

        if (confirmed == true)
        {
            try
            {
                await WarehouseService.SetActiveStatusAsync(warehouse.Id, isActive);
                string successKey = isActive ? "WarehouseActivated" : "WarehouseDeactivated";
                Snackbar.Add(Localization.GetString(successKey), Severity.Success);
                await _grid.ReloadServerData();
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Error changing warehouse status: {ex.Message}");
                string errorKey = isActive ? "ErrorActivatingWarehouse" : "ErrorDeactivatingWarehouse";
                Snackbar.Add(Localization.GetString(errorKey), Severity.Error);
            }
        }
    }

    public void Dispose()
    {
        _cts.Cancel();
        _cts.Dispose();
        Localization.OnLanguageChanged -= OnLanguageChanged;
    }
}
