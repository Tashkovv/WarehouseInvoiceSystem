@page "/warehouses/create"
@using WarehouseInvoiceSystem.Application.Interfaces
@using WarehouseInvoiceSystem.Application.DTOs.Warehouse
@inject IWarehouseService WarehouseService
@inject ILocalizationService Localization
@inject NavigationManager Navigation
@inject ISnackbar Snackbar

<PageTitle>@Localization.GetString("CreateWarehouse") - @Localization.GetString("InvoiceSystem")</PageTitle>

<MudText Typo="Typo.h4" Class="mb-6">@Localization.GetString("CreateWarehouse")</MudText>

<MudCard Elevation="2" Class="mb-4">
    <MudCardContent>
        <MudForm @ref="_form" @bind-IsValid="@_isValid">
            <MudGrid>
                <MudItem xs="12" md="6">
                    <MudTextField @bind-Value="_model.Name"
                                  Label="@Localization.GetString("WarehouseName")"
                                  Required="true"
                                  Variant="Variant.Outlined"
                                  RequiredError="@Localization.GetString("WarehouseNameRequired")"
                                  MaxLength="100" />
                </MudItem>

                <MudItem xs="12" md="6">
                    <MudTextField @bind-Value="_model.Address"
                                  Label="@Localization.GetString("Address")"
                                  Variant="Variant.Outlined"
                                  MaxLength="100" />
                </MudItem>

                <MudItem xs="12" md="4" Class="d-flex align-center">
                    <MudSwitch @bind-Value="_model.IsDefault"
                               Label="@Localization.GetString("DefaultWarehouse")"
                               Color="Color.Success" />
                </MudItem>
            </MudGrid>
        </MudForm>
    </MudCardContent>
</MudCard>

<!-- Actions -->
<MudItem xs="12">
    <div class="d-flex justify-end gap-2">
        <MudButton Variant="Variant.Outlined" OnClick="Cancel" Disabled="@_saving">
            @Localization.GetString("Cancel")
        </MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SaveWarehouse" Disabled="@(!_isValid || _saving)">
            @if (_saving)
            {
                <MudProgressCircular Class="ms-n1" Size="Size.Small" Indeterminate="true" />
                <MudText Class="ms-2">@Localization.GetString("Saving")</MudText>
            }
            else
            {
                @Localization.GetString("Save")
            }
        </MudButton>
    </div>
</MudItem>

@code {
    private MudForm _form = null!;
    private bool _isValid;
    private bool _saving;
    private CreateWarehouseDto _model = new() { IsDefault = false };

    protected override async Task OnInitializedAsync()
    {
        Localization.OnLanguageChanged += OnLanguageChanged;
    }

    private async void OnLanguageChanged()
    {
        await InvokeAsync(StateHasChanged);
    }

    private async Task SaveWarehouse()
    {
        await _form.Validate();
        if (!_isValid) return;

        _saving = true;

        try
        {
            await WarehouseService.CreateWarehouseAsync(_model);
            Snackbar.Add(Localization.GetString("WarehouseCreated"), Severity.Success);
            Navigation.NavigateTo("/warehouses");
        }
        catch (InvalidOperationException ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error creating warehouse: {ex.Message}");
            Snackbar.Add(Localization.GetString("ErrorCreatingWarehouse"), Severity.Error);
        }
        finally
        {
            _saving = false;
        }
    }

    private void Cancel()
    {
        Navigation.NavigateTo("/warehouses");
    }
}
