@page "/inventory/adjust"
@using WarehouseInvoiceSystem.Application.DTOs.Product
@using WarehouseInvoiceSystem.Application.DTOs.Warehouse
@using WarehouseInvoiceSystem.Application.Interfaces
@using WarehouseInvoiceSystem.Application.Models
@inject IInventoryService InventoryService
@inject IProductService ProductService
@inject IWarehouseService WarehouseService
@inject ILocalizationService Localization
@inject NavigationManager Navigation
@inject ISnackbar Snackbar

<PageTitle>@Localization.GetString("AdjustStock") - @Localization.GetString("InvoiceSystem")</PageTitle>

<MudText Typo="Typo.h4" Class="mb-6">@Localization.GetString("AdjustStock")</MudText>

<MudCard Elevation="2" Class="mb-4">
    <MudCardContent>
        <MudForm @ref="_form" @bind-IsValid="@_isValid">
            <MudGrid>
                <MudItem xs="12" md="6">
                    <MudAutocomplete T="ProductDto"
                                     Label="@Localization.GetString("SelectProduct")"
                                     SearchFunc="SearchProducts"
                                     Required="true"
                                     ToStringFunc="@(p => p?.Name ?? string.Empty)"
                                     Value="_selectedProduct"
                                     ValueChanged="@(p => _selectedProduct = p)"
                                     ResetValueOnEmptyText="true"
                                     Clearable="true"
                                     Variant="Variant.Outlined" />
                </MudItem>

                <MudItem xs="12" md="6">
                    <MudSelect T="Guid?"
                               @bind-Value="_selectedWarehouseId"
                               Label="@Localization.GetString("SelectWarehouse")"
                               Required="true"
                               RequiredError="@Localization.GetString("SelectWarehouse")"
                               Variant="Variant.Outlined">
                        @foreach (var w in _warehouses)
                        {
                            <MudSelectItem Value="(Guid?)w.Id">@w.Name</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>

                <MudItem xs="12" md="4">
                    <MudSelect T="string"
                               @bind-Value="_adjustmentType"
                               Label="@Localization.GetString("AdjustmentType")"
                               Placeholder="@Localization.GetString("AdjustmentType")"
                               Variant="Variant.Outlined"
                               Required="true">
                        <MudSelectItem Value="@AdjustmentType.Add.ToString()">@Localization.GetString("IncreaseStock")</MudSelectItem>
                        <MudSelectItem Value="@AdjustmentType.Remove.ToString()">@Localization.GetString("DecreaseStock")</MudSelectItem>
                    </MudSelect>
                </MudItem>

                <MudItem xs="12" md="4">
                    <MudNumericField @bind-Value="_quantity"
                                     Label="@Localization.GetString("Quantity")"
                                     Required="true"
                                     Variant="Variant.Outlined"
                                     RequiredError="@Localization.GetString("EnterQuantity")"
                                     Min="1m"
                                     Format="N2" />
                </MudItem>

                <MudItem xs="12" md="4">
                    <MudTextField @bind-Value="_reason"
                                  Label="@Localization.GetString("AdjustmentReason")"
                                  Variant="Variant.Outlined" />
                </MudItem>
            </MudGrid>
        </MudForm>
    </MudCardContent>
</MudCard>

<!-- Actions -->
<MudItem xs="12">
    <div class="d-flex justify-end gap-2">
        <MudButton Variant="Variant.Outlined" OnClick="Cancel" Disabled="@_saving">@Localization.GetString("Cancel")</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SaveAdjustment" Disabled="@(!_isValid || _saving)">
            @if (_saving)
            {
                <MudProgressCircular Class="mr-2" Size="Size.Small" Indeterminate="true" />
                @Localization.GetString("Saving")
            }
            else
            {
                @Localization.GetString("Adjust")
            }
        </MudButton>
    </div>
</MudItem>

@code {
    private MudForm _form = null!;
    private bool _isValid;
    private bool _saving;

    private List<WarehouseDto> _warehouses = new();
    private ProductDto? _selectedProduct;
    private Guid? _selectedWarehouseId;
    private string _adjustmentType = AdjustmentType.Add.ToString();
    private decimal _quantity = 0m;
    private string? _reason;

    protected override async Task OnInitializedAsync()
    {
        Localization.OnLanguageChanged += OnLanguageChanged;
        await LoadWarehouses();
    }

    private async void OnLanguageChanged()
    {
        await InvokeAsync(StateHasChanged);
    }

    private async Task LoadWarehouses()
    {
        try
        {
            _warehouses = (await WarehouseService.GetAllWarehousesAsync()).ToList();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading warehouses: {ex.Message}");
            Snackbar.Add(Localization.GetString("ErrorLoadingWarehouses"), Severity.Error);
        }
    }

    private async Task<IEnumerable<ProductDto>> SearchProducts(string value, CancellationToken cancellationToken)
    {
        if (string.IsNullOrEmpty(value))
            return await ProductService.GetActiveProductsAsync();

        return (await ProductService.GetActiveProductsAsync())
            .Where(p => p.Code.Contains(value, StringComparison.OrdinalIgnoreCase) || p.Name.Contains(value, StringComparison.OrdinalIgnoreCase));
    }

    private async Task SaveAdjustment()
    {
        await _form.Validate();
        if (!_isValid) return;

        if (_selectedProduct == null || !_selectedWarehouseId.HasValue)
        {
            Snackbar.Add(Localization.GetString("PleaseSelectProduct"), Severity.Warning);
            return;
        }

        _saving = true;

        try
        {
            decimal change = _adjustmentType == AdjustmentType.Add.ToString() ? _quantity : -_quantity;
            await InventoryService.AdjustStockAsync(_selectedProduct.Id, _selectedWarehouseId.Value, change, _reason ?? string.Empty);
            Snackbar.Add(Localization.GetString("StockAdjusted"), Severity.Success);
            Navigation.NavigateTo("/inventory");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error adjusting stock: {ex.Message}");
            Snackbar.Add(Localization.GetString("ErrorAdjustingStock"), Severity.Error);
        }
        finally
        {
            _saving = false;
        }
    }

    private void Cancel()
    {
        Navigation.NavigateTo("/inventory");
    }

    public enum AdjustmentType
    {
        Add = 1,
        Remove = 2
    }
}
