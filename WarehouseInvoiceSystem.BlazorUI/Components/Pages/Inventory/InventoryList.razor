@page "/inventory"
@implements IDisposable
@using WarehouseInvoiceSystem.Application.DTOs.StockLevel
@using WarehouseInvoiceSystem.Application.DTOs.Product
@using WarehouseInvoiceSystem.Application.DTOs.Warehouse
@using WarehouseInvoiceSystem.Domain.Queries
@using WarehouseInvoiceSystem.Domain.Queries.Common
@inject IInventoryService InventoryService
@inject IProductService ProductService
@inject IWarehouseService WarehouseService
@inject ILocalizationService Localization
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject NavigationManager Navigation

<PageTitle>@Localization.GetString("Inventory") - @Localization.GetString("InvoiceSystem")</PageTitle>

<div class="wis-page-header">
    <MudText Typo="Typo.h3" Class="wis-page-title">
        @Localization.GetString("Inventory")
    </MudText>
</div>

<WisGridToolbar CreateAction="OpenAdjustDialog"
                CreateLabel="@Localization.GetString("AdjustStock")"
                CreateIcon="@Icons.Material.Filled.Inventory2"
                SearchValue="@_searchString"
                SearchValueChanged="OnSearch"
                HasAnyActiveFilter="@(_filterIsLowStock == true || _activeAdvancedFilterCount > 0)"
                OnClearAll="ClearAllFilters"
                ActiveAdvancedFilterCount="@_activeAdvancedFilterCount">
    <Filters>
        <button class="wis-filter-btn @(_filterIsLowStock == true ? "wis-filter-btn--active wis-filter-btn--error" : "")"
                @onclick="ToggleLowStockFilter"
                type="button">
            <span class="wis-filter-btn__icon">
                <MudIcon Icon="@Icons.Material.Filled.Warning" Size="Size.Small" />
            </span>
            <span class="wis-filter-btn__label">@Localization.GetString("LowStock")</span>
        </button>
    </Filters>
    <AdvancedFilters>
        <div class="d-flex align-center flex-wrap gap-3">

            <WisAutocompleteFilter TValue="Guid"
                                   Label="@Localization.GetString("Warehouse")"
                                   AllLabel="@Localization.GetString("AllWarehouses")"
                                   Icon="@Icons.Material.Filled.Warehouse"
                                   LoadItems="LoadWarehouseItems"
                                   SelectedValue="@(_filterWarehouseId ?? default)"
                                   SelectedValueChanged="OnWarehouseFilterChanged"
                                   MinWidth="200px" />

            <WisAutocompleteFilter TValue="Guid"
                                   Label="@Localization.GetString("Product")"
                                   AllLabel="@Localization.GetString("AllProducts")"
                                   Icon="@Icons.Material.Filled.Inventory2"
                                   LoadItems="LoadProductItems"
                                   SelectedValue="@(_filterProductId ?? default)"
                                   SelectedValueChanged="OnProductFilterChanged"
                                   MinWidth="200px" />

        </div>
    </AdvancedFilters>
</WisGridToolbar>

<MudCard Elevation="2" Class="mb-4">
    <MudCardContent Class="pa-0">
        <MudDataGrid T="StockLevelDto"
                     @ref="_grid"
                     ServerData="LoadServerData"
                     RowClassFunc="GetRowClass"
                     RowClick="OnRowClick"
                     ReadOnly="true"
                     Hover="true"
                     FixedHeader="true"
                     Height="100%"
                     Filterable="false"
                     ShowColumnOptions="false"
                     ColumnResizeMode="ResizeMode.Column"
                     SortMode="SortMode.Single"
                     Class="wis-data-grid">
            <Columns>

                <PropertyColumn Property="x => x.ProductCode"
                                Title="@Localization.GetString("Code")"
                                Sortable="true"
                                IsEditable="false"
                                CellClass="wis-cell-mono" />

                <PropertyColumn Property="x => x.ProductName"
                                Title="@Localization.GetString("Product")"
                                Sortable="true"
                                IsEditable="false" />

                <PropertyColumn Property="x => x.WarehouseName"
                                Title="@Localization.GetString("Warehouse")"
                                Sortable="true"
                                IsEditable="false" />

                <PropertyColumn Property="x => x.Quantity"
                                Title="@Localization.GetString("CurrentStock")"
                                Sortable="true"
                                IsEditable="false">
                    <CellTemplate>
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                            <MudText Typo="Typo.body2"
                                     Class="wis-cell-amount"
                                     Color="@(IsLowStock(context.Item) ? Color.Error : Color.Default)">
                                @context.Item.Quantity.ToString("N2")
                            </MudText>
                            @if (IsLowStock(context.Item))
                            {
                                <MudIcon Icon="@Icons.Material.Filled.Warning"
                                         Size="Size.Small"
                                         Color="Color.Error" />
                            }
                        </MudStack>
                    </CellTemplate>
                </PropertyColumn>

                <PropertyColumn Property="x => x.MinimumQuantity"
                                Title="@Localization.GetString("MinimumQuantity")"
                                Sortable="false"
                                IsEditable="false">
                    <CellTemplate>
                        @(context.Item.MinimumQuantity?.ToString("N2") ?? "—")
                    </CellTemplate>
                </PropertyColumn>

                <PropertyColumn Property="x => x.ReorderPoint"
                                Title="@Localization.GetString("ReorderPoint")"
                                Sortable="false"
                                IsEditable="false">
                    <CellTemplate>
                        @(context.Item.ReorderPoint?.ToString("N2") ?? "—")
                    </CellTemplate>
                </PropertyColumn>

                <PropertyColumn Property="x => x.LastRestockedAt"
                                Title="@Localization.GetString("LastRestocked")"
                                Sortable="true"
                                IsEditable="false">
                    <CellTemplate>
                        @context.Item.LastRestockedAt.ToLocalTime().ToString("dd MMM yyyy")
                    </CellTemplate>
                </PropertyColumn>

                <TemplateColumn Sortable="false"
                                Filterable="false"
                                IsEditable="false"
                                HeaderClass="wis-col-actions-1"
                                CellClass="wis-col-actions-1">
                    <CellTemplate>
                        <MudStack Row="true" Justify="Justify.Center" AlignItems="AlignItems.Center">
                            <MudIconButton Icon="@Icons.Material.Filled.Tune"
                                           Size="Size.Small"
                                           Color="Color.Primary"
                                           Title="@Localization.GetString("EditThresholds")"
                                           OnClick="@(() => OpenSetThresholdsDialog(context.Item))" />
                        </MudStack>
                    </CellTemplate>
                </TemplateColumn>

            </Columns>

            <NoRecordsContent>
                <WisNoRecordsContent Icon="@Icons.Material.Filled.Inventory"
                                     Message="@Localization.GetString("NoItemsFound")" />
            </NoRecordsContent>

            <LoadingContent>
                <WisLoadingContent />
            </LoadingContent>

            <PagerContent>
                <WisPagerContent T="StockLevelDto" />
            </PagerContent>

        </MudDataGrid>
    </MudCardContent>
</MudCard>

@code {
    private readonly CancellationTokenSource _cts = new();
    private MudDataGrid<StockLevelDto> _grid = null!;
    private string _searchString = string.Empty;

    // Quick filter
    private bool? _filterIsLowStock = null;

    // Advanced filters
    private Guid? _filterWarehouseId = null;
    private Guid? _filterProductId = null;

    private int _activeAdvancedFilterCount =>
        (_filterWarehouseId.HasValue ? 1 : 0) +
        (_filterProductId.HasValue ? 1 : 0);

    protected override void OnInitialized()
    {
        Localization.OnLanguageChanged += OnLanguageChanged;
    }

    private async void OnLanguageChanged()
    {
        await InvokeAsync(StateHasChanged);
    }

    private async Task<GridData<StockLevelDto>> LoadServerData(GridState<StockLevelDto> state, CancellationToken ct)
    {
        string? sortBy = state.SortDefinitions.FirstOrDefault()?.SortBy;
        bool ascending = state.SortDefinitions.FirstOrDefault()?.Descending == false;

        GetStockQuery query = new()
        {
            Search = _searchString,
            WarehouseId = _filterWarehouseId,
            ProductId = _filterProductId,
            IsLowStock = _filterIsLowStock,
            Page = state.Page + 1,
            PageSize = state.PageSize,
            SortBy = sortBy,
            SortAscending = ascending,
        };

        PagedResult<StockLevelDto> result = await InventoryService.GetPagedStockAsync(query, ct);

        return new GridData<StockLevelDto>
        {
            Items = result.Items,
            TotalItems = result.TotalCount
        };
    }

    private async Task OnSearch(string text)
    {
        _searchString = text;
        await _grid.ReloadServerData();
    }

    private async Task ToggleLowStockFilter()
    {
        _filterIsLowStock = _filterIsLowStock == true ? null : true;
        await _grid.ReloadServerData();
    }

    private async Task ReloadGrid() => await _grid.ReloadServerData();

    private async Task<PagedResult<WisAutocompleteItem<Guid>>> LoadWarehouseItems(
        string search, int page, CancellationToken ct)
    {
        PagedResult<WarehouseDto> result = await WarehouseService.GetPagedAsync(new GetWarehousesQuery
        {
            Search = search,
            Page = page,
            PageSize = 10,
            SortBy = "Name",
            SortAscending = true,
            IsActive = true
        }, ct);

        return new PagedResult<WisAutocompleteItem<Guid>>
        {
            Items = result.Items.Select(w => new WisAutocompleteItem<Guid>
            {
                Label = w.Name + (w.IsDefault ? $" ({Localization.GetString("Default")})" : ""),
                Value = w.Id
            }).ToList(),
            TotalCount = result.TotalCount,
            Page = result.Page,
            PageSize = result.PageSize
        };
    }

    private async Task<PagedResult<WisAutocompleteItem<Guid>>> LoadProductItems(
        string search, int page, CancellationToken ct)
    {
        PagedResult<ProductDto> result = await ProductService.GetPagedAsync(new GetProductsQuery
        {
            Search = search,
            Page = page,
            PageSize = 10,
            SortBy = "Name",
            SortAscending = true,
            IsActive = true
        }, ct);

        return new PagedResult<WisAutocompleteItem<Guid>>
        {
            Items = result.Items.Select(p => new WisAutocompleteItem<Guid>
            {
                Label = p.Name,
                SubLabel = p.Code,
                Value = p.Id
            }).ToList(),
            TotalCount = result.TotalCount,
            Page = result.Page,
            PageSize = result.PageSize
        };
    }

    private async Task OnWarehouseFilterChanged(Guid value)
    {
        _filterWarehouseId = value == default ? null : value;
        await _grid.ReloadServerData();
    }

    private async Task OnProductFilterChanged(Guid value)
    {
        _filterProductId = value == default ? null : value;
        await _grid.ReloadServerData();
    }

    private async Task ClearAllFilters()
    {
        _filterIsLowStock = null;
        _filterWarehouseId = null;
        _filterProductId = null;
        await _grid.ReloadServerData();
    }

    private bool IsLowStock(StockLevelDto item) =>
        item.MinimumQuantity.HasValue && item.Quantity <= item.MinimumQuantity.Value;

    private string GetRowClass(StockLevelDto item, int index) =>
        IsLowStock(item) ? "row-status-error table-row-clickable" : "table-row-clickable";

    private void OnRowClick(DataGridRowClickEventArgs<StockLevelDto> args)
    {
        if (args.MouseEventArgs.Detail == 2)
            Navigation.NavigateTo($"/products/{args.Item.ProductId}/transactions?warehouse={args.Item.WarehouseId}");
    }

    private async Task OpenAdjustDialog()
    {
        DialogOptions options = new()
        {
            MaxWidth = MaxWidth.Small,
            FullWidth = true,
            CloseOnEscapeKey = true
        };

        IDialogReference dialog = await DialogService.ShowAsync<AdjustStockDialog>(
            Localization.GetString("AdjustStock"), new DialogParameters<AdjustStockDialog>(), options);

        DialogResult? result = await dialog.Result;

        if (result is { Canceled: false, Data: AdjustStockDialog.AdjustStockResult dto })
        {
            try
            {
                await InventoryService.AdjustStockAsync(
                    dto.ProductId, dto.WarehouseId, dto.QuantityChange, dto.Reason);
                Snackbar.Add(Localization.GetString("StockAdjusted"), Severity.Success);
                await _grid.ReloadServerData();
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Error adjusting stock: {ex.Message}");
                Snackbar.Add(Localization.GetString("ErrorAdjustingStock"), Severity.Error);
            }
        }
    }

    private async Task OpenSetThresholdsDialog(StockLevelDto stockLevel)
    {
        DialogParameters<SetThresholdsDialog> parameters = new();
        parameters.Add(x => x.StockLevel, stockLevel);

        DialogOptions options = new()
        {
            MaxWidth = MaxWidth.Small,
            FullWidth = true,
            CloseOnEscapeKey = true
        };

        IDialogReference dialog = await DialogService.ShowAsync<SetThresholdsDialog>(
            Localization.GetString("EditThresholds"), parameters, options);

        DialogResult? result = await dialog.Result;

        if (result is { Canceled: false, Data: SetThresholdsDialog.SetThresholdsResult dto })
        {
            try
            {
                await InventoryService.UpdateStockLevelAsync(
                    stockLevel.ProductId,
                    stockLevel.WarehouseId,
                    new UpdateStockLevelDto
                    {
                        Quantity = stockLevel.Quantity,
                        MinimumQuantity = dto.MinimumQuantity,
                        ReorderPoint = dto.ReorderPoint
                    });

                Snackbar.Add(Localization.GetString("ThresholdsUpdated"), Severity.Success);
                await _grid.ReloadServerData();
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Error updating thresholds: {ex.Message}");
                Snackbar.Add(Localization.GetString("ErrorUpdatingThresholds"), Severity.Error);
            }
        }
    }

    public void Dispose()
    {
        _cts.Cancel();
        _cts.Dispose();
        Localization.OnLanguageChanged -= OnLanguageChanged;
    }
}
