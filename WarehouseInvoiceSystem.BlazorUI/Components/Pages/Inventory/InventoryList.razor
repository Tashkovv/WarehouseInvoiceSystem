@page "/inventory"
@implements IDisposable
@using WarehouseInvoiceSystem.Application.DTOs.StockLevel
@using WarehouseInvoiceSystem.Application.DTOs.Product
@using WarehouseInvoiceSystem.Application.DTOs.Warehouse
@using WarehouseInvoiceSystem.Domain.Queries
@using WarehouseInvoiceSystem.Domain.Queries.Common
@inject IInventoryService InventoryService
@inject IProductService ProductService
@inject IWarehouseService WarehouseService
@inject ILocalizationService Localization
@inject IDialogService DialogService
@inject ISnackbar Snackbar

<PageTitle>@Localization.GetString("Inventory") - @Localization.GetString("InvoiceSystem")</PageTitle>

<div style="margin-bottom: 15px; padding: 4px 0;">
    <MudText Typo="Typo.h3" Class="wis-page-title">
        @Localization.GetString("Inventory")
    </MudText>
</div>

<WisGridToolbar CreateAction="OpenAdjustDialog"
                CreateLabel="@Localization.GetString("AdjustStock")"
                CreateIcon="@Icons.Material.Filled.Inventory2"
                SearchValue="@_searchString"
                SearchValueChanged="OnSearch"
                HasAnyActiveFilter="@(_filterIsLowStock == true)"
                OnClearAll="ClearAllFilters"
                ActiveAdvancedFilterCount="@_activeAdvancedFilterCount">
    <Filters>
        <button class="wis-filter-btn @(_filterIsLowStock == true ? "wis-filter-btn--active wis-filter-btn--error" : "")"
                @onclick="ToggleLowStockFilter"
                type="button">
            <span class="wis-filter-btn__icon">
                <MudIcon Icon="@Icons.Material.Filled.Warning" Size="Size.Small" />
            </span>
            <span class="wis-filter-btn__label">@Localization.GetString("LowStock")</span>
        </button>
    </Filters>
    <AdvancedFilters>
        <MudGrid Spacing="2" AlignItems="AlignItems.Start">

            @* Warehouse select *@
            <MudItem xs="12" sm="6" md="4">
                <MudSelect T="Guid?"
                           Value="_filterWarehouseId"
                           ValueChanged="OnWarehouseFilterChanged"
                           Label="@Localization.GetString("Warehouse")"
                           Variant="Variant.Outlined"
                           Dense="true"
                           AnchorOrigin="Origin.BottomLeft">
                    <MudSelectItem Value="@((Guid?)null)">
                        @Localization.GetString("AllWarehouses")
                    </MudSelectItem>
                    @foreach (WarehouseDto w in _warehouses)
                    {
                        <MudSelectItem Value="@((Guid?)w.Id)">
                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                @w.Name
                                @if (w.IsDefault)
                                {
                                    <MudChip T="string" Size="Size.Small" Color="Color.Success" Class="ml-1">
                                        @Localization.GetString("Default")
                                    </MudChip>
                                }
                            </MudStack>
                        </MudSelectItem>
                    }
                </MudSelect>
            </MudItem>

            @* Product autocomplete *@
            <MudItem xs="12" sm="6" md="4">
                <MudAutocomplete T="string"
                                 Value="_filterProductName"
                                 ValueChanged="OnProductFilterChanged"
                                 SearchFunc="SearchProducts"
                                 Label="@Localization.GetString("SelectProduct")"
                                 Variant="Variant.Outlined"
                                 Dense="true"
                                 Clearable="true"
                                 OnClearedClick="@(() => OnProductFilterChanged(null))" />
            </MudItem>

        </MudGrid>
    </AdvancedFilters>
</WisGridToolbar>

<MudCard Elevation="2" Class="mb-4">
    <MudCardContent Class="pa-0">
        <MudDataGrid T="StockLevelDto"
                     @ref="_grid"
                     ServerData="LoadServerData"
                     RowClassFunc="GetRowClass"
                     ReadOnly="true"
                     Hover="true"
                     FixedHeader="true"
                     Height="100%"
                     Filterable="false"
                     ShowColumnOptions="false"
                     ColumnResizeMode="ResizeMode.Column"
                     SortMode="SortMode.Single"
                     Class="wis-data-grid">
            <Columns>

                <PropertyColumn Property="x => x.ProductCode"
                                Title="@Localization.GetString("Code")"
                                Sortable="true"
                                IsEditable="false"
                                CellStyle="font-family: monospace;" />

                <PropertyColumn Property="x => x.ProductName"
                                Title="@Localization.GetString("ProductName")"
                                Sortable="true"
                                IsEditable="false" />

                <PropertyColumn Property="x => x.WarehouseName"
                                Title="@Localization.GetString("WarehouseName")"
                                Sortable="true"
                                IsEditable="false" />

                <PropertyColumn Property="x => x.Quantity"
                                Title="@Localization.GetString("CurrentStock")"
                                Sortable="true"
                                IsEditable="false">
                    <CellTemplate>
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                            <MudText Typo="Typo.body2"
                                     Style="font-weight: 600;"
                                     Color="@(IsLowStock(context.Item) ? Color.Error : Color.Default)">
                                @context.Item.Quantity.ToString("N2")
                            </MudText>
                            @if (IsLowStock(context.Item))
                            {
                                <MudIcon Icon="@Icons.Material.Filled.Warning"
                                         Size="Size.Small"
                                         Color="Color.Error" />
                            }
                        </MudStack>
                    </CellTemplate>
                </PropertyColumn>

                <PropertyColumn Property="x => x.MinimumQuantity"
                                Title="@Localization.GetString("MinimumQuantity")"
                                Sortable="false"
                                IsEditable="false">
                    <CellTemplate>
                        @(context.Item.MinimumQuantity?.ToString("N2") ?? "—")
                    </CellTemplate>
                </PropertyColumn>

                <PropertyColumn Property="x => x.ReorderPoint"
                                Title="@Localization.GetString("ReorderPoint")"
                                Sortable="false"
                                IsEditable="false">
                    <CellTemplate>
                        @(context.Item.ReorderPoint?.ToString("N2") ?? "—")
                    </CellTemplate>
                </PropertyColumn>

                <PropertyColumn Property="x => x.LastRestockedAt"
                                Title="@Localization.GetString("LastRestocked")"
                                Sortable="true"
                                IsEditable="false">
                    <CellTemplate>
                        @context.Item.LastRestockedAt.ToLocalTime().ToString("dd MMM yyyy")
                    </CellTemplate>
                </PropertyColumn>

                <TemplateColumn Sortable="false"
                                Filterable="false"
                                IsEditable="false"
                                MinWidth="60"
                                HeaderStyle="width: 60px;"
                                CellStyle="width: 60px;">
                    <CellTemplate>
                        <MudIconButton Icon="@Icons.Material.Filled.Inventory2"
                                       Size="Size.Small"
                                       Color="Color.Primary"
                                       Title="@Localization.GetString("AdjustStock")"
                                       OnClick="@(() => OpenAdjustDialog(context.Item.ProductId, context.Item.WarehouseId))" />
                    </CellTemplate>
                </TemplateColumn>

            </Columns>

            <NoRecordsContent>
                <div class="pa-8 d-flex flex-column align-center">
                    <MudIcon Icon="@Icons.Material.Filled.Inventory"
                             Size="Size.Large"
                             Color="Color.Secondary"
                             Class="mb-2" />
                    <MudText Color="Color.Secondary">
                        @Localization.GetString("NoItemsFound")
                    </MudText>
                </div>
            </NoRecordsContent>

            <LoadingContent>
                <div class="pa-6">
                    <MudProgressLinear Color="Color.Primary" Indeterminate="true" />
                </div>
            </LoadingContent>

            <PagerContent>
                <WisPagerContent T="StockLevelDto" />
            </PagerContent>

        </MudDataGrid>
    </MudCardContent>
</MudCard>

@code {
    private MudDataGrid<StockLevelDto> _grid = null!;
    private string _searchString = string.Empty;

    // Quick filter
    private bool? _filterIsLowStock = null;

    // Advanced filters
    private Guid? _filterWarehouseId = null;
    private string? _filterProductName = null;

    private int _activeAdvancedFilterCount =>
        (_filterWarehouseId.HasValue ? 1 : 0) +
        (!string.IsNullOrWhiteSpace(_filterProductName) ? 1 : 0);

    // Caches for filter controls
    private List<WarehouseDto> _warehouses = [];
    private List<ProductDto> _products = [];

    protected override async Task OnInitializedAsync()
    {
        Localization.OnLanguageChanged += OnLanguageChanged;

        try
        {
            _warehouses = (await WarehouseService.GetAllWarehousesAsync())
                .OrderByDescending(w => w.IsDefault)
                .ThenBy(w => w.Name)
                .ToList();

            _products = (await ProductService.GetActiveProductsAsync())
                .OrderBy(p => p.Name)
                .ToList();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading filter data: {ex.Message}");
        }
    }

    private async void OnLanguageChanged()
    {
        await InvokeAsync(StateHasChanged);
    }

    private async Task<GridData<StockLevelDto>> LoadServerData(GridState<StockLevelDto> state, CancellationToken ct)
    {
        string? sortBy = state.SortDefinitions.FirstOrDefault()?.SortBy;
        bool ascending = state.SortDefinitions.FirstOrDefault()?.Descending == false;

        // Resolve product name to ID for the query
        Guid? productId = null;
        if (!string.IsNullOrWhiteSpace(_filterProductName))
        {
            ProductDto? match = _products.FirstOrDefault(p =>
                p.Name.Equals(_filterProductName, StringComparison.OrdinalIgnoreCase));
            productId = match?.Id;
        }

        GetStockQuery query = new()
        {
            Search = _searchString,
            WarehouseId = _filterWarehouseId,
            ProductId = productId,
            IsLowStock = _filterIsLowStock,
            Page = state.Page + 1,
            PageSize = state.PageSize,
            SortBy = sortBy,
            SortAscending = ascending,
        };

        PagedResult<StockLevelDto> result = await InventoryService.GetPagedStockAsync(query);

        return new GridData<StockLevelDto>
        {
            Items = result.Items,
            TotalItems = result.TotalCount
        };
    }

    private async Task<IEnumerable<string>> SearchProducts(string value, CancellationToken ct)
    {
        if (string.IsNullOrWhiteSpace(value))
            return _products.Select(p => p.Name);

        return _products
            .Where(p => p.Name.Contains(value, StringComparison.OrdinalIgnoreCase) ||
                        p.Code.Contains(value, StringComparison.OrdinalIgnoreCase))
            .Select(p => p.Name);
    }

    private async Task OnSearch(string text)
    {
        _searchString = text;
        await _grid.ReloadServerData();
    }

    private async Task ToggleLowStockFilter()
    {
        _filterIsLowStock = _filterIsLowStock == true ? null : true;
        await _grid.ReloadServerData();
    }

    private async Task OnWarehouseFilterChanged(Guid? id)
    {
        _filterWarehouseId = id;
        await _grid.ReloadServerData();
    }

    private async Task OnProductFilterChanged(string? value)
    {
        _filterProductName = value;
        await _grid.ReloadServerData();
    }

    private async Task ReloadGrid() => await _grid.ReloadServerData();

    private async Task ClearAllFilters()
    {
        _filterIsLowStock = null;
        _filterWarehouseId = null;
        _filterProductName = null;
        await _grid.ReloadServerData();
    }

    private bool IsLowStock(StockLevelDto item) =>
        item.MinimumQuantity.HasValue && item.Quantity <= item.MinimumQuantity.Value;

    private string GetRowClass(StockLevelDto item, int index) =>
        IsLowStock(item) ? "row-status-error" : string.Empty;

    private Task OpenAdjustDialog() => OpenAdjustDialog(null, null);

    private async Task OpenAdjustDialog(Guid? productId, Guid? warehouseId)
    {
        DialogParameters<AdjustStockDialog> parameters = new();
        if (productId.HasValue)
            parameters.Add(x => x.PreSelectedProductId, productId);
        if (warehouseId.HasValue)
            parameters.Add(x => x.PreSelectedWarehouseId, warehouseId);

        DialogOptions options = new()
        {
            MaxWidth = MaxWidth.Small,
            FullWidth = true,
            CloseOnEscapeKey = true
        };

        IDialogReference dialog = await DialogService.ShowAsync<AdjustStockDialog>(
            Localization.GetString("AdjustStock"), parameters, options);

        DialogResult? result = await dialog.Result;

        if (result is { Canceled: false, Data: AdjustStockDialog.AdjustStockResult dto })
        {
            try
            {
                await InventoryService.AdjustStockAsync(
                    dto.ProductId, dto.WarehouseId, dto.QuantityChange, dto.Reason);
                Snackbar.Add(Localization.GetString("StockAdjusted"), Severity.Success);
                await _grid.ReloadServerData();
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Error adjusting stock: {ex.Message}");
                Snackbar.Add(Localization.GetString("ErrorAdjustingStock"), Severity.Error);
            }
        }
    }

    public void Dispose()
    {
        Localization.OnLanguageChanged -= OnLanguageChanged;
    }
}
