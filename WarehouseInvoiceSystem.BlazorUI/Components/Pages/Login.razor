@page "/login"
@layout WarehouseInvoiceSystem.BlazorUI.Components.Layout.EmptyLayout
@implements IDisposable
@using WarehouseInvoiceSystem.BlazorUI.Theme
@inject IUserService UserService
@inject ILocalizationService Localization
@inject NavigationManager Navigation
@inject IJSRuntime JS
@inject IThemeService ThemeService

<MudThemeProvider Theme="AppTheme.Theme" IsDarkMode="_isDarkMode" />
<MudPopoverProvider />

<div style="@PageBackgroundStyle">
    <MudCard Style="width: 420px;" Elevation="4">
        <MudCardHeader>
            <CardHeaderContent>
                <div class="d-flex align-center gap-2 mb-2">
                    <img src="app-logo.png" alt="Logo" style="width: 32px; height: 32px; object-fit: contain;" />
                    <MudText Typo="Typo.h5" Color="Color.Primary">@Localization.GetString("InvoiceSystem")</MudText>
                </div>
                <MudText Typo="Typo.body2" Color="Color.Secondary">@Localization.GetString("LoginDescription")</MudText>
            </CardHeaderContent>
        </MudCardHeader>
        <MudCardContent>
            @if (!string.IsNullOrEmpty(_error))
            {
                <MudAlert Severity="Severity.Error" Dense="true" Class="mb-4">
                    @Localization.GetString(_error)
                </MudAlert>
            }

            <form id="loginForm" method="post" action="/api/auth/login">
                <div class="mb-4">
                    <label class="mud-input-label" for="username">@Localization.GetString("Username")</label>
                    <input type="text" id="username" name="username" required autofocus
                           style="@InputStyle" />
                </div>

                <div class="mb-4">
                    <label class="mud-input-label" for="password">@Localization.GetString("Password")</label>
                    <input type="password" id="password" name="password" required
                           style="@InputStyle" />
                </div>

                <div class="d-flex align-center mb-4">
                    <input type="checkbox" id="remember" name="remember" value="true" style="margin-right: 8px;" />
                    <label for="remember" style="@CheckboxLabelStyle">@Localization.GetString("RememberMe")</label>
                </div>

                <div class="d-flex justify-end">
                    <WisButton Action="@(new WisDetailActionItem
                    {
                        Icon = Icons.Material.Filled.Login,
                        Label = Localization.GetString("Login"),
                        Color = Color.Primary,
                        OnClick = EventCallback.Factory.Create(this, SubmitLogin)
                    })" />
                </div>
            </form>
        </MudCardContent>
    </MudCard>
</div>

@code {
    private string? _error;
    private bool _isDarkMode;

    private string PageBackgroundStyle => _isDarkMode
        ? "display: flex; justify-content: center; align-items: center; min-height: 100vh; background-color: #0F172A;"
        : "display: flex; justify-content: center; align-items: center; min-height: 100vh; background-color: #F8FAFC;";

    private string InputStyle => _isDarkMode
        ? "width: 100%; padding: 12px; border: 1px solid #334155; border-radius: 8px; font-size: 1rem; font-family: Inter, sans-serif; background-color: #1E293B; color: #F1F5F9;"
        : "width: 100%; padding: 12px; border: 1px solid #ccc; border-radius: 8px; font-size: 1rem; font-family: Inter, sans-serif;";

    private string CheckboxLabelStyle => _isDarkMode
        ? "font-size: 0.875rem; color: #94A3B8;"
        : "font-size: 0.875rem; color: #475569;";

    protected override async Task OnInitializedAsync()
    {
        var uri = Navigation.ToAbsoluteUri(Navigation.Uri);
        if (Microsoft.AspNetCore.WebUtilities.QueryHelpers.ParseQuery(uri.Query).TryGetValue("error", out var errorValue))
            _error = errorValue.ToString();

        bool anyUsers = await UserService.AnyUsersExistAsync();
        if (!anyUsers)
            Navigation.NavigateTo("/setup");

        ThemeService.OnThemeChanged += HandleThemeChanged;
        _isDarkMode = ThemeService.IsDarkMode;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
            await ThemeService.InitializeAsync();
    }

    private void HandleThemeChanged()
    {
        _isDarkMode = ThemeService.IsDarkMode;
        InvokeAsync(StateHasChanged);
    }

    private async Task SubmitLogin()
    {
        await JS.InvokeVoidAsync("wisAuth.submitForm", "loginForm");
    }

    public void Dispose()
    {
        ThemeService.OnThemeChanged -= HandleThemeChanged;
    }
}
