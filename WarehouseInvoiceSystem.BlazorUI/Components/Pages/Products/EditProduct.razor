@page "/products/edit/{Id:guid}"
@using WarehouseInvoiceSystem.Application.Interfaces
@using WarehouseInvoiceSystem.Application.DTOs.Product
@inject IProductService ProductService
@inject ILocalizationService Localization
@inject NavigationManager Navigation
@inject ISnackbar Snackbar

<PageTitle>@Localization.GetString("EditProduct") - @Localization.GetString("InvoiceSystem")</PageTitle>

@if (_loading)
{
    <MudProgressLinear Color="Color.Primary" Indeterminate="true" />
}
else if (_model == null)
{
    <MudAlert Severity="Severity.Error">@Localization.GetString("ProductNotFound")</MudAlert>
}
else
{
    <div class="d-flex justify-space-between align-center mb-4">
        <MudText Typo="Typo.h4">@Localization.GetString("EditProduct")</MudText>
        <MudButton StartIcon="@Icons.Material.Filled.ArrowBack"
                   Variant="Variant.Text"
                   Href="/products">
            @Localization.GetString("BackToProducts")
        </MudButton>
    </div>

    <MudCard Elevation="2" Class="mb-4">
        <MudCardContent>
            <MudForm @ref="_form" @bind-IsValid="@_isValid">
                <MudGrid>
                    <MudItem xs="12" md="3">
                        <MudTextField @bind-Value="_model.Code"
                                      Label="@Localization.GetString("ProductCode")"
                                      Required="true"
                                      Variant="Variant.Outlined"
                                      RequiredError="@Localization.GetString("CodeRequired")"
                                      MaxLength="50" />
                    </MudItem>

                    <MudItem xs="12" md="3">
                        <MudTextField @bind-Value="_model.Name"
                                      Label="@Localization.GetString("ProductName")"
                                      Required="true"
                                      Variant="Variant.Outlined"
                                      RequiredError="@Localization.GetString("NameRequired")"
                                      MaxLength="100" />
                    </MudItem>

                    <MudItem xs="12" md="6">
                        <MudTextField @bind-Value="_model.Description"
                                      Label="@Localization.GetString("Description")"
                                      Variant="Variant.Outlined"
                                      MaxLength="500" />
                    </MudItem>

                    <MudItem xs="12" md="3">
                        <MudTextField @bind-Value="_model.Unit"
                                      Label="@Localization.GetString("Unit")"
                                      HelperText="@Localization.GetString("UnitHelper")"
                                      Required="true"
                                      Variant="Variant.Outlined"
                                      RequiredError="@Localization.GetString("UnitRequired")"
                                      MaxLength="10" />
                    </MudItem>

                    <MudItem xs="12" md="3">
                        <MudNumericField @bind-Value="_model.DefaultPrice"
                                         Label="@Localization.GetString("DefaultPrice")"
                                         Format="N2"
                                         TextUpdateSuppression="false"
                                         Min="0m"
                                         Required="true"
                                         Variant="Variant.Outlined"
                                         RequiredError="@Localization.GetString("PriceRequired")"
                                         Adornment="Adornment.Start"
                                         AdornmentText="MKD" />
                    </MudItem>

                    <MudItem xs="12" md="3" Class="d-flex align-center">
                        <MudSwitch @bind-Value="_model.IsActive"
                                   Label="@Localization.GetString("ProductActive")"
                                   Color="Color.Success" />
                    </MudItem>
                </MudGrid>
            </MudForm>
        </MudCardContent>
    </MudCard>

    <!-- Actions -->
    <MudItem xs="12">
        <div class="d-flex justify-end gap-2">
            <MudButton Variant="Variant.Outlined"
                       OnClick="Cancel"
                       Disabled="@_saving">
                @Localization.GetString("Cancel")
            </MudButton>
            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       OnClick="SaveProduct"
                       Disabled="@(!_isValid || _saving)">
                @if (_saving)
                {
                    <MudProgressCircular Class="ms-n1" Size="Size.Small" Indeterminate="true" />
                    <MudText Class="ms-2">@Localization.GetString("Saving")</MudText>
                }
                else
                {
                    @Localization.GetString("Save")
                }
            </MudButton>
        </div>
    </MudItem>
}

@code {
    [Parameter] public Guid Id { get; set; }

    private MudForm _form = null!;
    private bool _isValid;
    private bool _loading = true;
    private bool _saving;
    private UpdateProductDto? _model;

    protected override async Task OnInitializedAsync()
    {
        Localization.OnLanguageChanged += OnLanguageChanged;
        await LoadProduct();
    }

    private async void OnLanguageChanged()
    {
        await InvokeAsync(StateHasChanged);
    }

    private async Task LoadProduct()
    {
        _loading = true;

        try
        {
            ProductDto? product = await ProductService.GetProductByIdAsync(Id);
            if (product != null)
            {
                _model = new UpdateProductDto
                {
                    Code = product.Code,
                    Name = product.Name,
                    Description = product.Description,
                    Unit = product.Unit,
                    DefaultPrice = product.DefaultPrice,
                    IsActive = product.IsActive
                };
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading product: {ex.Message}");
            Snackbar.Add(Localization.GetString("ErrorLoadingProduct"), Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task SaveProduct()
    {
        await _form.ValidateAsync();
        if (!_isValid || _model == null) return;

        _saving = true;

        try
        {
            await ProductService.UpdateProductAsync(Id, _model);
            Snackbar.Add(Localization.GetString("ProductUpdated"), Severity.Success);
            Navigation.NavigateTo("/products");
        }
        catch (InvalidOperationException ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error updating product: {ex.Message}");
            Snackbar.Add(Localization.GetString("ErrorUpdatingProduct"), Severity.Error);
        }
        finally
        {
            _saving = false;
        }
    }

    private void Cancel()
    {
        Navigation.NavigateTo($"/products/{Id}");
    }
}