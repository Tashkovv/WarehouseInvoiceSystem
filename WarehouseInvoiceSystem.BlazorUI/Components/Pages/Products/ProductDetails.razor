@page "/products/{Id:guid}"
@implements IDisposable
@using WarehouseInvoiceSystem.Application.DTOs.Product
@using WarehouseInvoiceSystem.Application.DTOs.Warehouse
@using WarehouseInvoiceSystem.Application.DTOs.Invoice
@using WarehouseInvoiceSystem.Application.DTOs.PurchaseNote
@using WarehouseInvoiceSystem.Domain.Queries
@using WarehouseInvoiceSystem.Domain.Queries.Common
@using WarehouseInvoiceSystem.Domain.Enums
@inject IProductService ProductService
@inject IWarehouseService WarehouseService
@inject ILocalizationService Localization
@inject NavigationManager Navigation
@inject WisDialogService WisDialog
@inject IDialogService DialogService
@inject IInventoryService InventoryService
@inject ISnackbar Snackbar

<PageTitle>@Localization.GetString("ProductDetails") - @Localization.GetString("InvoiceSystem")</PageTitle>

@if (_loading)
{
    <MudProgressLinear Color="Color.Primary" Indeterminate="true" />
}
else if (_product == null)
{
    <MudAlert Severity="Severity.Error">@Localization.GetString("ProductNotFound")</MudAlert>
}
else
{
    <WisDetailHeader BackHref="/products"
                     BackLabel="@Localization.GetString("Products")"
                     PrimaryAction="@_primaryAction"
                     Actions="@_actions" />

    <MudGrid>

        @* ── Header card ── *@
        <MudItem xs="12">
            <MudCard Elevation="2">
                <MudCardContent Class="pa-4">

                    @* ── Identity row: name+chip left, warehouse filter right ── *@
                    <div class="wis-product-identity-row">
                        <div class="wis-detail-identity">
                            <MudText Typo="Typo.h4" Class="font-weight-bold mb-0">@_product.Name</MudText>
                            <MudChip T="string" Size="Size.Small" Color="@(_product.IsActive? Color.Success: Color.Default)">
                                @(_product.IsActive? Localization.GetString("ProductActive") : Localization.GetString("ProductInactive"))
                            </MudChip>
                        </div>
                        <WisAutocompleteFilter TValue="Guid"
                                               Label="@Localization.GetString("AllWarehouses")"
                                               AllLabel="@Localization.GetString("AllWarehouses")"
                                               Icon="@Icons.Material.Filled.Warehouse"
                                               LoadItems="LoadWarehouseItems"
                                               PopoverAnchorOrigin="Origin.BottomRight"
                                               PopoverTransformOrigin="Origin.TopRight"
                                               SelectedValue="@(_selectedWarehouseId ?? default)"
                                               SelectedValueChanged="@(async (Guid v) => await OnWarehouseChanged(v == default ? (Guid?)null : v))"
                                               MinWidth="200px" />
                    </div>

                    @* ── Meta row: code, unit, description ── *@
                    <div class="wis-detail-contact wis-product-meta-row">
                        <div class="wis-detail-contact-item">
                            <MudIcon Icon="@Icons.Material.Filled.Tag" Size="Size.Small" Color="Color.Secondary" />
                            <MudText Typo="Typo.body2" Style="font-weight: 500;">@_product.Code</MudText>
                        </div>
                        <div class="wis-detail-contact-item">
                            <MudIcon Icon="@Icons.Material.Filled.Scale" Size="Size.Small" Color="Color.Secondary" />
                            <MudText Typo="Typo.body2">@_product.Unit</MudText>
                        </div>
                        @if (!string.IsNullOrWhiteSpace(_product.Description))
                        {
                            <div class="wis-detail-contact-item">
                                <MudIcon Icon="@Icons.Material.Filled.Info" Size="Size.Small" Color="Color.Secondary" />
                                <MudText Typo="Typo.body2" Color="Color.Secondary">@_product.Description</MudText>
                            </div>
                        }
                    </div>

                    @* ── Stats bar — 4 stats, full width ── *@
                    <div class="wis-product-stats-bar">

                        @* Stat 1 *@
                        <div class="wis-product-stats-bar__stat">
                            <MudText Typo="Typo.caption" Color="Color.Secondary" Class="wis-section-label">@Localization.GetString("DefaultPrice")</MudText>
                            <div class="wis-stat-value mud-success-text">@_product.DefaultPrice.ToString("C")</div>
                        </div>

                        @* Stat 2 *@
                        <div class="wis-product-stats-bar__stat">
                            <MudText Typo="Typo.caption" Color="Color.Secondary" Class="wis-section-label">@Localization.GetString("TotalStock")</MudText>
                            <div class="wis-stat-value @StockColorClass">@_filteredTotalStock.ToString("N2") @_product.Unit</div>
                            <MudText Typo="Typo.caption" Color="@StockBadgeColor" Class="mt-1">@StockStatusLabel</MudText>
                        </div>

                        @* Stat 3 *@
                        <div class="wis-product-stats-bar__stat">
                            <MudText Typo="Typo.caption" Color="Color.Secondary" Class="wis-section-label">@Localization.GetString("StockValue")</MudText>
                            <div class="wis-stat-value mud-success-text">@_filteredStockValue.ToString("C")</div>
                        </div>

                        @* Stat 4 *@
                        <div class="wis-product-stats-bar__stat">
                            <MudText Typo="Typo.caption" Color="Color.Secondary" Class="wis-section-label">@Localization.GetString("GrossMargin")</MudText>
                            <div class="wis-stat-value @(_scopedGrossMarginPct > 30 ? "mud-success-text" : "mud-warning-text")">
                                @_scopedGrossMarginPct.ToString("N1")%
                            </div>
                        </div>

                    </div>

                </MudCardContent>
            </MudCard>
        </MudItem>

        @* ── Stock by Warehouse (only when All Warehouses selected) ── *@
        @if (!_selectedWarehouseId.HasValue && _details.StockByWarehouse.Any())
        {
            <MudItem xs="12">
                <MudCard Elevation="2">
                    <MudCardHeader>
                        <CardHeaderContent>
                            <MudText Typo="Typo.h6">@Localization.GetString("StockByWarehouse")</MudText>
                        </CardHeaderContent>
                    </MudCardHeader>
                    <MudCardContent Class="pa-0">
                        <MudTable Items="_details.StockByWarehouse"
                                  Hover="true"
                                  Elevation="0"
                                  Class="wis-secondary-list">
                            <HeaderContent>
                                <MudTh>@Localization.GetString("Warehouse")</MudTh>
                                <MudTh Style="text-align: right;">@Localization.GetString("Quantity")</MudTh>
                                <MudTh Style="text-align: right;">@Localization.GetString("Reserved")</MudTh>
                                <MudTh Style="text-align: right;">@Localization.GetString("Available")</MudTh>
                                <MudTh Style="text-align: right;">@Localization.GetString("Minimum")</MudTh>
                                <MudTh>@Localization.GetString("LastRestocked")</MudTh>
                            </HeaderContent>
                            <RowTemplate>
                                <MudTd DataLabel="@Localization.GetString("Warehouse")">
                                    <MudText Typo="Typo.body2">@context.WarehouseName</MudText>
                                </MudTd>
                                <MudTd DataLabel="@Localization.GetString("Quantity")" Style="text-align: right;">
                                    <MudText Typo="Typo.body2"
                                             Color="@(context.Quantity <= context.MinimumQuantity ? Color.Error : Color.Default)">
                                        @context.Quantity.ToString("N2") @_product.Unit
                                    </MudText>
                                </MudTd>
                                <MudTd DataLabel="@Localization.GetString("Reserved")" Style="text-align: right;">
                                    <MudText Typo="Typo.body2">@context.ReservedQuantity.ToString("N2") @_product.Unit</MudText>
                                </MudTd>
                                <MudTd DataLabel="@Localization.GetString("Available")" Style="text-align: right;">
                                    <MudText Typo="Typo.body2">@context.AvailableQuantity.ToString("N2") @_product.Unit</MudText>
                                </MudTd>
                                <MudTd DataLabel="@Localization.GetString("Minimum")" Style="text-align: right;">
                                    <MudText Typo="Typo.body2">@(context.MinimumQuantity?.ToString("N2") ?? "0,00") @_product.Unit</MudText>
                                </MudTd>
                                <MudTd DataLabel="@Localization.GetString("LastRestocked")">
                                    <MudText Typo="Typo.body2">@(context.LastRestockedAt?.ToString("dd MMM yyyy") ?? "-")</MudText>
                                </MudTd>
                            </RowTemplate>
                        </MudTable>
                    </MudCardContent>
                </MudCard>
            </MudItem>
        }

        @* ── Profitability ── *@
        <MudItem xs="12">
            <MudCard Elevation="2">
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudText Typo="Typo.h6">@Localization.GetString("Profitability")</MudText>
                    </CardHeaderContent>
                </MudCardHeader>
                <MudCardContent Class="pa-4">
                    <MudGrid Spacing="4" Class="wis-detail-stats">

                        <MudItem xs="3">
                            <MudText Typo="Typo.caption" Color="Color.Secondary" Class="wis-section-label">@Localization.GetString("AveragePurchasePrice")</MudText>
                            <div class="wis-stat-value">@_scopedAvgPurchasePrice.ToString("C")</div>
                        </MudItem>

                        <MudItem xs="3">
                            <MudText Typo="Typo.caption" Color="Color.Secondary" Class="wis-section-label">@Localization.GetString("CurrentSellingPrice")</MudText>
                            <div class="wis-stat-value mud-success-text">@_details.CurrentSellingPrice.ToString("C")</div>
                        </MudItem>

                        <MudItem xs="3">
                            <MudText Typo="Typo.caption" Color="Color.Secondary" Class="wis-section-label">@Localization.GetString("GrossMargin")</MudText>
                            <div class="wis-stat-value @(_scopedGrossMarginPct > 30 ? "mud-success-text" : "mud-warning-text")">
                                @_scopedGrossMarginPct.ToString("N1")%
                            </div>
                        </MudItem>

                        <MudItem xs="3">
                            <MudText Typo="Typo.caption" Color="Color.Secondary" Class="wis-section-label">@Localization.GetString("EstimatedProfit")</MudText>
                            <div class="wis-stat-value @(_scopedEstimatedProfit > 0 ? "mud-success-text" : "mud-error-text")">
                                @_scopedEstimatedProfit.ToString("C")
                            </div>
                        </MudItem>

                    </MudGrid>
                </MudCardContent>
            </MudCard>
        </MudItem>

        @* ── Transaction History Summary ── *@
        <MudItem xs="12">
            <MudCard Elevation="2">
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudText Typo="Typo.h6">@Localization.GetString("TransactionHistory")</MudText>
                    </CardHeaderContent>
                    <CardHeaderActions>
                        <MudButton Variant="Variant.Outlined"
                                   Size="Size.Small"
                                   Color="Color.Primary"
                                   EndIcon="@Icons.Material.Filled.ArrowForward"
                                   Href="@($"/products/{Id}/transactions{(_selectedWarehouseId.HasValue ? $"?warehouse={_selectedWarehouseId}" : "")}")"
                                   Class="wis-back-btn">
                            @Localization.GetString("Transactions")
                        </MudButton>
                    </CardHeaderActions>
                </MudCardHeader>
                <MudCardContent Class="pa-4">
                    <MudGrid Spacing="4" Class="wis-detail-stats">

                        <MudItem xs="12" sm="4" md="2">
                            <MudText Typo="Typo.caption" Color="Color.Secondary" Class="wis-section-label">@Localization.GetString("Purchased")</MudText>
                            <div class="wis-stat-value mud-info-text">@_scopedPurchased.Count()</div>
                            <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mt-1">
                                @_scopedPurchased.Sum(r => r.Quantity).ToString("N2") @_product.Unit
                            </MudText>
                        </MudItem>

                        <MudItem xs="12" sm="4" md="2">
                            <MudText Typo="Typo.caption" Color="Color.Secondary" Class="wis-section-label">@Localization.GetString("Sold")</MudText>
                            <div class="wis-stat-value mud-success-text">@_scopedSold.Count()</div>
                            <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mt-1">
                                @_scopedSold.Sum(r => r.Quantity).ToString("N2") @_product.Unit
                            </MudText>
                        </MudItem>

                        <MudItem xs="12" sm="4" md="2">
                            <MudText Typo="Typo.caption" Color="Color.Secondary" Class="wis-section-label">@Localization.GetString("TotalPurchased")</MudText>
                            <div class="wis-stat-value mud-info-text">@_scopedPurchased.Sum(r => r.TotalPrice).ToString("C")</div>
                        </MudItem>

                        <MudItem xs="12" sm="4" md="2">
                            <MudText Typo="Typo.caption" Color="Color.Secondary" Class="wis-section-label">@Localization.GetString("TotalSold")</MudText>
                            <div class="wis-stat-value mud-success-text">@_scopedSold.Sum(r => r.TotalPrice).ToString("C")</div>
                        </MudItem>

                        <MudItem xs="12" sm="4" md="4">
                            <MudText Typo="Typo.caption" Color="Color.Secondary" Class="wis-section-label">@Localization.GetString("Profit")</MudText>
                            <div class="wis-stat-value @(_scopedProfit >= 0 ? "mud-success-text" : "mud-error-text")">
                                @_scopedProfit.ToString("C")
                            </div>
                        </MudItem>

                    </MudGrid>
                </MudCardContent>
            </MudCard>
        </MudItem>

    </MudGrid>
}

@code {
    [Parameter] public Guid Id { get; set; }

    private bool _loading = true;
    private ProductDto? _product;
    private ProductDetailsDto _details = new();

    private Guid? _selectedWarehouseId = null;

    private WisDetailActionItem? _primaryAction;
    private List<WisDetailActionItem> _actions = [];

    // ── Warehouse autocomplete data source ────────────────────────────────────

    private async Task<PagedResult<WisAutocompleteItem<Guid>>> LoadWarehouseItems(
        string search, int page, CancellationToken ct)
    {
        PagedResult<WarehouseDto> result = await WarehouseService.GetPagedAsync(
            new GetWarehousesQuery
            {
                Search = search,
                Page = page,
                PageSize = 10,
                SortBy = "Name",
                SortAscending = true
            });

        return new PagedResult<WisAutocompleteItem<Guid>>
        {
            Items = result.Items.Select(w => new WisAutocompleteItem<Guid>
            {
                Label = w.Name + (w.IsDefault ? $" ({Localization.GetString("Default")})" : ""),
                Value = w.Id
            }).ToList(),
            TotalCount = result.TotalCount,
            Page = result.Page,
            PageSize = result.PageSize
        };
    }

    // ── Scoped computed properties ────────────────────────────────────────────

    private decimal _filteredTotalStock => _selectedWarehouseId.HasValue
        ? _details.StockByWarehouse.Where(s => s.WarehouseId == _selectedWarehouseId.Value).Sum(s => s.Quantity)
        : _details.TotalStockAcrossWarehouses;

    private decimal _filteredStockValue => _filteredTotalStock * _details.CurrentSellingPrice;

    private bool _filteredIsOutOfStock => _filteredTotalStock == 0;

    private bool _filteredHasLowStock => _selectedWarehouseId.HasValue
        ? _details.StockByWarehouse.Any(s => s.WarehouseId == _selectedWarehouseId.Value
                                          && s.Quantity <= s.MinimumQuantity
                                          && s.Quantity > 0)
        : _details.HasLowStock;

    private string StockColorClass =>
        _filteredIsOutOfStock ? "mud-error-text" :
        _filteredHasLowStock ? "mud-warning-text" :
                                "mud-default-text";

    private Color StockBadgeColor =>
        _filteredIsOutOfStock ? Color.Error :
        _filteredHasLowStock ? Color.Warning :
                                Color.Success;

    private string StockStatusLabel =>
        _filteredIsOutOfStock ? Localization.GetString("OutOfStock") :
        _filteredHasLowStock ? Localization.GetString("LowStock") :
                                Localization.GetString("InStock");

    private IEnumerable<ProductTransactionRow> _scopedPurchased =>
        _selectedWarehouseId.HasValue
            ? _allHistoryPurchased.Where(r => r.WarehouseId == _selectedWarehouseId.Value)
            : _allHistoryPurchased;

    private IEnumerable<ProductTransactionRow> _scopedSold =>
        _selectedWarehouseId.HasValue
            ? _allHistorySold.Where(r => r.WarehouseId == _selectedWarehouseId.Value)
            : _allHistorySold;

    private decimal _scopedAvgPurchasePrice =>
        _scopedPurchased.Any() ? _scopedPurchased.Average(r => r.UnitPrice) : 0;

    private decimal _scopedGrossMarginPct =>
        _details.CurrentSellingPrice > 0 && _scopedAvgPurchasePrice > 0
            ? (_details.CurrentSellingPrice - _scopedAvgPurchasePrice) / _details.CurrentSellingPrice * 100
            : _details.GrossMarginPercentage;

    private decimal _scopedEstimatedProfit =>
        (_details.CurrentSellingPrice - _scopedAvgPurchasePrice) * _filteredTotalStock;

    private decimal _scopedProfit =>
        _scopedSold.Sum(r => r.TotalPrice) - _scopedPurchased.Sum(r => r.TotalPrice);

    // ── Lifecycle ─────────────────────────────────────────────────────────────

    protected override async Task OnInitializedAsync()
    {
        Localization.OnLanguageChanged += OnLanguageChanged;
        await LoadProduct();
    }

    private async void OnLanguageChanged()
    {
        BuildActions();
        await InvokeAsync(StateHasChanged);
    }

    private async Task LoadProduct()
    {
        _loading = true;

        try
        {
            _product = await ProductService.GetProductByIdAsync(Id);
            if (_product != null)
            {
                // Single call — replaces GetProductAnalyticsAsync + GetAllWarehousesAsync + GetProductTransactionHistoryAsync
                _details = await ProductService.GetProductDetailsAsync(Id);

                _selectedWarehouseId = null;

                BuildActions();
                PopulateHistory(_details);
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading product: {ex.Message}");
            Snackbar.Add(Localization.GetString("ErrorLoadingProduct"), Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    private void BuildActions()
    {
        if (_product is null) return;

        _primaryAction = new WisDetailActionItem
        {
            Icon = Icons.Material.Filled.Inventory2,
            Label = Localization.GetString("AdjustStock"),
            OnClick = EventCallback.Factory.Create(this, OpenAdjustDialog)
        };

        _actions =
        [
            new WisDetailActionItem
            {
                Icon = Icons.Material.Filled.Edit,
                Label = Localization.GetString("Edit"),
                OnClick = EventCallback.Factory.Create(this, OpenEditDialog)
            },
            new WisDetailActionItem
            {
                Icon = _product.IsActive
                    ? Icons.Material.Filled.DoNotDisturbOn
                    : Icons.Material.Filled.CheckCircle,
                Label = _product.IsActive
                    ? Localization.GetString("Deactivate")
                    : Localization.GetString("Activate"),
                Color = _product.IsActive ? Color.Error : Color.Success,
                IsDividerBefore = true,
                OnClick = EventCallback.Factory.Create(this, ToggleActiveStatus)
            }
        ];
    }

    private async Task OpenEditDialog()
    {
        if (_product is null) return;

        ProductDto? dto = await WisDialog.ShowFormAsync<ProductDialog, ProductDto>(
            Localization.GetString("EditProduct"),
            p => p.Add(x => x.Product, _product));

        if (dto is null) return;

        try
        {
            UpdateProductDto updateDto = new()
            {
                Name = dto.Name,
                Code = dto.Code,
                Description = dto.Description,
                Unit = dto.Unit,
                DefaultPrice = dto.DefaultPrice,
                IsActive = _product.IsActive,
            };

            await ProductService.UpdateProductAsync(Id, updateDto);
            Snackbar.Add(Localization.GetString("ProductUpdated"), Severity.Success);
            await LoadProduct();
        }
        catch (InvalidOperationException ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error updating product: {ex.Message}");
            Snackbar.Add(Localization.GetString("ErrorUpdatingProduct"), Severity.Error);
        }
    }

    private async Task ToggleActiveStatus()
    {
        if (_product is null) return;

        if (_product.IsActive)
            await DeactivateProduct();
        else
            await ActivateProduct();
    }

    private async Task DeactivateProduct()
    {
        bool confirmed = await WisDialog.ConfirmAsync(
            Localization.GetString("DeactivateProduct"),
            Localization.GetString("DeactivateProductConfirm"),
            Localization.GetString("Deactivate"),
            Localization.GetString("Cancel"));

        if (!confirmed) return;

        try
        {
            await ProductService.SetActiveStatusAsync(Id, false);
            Snackbar.Add(Localization.GetString("ProductDeactivated"), Severity.Success);
            await LoadProduct();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error deactivating product: {ex.Message}");
            Snackbar.Add(Localization.GetString("ErrorUpdatingProduct"), Severity.Error);
        }
    }

    private async Task ActivateProduct()
    {
        bool confirmed = await WisDialog.ConfirmAsync(
            Localization.GetString("ActivateProduct"),
            Localization.GetString("ActivateProductConfirm"),
            Localization.GetString("Activate"),
            Localization.GetString("Cancel"));

        if (!confirmed) return;

        try
        {
            await ProductService.SetActiveStatusAsync(Id, true);
            Snackbar.Add(Localization.GetString("ProductActivated"), Severity.Success);
            await LoadProduct();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error activating product: {ex.Message}");
            Snackbar.Add(Localization.GetString("ErrorUpdatingProduct"), Severity.Error);
        }
    }

    private async Task OnWarehouseChanged(Guid? warehouseId)
    {
        _selectedWarehouseId = warehouseId;
        await InvokeAsync(StateHasChanged);
    }

    private async Task OpenAdjustDialog()
    {
        DialogParameters<AdjustStockDialog> parameters = new();
        parameters.Add(x => x.PreSelectedProductId, Id);
        if (_selectedWarehouseId.HasValue)
            parameters.Add(x => x.PreSelectedWarehouseId, _selectedWarehouseId.Value);

        DialogOptions options = new()
        {
            MaxWidth = MaxWidth.Small,
            FullWidth = true,
            CloseOnEscapeKey = true
        };

        IDialogReference dialog = await DialogService.ShowAsync<AdjustStockDialog>(
            Localization.GetString("AdjustStock"), parameters, options);

        DialogResult? result = await dialog.Result;

        if (result is { Canceled: false, Data: AdjustStockDialog.AdjustStockResult dto })
        {
            try
            {
                await InventoryService.AdjustStockAsync(
                    dto.ProductId, dto.WarehouseId, dto.QuantityChange, dto.Reason);
                Snackbar.Add(Localization.GetString("StockAdjusted"), Severity.Success);
                await LoadProduct();
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Error adjusting stock: {ex.Message}");
                Snackbar.Add(Localization.GetString("ErrorAdjustingStock"), Severity.Error);
            }
        }
    }

    // ── Transaction History (summary data) ───────────────────────────────────

    private List<ProductTransactionRow> _allHistoryPurchased = [];
    private List<ProductTransactionRow> _allHistorySold = [];

    /// <summary>Populates history lists from the already-loaded ProductDetailsDto — no extra DB call.</summary>
    private void PopulateHistory(ProductDetailsDto details)
    {
        _allHistoryPurchased = details.Purchased
            .Select(r => new ProductTransactionRow
            {
                WarehouseId = r.WarehouseId,
                Quantity = r.Quantity,
                UnitPrice = r.UnitPrice,
                TotalPrice = r.TotalPrice
            }).ToList();

        _allHistorySold = details.Sold
            .Select(r => new ProductTransactionRow
            {
                WarehouseId = r.WarehouseId,
                Quantity = r.Quantity,
                UnitPrice = r.UnitPrice,
                TotalPrice = r.TotalPrice
            }).ToList();
    }

    // ── Helpers ───────────────────────────────────────────────────────────────

    private class ProductTransactionRow
    {
        public Guid WarehouseId { get; set; }
        public decimal Quantity { get; set; }
        public decimal UnitPrice { get; set; }
        public decimal TotalPrice { get; set; }
    }

    public void Dispose()
    {
        Localization.OnLanguageChanged -= OnLanguageChanged;
    }
}
