@page "/products/{Id:guid}"
@attribute [Authorize]
@inherits PageBase
@using WarehouseInvoiceSystem.Application.DTOs.Product
@using WarehouseInvoiceSystem.Application.DTOs.Warehouse
@using WarehouseInvoiceSystem.Application.DTOs.Invoice
@using WarehouseInvoiceSystem.Application.DTOs.PurchaseNote
@using WarehouseInvoiceSystem.Application.DTOs.StockLevel
@using WarehouseInvoiceSystem.Domain.Queries
@using WarehouseInvoiceSystem.Domain.Queries.Common
@using WarehouseInvoiceSystem.Domain.Enums
@inject IProductService ProductService
@inject IWarehouseService WarehouseService

<PageTitle>@Localization.GetString("ProductDetails") - @Localization.GetString("InvoiceSystem")</PageTitle>

@if (_loading)
{
    <MudProgressLinear Color="Color.Primary" Indeterminate="true" />
}
else if (_product == null)
{
    <MudAlert Severity="Severity.Error">@Localization.GetString("ProductNotFound")</MudAlert>
}
else
{
    <WisDetailHeader BackHref="/products"
                     BackLabel="@Localization.GetString("Products")"
                     PrimaryAction="@_primaryAction"
                     Actions="@_actions" />

    <MudGrid>

        @* ── Header card ── *@
        <MudItem xs="12">
            <MudCard Elevation="2">
                <MudCardContent Class="pa-4">

                    @* ── Identity row: name+chip left, warehouse filter right ── *@
                    <div class="wis-product-identity-row">
                        <div class="wis-detail-identity">
                            <MudText Typo="Typo.h4" Class="font-weight-bold mb-0">@_product.Name</MudText>
                            <MudChip T="string" Size="Size.Small" Color="@(_product.IsActive? Color.Success: Color.Default)">
                                @(_product.IsActive? Localization.GetString("ProductActive") : Localization.GetString("ProductInactive"))
                            </MudChip>
                        </div>
                        <WisAutocompleteFilter TValue="Guid"
                                               Label="@Localization.GetString("AllWarehouses")"
                                               AllLabel="@Localization.GetString("AllWarehouses")"
                                               Icon="@Icons.Material.Filled.Warehouse"
                                               LoadItems="LoadWarehouseItems"
                                               PopoverAnchorOrigin="Origin.BottomRight"
                                               PopoverTransformOrigin="Origin.TopRight"
                                               SelectedValue="@(_selectedWarehouseId ?? default)"
                                               SelectedValueChanged="@(async (Guid v) => await OnWarehouseChanged(v == default ? (Guid?)null : v))"
                                               MinWidth="200px" />
                    </div>

                    @* ── Meta row: code, unit, description ── *@
                    <div class="wis-detail-contact wis-product-meta-row">
                        <div class="wis-detail-contact-item">
                            <MudIcon Icon="@Icons.Material.Filled.Tag" Size="Size.Small" Color="Color.Secondary" />
                            <MudText Typo="Typo.body2" Style="font-weight: 500;">@_product.Code</MudText>
                        </div>
                        <div class="wis-detail-contact-item">
                            <MudIcon Icon="@Icons.Material.Filled.Scale" Size="Size.Small" Color="Color.Secondary" />
                            <MudText Typo="Typo.body2">@_product.Unit</MudText>
                        </div>
                        @if (!string.IsNullOrWhiteSpace(_product.Description))
                        {
                            <div class="wis-detail-contact-item">
                                <MudIcon Icon="@Icons.Material.Filled.Info" Size="Size.Small" Color="Color.Secondary" />
                                <MudText Typo="Typo.body2" Color="Color.Secondary">@_product.Description</MudText>
                            </div>
                        }
                    </div>

                    @* ── Stats bar — 4 stats, full width ── *@
                    <div class="wis-product-stats-bar">

                        @* Stat 1a *@
                        <div class="wis-product-stats-bar__stat">
                            <MudText Typo="Typo.caption" Color="Color.Secondary" Class="wis-section-label">@Localization.GetString("CostPrice")</MudText>
                            <div class="wis-stat-value mud-default-text">@_product.CostPrice.ToString("C")</div>
                        </div>

                        @* Stat 1b *@
                        <div class="wis-product-stats-bar__stat">
                            <MudText Typo="Typo.caption" Color="Color.Secondary" Class="wis-section-label">@Localization.GetString("SellingPrice")</MudText>
                            <div class="wis-stat-value mud-success-text">@_product.SellingPrice.ToString("C")</div>
                        </div>

                        @* Stat 2 *@
                        <div class="wis-product-stats-bar__stat">
                            <MudText Typo="Typo.caption" Color="Color.Secondary" Class="wis-section-label">@Localization.GetString("TotalStock")</MudText>
                            <div class="wis-stat-value @StockColorClass">@_filteredTotalStock.ToString("N2") @_product.Unit</div>
                            <MudText Typo="Typo.caption" Color="@StockBadgeColor" Class="mt-1">@StockStatusLabel</MudText>
                        </div>

                        @* Stat 3 *@
                        <div class="wis-product-stats-bar__stat">
                            <MudText Typo="Typo.caption" Color="Color.Secondary" Class="wis-section-label">@Localization.GetString("StockValue")</MudText>
                            <div class="wis-stat-value mud-success-text">@_filteredStockValue.ToString("C")</div>
                        </div>

                        @* Stat 4 *@
                        <div class="wis-product-stats-bar__stat">
                            <MudText Typo="Typo.caption" Color="Color.Secondary" Class="wis-section-label">@Localization.GetString("GrossMargin")</MudText>
                            <div class="wis-stat-value @(_scopedGrossMarginPct > 30 ? "mud-success-text" : "mud-warning-text")">
                                @_scopedGrossMarginPct.ToString("N1")%
                            </div>
                        </div>

                    </div>

                </MudCardContent>
            </MudCard>
        </MudItem>

        @* ── Stock by Warehouse (only when All Warehouses selected) ── *@
        @if (!_selectedWarehouseId.HasValue && _details.StockByWarehouse.Any())
        {
            <MudItem xs="12">
                <MudCard Elevation="2">
                    <MudCardHeader>
                        <CardHeaderContent>
                            <MudText Typo="Typo.h6">@Localization.GetString("StockByWarehouse")</MudText>
                        </CardHeaderContent>
                    </MudCardHeader>
                    <MudCardContent Class="pa-0">
                        <MudTable Items="_details.StockByWarehouse"
                                  Hover="true"
                                  Elevation="0"
                                  Class="wis-secondary-list">
                            <HeaderContent>
                                <MudTh>@Localization.GetString("Warehouse")</MudTh>
                                <MudTh Class="text-right">@Localization.GetString("Quantity")</MudTh>
                                <MudTh>@Localization.GetString("LastRestocked")</MudTh>
                                <MudTh Class="text-right">@Localization.GetString("Reserved")</MudTh>
                                <MudTh Class="text-right">@Localization.GetString("Available")</MudTh>
                                <MudTh Class="text-right">@Localization.GetString("Minimum")</MudTh>
                                <MudTh />
                            </HeaderContent>
                            <RowTemplate>
                                <MudTd DataLabel="@Localization.GetString("Warehouse")">
                                    <MudText Typo="Typo.body2">@context.WarehouseName</MudText>
                                </MudTd>
                                <MudTd DataLabel="@Localization.GetString("Quantity")" Class="text-right">
                                    <MudText Typo="Typo.body2"
                                             Color="@(context.Quantity <= context.MinimumQuantity ? Color.Error : Color.Default)">
                                        @context.Quantity.ToString("N2") @_product.Unit
                                    </MudText>
                                </MudTd>
                                <MudTd DataLabel="@Localization.GetString("LastRestocked")">
                                    <MudText Typo="Typo.body2">@(context.LastRestockedAt?.ToString("dd MMM yyyy") ?? "-")</MudText>
                                </MudTd>
                                <MudTd DataLabel="@Localization.GetString("Reserved")" Class="text-right">
                                    <MudText Typo="Typo.body2">@context.ReservedQuantity.ToString("N2") @_product.Unit</MudText>
                                </MudTd>
                                <MudTd DataLabel="@Localization.GetString("Available")" Class="text-right">
                                    <MudText Typo="Typo.body2">@context.AvailableQuantity.ToString("N2") @_product.Unit</MudText>
                                </MudTd>
                                <MudTd DataLabel="@Localization.GetString("Minimum")" Class="text-right">
                                    <MudText Typo="Typo.body2">@(context.MinimumQuantity?.ToString("N2") ?? "0,00") @_product.Unit</MudText>
                                </MudTd>
                                <MudTd>
                                    <MudIconButton Icon="@Icons.Material.Filled.Tune"
                                                   Size="Size.Small"
                                                   Color="Color.Primary"

                                                   OnClick="@(() => OpenSetThresholdsDialog(context))" />
                                </MudTd>
                            </RowTemplate>
                        </MudTable>
                    </MudCardContent>
                </MudCard>
            </MudItem>
        }

        @* ── Profitability ── *@
        <MudItem xs="12">
            <MudCard Elevation="2">
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudText Typo="Typo.h6">@Localization.GetString("Profitability")</MudText>
                    </CardHeaderContent>
                </MudCardHeader>
                <MudCardContent Class="pa-4">
                    <MudGrid Spacing="4" Class="wis-detail-stats">

                        <MudItem xs="3">
                            <MudText Typo="Typo.caption" Color="Color.Secondary" Class="wis-section-label">@Localization.GetString("AveragePurchasePrice")</MudText>
                            <div class="wis-stat-value">@_scopedAvgPurchasePrice.ToString("C")</div>
                        </MudItem>

                        <MudItem xs="3">
                            <MudText Typo="Typo.caption" Color="Color.Secondary" Class="wis-section-label">@Localization.GetString("AverageSellingPrice")</MudText>
                            <div class="wis-stat-value mud-success-text">@_scopedAvgSellingPrice.ToString("C")</div>
                        </MudItem>

                        <MudItem xs="3">
                            <MudText Typo="Typo.caption" Color="Color.Secondary" Class="wis-section-label">@Localization.GetString("GrossMargin")</MudText>
                            <div class="wis-stat-value @(_scopedGrossMarginPct > 30 ? "mud-success-text" : "mud-warning-text")">
                                @_scopedGrossMarginPct.ToString("N1")%
                            </div>
                        </MudItem>

                        <MudItem xs="3">
                            <MudText Typo="Typo.caption" Color="Color.Secondary" Class="wis-section-label">@Localization.GetString("EstimatedProfit")</MudText>
                            <div class="wis-stat-value @(_scopedEstimatedProfit > 0 ? "mud-success-text" : "mud-error-text")">
                                @_scopedEstimatedProfit.ToString("C")
                            </div>
                        </MudItem>

                    </MudGrid>
                </MudCardContent>
            </MudCard>
        </MudItem>

        @* ── Transaction History Summary ── *@
        <MudItem xs="12">
            <MudCard Elevation="2">
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudText Typo="Typo.h6">@Localization.GetString("TransactionHistory")</MudText>
                    </CardHeaderContent>
                    <CardHeaderActions>
                        <WisSplitButton PrimaryAction="@_transactionsAction" />
                    </CardHeaderActions>
                </MudCardHeader>
                <MudCardContent Class="pa-4">
                    <MudGrid Spacing="4" Class="wis-detail-stats">

                        <MudItem xs="12" sm="4" md="2">
                            <MudText Typo="Typo.caption" Color="Color.Secondary" Class="wis-section-label">@Localization.GetString("Purchased")</MudText>
                            <div class="wis-stat-value mud-info-text">@_scopedPurchasedCount</div>
                            <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mt-1">
                                @_scopedPurchasedQuantity.ToString("N2") @_product.Unit
                            </MudText>
                        </MudItem>

                        <MudItem xs="12" sm="4" md="2">
                            <MudText Typo="Typo.caption" Color="Color.Secondary" Class="wis-section-label">@Localization.GetString("Sold")</MudText>
                            <div class="wis-stat-value mud-success-text">@_scopedSoldCount</div>
                            <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mt-1">
                                @_scopedSoldQuantity.ToString("N2") @_product.Unit
                            </MudText>
                        </MudItem>

                        <MudItem xs="12" sm="4" md="2">
                            <MudText Typo="Typo.caption" Color="Color.Secondary" Class="wis-section-label">@Localization.GetString("TotalPurchased")</MudText>
                            <div class="wis-stat-value mud-info-text">@_scopedPurchasedAmount.ToString("C")</div>
                        </MudItem>

                        <MudItem xs="12" sm="4" md="2">
                            <MudText Typo="Typo.caption" Color="Color.Secondary" Class="wis-section-label">@Localization.GetString("TotalSold")</MudText>
                            <div class="wis-stat-value mud-success-text">@_scopedSoldAmount.ToString("C")</div>
                        </MudItem>

                        <MudItem xs="12" sm="4" md="4">
                            <MudText Typo="Typo.caption" Color="Color.Secondary" Class="wis-section-label">@Localization.GetString("Profit")</MudText>
                            <div class="wis-stat-value @(_scopedProfit >= 0 ? "mud-success-text" : "mud-error-text")">
                                @_scopedProfit.ToString("C")
                            </div>
                        </MudItem>

                    </MudGrid>
                </MudCardContent>
            </MudCard>
        </MudItem>

    </MudGrid>
}

@code {
    [Parameter] public Guid Id { get; set; }

    private ProductDto? _product;
    private ProductDetailsDto _details = new();

    private Guid? _selectedWarehouseId = null;

    private WisDetailActionItem? _primaryAction;
    private List<WisDetailActionItem> _actions = [];
    private WisDetailActionItem? _transactionsAction;

    // ── Warehouse autocomplete data source ────────────────────────────────────

    private async Task<PagedResult<WisAutocompleteItem<Guid>>> LoadWarehouseItems(
        string search, int page, CancellationToken ct)
    {
        PagedResult<WarehouseDto> result = await WarehouseService.GetPagedAsync(
            new GetWarehousesQuery
            {
                Search = search,
                Page = page,
                PageSize = 10,
                SortBy = "Name",
                SortAscending = true
            }, ct);

        return new PagedResult<WisAutocompleteItem<Guid>>
        {
            Items = result.Items.Select(w => new WisAutocompleteItem<Guid>
            {
                Label = w.Name + (w.IsDefault ? $" ({Localization.GetString("Default")})" : ""),
                Value = w.Id
            }).ToList(),
            TotalCount = result.TotalCount,
            Page = result.Page,
            PageSize = result.PageSize
        };
    }

    // ── Scoped computed properties ────────────────────────────────────────────

    private decimal _filteredTotalStock => _selectedWarehouseId.HasValue
        ? _details.StockByWarehouse.Where(s => s.WarehouseId == _selectedWarehouseId.Value).Sum(s => s.Quantity)
        : _details.TotalStockAcrossWarehouses;

    private decimal _filteredStockValue => _filteredTotalStock * _scopedAvgSellingPrice;

    private bool _filteredIsOutOfStock => _filteredTotalStock == 0;

    private bool _filteredHasLowStock => _selectedWarehouseId.HasValue
        ? _details.StockByWarehouse.Any(s => s.WarehouseId == _selectedWarehouseId.Value
                                          && s.Quantity <= s.MinimumQuantity
                                          && s.Quantity > 0)
        : _details.HasLowStock;

    private string StockColorClass =>
        _filteredIsOutOfStock ? "mud-error-text" :
        _filteredHasLowStock ? "mud-warning-text" :
                                "mud-default-text";

    private Color StockBadgeColor =>
        _filteredIsOutOfStock ? Color.Error :
        _filteredHasLowStock ? Color.Warning :
                                Color.Success;

    private string StockStatusLabel =>
        _filteredIsOutOfStock ? Localization.GetString("OutOfStock") :
        _filteredHasLowStock ? Localization.GetString("LowStock") :
                                Localization.GetString("InStock");

    // ── Transaction summary computed properties ──────────────────────────────
    // Read directly from pre-aggregated WarehouseTransactionSummaryDto — no in-memory lists.
    // When a warehouse is selected but has no transactions, values are zero (not global totals).
    // Global totals are only used when no warehouse is selected (null).

    private WarehouseTransactionSummaryDto? _scopedPurchasedSummary =>
        _selectedWarehouseId.HasValue
            ? _details.PurchasedByWarehouse.FirstOrDefault(s => s.WarehouseId == _selectedWarehouseId.Value)
            : null;

    private WarehouseTransactionSummaryDto? _scopedSoldSummary =>
        _selectedWarehouseId.HasValue
            ? _details.SoldByWarehouse.FirstOrDefault(s => s.WarehouseId == _selectedWarehouseId.Value)
            : null;

    private int _scopedPurchasedCount =>
        _selectedWarehouseId.HasValue ? (_scopedPurchasedSummary?.Count ?? 0) : _details.TotalPurchasedCount;

    private decimal _scopedPurchasedQuantity =>
        _selectedWarehouseId.HasValue ? (_scopedPurchasedSummary?.TotalQuantity ?? 0) : _details.TotalPurchasedQuantity;

    private decimal _scopedPurchasedAmount =>
        _selectedWarehouseId.HasValue ? (_scopedPurchasedSummary?.TotalAmount ?? 0) : _details.TotalPurchasedAmount;

    private int _scopedSoldCount =>
        _selectedWarehouseId.HasValue ? (_scopedSoldSummary?.Count ?? 0) : _details.TotalSoldCount;

    private decimal _scopedSoldQuantity =>
        _selectedWarehouseId.HasValue ? (_scopedSoldSummary?.TotalQuantity ?? 0) : _details.TotalSoldQuantity;

    private decimal _scopedSoldAmount =>
        _selectedWarehouseId.HasValue ? (_scopedSoldSummary?.TotalAmount ?? 0) : _details.TotalSoldAmount;

    private decimal _scopedAvgPurchasePrice =>
        _selectedWarehouseId.HasValue ? (_scopedPurchasedSummary?.AverageUnitPrice ?? 0) : _details.AveragePurchasePrice;

    private decimal _scopedAvgSellingPrice =>
        _selectedWarehouseId.HasValue ? (_scopedSoldSummary?.AverageUnitPrice ?? _details.AverageSellingPrice) : _details.AverageSellingPrice;

    private decimal _scopedGrossMarginPct =>
    _selectedWarehouseId.HasValue
        ? (_scopedAvgSellingPrice > 0 && _scopedAvgPurchasePrice > 0
            ? (_scopedAvgSellingPrice - _scopedAvgPurchasePrice) / _scopedAvgSellingPrice * 100
            : 0)
        : _details.GrossMarginPercentage;

    private decimal _scopedEstimatedProfit =>
        (_scopedAvgSellingPrice - _scopedAvgPurchasePrice) * _filteredTotalStock;

    private decimal _scopedProfit =>
        _scopedSoldAmount - _scopedPurchasedAmount;

    // ── Lifecycle ─────────────────────────────────────────────────────────────

    protected override async Task OnInitializedAsync()
    {
        await base.OnInitializedAsync();
        await LoadProduct();
    }

    protected override async void OnLanguageChanged()
    {
        BuildActions();
        await InvokeAsync(StateHasChanged);
    }

    private async Task LoadProduct() =>
        await SafeLoadAsync(async () =>
        {
            _product = await ProductService.GetProductByIdAsync(Id, CancellationToken.None);
            if (_product != null)
            {
                // Single call — replaces GetProductAnalyticsAsync + GetAllWarehousesAsync + GetProductTransactionHistoryAsync
                _details = await ProductService.GetProductDetailsAsync(Id, CancellationToken.None);
                _selectedWarehouseId = null;
                BuildActions();
            }
        }, "ErrorLoadingProduct");

    private void BuildActions()
    {
        if (_product is null) return;

        _primaryAction = _act.Primary(Icons.Material.Filled.Inventory2, Localization.GetString("AdjustStock"), OpenAdjustDialog);

        bool noWarehouse = !_selectedWarehouseId.HasValue;
        _actions =
        [
            _act.Primary(Icons.Material.Filled.Tune, Localization.GetString("Thresholds"), OpenSetThresholdsFromAction,
                disabled: noWarehouse,
                disabledReason: noWarehouse ? Localization.GetString("SelectWarehouseForThresholds") : null),
            _act.Primary(Icons.Material.Filled.Edit, Localization.GetString("Edit"), OpenEditDialog),
            _act.Primary(Icons.Material.Filled.CompareArrows, Localization.GetString("Compare"), () => Navigation.NavigateTo($"/products/{Id}/compare")),
            _product.IsActive
                ? _act.Warning(Icons.Material.Filled.PowerSettingsNew, Localization.GetString("Deactivate"), ToggleActiveStatus, dividerBefore: true)
                : _act.Success(Icons.Material.Filled.PowerSettingsNew,  Localization.GetString("Activate"),   ToggleActiveStatus, dividerBefore: true),
        ];

        if (!_product.IsActive)
        {
            _actions.Add(_act.Error(Icons.Material.Filled.DeleteForever, Localization.GetString("Delete"), DeleteProduct, dividerBefore: true));
        }

        _transactionsAction = _act.Secondary(Icons.Material.Filled.SyncAlt, Localization.GetString("Transactions"), () => Navigation.NavigateTo($"/products/{Id}/transactions{(_selectedWarehouseId.HasValue ? $"?warehouse={_selectedWarehouseId}" : "")}"));
    }

    private async Task OpenEditDialog()
    {
        if (_product is null) return;
        if (await WisDialog.ShowFormAsync<ProductDialog, bool>(
                Localization.GetString("EditProduct"),
                p => p.Add(x => x.Product, _product)) == true)
            await LoadProduct();
    }

    private async Task ToggleActiveStatus()
    {
        if (_product is null) return;

        if (_product.IsActive)
            await DeactivateProduct();
        else
            await ActivateProduct();
    }

    private async Task DeactivateProduct() =>
        await ConfirmAndExecuteAsync(
            Localization.GetString("DeactivateProduct"),
            Localization.GetString("DeactivateProductConfirm"),
            async () => { await ProductService.SetActiveStatusAsync(Id, false); await LoadProduct(); },
            "ProductDeactivated", "ErrorUpdatingProduct",
            Localization.GetString("Deactivate"), Localization.GetString("Cancel"));

    private async Task ActivateProduct() =>
        await ConfirmAndExecuteAsync(
            Localization.GetString("ActivateProduct"),
            Localization.GetString("ActivateProductConfirm"),
            async () => { await ProductService.SetActiveStatusAsync(Id, true); await LoadProduct(); },
            "ProductActivated", "ErrorUpdatingProduct",
            Localization.GetString("Activate"), Localization.GetString("Cancel"));

    private async Task DeleteProduct()
    {
        bool confirmed = await WisDialog.ConfirmAsync(
            Localization.GetString("Delete"),
            Localization.GetString("DeleteProductConfirm"),
            Localization.GetString("Delete"),
            Localization.GetString("Cancel"));
        if (!confirmed) return;

        try
        {
            await ProductService.DeleteProductAsync(Id);
            Snackbar.Add(Localization.GetString("ProductDeleted"), Severity.Success);
            Navigation.NavigateTo("/products");
        }
        catch (InvalidOperationException ex)
        {
            string key = ex.Message is "ProductInUseCannotDelete" or "ProductMustBeInactiveToDelete"
                ? ex.Message : "ErrorDeletingProduct";
            Snackbar.Add(Localization.GetString(key), Severity.Error);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error deleting product: {ex.Message}");
            Snackbar.Add(Localization.GetString("ErrorDeletingProduct"), Severity.Error);
        }
    }

    private async Task OnWarehouseChanged(Guid? warehouseId)
    {
        _selectedWarehouseId = warehouseId;
        BuildActions();
        await InvokeAsync(StateHasChanged);
    }

    private async Task OpenAdjustDialog()
    {
        if (await WisDialog.ShowFormAsync<AdjustStockDialog, bool>(
                Localization.GetString("AdjustStock"),
                p =>
                {
                    p.Add(x => x.PreSelectedProductId, Id);
                    if (_selectedWarehouseId.HasValue)
                        p.Add(x => x.PreSelectedWarehouseId, _selectedWarehouseId.Value);
                },
                MaxWidth.Small) == true)
            await LoadProduct();
    }

    private async Task OpenSetThresholdsFromAction()
    {
        if (!_selectedWarehouseId.HasValue) return;
        WarehouseStockDto? row = _details.StockByWarehouse.FirstOrDefault(s => s.WarehouseId == _selectedWarehouseId.Value);
        if (row is null) return;
        await OpenSetThresholdsDialog(row);
    }

    private async Task OpenSetThresholdsDialog(WarehouseStockDto row)
    {
        StockLevelDto stockLevel = new()
        {
            ProductId = Id,
            WarehouseId = row.WarehouseId,
            ProductCode = _product!.Code,
            ProductName = _product!.Name,
            Quantity = row.Quantity,
            AvailableQuantity = row.AvailableQuantity,
            MinimumQuantity = row.MinimumQuantity,
            ReorderPoint = row.ReorderPoint,
            LastRestockedAt = row.LastRestockedAt ?? DateTime.MinValue
        };

        if (await WisDialog.ShowFormAsync<SetThresholdsDialog, bool>(
                Localization.GetString("EditThresholds"),
                p => p.Add(x => x.StockLevel, stockLevel),
                MaxWidth.Small) == true)
            await LoadProduct();
    }

}
