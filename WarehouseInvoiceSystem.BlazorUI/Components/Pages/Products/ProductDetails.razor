@page "/products/{Id:guid}"
@implements IDisposable
@using WarehouseInvoiceSystem.Application.Interfaces
@using WarehouseInvoiceSystem.Application.DTOs.Product
@using WarehouseInvoiceSystem.Application.DTOs.Warehouse
@using WarehouseInvoiceSystem.Application.DTOs.Invoice
@using WarehouseInvoiceSystem.Application.DTOs.PurchaseNote
@using WarehouseInvoiceSystem.Domain.Enums
@inject IProductService ProductService
@inject IWarehouseService WarehouseService
@inject IInvoiceService InvoiceService
@inject IPurchaseNoteService PurchaseNoteService
@inject ILocalizationService Localization
@inject NavigationManager Navigation
@inject IDialogService DialogService
@inject ISnackbar Snackbar

<PageTitle>@Localization.GetString("ProductDetails") - @Localization.GetString("InvoiceSystem")</PageTitle>

@if (_loading)
{
    <MudProgressLinear Color="Color.Primary" Indeterminate="true" />
}
else if (_product == null)
{
    <MudAlert Severity="Severity.Error">@Localization.GetString("ProductNotFound")</MudAlert>
}
else
{
    <div class="d-flex justify-space-between align-center mb-4">
        <div>
            <MudButton StartIcon="@Icons.Material.Filled.ArrowBack"
                       Variant="Variant.Text"
                       Href="/products">
                @Localization.GetString("BackToProducts")
            </MudButton>
        </div>
        <div>
            <MudButton StartIcon="@Icons.Material.Filled.Inventory2"
                       Color="Color.Tertiary"
                       Variant="Variant.Filled"
                       Class="mr-2"
                       Href="@CreateAdjustLink()">
                @Localization.GetString("AdjustStock")
            </MudButton>
            <MudButton StartIcon="@Icons.Material.Filled.Edit"
                       Color="Color.Primary"
                       Variant="Variant.Filled"
                       Class="mr-2"
                       OnClick="EditProduct">
                @Localization.GetString("Edit")
            </MudButton>
            <MudButton StartIcon="@Icons.Material.Filled.Delete"
                       Color="Color.Error"
                       Variant="Variant.Outlined"
                       OnClick="DeleteProduct">
                @Localization.GetString("Delete")
            </MudButton>
        </div>
    </div>

    <MudGrid>
        <!-- Product Header - Single Card -->
        <MudItem xs="12">
            <MudCard Elevation="2">
                <MudCardContent Class="pa-6">
                    <MudGrid Spacing="4">
                        <!-- Left: Name + Status + Code + Unit -->
                        <MudItem xs="12" md="6">
                            <MudStack Spacing="2">
                                <div class="d-flex align-center gap-3 flex-wrap">
                                    <MudText Typo="Typo.h4" Class="mb-0">@_product.Name</MudText>
                                    <MudChip T="string" Size="Size.Small" Color="@(_product.IsActive? Color.Success: Color.Default)">
                                        @(_product.IsActive? Localization.GetString("ProductActive") : Localization.GetString("ProductInactive"))
                                    </MudChip>
                                </div>

                                <MudDivider Class="my-2" />

                                <MudStack Spacing="1">
                                    <div class="d-flex align-center">
                                        <MudIcon Icon="@Icons.Material.Filled.Tag" Size="Size.Small" Class="mr-2" Color="Color.Secondary" />
                                        <MudText Typo="Typo.body2">
                                            <span class="text-secondary">@Localization.GetString("Code"):</span>
                                            <strong>@_product.Code</strong>
                                        </MudText>
                                    </div>

                                    <div class="d-flex align-center">
                                        <MudIcon Icon="@Icons.Material.Filled.Scale" Size="Size.Small" Class="mr-2" Color="Color.Secondary" />
                                        <MudText Typo="Typo.body2">
                                            <span class="text-secondary">@Localization.GetString("Unit"):</span>
                                            <strong>@_product.Unit</strong>
                                        </MudText>
                                    </div>

                                    @if (!string.IsNullOrWhiteSpace(_product.Description))
                                    {
                                        <div class="d-flex align-center">
                                            <MudIcon Icon="@Icons.Material.Filled.Info" Size="Size.Small" Class="mr-2" Color="Color.Secondary" />
                                            <MudText Typo="Typo.body2" Color="Color.Secondary">
                                                @_product.Description
                                            </MudText>
                                        </div>
                                    }
                                </MudStack>
                            </MudStack>
                        </MudItem>

                        <!-- Divider (visible on medium+ screens) -->
                        <MudHidden Breakpoint="Breakpoint.SmAndDown">
                            <MudItem md="1" Class="d-flex align-center justify-center">
                                <MudDivider Vertical="true" />
                            </MudItem>
                        </MudHidden>

                        <!-- Right: Pricing + Inventory Summary -->
                        <MudItem xs="12" md="5">
                            <MudStack Spacing="3">
                                <!-- Default Price + Gross Margin -->
                                <MudStack Row="true" Spacing="4">
                                    <div style="flex: 1;">
                                        <div class="d-flex align-center mb-1">
                                            <MudIcon Icon="@Icons.Material.Filled.AttachMoney" Size="Size.Small" Class="mr-1" Color="Color.Secondary" />
                                            <MudText Typo="Typo.caption" Color="Color.Secondary">@Localization.GetString("DefaultPrice")</MudText>
                                        </div>
                                        <MudText Typo="Typo.h5" Color="Color.Success" Class="font-weight-bold">
                                            @_product.DefaultPrice.ToString("C")
                                        </MudText>
                                    </div>
                                    <div style="flex: 1;">
                                        <div class="d-flex align-center mb-1">
                                            <MudIcon Icon="@Icons.Material.Filled.TrendingUp" Size="Size.Small" Class="mr-1" Color="Color.Secondary" />
                                            <MudText Typo="Typo.caption" Color="Color.Secondary">@Localization.GetString("GrossMargin")</MudText>
                                        </div>
                                        <MudText Typo="Typo.h5" Class="font-weight-bold"
                                                 Color="@(_analytics.GrossMarginPercentage > 30 ? Color.Success : Color.Warning)">
                                            @_analytics.GrossMarginPercentage.ToString("N1")%
                                        </MudText>
                                    </div>
                                </MudStack>

                                <MudDivider />

                                <!-- Stock Overview -->
                                <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-1">@Localization.GetString("InventorySummary")</MudText>

                                <MudStack Row="true" Spacing="3">
                                    <div style="flex: 1;">
                                        <MudText Typo="Typo.caption" Color="Color.Secondary">@Localization.GetString("TotalStock")</MudText>
                                        <MudText Typo="Typo.h6"
                                                 Color="@(_filteredIsOutOfStock ? Color.Error : _filteredHasLowStock ? Color.Warning : Color.Default)">
                                            @_filteredTotalStock.ToString("N2") @_product.Unit
                                        </MudText>
                                    </div>

                                    <div style="flex: 1;">
                                        <MudText Typo="Typo.caption" Color="Color.Secondary">@Localization.GetString("StockValue")</MudText>
                                        <MudText Typo="Typo.h6" Color="Color.Success">
                                            @_filteredStockValue.ToString("C")
                                        </MudText>
                                    </div>
                                </MudStack>

                                @if (_filteredIsOutOfStock)
                                {
                                    <MudAlert Severity="Severity.Error" Dense="true" NoIcon="false" Class="pa-2">
                                        <MudText Typo="Typo.body2">@Localization.GetString("OutOfStock")</MudText>
                                    </MudAlert>
                                }
                                else if (_filteredHasLowStock)
                                {
                                    <MudAlert Severity="Severity.Warning" Dense="true" NoIcon="false" Class="pa-2">
                                        <MudText Typo="Typo.body2">@Localization.GetString("LowStock")</MudText>
                                    </MudAlert>
                                }
                                else
                                {
                                    <MudAlert Severity="Severity.Success" Dense="true" NoIcon="false" Class="pa-2">
                                        <MudText Typo="Typo.body2">@Localization.GetString("InStock")</MudText>
                                    </MudAlert>
                                }
                            </MudStack>
                        </MudItem>
                    </MudGrid>
                </MudCardContent>
            </MudCard>
        </MudItem>

        <!-- Warehouse Selector -->
        <MudItem xs="12">
            <MudCard Elevation="2">
                <MudCardContent Class="pa-6">
                    <MudGrid>
                        <MudItem xs="12" md="6">
                            <MudText Typo="Typo.h6" Class="mb-2">@Localization.GetString("SelectWarehouse")</MudText>
                            <MudText Typo="Typo.body2" Color="Color.Secondary">
                                @Localization.GetString("ViewInventoryForSpecificWarehouse")
                            </MudText>
                        </MudItem>
                        <MudItem xs="12" md="6" Class="d-flex align-center justify-end">
                            <MudSelect T="Guid?"
                                       Value="_selectedWarehouseId"
                                       ValueChanged="@(async (Guid? v) => await OnWarehouseChanged(v))"
                                       Label="@Localization.GetString("Warehouse")"
                                       Variant="Variant.Outlined"
                                       AnchorOrigin="Origin.BottomLeft"
                                       Style="min-width: 300px;">
                                <MudSelectItem Value="@((Guid?)null)">
                                    @Localization.GetString("AllWarehouses")
                                </MudSelectItem>
                                @foreach (WarehouseDto w in _warehouses)
                                {
                                    <MudSelectItem Value="@((Guid?)w.Id)">
                                        @w.Name @(w.IsDefault ? $" ({Localization.GetString("Default")})" : "")
                                    </MudSelectItem>
                                }
                            </MudSelect>
                        </MudItem>
                    </MudGrid>
                </MudCardContent>
            </MudCard>
        </MudItem>

        <!-- Stock by Warehouse (only show if "All Warehouses" selected) -->
        @if (!_selectedWarehouseId.HasValue && _analytics.StockByWarehouse.Any())
        {
            <MudItem xs="12">
                <MudCard Elevation="2">
                    <MudCardHeader>
                        <CardHeaderContent>
                            <MudText Typo="Typo.h6">@Localization.GetString("StockByWarehouse")</MudText>
                        </CardHeaderContent>
                    </MudCardHeader>
                    <MudCardContent Class="pa-0">
                        <MudTable Items="_analytics.StockByWarehouse"
                                  Hover="true"
                                  Dense="true"
                                  Elevation="0">
                            <HeaderContent>
                                <MudTh>@Localization.GetString("Warehouse")</MudTh>
                                <MudTh Style="text-align: right;">@Localization.GetString("Quantity")</MudTh>
                                <MudTh Style="text-align: right;">@Localization.GetString("Reserved")</MudTh>
                                <MudTh Style="text-align: right;">@Localization.GetString("Available")</MudTh>
                                <MudTh Style="text-align: right;">@Localization.GetString("Minimum")</MudTh>
                                <MudTh>@Localization.GetString("LastRestocked")</MudTh>
                            </HeaderContent>
                            <RowTemplate>
                                <MudTd DataLabel="@Localization.GetString("Warehouse")">
                                    @context.WarehouseName
                                </MudTd>
                                <MudTd DataLabel="@Localization.GetString("Quantity")" Style="text-align: right;">
                                    <MudText Typo="Typo.body2" Class="font-weight-bold"
                                             Color="@(context.Quantity <= context.MinimumQuantity ? Color.Error : Color.Default)">
                                        @context.Quantity.ToString("N2") @_product.Unit
                                    </MudText>
                                </MudTd>
                                <MudTd DataLabel="@Localization.GetString("Reserved")" Style="text-align: right;">
                                    @context.ReservedQuantity.ToString("N2") @_product.Unit
                                </MudTd>
                                <MudTd DataLabel="@Localization.GetString("Available")" Style="text-align: right;">
                                    @context.AvailableQuantity.ToString("N2") @_product.Unit
                                </MudTd>
                                <MudTd DataLabel="@Localization.GetString("Minimum")" Style="text-align: right;">
                                    @(context.MinimumQuantity?.ToString("N2") ?? "0,00") @_product.Unit
                                </MudTd>
                                <MudTd DataLabel="@Localization.GetString("LastRestocked")">
                                    @(context.LastRestockedAt?.ToString("dd MMM yyyy") ?? "-")
                                </MudTd>
                            </RowTemplate>
                        </MudTable>
                    </MudCardContent>
                </MudCard>
            </MudItem>
        }

        <!-- Sales & Purchase Analytics -->
        <MudItem xs="12" md="6">
            <MudCard Elevation="2">
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudText Typo="Typo.h6" Color="Color.Success" Class="d-flex align-center">
                            <MudIcon Icon="@Icons.Material.Filled.PointOfSale" Class="mr-2" />
                            @Localization.GetString("SalesAnalytics")
                        </MudText>
                    </CardHeaderContent>
                </MudCardHeader>
                <MudCardContent Class="pa-6">
                    <MudStack Spacing="3">
                        <div class="d-flex justify-space-between">
                            <MudText>@Localization.GetString("TotalUnitsSold"):</MudText>
                            <MudText Class="font-weight-bold">@_analytics.TotalUnitsSold.ToString("N0") @_product.Unit</MudText>
                        </div>
                        <div class="d-flex justify-space-between">
                            <MudText>@Localization.GetString("TotalRevenue"):</MudText>
                            <MudText Class="font-weight-bold" Color="Color.Success">@_analytics.TotalRevenue.ToString("C")</MudText>
                        </div>
                        <div class="d-flex justify-space-between">
                            <MudText>@Localization.GetString("AverageSaleQuantity"):</MudText>
                            <MudText>@_analytics.AverageSaleQuantity.ToString("N2") @_product.Unit</MudText>
                        </div>
                        <div class="d-flex justify-space-between">
                            <MudText>@Localization.GetString("LastSale"):</MudText>
                            <MudText>@(_analytics.LastSaleDate?.ToString("dd MMM yyyy") ?? Localization.GetString("Never"))</MudText>
                        </div>
                        @if (!string.IsNullOrEmpty(_analytics.TopCustomer))
                        {
                            <MudDivider />
                            <div>
                                <MudText Typo="Typo.subtitle2" Color="Color.Secondary">@Localization.GetString("TopCustomer")</MudText>
                                <MudText Class="font-weight-bold">@_analytics.TopCustomer</MudText>
                                <MudText Typo="Typo.caption">@_analytics.TopCustomerQuantity.ToString("N2") @_product.Unit</MudText>
                            </div>
                        }
                    </MudStack>
                </MudCardContent>
            </MudCard>
        </MudItem>

        <MudItem xs="12" md="6">
            <MudCard Elevation="2">
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudText Typo="Typo.h6" Color="Color.Info" Class="d-flex align-center">
                            <MudIcon Icon="@Icons.Material.Filled.ShoppingCart" Class="mr-2" />
                            @Localization.GetString("PurchaseAnalytics")
                        </MudText>
                    </CardHeaderContent>
                </MudCardHeader>
                <MudCardContent Class="pa-6">
                    <MudStack Spacing="3">
                        <div class="d-flex justify-space-between">
                            <MudText>@Localization.GetString("TotalUnitsPurchased"):</MudText>
                            <MudText Class="font-weight-bold">@_analytics.TotalUnitsPurchased.ToString("N0") @_product.Unit</MudText>
                        </div>
                        <div class="d-flex justify-space-between">
                            <MudText>@Localization.GetString("TotalCost"):</MudText>
                            <MudText Class="font-weight-bold" Color="Color.Error">@_analytics.TotalPurchaseCost.ToString("C")</MudText>
                        </div>
                        <div class="d-flex justify-space-between">
                            <MudText>@Localization.GetString("AveragePurchaseQuantity"):</MudText>
                            <MudText>@_analytics.AveragePurchaseQuantity.ToString("N2") @_product.Unit</MudText>
                        </div>
                        <div class="d-flex justify-space-between">
                            <MudText>@Localization.GetString("LastPurchase"):</MudText>
                            <MudText>@(_analytics.LastPurchaseDate?.ToString("dd MMM yyyy") ?? Localization.GetString("Never"))</MudText>
                        </div>
                        @if (!string.IsNullOrEmpty(_analytics.TopSupplier))
                        {
                            <MudDivider />
                            <div>
                                <MudText Typo="Typo.subtitle2" Color="Color.Secondary">@Localization.GetString("TopSupplier")</MudText>
                                <MudText Class="font-weight-bold">@_analytics.TopSupplier</MudText>
                                <MudText Typo="Typo.caption">@_analytics.TopSupplierQuantity.ToString("N2") @_product.Unit</MudText>
                            </div>
                        }
                    </MudStack>
                </MudCardContent>
            </MudCard>
        </MudItem>

        <!-- Profitability -->
        <MudItem xs="12">
            <MudCard Elevation="2">
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudText Typo="Typo.h6" Class="d-flex align-center">
                            <MudIcon Icon="@Icons.Material.Filled.Savings" Class="mr-2" />
                            @Localization.GetString("Profitability")
                        </MudText>
                    </CardHeaderContent>
                </MudCardHeader>
                <MudCardContent Class="pa-6">
                    <MudGrid>
                        <MudItem xs="12" sm="6" md="3">
                            <div>
                                <div class="d-flex align-center mb-1">
                                    <MudIcon Icon="@Icons.Material.Filled.ShoppingCart" Size="Size.Small" Class="mr-1" Color="Color.Secondary" />
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">@Localization.GetString("AveragePurchasePrice")</MudText>
                                </div>
                                <MudText Typo="Typo.h6" Class="font-weight-medium">@_analytics.AveragePurchasePrice.ToString("C")</MudText>
                            </div>
                        </MudItem>
                        <MudItem xs="12" sm="6" md="3">
                            <div>
                                <div class="d-flex align-center mb-1">
                                    <MudIcon Icon="@Icons.Material.Filled.Sell" Size="Size.Small" Class="mr-1" Color="Color.Secondary" />
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">@Localization.GetString("CurrentSellingPrice")</MudText>
                                </div>
                                <MudText Typo="Typo.h6" Class="font-weight-medium">@_analytics.CurrentSellingPrice.ToString("C")</MudText>
                            </div>
                        </MudItem>
                        <MudItem xs="12" sm="6" md="3">
                            <div>
                                <div class="d-flex align-center mb-1">
                                    <MudIcon Icon="@Icons.Material.Filled.TrendingUp" Size="Size.Small" Class="mr-1" Color="Color.Secondary" />
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">@Localization.GetString("GrossMargin")</MudText>
                                </div>
                                <MudText Typo="Typo.h6" Color="@(_analytics.GrossMarginPercentage > 30 ? Color.Success : Color.Warning)">
                                    @_analytics.GrossMarginPercentage.ToString("N1")%
                                </MudText>
                            </div>
                        </MudItem>
                        <MudItem xs="12" sm="6" md="3">
                            <div>
                                <div class="d-flex align-center mb-1">
                                    <MudIcon Icon="@Icons.Material.Filled.Savings" Size="Size.Small" Class="mr-1" Color="Color.Secondary" />
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">@Localization.GetString("EstimatedProfit")</MudText>
                                </div>
                                <MudText Typo="Typo.h6" Color="Color.Success">
                                    @(((_analytics.CurrentSellingPrice - _analytics.AveragePurchasePrice) * _filteredTotalStock).ToString("C"))
                                </MudText>
                            </div>
                        </MudItem>
                    </MudGrid>
                </MudCardContent>
            </MudCard>
        </MudItem>

        <!-- Recent Stock Movements -->
        <MudItem xs="12">
            <MudCard Elevation="2">
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudText Typo="Typo.h6">@Localization.GetString("RecentStockMovements")</MudText>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">@_selectedWarehouseName</MudText>
                    </CardHeaderContent>
                </MudCardHeader>
                <MudCardContent Class="pa-0">
                    @if (_filteredTransactions.Any())
                    {
                        <MudTable Items="_filteredTransactions.Take(10)"
                                  Hover="true"
                                  Breakpoint="Breakpoint.Sm"
                                  Dense="true"
                                  Elevation="0">
                            <HeaderContent>
                                <MudTh>@Localization.GetString("Date")</MudTh>
                                <MudTh>@Localization.GetString("Type")</MudTh>
                                <MudTh>@Localization.GetString("Warehouse")</MudTh>
                                <MudTh Style="text-align: right;">@Localization.GetString("Quantity")</MudTh>
                                <MudTh>@Localization.GetString("Note")</MudTh>
                            </HeaderContent>
                            <RowTemplate>
                                <MudTd DataLabel="@Localization.GetString("Date")">
                                    @context.Date.ToString("dd MMM yyyy HH:mm")
                                </MudTd>
                                <MudTd DataLabel="@Localization.GetString("Type")">
                                    @if (context.Type == "Inbound")
                                    {
                                        <MudChip T="string" Size="Size.Small" Color="Color.Success" Icon="@Icons.Material.Filled.ArrowDownward">
                                            @Localization.GetString("Inbound")
                                        </MudChip>
                                    }
                                    else if (context.Type == "Outbound")
                                    {
                                        <MudChip T="string" Size="Size.Small" Color="Color.Warning" Icon="@Icons.Material.Filled.ArrowUpward">
                                            @Localization.GetString("Outbound")
                                        </MudChip>
                                    }
                                    else
                                    {
                                        <MudChip T="string" Size="Size.Small" Color="Color.Info">
                                            @Localization.GetString(@context.Type)
                                        </MudChip>
                                    }
                                </MudTd>
                                <MudTd DataLabel="@Localization.GetString("Warehouse")">
                                    @context.WarehouseName
                                </MudTd>
                                <MudTd DataLabel="@Localization.GetString("Quantity")" Style="text-align: right;">
                                    <MudText Typo="Typo.body2" Class="font-weight-bold">
                                        @context.Quantity.ToString("N2") @_product.Unit
                                    </MudText>
                                </MudTd>
                                <MudTd DataLabel="@Localization.GetString("Note")">
                                    <MudText Typo="Typo.caption">@(string.IsNullOrEmpty(context.Note) ? "-" : context.Note)</MudText>
                                </MudTd>
                            </RowTemplate>
                        </MudTable>
                    }
                    else
                    {
                        <div class="pa-6 text-center">
                            <MudIcon Icon="@Icons.Material.Filled.SwapVert"
                                     Size="Size.Large"
                                     Color="Color.Secondary"
                                     Class="mb-2" />
                            <MudText Color="Color.Secondary">@Localization.GetString("NoRecentMovements")</MudText>
                        </div>
                    }
                </MudCardContent>
            </MudCard>
        </MudItem>
        <!-- ── Transaction History ── -->
        <MudItem xs="12">
            <MudCard Elevation="2">
                <MudCardHeader>
                    <CardHeaderContent>
                        <div class="d-flex align-center gap-3">
                            <MudText Typo="Typo.h6">@Localization.GetString("TransactionHistory")</MudText>
                            <MudChip T="string" Size="Size.Small" Color="Color.Default">
                                @_totalTransactionCount @Localization.GetString("Transactions")
                            </MudChip>
                        </div>
                    </CardHeaderContent>
                    <CardHeaderActions>
                        <!-- Purchased / Sold toggle -->
                        <MudButtonGroup Variant="Variant.Outlined" Size="Size.Small" Class="mr-4">
                            <MudButton Color="@(_historyMode == HistoryMode.Purchased ? Color.Primary : Color.Default)"
                                       Variant="@(_historyMode == HistoryMode.Purchased ? Variant.Filled : Variant.Outlined)"
                                       OnClick="@(() => SetHistoryMode(HistoryMode.Purchased))">
                                @Localization.GetString("Purchased")
                            </MudButton>
                            <MudButton Color="@(_historyMode == HistoryMode.Sold ? Color.Success : Color.Default)"
                                       Variant="@(_historyMode == HistoryMode.Sold ? Variant.Filled : Variant.Outlined)"
                                       OnClick="@(() => SetHistoryMode(HistoryMode.Sold))">
                                @Localization.GetString("Sold")
                            </MudButton>
                        </MudButtonGroup>
                    </CardHeaderActions>
                </MudCardHeader>

                <!-- Filters row -->
                <MudCardContent Class="pa-4" Style="border-bottom: 1px solid var(--mud-palette-divider);">
                    <div class="d-flex align-center flex-wrap gap-3">
                        <!-- Party selector -->
                        <MudSelect T="string"
                                   Value="_historyPartyFilter"
                                   ValueChanged="@((string v) => { _historyPartyFilter = v; })"
                                   Label="@(_historyMode == HistoryMode.Purchased ? Localization.GetString("Vendor") : Localization.GetString("Client"))"
                                   Variant="Variant.Outlined"
                                   Margin="Margin.Dense"
                                   Clearable="true"
                                   Style="min-width: 220px;">
                            @foreach (string party in _historyParties)
                            {
                                <MudSelectItem Value="@((string)party)">@party</MudSelectItem>
                            }
                        </MudSelect>

                        <!-- From date -->
                        <div>
                            <MudDatePicker @bind-Date="_historyFrom"
                                           Variant="Variant.Outlined"
                                           Margin="Margin.Dense"
                                           DateFormat="dd MMM yyyy"
                                           Label="@Localization.GetString("From")"
                                           PickerVariant="PickerVariant.Inline"
                                           Style="width: 315px;" />
                        </div>

                        <!-- To date -->
                        <div>
                            <MudDatePicker @bind-Date="_historyTo"
                                           Variant="Variant.Outlined"
                                           Margin="Margin.Dense"
                                           DateFormat="dd MMM yyyy"
                                           Label="@Localization.GetString("To")"
                                           MaxDate="DateTime.Today"
                                           PickerVariant="PickerVariant.Inline"
                                           Style="width: 315px;" />
                        </div>

                        @if (_historyPartyFilter != null || _historyFrom != null || _historyTo != null)
                        {
                            <MudButton Variant="Variant.Text"
                                       Color="Color.Default"
                                       Size="Size.Small"
                                       StartIcon="@Icons.Material.Filled.Clear"
                                       OnClick="ClearHistoryFilter">
                                @Localization.GetString("ClearFilters")
                            </MudButton>
                        }

                        <MudSpacer />

                        <!-- Summary chips -->
                        @if (_filteredHistory.Any())
                        {
                            <MudChip T="string" Size="Size.Small" Color="Color.Default" Icon="@Icons.Material.Filled.Numbers">
                                @_filteredHistory.Count() @Localization.GetString("Transactions")
                            </MudChip>
                            <MudChip T="string" Size="Size.Small"
                                     Color="@(_historyMode == HistoryMode.Purchased ? Color.Info : Color.Success)"
                                     Icon="@Icons.Material.Filled.AttachMoney">
                                @_filteredHistory.Sum(h => h.TotalPrice).ToString("C")
                            </MudChip>
                            <MudChip T="string" Size="Size.Small" Color="Color.Default" Icon="@Icons.Material.Filled.Scale">
                                @_filteredHistory.Sum(h => h.Quantity).ToString("N2") @_product!.Unit
                            </MudChip>
                        }
                    </div>
                </MudCardContent>

                <MudCardContent Class="pa-0">
                    @if (_loadingHistory)
                    {
                        <div class="pa-6">
                            <MudProgressLinear Color="Color.Primary" Indeterminate="true" />
                        </div>
                    }
                    else if (_filteredHistory.Any())
                    {
                        <MudTable Items="_filteredHistory"
                                  Hover="true"
                                  Dense="true"
                                  Elevation="0"
                                  Breakpoint="Breakpoint.Sm"
                                  T="ProductTransactionRow"
                                  RowClass="table-row-clickable"
                                  OnRowClick="@((TableRowClickEventArgs<ProductTransactionRow> args) => Navigation.NavigateTo(args.Item!.DocumentUrl))">
                            <HeaderContent>
                                <MudTh>@Localization.GetString("Date")</MudTh>
                                <MudTh>@Localization.GetString("DocumentNumber")</MudTh>
                                <MudTh>@(_historyMode == HistoryMode.Purchased ? Localization.GetString("Vendor") : Localization.GetString("Client"))</MudTh>
                                <MudTh Style="text-align: right;">@Localization.GetString("Quantity")</MudTh>
                                <MudTh Style="text-align: right;">@Localization.GetString("UnitPrice")</MudTh>
                                <MudTh Style="text-align: right;">@Localization.GetString("Total")</MudTh>
                            </HeaderContent>
                            <RowTemplate>
                                <MudTd DataLabel="@Localization.GetString("Date")">
                                    <MudText Typo="Typo.body2">@context.Date.ToString("dd MMM yyyy")</MudText>
                                </MudTd>
                                <MudTd DataLabel="@Localization.GetString("DocumentNumber")">
                                    <MudText Typo="Typo.body2" Class="font-weight-medium">@context.DocumentNumber</MudText>
                                </MudTd>
                                <MudTd DataLabel="@(_historyMode == HistoryMode.Purchased ? Localization.GetString("Vendor") : Localization.GetString("Client"))">
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">@context.PartyName</MudText>
                                </MudTd>
                                <MudTd DataLabel="@Localization.GetString("Quantity")" Style="text-align: right;">
                                    <MudText Typo="Typo.body2">@context.Quantity.ToString("N2") @_product!.Unit</MudText>
                                </MudTd>
                                <MudTd DataLabel="@Localization.GetString("UnitPrice")" Style="text-align: right;">
                                    <MudText Typo="Typo.body2">@context.UnitPrice.ToString("C")</MudText>
                                </MudTd>
                                <MudTd DataLabel="@Localization.GetString("Total")" Style="text-align: right;">
                                    <MudText Typo="Typo.body2" Class="font-weight-bold"
                                             Color="@(_historyMode == HistoryMode.Purchased ? Color.Info : Color.Success)">
                                        @context.TotalPrice.ToString("C")
                                    </MudText>
                                </MudTd>
                            </RowTemplate>
                        </MudTable>
                    }
                    else
                    {
                        <div class="pa-6 text-center">
                            <MudIcon Icon="@(_historyMode == HistoryMode.Purchased ? Icons.Material.Filled.ShoppingCart : Icons.Material.Filled.PointOfSale)"
                                     Size="Size.Large"
                                     Color="Color.Secondary"
                                     Class="mb-2" />
                            <MudText Color="Color.Secondary">
                                @(_historyMode == HistoryMode.Purchased
                                                        ? Localization.GetString("NoPurchaseData")
                                                        : Localization.GetString("NoSalesData"))
                            </MudText>
                        </div>
                    }
                </MudCardContent>
            </MudCard>
        </MudItem>

    </MudGrid>
}

@code {
    [Parameter] public Guid Id { get; set; }

    private bool _loading = true;
    private ProductDto? _product;
    private ProductAnalyticsDto _analytics = new();

    private List<WarehouseDto> _warehouses = [];
    private Guid? _selectedWarehouseId = null;

    private decimal _filteredTotalStock => _selectedWarehouseId.HasValue
        ? _analytics.StockByWarehouse.Where(s => s.WarehouseId == _selectedWarehouseId.Value).Sum(s => s.Quantity)
        : _analytics.TotalStockAcrossWarehouses;

    private decimal _filteredStockValue => _filteredTotalStock * _analytics.CurrentSellingPrice;

    private bool _filteredIsOutOfStock => _filteredTotalStock == 0;

    private bool _filteredHasLowStock => _selectedWarehouseId.HasValue
        ? _analytics.StockByWarehouse.Any(s => s.WarehouseId == _selectedWarehouseId.Value && s.Quantity <= s.MinimumQuantity && s.Quantity > 0)
        : _analytics.HasLowStock;

    private IEnumerable<RecentTransactionDto> _filteredTransactions => _selectedWarehouseId.HasValue
        ? _analytics.RecentTransactions.Where(t => _warehouses.Any(w => w.Id == _selectedWarehouseId.Value && w.Name == t.WarehouseName))
        : _analytics.RecentTransactions;

    private string _selectedWarehouseName => _selectedWarehouseId.HasValue
        ? _warehouses.FirstOrDefault(w => w.Id == _selectedWarehouseId.Value)?.Name ?? ""
        : Localization.GetString("AllWarehouses");

    private WarehouseStockDto? _filteredStockByWarehouse => _selectedWarehouseId.HasValue
        ? _analytics.StockByWarehouse.FirstOrDefault(s => s.WarehouseId == _selectedWarehouseId.Value)
        : null;

    protected override async Task OnInitializedAsync()
    {
        Localization.OnLanguageChanged += OnLanguageChanged;
        await LoadProduct();
    }

    private async void OnLanguageChanged()
    {
        await InvokeAsync(StateHasChanged);
    }

    private async Task LoadProduct()
    {
        _loading = true;

        try
        {
            _product = await ProductService.GetProductByIdAsync(Id);
            if (_product != null)
            {
                _analytics = await ProductService.GetProductAnalyticsAsync(Id);

                IEnumerable<WarehouseDto> warehouses = await WarehouseService.GetAllWarehousesAsync();
                _warehouses = warehouses.ToList();

                _selectedWarehouseId = null;

                await LoadHistory();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading product: {ex.Message}");
            Snackbar.Add(Localization.GetString("ErrorLoadingProduct"), Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task OnWarehouseChanged(Guid? warehouseId)
    {
        _selectedWarehouseId = warehouseId;
        await InvokeAsync(StateHasChanged);
    }

    private void EditProduct()
    {
        Navigation.NavigateTo($"/products/edit/{Id}");
    }

    private string CreateAdjustLink()
    {
        if (_selectedWarehouseId != null)
            return $"/inventory/adjust/?productId={Id}&warehouseId={_selectedWarehouseId}";

        return $"/inventory/adjust?productId={Id}";
    }

    private async Task DeleteProduct()
    {
        bool? result = await DialogService.ShowMessageBox(
            Localization.GetString("ConfirmDelete"),
            Localization.GetString("DeleteProductConfirm"),
            yesText: Localization.GetString("Yes"),
            cancelText: Localization.GetString("No"));

        if (result == true)
        {
            try
            {
                bool deleted = await ProductService.DeleteProductAsync(Id);
                if (deleted)
                {
                    Snackbar.Add(Localization.GetString("ProductDeleted"), Severity.Success);
                    Navigation.NavigateTo("/products");
                }
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Error deleting product: {ex.Message}");
                Snackbar.Add(Localization.GetString("ErrorDeletingProduct"), Severity.Error);
            }
        }
    }

    // ── Transaction History ──
    private enum HistoryMode { Purchased, Sold }

    private bool _loadingHistory = false;
    private HistoryMode _historyMode = HistoryMode.Purchased;
    private string? _historyPartyFilter = null;
    private DateTime? _historyFrom = null;
    private DateTime? _historyTo = null;

    private List<ProductTransactionRow> _allHistoryPurchased = [];
    private List<ProductTransactionRow> _allHistorySold = [];
    private List<ProductTransactionRow> _allHistory => _historyMode == HistoryMode.Purchased ? _allHistoryPurchased : _allHistorySold;

    private int _totalTransactionCount => _allHistoryPurchased.Count + _allHistorySold.Count;

    private IEnumerable<ProductTransactionRow> _filteredHistory => _allHistory
        .Where(h => _historyPartyFilter == null || h.PartyName == _historyPartyFilter)
        .Where(h => _historyFrom == null || h.Date.Date >= _historyFrom.Value.Date)
        .Where(h => _historyTo == null || h.Date.Date <= _historyTo.Value.Date)
        .OrderByDescending(h => h.Date);

    private IEnumerable<string> _historyParties => _allHistory
        .Select(h => h.PartyName)
        .Distinct()
        .OrderBy(p => p);

    private async Task SetHistoryMode(HistoryMode mode)
    {
        _historyMode = mode;
        _historyPartyFilter = null;
        await InvokeAsync(StateHasChanged);
    }

    private async Task LoadHistory()
    {
        _loadingHistory = true;
        _allHistoryPurchased = [];
        _allHistorySold = [];

        try
        {
            // ── Purchased: PurchaseNotes + Payable Invoices ──
            IEnumerable<PurchaseNoteDto> notes = await PurchaseNoteService.GetAllPurchaseNotesAsync();
            foreach (PurchaseNoteDto note in notes)
            {
                if (note.LineItems == null) continue;
                foreach (var item in note.LineItems.Where(i => i.ProductId == Id))
                {
                    _allHistoryPurchased.Add(new ProductTransactionRow
                    {
                        Date = note.PurchaseDate,
                        DocumentNumber = note.NoteNumber,
                        DocumentUrl = $"/purchase-notes/{note.Id}",
                        PartyName = note.IndividualFullName ?? "-",
                        Quantity = item.Quantity,
                        UnitPrice = item.UnitPrice,
                        TotalPrice = item.UnitPrice * item.Quantity
                    });
                }
            }

            IEnumerable<InvoiceDto> invoices = await InvoiceService.GetAllInvoicesAsync();
            foreach (InvoiceDto invoice in invoices.Where(i => i.Type == InvoiceType.Payable))
            {
                if (invoice.LineItems == null) continue;
                foreach (var item in invoice.LineItems.Where(i => i.ProductId == Id))
                {
                    _allHistoryPurchased.Add(new ProductTransactionRow
                    {
                        Date = invoice.IssueDate,
                        DocumentNumber = invoice.InvoiceNumber,
                        DocumentUrl = $"/invoices/{invoice.Id}",
                        PartyName = invoice.CompanyName ?? "-",
                        Quantity = item.Quantity,
                        UnitPrice = item.UnitPrice,
                        TotalPrice = item.TotalAmount
                    });
                }
            }

            // ── Sold: Receivable Invoices ──
            foreach (InvoiceDto invoice in invoices.Where(i => i.Type == InvoiceType.Receivable))
            {
                if (invoice.LineItems == null) continue;
                foreach (var item in invoice.LineItems.Where(i => i.ProductId == Id))
                {
                    _allHistorySold.Add(new ProductTransactionRow
                    {
                        Date = invoice.IssueDate,
                        DocumentNumber = invoice.InvoiceNumber,
                        DocumentUrl = $"/invoices/{invoice.Id}",
                        PartyName = invoice.CompanyName ?? "-",
                        Quantity = item.Quantity,
                        UnitPrice = item.UnitPrice,
                        TotalPrice = item.TotalAmount
                    });
                }
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading transaction history: {ex.Message}");
        }
        finally
        {
            _loadingHistory = false;
        }
    }

    private async Task ClearHistoryFilter()
    {
        _historyPartyFilter = null;
        _historyFrom = null;
        _historyTo = null;
        await InvokeAsync(StateHasChanged);
    }

    private class ProductTransactionRow
    {
        public DateTime Date { get; set; }
        public string DocumentNumber { get; set; } = string.Empty;
        public string DocumentUrl { get; set; } = string.Empty;
        public string PartyName { get; set; } = string.Empty;
        public decimal Quantity { get; set; }
        public decimal UnitPrice { get; set; }
        public decimal TotalPrice { get; set; }
    }


    public void Dispose()
    {
        Localization.OnLanguageChanged -= OnLanguageChanged;
    }
}
