@page "/products/{Id:guid}"
@implements IDisposable
@using WarehouseInvoiceSystem.Application.DTOs.Product
@using WarehouseInvoiceSystem.Application.DTOs.Warehouse
@using WarehouseInvoiceSystem.Application.DTOs.Invoice
@using WarehouseInvoiceSystem.Application.DTOs.PurchaseNote
@using WarehouseInvoiceSystem.Domain.Enums
@inject IProductService ProductService
@inject IWarehouseService WarehouseService
@inject ILocalizationService Localization
@inject NavigationManager Navigation
@inject WisDialogService WisDialog
@inject IDialogService DialogService
@inject IInventoryService InventoryService
@inject ISnackbar Snackbar

<PageTitle>@Localization.GetString("ProductDetails") - @Localization.GetString("InvoiceSystem")</PageTitle>

@if (_loading)
{
    <MudProgressLinear Color="Color.Primary" Indeterminate="true" />
}
else if (_product == null)
{
    <MudAlert Severity="Severity.Error">@Localization.GetString("ProductNotFound")</MudAlert>
}
else
{
    <WisDetailHeader BackHref="/products"
                     BackLabel="@Localization.GetString("Products")"
                     PrimaryAction="@_primaryAction"
                     Actions="@_actions" />

    <MudGrid>

        @* ── Header card ── *@
        <MudItem xs="12">
            <MudCard Elevation="2">
                <MudCardContent Class="pa-4">

                    @* ── Identity row: name+chip left, warehouse filter right ── *@
                    <div class="wis-product-identity-row">
                        <div class="wis-detail-identity">
                            <MudText Typo="Typo.h4" Class="font-weight-bold mb-0">@_product.Name</MudText>
                            <MudChip T="string" Size="Size.Small" Color="@(_product.IsActive? Color.Success: Color.Default)">
                                @(_product.IsActive? Localization.GetString("ProductActive") : Localization.GetString("ProductInactive"))
                            </MudChip>
                        </div>
                        <FilterPopoverList TValue="Guid?"
                                           Label="@Localization.GetString("AllWarehouses")"
                                           Items="_warehouseItems"
                                           Mode="FilterSelectionMode.Single"
                                           PopoverAnchorOrigin="Origin.BottomRight"
                                           PopoverTransformOrigin="Origin.TopRight"
                                           SelectedValue="_selectedWarehouseId"
                                           SelectedValueChanged="@(async (Guid? v) => await OnWarehouseChanged(v))" />
                    </div>

                    @* ── Meta row: code, unit, description ── *@
                    <div class="wis-detail-contact wis-product-meta-row">
                        <div class="wis-detail-contact-item">
                            <MudIcon Icon="@Icons.Material.Filled.Tag" Size="Size.Small" Color="Color.Secondary" />
                            <MudText Typo="Typo.body2" Style="font-weight: 500;">@_product.Code</MudText>
                        </div>
                        <div class="wis-detail-contact-item">
                            <MudIcon Icon="@Icons.Material.Filled.Scale" Size="Size.Small" Color="Color.Secondary" />
                            <MudText Typo="Typo.body2">@_product.Unit</MudText>
                        </div>
                        @if (!string.IsNullOrWhiteSpace(_product.Description))
                        {
                            <div class="wis-detail-contact-item">
                                <MudIcon Icon="@Icons.Material.Filled.Info" Size="Size.Small" Color="Color.Secondary" />
                                <MudText Typo="Typo.body2" Color="Color.Secondary">@_product.Description</MudText>
                            </div>
                        }
                    </div>

                    @* ── Stats bar — 4 stats, full width ── *@
                    <div class="wis-product-stats-bar">

                        @* Stat 1 *@
                        <div class="wis-product-stats-bar__stat">
                            <MudText Typo="Typo.caption" Color="Color.Secondary" Class="wis-section-label">@Localization.GetString("DefaultPrice")</MudText>
                            <div class="wis-stat-value mud-success-text">@_product.DefaultPrice.ToString("C")</div>
                        </div>

                        @* Stat 2 *@
                        <div class="wis-product-stats-bar__stat">
                            <MudText Typo="Typo.caption" Color="Color.Secondary" Class="wis-section-label">@Localization.GetString("TotalStock")</MudText>
                            <div class="wis-stat-value @StockColorClass">@_filteredTotalStock.ToString("N2") @_product.Unit</div>
                            <MudText Typo="Typo.caption" Color="@StockBadgeColor" Class="mt-1">@StockStatusLabel</MudText>
                        </div>

                        @* Stat 3 *@
                        <div class="wis-product-stats-bar__stat">
                            <MudText Typo="Typo.caption" Color="Color.Secondary" Class="wis-section-label">@Localization.GetString("StockValue")</MudText>
                            <div class="wis-stat-value mud-success-text">@_filteredStockValue.ToString("C")</div>
                        </div>

                        @* Stat 4 *@
                        <div class="wis-product-stats-bar__stat">
                            <MudText Typo="Typo.caption" Color="Color.Secondary" Class="wis-section-label">@Localization.GetString("GrossMargin")</MudText>
                            <div class="wis-stat-value @(_scopedGrossMarginPct > 30 ? "mud-success-text" : "mud-warning-text")">
                                @_scopedGrossMarginPct.ToString("N1")%
                            </div>
                        </div>

                    </div>

                </MudCardContent>
            </MudCard>
        </MudItem>

        @* ── Stock by Warehouse (only when All Warehouses selected) ── *@
        @if (!_selectedWarehouseId.HasValue && _analytics.StockByWarehouse.Any())
        {
            <MudItem xs="12">
                <MudCard Elevation="2">
                    <MudCardHeader>
                        <CardHeaderContent>
                            <MudText Typo="Typo.h6">@Localization.GetString("StockByWarehouse")</MudText>
                        </CardHeaderContent>
                    </MudCardHeader>
                    <MudCardContent Class="pa-0">
                        <MudTable Items="_analytics.StockByWarehouse"
                                  Hover="true"
                                  Elevation="0"
                                  Class="wis-secondary-list">
                            <HeaderContent>
                                <MudTh>@Localization.GetString("Warehouse")</MudTh>
                                <MudTh Style="text-align: right;">@Localization.GetString("Quantity")</MudTh>
                                <MudTh Style="text-align: right;">@Localization.GetString("Reserved")</MudTh>
                                <MudTh Style="text-align: right;">@Localization.GetString("Available")</MudTh>
                                <MudTh Style="text-align: right;">@Localization.GetString("Minimum")</MudTh>
                                <MudTh>@Localization.GetString("LastRestocked")</MudTh>
                            </HeaderContent>
                            <RowTemplate>
                                <MudTd DataLabel="@Localization.GetString("Warehouse")">
                                    <MudText Typo="Typo.body2">@context.WarehouseName</MudText>
                                </MudTd>
                                <MudTd DataLabel="@Localization.GetString("Quantity")" Style="text-align: right;">
                                    <MudText Typo="Typo.body2"
                                             Color="@(context.Quantity <= context.MinimumQuantity ? Color.Error : Color.Default)">
                                        @context.Quantity.ToString("N2") @_product.Unit
                                    </MudText>
                                </MudTd>
                                <MudTd DataLabel="@Localization.GetString("Reserved")" Style="text-align: right;">
                                    <MudText Typo="Typo.body2">@context.ReservedQuantity.ToString("N2") @_product.Unit</MudText>
                                </MudTd>
                                <MudTd DataLabel="@Localization.GetString("Available")" Style="text-align: right;">
                                    <MudText Typo="Typo.body2">@context.AvailableQuantity.ToString("N2") @_product.Unit</MudText>
                                </MudTd>
                                <MudTd DataLabel="@Localization.GetString("Minimum")" Style="text-align: right;">
                                    <MudText Typo="Typo.body2">@(context.MinimumQuantity?.ToString("N2") ?? "0,00") @_product.Unit</MudText>
                                </MudTd>
                                <MudTd DataLabel="@Localization.GetString("LastRestocked")">
                                    <MudText Typo="Typo.body2">@(context.LastRestockedAt?.ToString("dd MMM yyyy") ?? "-")</MudText>
                                </MudTd>
                            </RowTemplate>
                        </MudTable>
                    </MudCardContent>
                </MudCard>
            </MudItem>
        }

        @* ── Profitability ── *@
        <MudItem xs="12">
            <MudCard Elevation="2">
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudText Typo="Typo.h6">@Localization.GetString("Profitability")</MudText>
                    </CardHeaderContent>
                </MudCardHeader>
                <MudCardContent Class="pa-4">
                    <MudGrid Spacing="4" Class="wis-detail-stats">

                        <MudItem xs="3">
                            <MudText Typo="Typo.caption" Color="Color.Secondary" Class="wis-section-label">@Localization.GetString("AveragePurchasePrice")</MudText>
                            <div class="wis-stat-value">@_scopedAvgPurchasePrice.ToString("C")</div>
                        </MudItem>

                        <MudItem xs="3">
                            <MudText Typo="Typo.caption" Color="Color.Secondary" Class="wis-section-label">@Localization.GetString("CurrentSellingPrice")</MudText>
                            <div class="wis-stat-value mud-success-text">@_analytics.CurrentSellingPrice.ToString("C")</div>
                        </MudItem>

                        <MudItem xs="3">
                            <MudText Typo="Typo.caption" Color="Color.Secondary" Class="wis-section-label">@Localization.GetString("GrossMargin")</MudText>
                            <div class="wis-stat-value @(_scopedGrossMarginPct > 30 ? "mud-success-text" : "mud-warning-text")">
                                @_scopedGrossMarginPct.ToString("N1")%
                            </div>
                        </MudItem>

                        <MudItem xs="3">
                            <MudText Typo="Typo.caption" Color="Color.Secondary" Class="wis-section-label">@Localization.GetString("EstimatedProfit")</MudText>
                            <div class="wis-stat-value @(_scopedEstimatedProfit > 0 ? "mud-success-text" : "mud-error-text")">
                                @_scopedEstimatedProfit.ToString("C")
                            </div>
                        </MudItem>

                    </MudGrid>
                </MudCardContent>
            </MudCard>
        </MudItem>

        @* ── Recent Stock Movements ── *@
        <MudItem xs="12">
            <MudCard Elevation="2">
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudText Typo="Typo.h6">@Localization.GetString("RecentStockMovements")</MudText>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">@_selectedWarehouseName</MudText>
                    </CardHeaderContent>
                </MudCardHeader>
                <MudCardContent Class="pa-0">
                    @if (_filteredTransactions.Any())
                    {
                        <MudTable Items="_filteredTransactions.Take(5)"
                                  Hover="true"
                                  Breakpoint="Breakpoint.Sm"
                                  Elevation="0"
                                  Class="wis-secondary-list">
                            <HeaderContent>
                                <MudTh>@Localization.GetString("Date")</MudTh>
                                <MudTh>@Localization.GetString("Type")</MudTh>
                                <MudTh>@Localization.GetString("Warehouse")</MudTh>
                                <MudTh Style="text-align: right;">@Localization.GetString("Quantity")</MudTh>
                                <MudTh>@Localization.GetString("Note")</MudTh>
                            </HeaderContent>
                            <RowTemplate>
                                <MudTd DataLabel="@Localization.GetString("Date")">
                                    <MudText Typo="Typo.body2">@context.Date.ToString("dd MMM yyyy HH:mm")</MudText>
                                </MudTd>
                                <MudTd DataLabel="@Localization.GetString("Type")">
                                    @if (context.Type == "Inbound")
                                    {
                                        <MudChip T="string" Size="Size.Small" Color="Color.Success"
                                                 Variant="Variant.Outlined"
                                                 Icon="@Icons.Material.Filled.ArrowDownward">
                                            @Localization.GetString("Inbound")
                                        </MudChip>
                                    }
                                    else if (context.Type == "Outbound")
                                    {
                                        <MudChip T="string" Size="Size.Small" Color="Color.Warning"
                                                 Variant="Variant.Outlined"
                                                 Icon="@Icons.Material.Filled.ArrowUpward">
                                            @Localization.GetString("Outbound")
                                        </MudChip>
                                    }
                                    else
                                    {
                                        <MudChip T="string" Size="Size.Small" Color="Color.Info"
                                                 Variant="Variant.Outlined">
                                            @Localization.GetString(@context.Type)
                                        </MudChip>
                                    }
                                </MudTd>
                                <MudTd DataLabel="@Localization.GetString("Warehouse")">
                                    <MudText Typo="Typo.body2">@context.WarehouseName</MudText>
                                </MudTd>
                                <MudTd DataLabel="@Localization.GetString("Quantity")" Style="text-align: right;">
                                    <MudText Typo="Typo.body2">@context.Quantity.ToString("N2") @_product.Unit</MudText>
                                </MudTd>
                                <MudTd DataLabel="@Localization.GetString("Note")">
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">@(string.IsNullOrEmpty(context.Note) ? "-" : context.Note)</MudText>
                                </MudTd>
                            </RowTemplate>
                        </MudTable>
                    }
                    else
                    {
                        <div class="pa-6 d-flex align-center">
                            <MudIcon Icon="@Icons.Material.Filled.SwapVert"
                                     Size="Size.Large"
                                     Color="Color.Secondary"
                                     Class="mr-2" />
                            <MudText Color="Color.Secondary">@Localization.GetString("NoRecentMovements")</MudText>
                        </div>
                    }
                </MudCardContent>
            </MudCard>
        </MudItem>

        @* ── Transaction History ── *@
        <MudItem xs="12">
            <MudCard Elevation="2">
                <MudCardHeader>
                    <CardHeaderContent>
                        <div class="d-flex align-center gap-3">
                            <MudText Typo="Typo.h6">@Localization.GetString("TransactionHistory")</MudText>
                            <MudChip T="string" Size="Size.Small" Color="Color.Default">
                                @_totalTransactionCount @Localization.GetString("Transactions")
                            </MudChip>
                        </div>
                    </CardHeaderContent>
                    <CardHeaderActions>
                        <div class="d-flex gap-2 mr-4">
                            <button class="wis-pill-btn @(_historyMode == HistoryMode.Purchased ? "wis-pill-btn--active" : "")"
                                    type="button"
                                    @onclick="@(() => SetHistoryMode(HistoryMode.Purchased))">
                                @Localization.GetString("Purchased")
                            </button>
                            <button class="wis-pill-btn @(_historyMode == HistoryMode.Sold ? "wis-pill-btn--sold-active" : "")"
                                    type="button"
                                    @onclick="@(() => SetHistoryMode(HistoryMode.Sold))">
                                @Localization.GetString("Sold")
                            </button>
                        </div>
                    </CardHeaderActions>
                </MudCardHeader>

                <MudCardContent Class="pa-4" Style="border-bottom: 1px solid var(--mud-palette-divider);">
                    <div class="d-flex align-center flex-wrap gap-3">
                        <div style="flex-shrink: 0;">
                            <FilterPopoverList TValue="string"
                                               Label="@(_historyMode == HistoryMode.Purchased ? Localization.GetString("Vendor") : Localization.GetString("Client"))"
                                               Items="@(_historyParties.Select(p => new FilterPopoverItem<string> { Label = p, Value = p, Color = Color.Default }).ToList())"
                                               Mode="FilterSelectionMode.Single"
                                               SelectedValue="@_historyPartyFilter"
                                               SelectedValueChanged="@((string v) => { _historyPartyFilter = string.IsNullOrEmpty(v) ? null : v; StateHasChanged(); })" />
                        </div>

                        @* Period preset + date range picker *@
                        <WisDateRangeFilter @ref="_dateRangeFilter"
                                            DateRange="_historyDateRange"
                                            DateRangeChanged="OnDateRangeChanged"
                                            DatePreset="_historyDatePreset"
                                            DatePresetChanged="OnDatePresetChanged" />

                        @if (_historyPartyFilter != null || _historyDateRange.Start != null || _historyDateRange.End != null)
                        {
                            <button type="button"
                                    class="wis-filter-btn wis-filter-btn--clear"
                                    @onclick="ClearHistoryFilter">
                                <MudIcon Icon="@Icons.Material.Filled.FilterAltOff" Size="Size.Small" Style="margin-right: 6px;" />
                                @Localization.GetString("ClearFilters")
                            </button>
                        }

                        <MudSpacer />

                        @if (_filteredHistory.Any())
                        {
                            <MudChip T="string" Size="Size.Small" Color="Color.Default" Icon="@Icons.Material.Filled.Numbers">
                                @_filteredHistory.Count() @Localization.GetString("Transactions")
                            </MudChip>
                            <MudChip T="string" Size="Size.Small"
                                     Color="@(_historyMode == HistoryMode.Purchased ? Color.Info : Color.Success)"
                                     Icon="@Icons.Material.Filled.AttachMoney">
                                @_filteredHistory.Sum(h => h.TotalPrice).ToString("C")
                            </MudChip>
                            <MudChip T="string" Size="Size.Small" Color="Color.Default" Icon="@Icons.Material.Filled.Scale">
                                @_filteredHistory.Sum(h => h.Quantity).ToString("N2") @_product!.Unit
                            </MudChip>
                        }
                    </div>
                </MudCardContent>

                <MudCardContent Class="pa-0">
                    @if (_loadingHistory)
                    {
                        <div class="pa-6">
                            <MudProgressLinear Color="Color.Primary" Indeterminate="true" />
                        </div>
                    }
                    else if (_filteredHistory.Any())
                    {
                        <MudTable Items="_filteredHistory"
                                  Hover="true"
                                  Elevation="0"
                                  Breakpoint="Breakpoint.Sm"
                                  T="ProductTransactionRow"
                                  RowClass="table-row-clickable"
                                  Class="wis-secondary-list"
                                  OnRowClick="@((TableRowClickEventArgs<ProductTransactionRow> args) => Navigation.NavigateTo(args.Item!.DocumentUrl))">
                            <HeaderContent>
                                <MudTh>@Localization.GetString("Date")</MudTh>
                                <MudTh>@Localization.GetString("DocumentNumber")</MudTh>
                                <MudTh>@(_historyMode == HistoryMode.Purchased ? Localization.GetString("Vendor") : Localization.GetString("Client"))</MudTh>
                                <MudTh Style="text-align: right;">@Localization.GetString("Quantity")</MudTh>
                                <MudTh Style="text-align: right;">@Localization.GetString("UnitPrice")</MudTh>
                                <MudTh Style="text-align: right;">@Localization.GetString("Total")</MudTh>
                            </HeaderContent>
                            <RowTemplate>
                                <MudTd DataLabel="@Localization.GetString("Date")">
                                    <MudText Typo="Typo.body2">@context.Date.ToString("dd MMM yyyy")</MudText>
                                </MudTd>
                                <MudTd DataLabel="@Localization.GetString("DocumentNumber")">
                                    <MudText Typo="Typo.body2" Class="font-weight-medium">@context.DocumentNumber</MudText>
                                </MudTd>
                                <MudTd DataLabel="@(_historyMode == HistoryMode.Purchased ? Localization.GetString("Vendor") : Localization.GetString("Client"))">
                                    <MudText Typo="Typo.body2" Color="Color.Secondary">@context.PartyName</MudText>
                                </MudTd>
                                <MudTd DataLabel="@Localization.GetString("Quantity")" Style="text-align: right;">
                                    <MudText Typo="Typo.body2">@context.Quantity.ToString("N2") @_product!.Unit</MudText>
                                </MudTd>
                                <MudTd DataLabel="@Localization.GetString("UnitPrice")" Style="text-align: right;">
                                    <MudText Typo="Typo.body2">@context.UnitPrice.ToString("C")</MudText>
                                </MudTd>
                                <MudTd DataLabel="@Localization.GetString("Total")" Style="text-align: right;">
                                    <MudText Typo="Typo.body2"
                                             Color="@(_historyMode == HistoryMode.Purchased ? Color.Info : Color.Success)">
                                        @context.TotalPrice.ToString("C")
                                    </MudText>
                                </MudTd>
                            </RowTemplate>
                        </MudTable>
                    }
                    else
                    {
                        <div class="pa-6 d-flex align-center">
                            <MudIcon Icon="@(_historyMode == HistoryMode.Purchased ? Icons.Material.Filled.ShoppingCart : Icons.Material.Filled.PointOfSale)"
                                     Size="Size.Large"
                                     Color="Color.Secondary"
                                     Class="mr-2" />
                            <MudText Color="Color.Secondary">
                                @(_historyMode == HistoryMode.Purchased
                                                        ? Localization.GetString("NoPurchaseData")
                                                        : Localization.GetString("NoSalesData"))
                            </MudText>
                        </div>
                    }
                </MudCardContent>
            </MudCard>
        </MudItem>

    </MudGrid>
}

@code {
    [Parameter] public Guid Id { get; set; }

    private bool _loading = true;
    private ProductDto? _product;
    private ProductAnalyticsDto _analytics = new();

    private List<WarehouseDto> _warehouses = [];

    private List<FilterPopoverItem<Guid?>> _warehouseItems => new[] {
            new FilterPopoverItem<Guid?> { Label = Localization.GetString("AllWarehouses"), Value = null, Color = Color.Default }
        }
        .Concat(_warehouses.Select(w => new FilterPopoverItem<Guid?>
        {
            Label = w.Name + (w.IsDefault ? $" ({Localization.GetString("Default")})" : ""),
            Value = w.Id,
            Color = Color.Default
        }))
        .ToList();
    private Guid? _selectedWarehouseId = null;

    private WisDetailActionItem? _primaryAction;
    private List<WisDetailActionItem> _actions = [];

    // ── Scoped computed properties ────────────────────────────────────────────

    private decimal _filteredTotalStock => _selectedWarehouseId.HasValue
        ? _analytics.StockByWarehouse.Where(s => s.WarehouseId == _selectedWarehouseId.Value).Sum(s => s.Quantity)
        : _analytics.TotalStockAcrossWarehouses;

    private decimal _filteredStockValue => _filteredTotalStock * _analytics.CurrentSellingPrice;

    private bool _filteredIsOutOfStock => _filteredTotalStock == 0;

    private bool _filteredHasLowStock => _selectedWarehouseId.HasValue
        ? _analytics.StockByWarehouse.Any(s => s.WarehouseId == _selectedWarehouseId.Value
                                            && s.Quantity <= s.MinimumQuantity
                                            && s.Quantity > 0)
        : _analytics.HasLowStock;

    private string StockColorClass =>
        _filteredIsOutOfStock ? "mud-error-text" :
        _filteredHasLowStock ? "mud-warning-text" :
                                "mud-default-text";

    private Color StockBadgeColor =>
        _filteredIsOutOfStock ? Color.Error :
        _filteredHasLowStock ? Color.Warning :
                                Color.Success;

    private string StockStatusLabel =>
        _filteredIsOutOfStock ? Localization.GetString("OutOfStock") :
        _filteredHasLowStock ? Localization.GetString("LowStock") :
                                Localization.GetString("InStock");

    private IEnumerable<RecentTransactionDto> _filteredTransactions => _selectedWarehouseId.HasValue
        ? _analytics.RecentTransactions.Where(t => t.WarehouseName ==
              _warehouses.FirstOrDefault(w => w.Id == _selectedWarehouseId.Value)?.Name)
        : _analytics.RecentTransactions;

    private string _selectedWarehouseName => _selectedWarehouseId.HasValue
        ? _warehouses.FirstOrDefault(w => w.Id == _selectedWarehouseId.Value)?.Name ?? ""
        : Localization.GetString("AllWarehouses");

    private IEnumerable<ProductTransactionRow> _scopedPurchased =>
        _selectedWarehouseId.HasValue
            ? _allHistoryPurchased.Where(r => r.WarehouseId == _selectedWarehouseId.Value)
            : _allHistoryPurchased;

    private IEnumerable<ProductTransactionRow> _scopedSold =>
        _selectedWarehouseId.HasValue
            ? _allHistorySold.Where(r => r.WarehouseId == _selectedWarehouseId.Value)
            : _allHistorySold;

    private decimal _scopedAvgPurchasePrice =>
        _scopedPurchased.Any() ? _scopedPurchased.Average(r => r.UnitPrice) : 0;

    private decimal _scopedGrossMarginPct =>
        _analytics.CurrentSellingPrice > 0 && _scopedAvgPurchasePrice > 0
            ? (_analytics.CurrentSellingPrice - _scopedAvgPurchasePrice) / _analytics.CurrentSellingPrice * 100
            : _analytics.GrossMarginPercentage;

    private decimal _scopedEstimatedProfit =>
        (_analytics.CurrentSellingPrice - _scopedAvgPurchasePrice) * _filteredTotalStock;

    // ── Lifecycle ─────────────────────────────────────────────────────────────

    protected override async Task OnInitializedAsync()
    {
        Localization.OnLanguageChanged += OnLanguageChanged;
        await LoadProduct();
    }

    private async void OnLanguageChanged()
    {
        BuildActions();
        await InvokeAsync(StateHasChanged);
    }

    private async Task LoadProduct()
    {
        _loading = true;

        try
        {
            _product = await ProductService.GetProductByIdAsync(Id);
            if (_product != null)
            {
                _analytics = await ProductService.GetProductAnalyticsAsync(Id);

                IEnumerable<WarehouseDto> warehouses = await WarehouseService.GetAllWarehousesAsync();
                _warehouses = warehouses.ToList();

                _selectedWarehouseId = null;

                BuildActions();
                await LoadHistory();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading product: {ex.Message}");
            Snackbar.Add(Localization.GetString("ErrorLoadingProduct"), Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    private void BuildActions()
    {
        if (_product is null) return;

        _primaryAction = new WisDetailActionItem
        {
            Icon = Icons.Material.Filled.Inventory2,
            Label = Localization.GetString("AdjustStock"),
            OnClick = EventCallback.Factory.Create(this, OpenAdjustDialog)
        };

        _actions =
        [
            new WisDetailActionItem
            {
                Icon = Icons.Material.Filled.Edit,
                Label = Localization.GetString("Edit"),
                OnClick = EventCallback.Factory.Create(this, OpenEditDialog)
            },
            new WisDetailActionItem
            {
                Icon = _product.IsActive
                    ? Icons.Material.Filled.DoNotDisturbOn
                    : Icons.Material.Filled.CheckCircle,
                Label = _product.IsActive
                    ? Localization.GetString("Deactivate")
                    : Localization.GetString("Activate"),
                Color = _product.IsActive ? Color.Error : Color.Success,
                IsDividerBefore = true,
                OnClick = EventCallback.Factory.Create(this, ToggleActiveStatus)
            }
        ];
    }

    private async Task OpenEditDialog()
    {
        if (_product is null) return;

        ProductDto? dto = await WisDialog.ShowFormAsync<ProductDialog, ProductDto>(
            Localization.GetString("EditProduct"),
            p => p.Add(x => x.Product, _product));

        if (dto is null) return;

        try
        {
            UpdateProductDto updateDto = new()
            {
                Name = dto.Name,
                Code = dto.Code,
                Description = dto.Description,
                Unit = dto.Unit,
                DefaultPrice = dto.DefaultPrice,
                IsActive = _product.IsActive,
            };

            await ProductService.UpdateProductAsync(Id, updateDto);
            Snackbar.Add(Localization.GetString("ProductUpdated"), Severity.Success);
            await LoadProduct();
        }
        catch (InvalidOperationException ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error updating product: {ex.Message}");
            Snackbar.Add(Localization.GetString("ErrorUpdatingProduct"), Severity.Error);
        }
    }

    private async Task ToggleActiveStatus()
    {
        if (_product is null) return;

        if (_product.IsActive)
            await DeactivateProduct();
        else
            await ActivateProduct();
    }

    private async Task DeactivateProduct()
    {
        bool confirmed = await WisDialog.ConfirmAsync(
            Localization.GetString("DeactivateProduct"),
            Localization.GetString("DeactivateProductConfirm"),
            Localization.GetString("Deactivate"),
            Localization.GetString("Cancel"));

        if (!confirmed) return;

        try
        {
            await ProductService.SetActiveStatusAsync(Id, false);
            Snackbar.Add(Localization.GetString("ProductDeactivated"), Severity.Success);
            await LoadProduct();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error deactivating product: {ex.Message}");
            Snackbar.Add(Localization.GetString("ErrorUpdatingProduct"), Severity.Error);
        }
    }

    private async Task ActivateProduct()
    {
        bool confirmed = await WisDialog.ConfirmAsync(
            Localization.GetString("ActivateProduct"),
            Localization.GetString("ActivateProductConfirm"),
            Localization.GetString("Activate"),
            Localization.GetString("Cancel"));

        if (!confirmed) return;

        try
        {
            await ProductService.SetActiveStatusAsync(Id, true);
            Snackbar.Add(Localization.GetString("ProductActivated"), Severity.Success);
            await LoadProduct();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error activating product: {ex.Message}");
            Snackbar.Add(Localization.GetString("ErrorUpdatingProduct"), Severity.Error);
        }
    }

    private async Task OnWarehouseChanged(Guid? warehouseId)
    {
        _selectedWarehouseId = warehouseId;
        _historyPartyFilter = null;
        await InvokeAsync(StateHasChanged);
    }

    private async Task OpenAdjustDialog()
    {
        DialogParameters<AdjustStockDialog> parameters = new();
        parameters.Add(x => x.PreSelectedProductId, Id);
        if (_selectedWarehouseId.HasValue)
            parameters.Add(x => x.PreSelectedWarehouseId, _selectedWarehouseId.Value);

        DialogOptions options = new()
        {
            MaxWidth = MaxWidth.Small,
            FullWidth = true,
            CloseOnEscapeKey = true
        };

        IDialogReference dialog = await DialogService.ShowAsync<AdjustStockDialog>(
            Localization.GetString("AdjustStock"), parameters, options);

        DialogResult? result = await dialog.Result;

        if (result is { Canceled: false, Data: AdjustStockDialog.AdjustStockResult dto })
        {
            try
            {
                await InventoryService.AdjustStockAsync(
                    dto.ProductId, dto.WarehouseId, dto.QuantityChange, dto.Reason);
                Snackbar.Add(Localization.GetString("StockAdjusted"), Severity.Success);
                await LoadProduct();
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Error adjusting stock: {ex.Message}");
                Snackbar.Add(Localization.GetString("ErrorAdjustingStock"), Severity.Error);
            }
        }
    }

    // ── Transaction History ───────────────────────────────────────────────────

    private enum HistoryMode { Purchased, Sold }

    private bool _loadingHistory = false;
    private HistoryMode _historyMode = HistoryMode.Purchased;
    private string? _historyPartyFilter = null;
    private DateRange _historyDateRange = new(null, null);
    private int? _historyDatePreset = null;
    private WisDateRangeFilter? _dateRangeFilter;

    private List<ProductTransactionRow> _allHistoryPurchased = [];
    private List<ProductTransactionRow> _allHistorySold = [];

    private IEnumerable<ProductTransactionRow> _activeHistory =>
        _historyMode == HistoryMode.Purchased ? _scopedPurchased : _scopedSold;

    private int _totalTransactionCount =>
        _scopedPurchased.Count() + _scopedSold.Count();

    private IEnumerable<ProductTransactionRow> _filteredHistory => _activeHistory
        .Where(h => _historyPartyFilter == null || h.PartyName == _historyPartyFilter)
        .Where(h => _historyDateRange.Start == null || h.Date.Date >= _historyDateRange.Start.Value.Date)
        .Where(h => _historyDateRange.End == null || h.Date.Date <= _historyDateRange.End.Value.Date)
        .OrderByDescending(h => h.Date);

    private IEnumerable<string> _historyParties => _activeHistory
        .Select(h => h.PartyName)
        .Distinct()
        .OrderBy(p => p);

    private async Task SetHistoryMode(HistoryMode mode)
    {
        _historyMode = mode;
        _historyPartyFilter = null;
        await InvokeAsync(StateHasChanged);
    }

    private async Task LoadHistory()
    {
        _loadingHistory = true;
        _allHistoryPurchased = [];
        _allHistorySold = [];

        try
        {
            ProductTransactionHistoryDto history = await ProductService
                .GetProductTransactionHistoryAsync(Id);

            _allHistoryPurchased = history.Purchased
                .Select(r => new ProductTransactionRow
                {
                    Date = r.Date,
                    DocumentNumber = r.DocumentNumber,
                    DocumentUrl = r.DocumentUrl,
                    PartyName = r.PartyName,
                    WarehouseId = r.WarehouseId,
                    WarehouseName = r.WarehouseName,
                    Quantity = r.Quantity,
                    UnitPrice = r.UnitPrice,
                    TotalPrice = r.TotalPrice
                }).ToList();

            _allHistorySold = history.Sold
                .Select(r => new ProductTransactionRow
                {
                    Date = r.Date,
                    DocumentNumber = r.DocumentNumber,
                    DocumentUrl = r.DocumentUrl,
                    PartyName = r.PartyName,
                    WarehouseId = r.WarehouseId,
                    WarehouseName = r.WarehouseName,
                    Quantity = r.Quantity,
                    UnitPrice = r.UnitPrice,
                    TotalPrice = r.TotalPrice
                }).ToList();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading transaction history: {ex.Message}");
        }
        finally
        {
            _loadingHistory = false;
        }
    }

    private async Task ClearHistoryFilter()
    {
        _historyPartyFilter = null;
        if (_dateRangeFilter is not null)
            await _dateRangeFilter.ClearAsync();
        await InvokeAsync(StateHasChanged);
    }

    private async Task OnDatePresetChanged(int? days)
    {
        _historyDatePreset = days;
        await InvokeAsync(StateHasChanged);
    }

    private async Task OnDateRangeChanged(DateRange range)
    {
        _historyDateRange = range;
        await InvokeAsync(StateHasChanged);
    }

    // ── Helpers ───────────────────────────────────────────────────────────────

    private class ProductTransactionRow
    {
        public DateTime Date { get; set; }
        public string DocumentNumber { get; set; } = string.Empty;
        public string DocumentUrl { get; set; } = string.Empty;
        public string PartyName { get; set; } = string.Empty;
        public Guid WarehouseId { get; set; }
        public string WarehouseName { get; set; } = string.Empty;
        public decimal Quantity { get; set; }
        public decimal UnitPrice { get; set; }
        public decimal TotalPrice { get; set; }
    }

    public void Dispose()
    {
        Localization.OnLanguageChanged -= OnLanguageChanged;
    }
}
