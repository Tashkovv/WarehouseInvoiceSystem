@page "/products/{Id:guid}/transactions"
@inherits PageBase
@using WarehouseInvoiceSystem.Application.DTOs.Product
@using WarehouseInvoiceSystem.Application.DTOs.Warehouse
@using WarehouseInvoiceSystem.Application.DTOs.InventoryTransaction
@using WarehouseInvoiceSystem.Application.DTOs.Company
@using WarehouseInvoiceSystem.Application.DTOs.Individual
@using WarehouseInvoiceSystem.Domain.Enums
@using WarehouseInvoiceSystem.Domain.Queries
@using WarehouseInvoiceSystem.Domain.Queries.Common
@using WarehouseInvoiceSystem.Application.Models
@inject IProductService ProductService
@inject IInventoryService InventoryService
@inject IWarehouseService WarehouseService
@inject ICompanyService CompanyService
@inject IIndividualService IndividualService
@inject IExcelExportService ExcelExportService

<PageTitle>@Localization.GetString("TransactionHistory") - @Localization.GetString("InvoiceSystem")</PageTitle>

@if (_loading)
{
    <MudProgressLinear Color="Color.Primary" Indeterminate="true" />
}
else if (_product == null)
{
    <MudAlert Severity="Severity.Error">@Localization.GetString("ProductNotFound")</MudAlert>
}
else
{
    @* ── Back nav ── *@
    <WisDetailHeader BackHref="@($"/inventory")"
                     BackLabel="@Localization.GetString("Inventory")" />

    <MudGrid>

        @* ── Product context bar ── *@
        <MudItem xs="12">
            <MudCard Elevation="2">
                <MudCardContent Class="pa-4">

                    <div class="wis-product-identity-row">
                        <div class="wis-detail-identity">
                            <MudText Typo="Typo.h4" Class="font-weight-bold mb-0">
                                @Localization.GetString("TransactionHistory")
                            </MudText>
                        </div>

                        <WisAutocompleteFilter TValue="Guid"
                                               Label="@Localization.GetString("AllWarehouses")"
                                               AllLabel="@Localization.GetString("All")"
                                               Icon="@Icons.Material.Filled.Warehouse"
                                               LoadItems="LoadWarehouseItems"
                                               PopoverAnchorOrigin="Origin.BottomRight"
                                               PopoverTransformOrigin="Origin.TopRight"
                                               SelectedValue="@(_selectedWarehouseId ?? default)"
                                               SelectedValueChanged="@(async (Guid v) => await OnWarehouseChanged(v == default ? (Guid?)null : v))"
                                               MinWidth="200px" />
                    </div>

                    @* ── Product meta row ── *@
                    <div class="wis-detail-contact wis-product-meta-row">
                        <div class="wis-detail-contact-item">
                            <MudIcon Icon="@Icons.Material.Filled.Inventory2" Size="Size.Small" Color="Color.Secondary" />
                            <MudText Typo="Typo.body2" Color="Color.Secondary">@_product.Code — @_product.Name</MudText>
                        </div>
                        <div class="wis-detail-contact-item">
                            <MudIcon Icon="@Icons.Material.Filled.Scale" Size="Size.Small" Color="Color.Secondary" />
                            <MudText Typo="Typo.body2" Color="Color.Secondary">@_product.Unit</MudText>
                        </div>
                        @if (_currentStock.HasValue)
                        {
                            <div class="wis-detail-contact-item">
                                <MudIcon Icon="@Icons.Material.Filled.Warehouse" Size="Size.Small" Color="Color.Secondary" />
                                <MudText Typo="Typo.body2" Color="Color.Secondary">
                                    @Localization.GetString("Stock"): @_currentStock.Value.ToString("N2") @_product.Unit
                                    @if (!string.IsNullOrEmpty(_selectedWarehouseName))
                                    {
                                        <span class="ml-1">(@_selectedWarehouseName)</span>
                                    }
                                </MudText>
                            </div>
                        }
                        <div class="wis-detail-contact-item">
                            <MudIcon Icon="@Icons.Material.Filled.ArrowDownward" Size="Size.Small" Color="Color.Success" />
                            <MudText Typo="Typo.body2" Color="Color.Success">
                                @Localization.GetString("TotalIncoming"): @_totalIncoming.ToString("N2") @_product.Unit
                            </MudText>
                        </div>
                        <div class="wis-detail-contact-item">
                            <MudIcon Icon="@Icons.Material.Filled.ArrowUpward" Size="Size.Small" Color="Color.Error" />
                            <MudText Typo="Typo.body2" Color="Color.Error">
                                @Localization.GetString("TotalOutgoing"): @_totalOutgoing.ToString("N2") @_product.Unit
                            </MudText>
                        </div>
                    </div>

                    @* ── Tab toggle ── *@
                    <div class="d-flex gap-2 pt-2">
                        <button class="wis-pill-btn @(_activeTab == Tab.StockMovements ? "wis-pill-btn--active" : "")"
                                type="button"
                                @onclick="@(() => SetTab(Tab.StockMovements))">
                            @Localization.GetString("StockMovements")
                        </button>
                        <button class="wis-pill-btn @(_activeTab == Tab.DocumentHistory ? "wis-pill-btn--sold-active" : "")"
                                type="button"
                                @onclick="@(() => SetTab(Tab.DocumentHistory))">
                            @Localization.GetString("DocumentHistory")
                        </button>
                    </div>

                </MudCardContent>
            </MudCard>
        </MudItem>

        @* ── Stock Movements tab ── *@
        @if (_activeTab == Tab.StockMovements)
        {
            <MudItem xs="12">
                <MudCard Elevation="2">

                    @* Filter bar *@
                    <MudCardContent Class="pa-4" Style="border-bottom: 1px solid var(--mud-palette-divider);">
                        <div class="d-flex align-center flex-wrap gap-3">

                            @* Type filter — multi-select chips *@
                            <FilterPopoverList TValue="InventoryTransactionType"
                                               Label="@Localization.GetString("Type")"
                                               Items="_transactionTypeItems"
                                               Mode="FilterSelectionMode.Multiple"
                                               SelectedValues="_movementTypeFilter"
                                               FilterVariant="Variant.Outlined"
                                               SelectedValuesChanged="OnMovementTypeFilterChanged" />

                            @* Date range *@
                            <WisDateRangeFilter @ref="_movementDateRangeFilter"
                                                DateRange="_movementDateRange"
                                                DateRangeChanged="OnMovementDateRangeChanged"
                                                DatePreset="_movementDatePreset"
                                                DatePresetChanged="OnMovementDatePresetChanged"
                                                OnChanged="ReloadMovements" />

                            @* Partner filter *@
                            <WisAutocompleteFilter TValue="Guid"
                                                   Label="@Localization.GetString("AllPartners")"
                                                   AllLabel="@Localization.GetString("AllPartners")"
                                                   Icon="@Icons.Material.Filled.People"
                                                   LoadItems="LoadMovementPartnerItems"
                                                   SelectedValue="@(_movementPartnerId ?? default)"
                                                   SelectedValueChanged="@(async (Guid v) => await OnMovementPartnerChanged(v == default ? (Guid?)null : v))"
                                                   MinWidth="180px" />

                            @* Clear *@
                            @if (_movementTypeFilter.Count > 0 || _movementDateRange.Start != null || _movementDateRange.End != null || _movementPartnerId.HasValue)
                            {
                                <button type="button"
                                        class="wis-filter-btn wis-filter-btn--clear"
                                        @onclick="ClearMovementFilters">
                                    <MudIcon Icon="@Icons.Material.Filled.FilterAltOff" Size="Size.Small" Style="margin-right: 6px;" />
                                    @Localization.GetString("ClearFilters")
                                </button>
                            }

                            <MudSpacer />

                            <WisButton Action="@(new WisDetailActionItem
                            {
                                Icon = Icons.Material.Filled.Print,
                                Label = Localization.GetString("Export"),
                                Disabled = _exportingMovements,
                                OnClick = EventCallback.Factory.Create(this, ExportMovements)
                            })" />

                        </div>
                    </MudCardContent>

                    @* Table *@
                    <MudCardContent Class="pa-0">
                        <MudTable T="InventoryTransactionDto"
                                  @ref="_movementsTable"
                                  ServerData="LoadMovementsServerData"
                                  Hover="true"
                                  Elevation="0"
                                  Breakpoint="Breakpoint.Sm"
                                  Class="wis-secondary-list"
                                  RowClassFunc="GetMovementRowClass">
                            <HeaderContent>
                                <MudTh>@Localization.GetString("Date")</MudTh>
                                <MudTh>@Localization.GetString("Warehouse")</MudTh>
                                <MudTh Class="text-right">@Localization.GetString("Quantity")</MudTh>
                                <MudTh>@Localization.GetString("Type")</MudTh>
                                <MudTh>@Localization.GetString("Note")</MudTh>
                            </HeaderContent>
                            <RowTemplate>
                                <MudTd DataLabel="@Localization.GetString("Date")">
                                    <MudText Typo="Typo.body2"
                                             Color="Color.Default">
                                        @context.CreatedAt.ToString("dd MMM yyyy HH:mm")
                                    </MudText>
                                </MudTd>
                                <MudTd DataLabel="@Localization.GetString("Warehouse")">
                                    <MudText Typo="Typo.body2"
                                             Color="Color.Default">
                                        @context.WarehouseName
                                    </MudText>
                                </MudTd>
                                <MudTd DataLabel="@Localization.GetString("Quantity")" Class="text-right">
                                    <MudText Typo="Typo.body2"
                                             Color="@GetQuantityColor(context.Type, context.Quantity)">
                                        @GetQuantityText(context.Type, context.Quantity) @_product!.Unit
                                    </MudText>
                                </MudTd>
                                <MudTd DataLabel="@Localization.GetString("Type")">
                                    <MudChip T="string"
                                             Size="Size.Small"
                                             Color="@GetMovementTypeColor(context.Type)"
                                             Variant="Variant.Outlined"
                                             Icon="@GetMovementTypeIcon(context.Type)">
                                        @GetMovementTypeLabel(context.Type)
                                    </MudChip>
                                </MudTd>
                                <MudTd DataLabel="@Localization.GetString("Note")">
                                    <MudText Typo="Typo.body2" Color="Color.Secondary">
                                        @(string.IsNullOrEmpty(context.Note) ? "-" : context.Note)
                                    </MudText>
                                </MudTd>
                            </RowTemplate>
                            <NoRecordsContent>
                                <WisNoRecordsContent Icon="@Icons.Material.Filled.SwapVert"
                                                     Message="@Localization.GetString("NoRecentMovements")" />
                            </NoRecordsContent>
                            <PagerContent>
                                <WisPagerContent T="InventoryTransactionDto" Table="_movementsTable" PageSizeOptions="[25, 50, 100]" />
                            </PagerContent>
                        </MudTable>
                    </MudCardContent>

                </MudCard>
            </MudItem>
        }

        @* ── Document History tab ── *@
        @if (_activeTab == Tab.DocumentHistory)
        {
            <MudItem xs="12">
                <MudCard Elevation="2">

                    @* Header: Purchased / Sold toggle *@
                    <MudCardHeader>
                        <CardHeaderContent>
                            <div class="d-flex align-center gap-3">
                                <MudText Typo="Typo.h6">@Localization.GetString("DocumentHistory")</MudText>
                            </div>
                        </CardHeaderContent>
                        <CardHeaderActions>
                            <div class="d-flex gap-2 mr-4">
                                <button class="wis-pill-btn @(_historyMode == HistoryMode.Purchased ? "wis-pill-btn--active" : "")"
                                        type="button"
                                        @onclick="@(() => SetHistoryMode(HistoryMode.Purchased))">
                                    @Localization.GetString("Purchased")
                                </button>
                                <button class="wis-pill-btn @(_historyMode == HistoryMode.Sold ? "wis-pill-btn--sold-active" : "")"
                                        type="button"
                                        @onclick="@(() => SetHistoryMode(HistoryMode.Sold))">
                                    @Localization.GetString("Sold")
                                </button>
                            </div>
                        </CardHeaderActions>
                    </MudCardHeader>

                    @* Filter bar *@
                    <MudCardContent Class="pa-4" Style="border-bottom: 1px solid var(--mud-palette-divider);">
                        <div class="d-flex align-center flex-wrap gap-3">

                            <WisDateRangeFilter @ref="_historyDateRangeFilter"
                                                DateRange="_historyDateRange"
                                                DateRangeChanged="OnHistoryDateRangeChanged"
                                                DatePreset="_historyDatePreset"
                                                DatePresetChanged="OnHistoryDatePresetChanged"
                                                OnChanged="ReloadHistory" />

                            @if (_historyMode == HistoryMode.Purchased)
                            {
                                <WisAutocompleteFilter TValue="Guid"
                                                       Label="@Localization.GetString("AllVendors")"
                                                       AllLabel="@Localization.GetString("AllVendors")"
                                                       Icon="@Icons.Material.Filled.People"
                                                       LoadItems="LoadVendorItems"
                                                       SelectedValue="@(_historyVendorId ?? default)"
                                                       SelectedValueChanged="@(async (Guid v) => await OnHistoryVendorChanged(v == default ? (Guid?)null : v))"
                                                       MinWidth="180px" />
                            }
                            else
                            {
                                <WisAutocompleteFilter TValue="Guid"
                                                       Label="@Localization.GetString("AllClients")"
                                                       AllLabel="@Localization.GetString("AllClients")"
                                                       Icon="@Icons.Material.Filled.Business"
                                                       LoadItems="LoadClientItems"
                                                       SelectedValue="@(_historyClientId ?? default)"
                                                       SelectedValueChanged="@(async (Guid v) => await OnHistoryClientChanged(v == default ? (Guid?)null : v))"
                                                       MinWidth="180px" />
                            }

                            @if (_historyDateRange.Start != null || _historyDateRange.End != null || _historyVendorId.HasValue || _historyClientId.HasValue)
                            {
                                <button type="button"
                                        class="wis-filter-btn wis-filter-btn--clear"
                                        @onclick="ClearHistoryFilters">
                                    <MudIcon Icon="@Icons.Material.Filled.FilterAltOff" Size="Size.Small" Style="margin-right: 6px;" />
                                    @Localization.GetString("ClearFilters")
                                </button>
                            }

                            <div class="d-flex align-center gap-2 ml-auto">
                                <MudChip T="string" Size="Size.Small" Color="Color.Default"
                                         Icon="@Icons.Material.Filled.Scale">
                                    @_historyTotalQuantity.ToString("N2") @_product!.Unit
                                </MudChip>
                                <MudChip T="string" Size="Size.Small"
                                         Color="@(_historyMode == HistoryMode.Purchased ? Color.Info : Color.Success)"
                                         Icon="@Icons.Material.Filled.AttachMoney">
                                    @_historyTotalAmount.ToString("C")
                                </MudChip>
                            </div>

                        </div>
                    </MudCardContent>

                    @* Table *@
                    <MudCardContent Class="pa-0">
                        <MudTable T="ProductTransactionRowDto"
                                  @ref="_historyTable"
                                  ServerData="LoadHistoryServerData"
                                  Hover="true"
                                  Elevation="0"
                                  Breakpoint="Breakpoint.Sm"
                                  RowClass="table-row-clickable"
                                  Class="wis-secondary-list"
                                  OnRowClick="@((TableRowClickEventArgs<ProductTransactionRowDto> args) => Navigation.NavigateTo(args.Item!.DocumentUrl))">
                            <HeaderContent>
                                <MudTh>@Localization.GetString("DocumentNumber")</MudTh>
                                @if (_historyMode == HistoryMode.Purchased)
                                {
                                    <MudTh>@Localization.GetString("Type")</MudTh>
                                }
                                <MudTh>@(_historyMode == HistoryMode.Purchased ? Localization.GetString("Vendor") : Localization.GetString("Client"))</MudTh>
                                <MudTh>@Localization.GetString("Warehouse")</MudTh>
                                <MudTh>@Localization.GetString("Date")</MudTh>
                                <MudTh Class="text-right">@Localization.GetString("Quantity")</MudTh>
                                <MudTh Class="text-right">@Localization.GetString("UnitPrice")</MudTh>
                                <MudTh Class="text-right">@Localization.GetString("Total")</MudTh>
                            </HeaderContent>
                            <RowTemplate>
                                <MudTd DataLabel="@Localization.GetString("DocumentNumber")">
                                    <MudText Typo="Typo.body2" Class="font-weight-medium">@context.DocumentNumber</MudText>
                                </MudTd>
                                @if (_historyMode == HistoryMode.Purchased)
                                {
                                    <MudTd DataLabel="@Localization.GetString("Type")">
                                        <MudChip T="string" Size="Size.Small"
                                                 Color="@(context.DocumentType == "PurchaseNote" ? Color.Info : Color.Default)">
                                            @Localization.GetString(context.DocumentType!)
                                        </MudChip>
                                    </MudTd>
                                }
                                <MudTd DataLabel="@(_historyMode == HistoryMode.Purchased ? Localization.GetString("Vendor") : Localization.GetString("Client"))">
                                    <MudText Typo="Typo.body2" Color="Color.Secondary">@context.PartyName</MudText>
                                </MudTd>
                                <MudTd DataLabel="@Localization.GetString("Warehouse")">
                                    <MudText Typo="Typo.body2" Color="Color.Secondary">@context.WarehouseName</MudText>
                                </MudTd>
                                <MudTd DataLabel="@Localization.GetString("Date")">
                                    <MudText Typo="Typo.body2">@context.Date.ToString("dd MMM yyyy")</MudText>
                                </MudTd>
                                <MudTd DataLabel="@Localization.GetString("Quantity")" Class="text-right">
                                    <MudText Typo="Typo.body2">@context.Quantity.ToString("N2") @_product!.Unit</MudText>
                                </MudTd>
                                <MudTd DataLabel="@Localization.GetString("UnitPrice")" Class="text-right">
                                    <MudText Typo="Typo.body2">@context.UnitPrice.ToString("C")</MudText>
                                </MudTd>
                                <MudTd DataLabel="@Localization.GetString("Total")" Class="text-right">
                                    <MudText Typo="Typo.body2"
                                             Color="@(_historyMode == HistoryMode.Purchased ? Color.Info : Color.Success)">
                                        @context.TotalPrice.ToString("C")
                                    </MudText>
                                </MudTd>
                            </RowTemplate>
                            <NoRecordsContent>
                                <WisNoRecordsContent Icon="@(_historyMode == HistoryMode.Purchased ? Icons.Material.Filled.ShoppingCart : Icons.Material.Filled.PointOfSale)"
                                                     Message="@(_historyMode == HistoryMode.Purchased ? Localization.GetString("NoPurchaseData") : Localization.GetString("NoSalesData"))" />
                            </NoRecordsContent>
                            <PagerContent>
                                <WisPagerContent T="ProductTransactionRowDto" Table="_historyTable" PageSizeOptions="[10, 25, 50]" />
                            </PagerContent>
                        </MudTable>
                    </MudCardContent>

                </MudCard>
            </MudItem>
        }

    </MudGrid>
}

@code {
    [Parameter] public Guid Id { get; set; }

    [SupplyParameterFromQuery(Name = "warehouse")]
    public Guid? WarehouseQueryParam { get; set; }

    private enum Tab { StockMovements, DocumentHistory }

    private ProductDto? _product;
    private ProductDetailsDto _details = new();
    private Guid? _selectedWarehouseId;
    private Tab _activeTab = Tab.StockMovements;
    private decimal _totalIncoming;
    private decimal _totalOutgoing;

    // ── Table refs ────────────────────────────────────────────────────────────

    private MudTable<InventoryTransactionDto>? _movementsTable;
    private MudTable<ProductTransactionRowDto>? _historyTable;

    // ── Warehouse autocomplete data source ────────────────────────────────────

    private async Task<PagedResult<WisAutocompleteItem<Guid>>> LoadWarehouseItems(
        string search, int page, CancellationToken ct)
    {
        PagedResult<WarehouseDto> result = await WarehouseService.GetPagedAsync(
            new GetWarehousesQuery
            {
                Search = search,
                Page = page,
                PageSize = 10,
                SortBy = "Name",
                SortAscending = true
            }, ct);

        return new PagedResult<WisAutocompleteItem<Guid>>
        {
            Items = result.Items.Select(w => new WisAutocompleteItem<Guid>
            {
                Label = w.Name + (w.IsDefault ? $" ({Localization.GetString("Default")})" : ""),
                Value = w.Id
            }).ToList(),
            TotalCount = result.TotalCount,
            Page = result.Page,
            PageSize = result.PageSize
        };
    }

    // ── Computed stock summary (from _details, always in memory — bounded set) ─

    private string _selectedWarehouseName => _selectedWarehouseId.HasValue
        ? _details.StockByWarehouse.FirstOrDefault(s => s.WarehouseId == _selectedWarehouseId.Value)?.WarehouseName ?? ""
        : "";

    private decimal? _currentStock => _selectedWarehouseId.HasValue
        ? _details.StockByWarehouse.Where(s => s.WarehouseId == _selectedWarehouseId.Value).Sum(s => s.Quantity)
        : _details.TotalStockAcrossWarehouses;

    // ── Lifecycle ─────────────────────────────────────────────────────────────

    protected override async Task OnInitializedAsync()
    {
        await base.OnInitializedAsync();
        await LoadAsync();
    }

    protected override async Task OnParametersSetAsync()
    {
        if (WarehouseQueryParam.HasValue && _selectedWarehouseId == null)
            _selectedWarehouseId = WarehouseQueryParam;
    }

    private async Task LoadAsync() =>
        await SafeLoadAsync(async () =>
        {
            _product = await ProductService.GetProductByIdAsync(Id, CancellationToken.None);
            // GetProductDetailsAsync is used only for the stock summary header —
            // document history and movements are loaded by the tables via ServerData.
            _details = await ProductService.GetProductDetailsAsync(Id, CancellationToken.None);

            if (_product != null && WarehouseQueryParam.HasValue)
                _selectedWarehouseId = WarehouseQueryParam;

            await ComputeMovementTotalsAsync();
        }, "ErrorLoadingProduct");

    // ── Interactions ──────────────────────────────────────────────────────────

    private async Task OnWarehouseChanged(Guid? warehouseId)
    {
        _selectedWarehouseId = warehouseId;
        await ComputeMovementTotalsAsync();
        // Reload both tables — warehouse is a server-side filter
        if (_movementsTable is not null)
            await _movementsTable.ReloadServerData();
        if (_historyTable is not null)
            await _historyTable.ReloadServerData();
    }

    private async Task ComputeMovementTotalsAsync()
    {
        IEnumerable<InventoryTransactionDto> transactions = await InventoryService.GetAllFilteredTransactionsAsync(
            new GetInventoryTransactionsQuery { ProductId = Id, WarehouseId = _selectedWarehouseId },
            CancellationToken.None);

        var list = transactions.ToList();
        _totalIncoming = list
            .Where(t => t.Type is InventoryTransactionType.Inbound or InventoryTransactionType.TransferIn
                || (t.Type is InventoryTransactionType.Adjustment or InventoryTransactionType.Reversed && t.Quantity > 0))
            .Sum(t => t.Quantity);
        _totalOutgoing = list
            .Where(t => t.Type is InventoryTransactionType.Outbound or InventoryTransactionType.TransferOut
                || (t.Type is InventoryTransactionType.Adjustment or InventoryTransactionType.Reversed && t.Quantity < 0))
            .Sum(t => Math.Abs(t.Quantity));
    }

    private void SetTab(Tab tab)
    {
        _activeTab = tab;
        StateHasChanged();
    }

    // ── Stock Movements ───────────────────────────────────────────────────────

    private IReadOnlyCollection<InventoryTransactionType> _movementTypeFilter = [];
    private DateRange _movementDateRange = new(null, null);
    private int? _movementDatePreset = null;
    private WisDateRangeFilter? _movementDateRangeFilter;
    private bool _exportingMovements = false;
    private Guid? _movementPartnerId;
    private readonly Dictionary<Guid, bool> _movementPartnerTypeMap = new(); // true = individual

    private List<FilterPopoverItem<InventoryTransactionType>> _transactionTypeItems =>
    [
        new() { Label = Localization.GetString("Inbound"),     Value = InventoryTransactionType.Inbound,     Color = Color.Success,  Icon = Icons.Material.Filled.ArrowDownward },
        new() { Label = Localization.GetString("Outbound"),    Value = InventoryTransactionType.Outbound,    Color = Color.Error,    Icon = Icons.Material.Filled.ArrowUpward },
        new() { Label = Localization.GetString("Adjustment"),  Value = InventoryTransactionType.Adjustment,  Color = Color.Info,     Icon = Icons.Material.Filled.Tune },
        new() { Label = Localization.GetString("TransferIn"),  Value = InventoryTransactionType.TransferIn,  Color = Color.Tertiary, Icon = Icons.Material.Filled.CallMade },
        new() { Label = Localization.GetString("TransferOut"), Value = InventoryTransactionType.TransferOut, Color = Color.Warning,  Icon = Icons.Material.Filled.CallReceived },
        new() { Label = Localization.GetString("Reversed"),    Value = InventoryTransactionType.Reversed,    Color = Color.Dark,     Icon = Icons.Material.Filled.Undo },
    ];

    private async Task<TableData<InventoryTransactionDto>> LoadMovementsServerData(TableState state, CancellationToken ct)
    {
        bool partnerIsIndividual = _movementPartnerId.HasValue
            && _movementPartnerTypeMap.TryGetValue(_movementPartnerId.Value, out bool isInd) && isInd;

        PagedResult<InventoryTransactionDto> result = await InventoryService.GetPagedTransactionsByProductAsync(
            new GetInventoryTransactionsQuery
            {
                ProductId = Id,
                WarehouseId = _selectedWarehouseId,
                Types = _movementTypeFilter.Count > 0 ? [.. _movementTypeFilter] : null,
                DateFrom = _movementDateRange.Start,
                DateTo = _movementDateRange.End,
                CompanyId = _movementPartnerId.HasValue && !partnerIsIndividual ? _movementPartnerId : null,
                IndividualId = _movementPartnerId.HasValue && partnerIsIndividual ? _movementPartnerId : null,
                Page = state.Page + 1,
                PageSize = state.PageSize
            }, ct);

        return new TableData<InventoryTransactionDto>
        {
            Items = result.Items,
            TotalItems = result.TotalCount
        };
    }

    private async Task OnMovementTypeFilterChanged(IReadOnlyCollection<InventoryTransactionType> values)
    {
        _movementTypeFilter = values;
        if (_movementsTable is not null)
            await _movementsTable.ReloadServerData();
    }

    private Task OnMovementDatePresetChanged(int? days)
    {
        _movementDatePreset = days;
        return Task.CompletedTask;
    }

    private Task OnMovementDateRangeChanged(DateRange range)
    {
        _movementDateRange = range;
        return Task.CompletedTask;
    }

    private async Task ReloadMovements()
    {
        if (_movementsTable is not null)
            await _movementsTable.ReloadServerData();
    }

    private async Task ClearMovementFilters()
    {
        _movementTypeFilter = [];
