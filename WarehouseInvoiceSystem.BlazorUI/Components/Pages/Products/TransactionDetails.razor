    // ── Stock Movement helpers ────────────────────────────────────────────────

    private static string GetMovementRowClass(InventoryTransactionDto dto, int _) => dto.Type switch
    {
        InventoryTransactionType.Inbound => "row-status-success",
        InventoryTransactionType.TransferIn => "row-status-tertiary",
        InventoryTransactionType.Outbound => "row-status-error",
        InventoryTransactionType.TransferOut => "row-status-warning",
        InventoryTransactionType.Adjustment => "row-status-info",
        InventoryTransactionType.Reversed => "row-status-dark",
        _ => ""
    };

    private async Task ExportMovements()
    {
        _exportingMovements = true;
        StateHasChanged();

        try
        {
            List<InventoryTransactionDto> transactions = [.. await InventoryService.GetAllFilteredTransactionsAsync(
                new GetInventoryTransactionsQuery
                {
                    ProductId = Id,
                    WarehouseId = _selectedWarehouseId,
                    Types = _movementTypeFilter.Count > 0 ? [.. _movementTypeFilter] : null,
                    DateFrom = _movementDateRange.Start,
                    DateTo = _movementDateRange.End,
                }, CancellationToken.None)];

            decimal totalIncoming = transactions
                .Where(t => t.Type is InventoryTransactionType.Inbound or InventoryTransactionType.TransferIn
                    || (t.Type is InventoryTransactionType.Adjustment or InventoryTransactionType.Reversed && t.Quantity > 0))
                .Sum(t => t.Quantity);

            decimal totalOutgoing = transactions
                .Where(t => t.Type is InventoryTransactionType.Outbound or InventoryTransactionType.TransferOut
                    || (t.Type is InventoryTransactionType.Adjustment or InventoryTransactionType.Reversed && t.Quantity < 0))
                .Sum(t => Math.Abs(t.Quantity));

            string unit = _product!.Unit;

            byte[] fileBytes = await ExcelExportService.ExportListToExcelAsync(
                transactions,
                ExportColumnDefinitions.TransactionColumns(Localization, unit),
                new ExportListOptions(
                    Localization.GetString("StockMovements"),
                    $"{Localization.GetString("StockMovementsFor")} {_product.Name}",
                    [
                        $"{Localization.GetString("TotalIncoming")}: +{totalIncoming:N2} {unit}",
                        $"{Localization.GetString("TotalOutgoing")}: -{totalOutgoing:N2} {unit}",
                        $"{Localization.GetString("CurrentStock")}: {_currentStock?.ToString("N2") ?? "0.00"} {unit}",
                    ]));

            string fileName = $"{Localization.GetString("StockMovements")}_{_product.Name}_{DateTime.UtcNow:yyyyMMdd}.xlsx";
            await DownloadFileAsync(fileBytes, fileName);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error exporting movements: {ex.Message}");
            Snackbar.Add(Localization.GetString("ExportError"), Severity.Error);
        }
        finally
        {
            _exportingMovements = false;
            StateHasChanged();
        }
    }

