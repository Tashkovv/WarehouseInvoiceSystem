    private async Task<TableData<ProductTransactionRowDto>> LoadHistoryServerData(TableState state, CancellationToken ct)
    {
        bool vendorIsIndividual = _historyVendorId.HasValue
            && _vendorTypeMap.TryGetValue(_historyVendorId.Value, out bool isInd) && isInd;

        GetProductHistoryQuery query = new()
        {
            ProductId = Id,
            WarehouseId = _selectedWarehouseId,
            Purchased = _historyMode == HistoryMode.Purchased,
            CompanyId = _historyMode == HistoryMode.Sold
                ? _historyClientId
                : (_historyVendorId.HasValue && !vendorIsIndividual ? _historyVendorId : null),
            IndividualId = _historyMode == HistoryMode.Purchased && vendorIsIndividual
                ? _historyVendorId
                : null,
            DateFrom = _historyDateRange.Start,
            DateTo = _historyDateRange.End,
            Page = state.Page + 1,
            PageSize = state.PageSize
        };

        PagedResult<ProductTransactionRowDto> result = await ProductService.GetPagedProductHistoryAsync(query, ct);

        var totals = await ProductService.GetProductHistoryTotalsAsync(query, ct);
        _historyTotalQuantity = totals.TotalQuantity;
        _historyTotalAmount = totals.TotalAmount;
        await InvokeAsync(StateHasChanged);

        return new TableData<ProductTransactionRowDto>
        {
            Items = result.Items,
            TotalItems = result.TotalCount
        };
    }

    private async Task SetHistoryMode(HistoryMode mode)
    {
        if (_historyMode == mode) return;
        _historyMode = mode;
        _historyVendorId = null;
        _historyClientId = null;
        if (_historyTable is not null)
            await _historyTable.ReloadServerData();
    }

