@page "/products/create"
@using WarehouseInvoiceSystem.Application.Interfaces
@using WarehouseInvoiceSystem.Application.DTOs.Product
@inject IProductService ProductService
@inject ILocalizationService Localization
@inject NavigationManager Navigation
@inject ISnackbar Snackbar

<PageTitle>@Localization.GetString("CreateProduct") - @Localization.GetString("WarehouseInvoiceSystem")</PageTitle>

<MudText Typo="Typo.h4" Class="mb-6">@Localization.GetString("CreateProduct")</MudText>

<MudCard Elevation="2" Class="mb-4">
    <MudCardContent>
        <MudForm @ref="_form" @bind-IsValid="@_isValid">
            <MudGrid>
                <MudItem xs="12" md="6">
                    <MudTextField @bind-Value="_model.Code"
                                  Label="@Localization.GetString("ProductCode")"
                                  Required="true"
                                  Variant="Variant.Outlined"
                                  RequiredError="@Localization.GetString("CodeRequired")"
                                  MaxLength="50" />
                </MudItem>

                <MudItem xs="12" md="6">
                    <MudTextField @bind-Value="_model.Name"
                                  Label="@Localization.GetString("ProductName")"
                                  Required="true"
                                  Variant="Variant.Outlined"
                                  RequiredError="@Localization.GetString("NameRequired")"
                                  MaxLength="100" />
                </MudItem>

                <MudItem xs="12">
                    <MudTextField @bind-Value="_model.Description"
                                  Label="@Localization.GetString("Description")"
                                  Lines="3"
                                  Variant="Variant.Outlined"
                                  MaxLength="500" />
                </MudItem>

                <MudItem xs="12" md="6">
                    <MudTextField @bind-Value="_model.Unit"
                                  Label="@Localization.GetString("Unit")"
                                  HelperText="@Localization.GetString("UnitHelper")"
                                  Required="true"
                                  Variant="Variant.Outlined"
                                  RequiredError="@Localization.GetString("UnitRequired")"
                                  MaxLength="10" />
                </MudItem>

                <MudItem xs="12" md="6">
                    <MudNumericField @bind-Value="_model.DefaultPrice"
                                     Label="@Localization.GetString("DefaultPrice")"
                                     Min="0m"
                                     Required="true"
                                     Variant="Variant.Outlined"
                                     RequiredError="@Localization.GetString("PriceRequired")"
                                     Format="N2"
                                     TextUpdateSuppression="false"
                                     Adornment="Adornment.Start"
                                     AdornmentText="MKD" />
                </MudItem>

                <MudItem xs="12">
                    <MudSwitch @bind-Value="_model.IsActive"
                               Label="@Localization.GetString("ProductActive")"
                               Color="Color.Success" />
                </MudItem>
            </MudGrid>
        </MudForm>
    </MudCardContent>
</MudCard>
<!-- Actions -->
<MudItem xs="12">
    <div class="d-flex justify-end gap-2">
        <MudButton Variant="Variant.Filled"
                   Color="Color.Primary"
                   OnClick="SaveProduct"
                   Disabled="@(!_isValid || _saving)">
            @if (_saving)
            {
                <MudProgressCircular Class="ms-n1" Size="Size.Small" Indeterminate="true" />
                <MudText Class="ms-2">@Localization.GetString("Saving")</MudText>
            }
            else
            {
                @Localization.GetString("Save")
            }
        </MudButton>
        <MudButton Variant="Variant.Outlined"
                   OnClick="Cancel"
                   Disabled="@_saving">
            @Localization.GetString("Cancel")
        </MudButton>
    </div>
</MudItem>

@code {
    private MudForm _form = null!;
    private bool _isValid;
    private bool _saving;
    private CreateProductDto _model = new() { IsActive = true };

    private async Task SaveProduct()
    {
        await _form.Validate();
        if (!_isValid) return;

        _saving = true;

        try
        {
            await ProductService.CreateProductAsync(_model);
            Snackbar.Add(Localization.GetString("ProductCreated"), Severity.Success);
            Navigation.NavigateTo("/products");
        }
        catch (InvalidOperationException ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error creating product: {ex.Message}");
            Snackbar.Add(Localization.GetString("ErrorCreatingProduct"), Severity.Error);
        }
        finally
        {
            _saving = false;
        }
    }

    private void Cancel()
    {
        Navigation.NavigateTo("/products");
    }
}