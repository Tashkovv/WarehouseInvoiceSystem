@page "/products"
@attribute [Authorize]
@inherits PageBase
@using WarehouseInvoiceSystem.Application.DTOs.Product
@using WarehouseInvoiceSystem.Domain.Queries
@using WarehouseInvoiceSystem.Domain.Queries.Common
@inject IProductService ProductService

<PageTitle>@Localization.GetString("Products") - @Localization.GetString("InvoiceSystem")</PageTitle>

<div class="wis-page-header">
    <MudText Typo="Typo.h3" Class="wis-page-title">
        @Localization.GetString("Products")
    </MudText>
</div>

<WisGridToolbar CreateAction="OpenCreateDialog"
                CreateLabel="@Localization.GetString("Product")"
                CreateActions="_toolbarActions"
                SearchValue="@_searchString"
                SearchValueChanged="OnSearch"
                HasAnyActiveFilter="@(_filterIsActive.HasValue)"
                OnClearAll="ClearAllFilters">
    <Filters>
        <FilterPopoverList TValue="bool?"
                           Label="@Localization.GetString("Status")"
                           Items="_statusFilterItems"
                           Mode="FilterSelectionMode.Single"
                           SelectedValue="_filterIsActive"
                           FilterVariant="Variant.Outlined"
                           SelectedValueChanged="OnStatusFilterChanged" />
    </Filters>
</WisGridToolbar>

<MudCard Elevation="2" Class="mb-4">
    <MudCardContent Class="pa-0">
        <MudDataGrid T="ProductDto"
                     @ref="_grid"
                     ServerData="LoadServerData"
                     RowClick="OnRowClick"
                     RowClassFunc="GetRowClass"
                     ReadOnly="true"
                     Hover="true"
                     FixedHeader="true"
                     Height="100%"
                     Filterable="false"
                     ShowColumnOptions="false"
                     ColumnResizeMode="ResizeMode.Column"
                     SortMode="SortMode.Single"
                     Class="wis-data-grid">
            <Columns>

                <TemplateColumn Sortable="false"
                                Filterable="false"
                                HeaderClass="wis-col-actions-1"
                                CellClass="wis-col-actions-1">
                    <CellTemplate>
                        <MudStack Row="true" Justify="Justify.Center" AlignItems="AlignItems.Center">
                            <WisSplitButton Actions="@BuildRowActions(context.Item)"
                                            AnchorOrigin="Origin.BottomLeft"
                                            TransformOrigin="Origin.TopLeft"
                                            HideLabel="true" />
                        </MudStack>
                    </CellTemplate>
                </TemplateColumn>

                <PropertyColumn Property="x => x.Code"
                                Title="@Localization.GetString("Code")"
                                Sortable="true"
                                CellClass="wis-cell-mono-medium" />

                <PropertyColumn Property="x => x.Name"
                                Title="@Localization.GetString("Name")"
                                Sortable="true"
                                CellClass="wis-cell-primary" />

                <PropertyColumn Property="x => x.Description"
                                Title="@Localization.GetString("Description")"
                                Sortable="false"
                                />

                <PropertyColumn Property="x => x.Unit"
                                Title="@Localization.GetString("Unit")"
                                Sortable="false"
                                />

                <PropertyColumn Property="x => x.CostPrice"
                                Title="@Localization.GetString("CostPrice")"
                                Sortable="true"
                                HeaderClass="text-right"
                                CellClass="text-right"
>
                    <CellTemplate>
                        <MudText Typo="Typo.body2" Class="wis-cell-amount">
                            @context.Item.CostPrice.ToString("C")
                        </MudText>
                    </CellTemplate>
                </PropertyColumn>

                <PropertyColumn Property="x => x.SellingPrice"
                                Title="@Localization.GetString("SellingPrice")"
                                Sortable="true"
                                HeaderClass="text-right"
                                CellClass="text-right"
>
                    <CellTemplate>
                        <MudText Typo="Typo.body2" Class="wis-cell-amount">
                            @context.Item.SellingPrice.ToString("C")
                        </MudText>
                    </CellTemplate>
                </PropertyColumn>

                <PropertyColumn Property="x => x.IsActive"
                                Title="@Localization.GetString("Status")"
                                Sortable="false"
>
                    <CellTemplate>
                        <MudChip T="string"
                                 Size="Size.Small"
                                 Variant="Variant.Outlined"
                                 Color="@(context.Item.IsActive ? Color.Success : Color.Default)">
                            @(context.Item.IsActive ? Localization.GetString("ProductActive")
                                                    : Localization.GetString("ProductInactive"))
                        </MudChip>
                    </CellTemplate>
                </PropertyColumn>

            </Columns>

            <NoRecordsContent>
                <WisNoRecordsContent Icon="@Icons.Material.Filled.Inventory2"
                                     Message="@Localization.GetString("NoProductsFound")" />
            </NoRecordsContent>

            <LoadingContent>
                <WisLoadingContent />
            </LoadingContent>

            <PagerContent>
                <WisPagerContent T="ProductDto" />
            </PagerContent>

        </MudDataGrid>
    </MudCardContent>
</MudCard>

@code {
    private MudDataGrid<ProductDto> _grid = null!;
    private string _searchString = string.Empty;
    private bool? _filterIsActive = null;

    private List<FilterPopoverItem<bool?>> _statusFilterItems = [];
    private List<WisDetailActionItem> _toolbarActions = [];

    protected override void OnInitialized()
    {
        base.OnInitialized();
        BuildFilterItems();
        BuildToolbarActions();
    }

    private void BuildToolbarActions()
    {
        _toolbarActions =
        [
            new WisDetailActionItem
            {
                Icon = Icons.Material.Filled.CompareArrows,
                Label = Localization.GetString("CompareProducts"),
                OnClick = EventCallback.Factory.Create(this, () => Navigation.NavigateTo("/products/compare"))
            }
        ];
    }

    private void BuildFilterItems()
    {
        _statusFilterItems =
        [
            new() { Label = Localization.GetString("All"),              Value = null,  Color = Color.Info },
            new() { Label = Localization.GetString("ActiveProducts"),   Value = true,  Color = Color.Success },
            new() { Label = Localization.GetString("InactiveProducts"), Value = false, Color = Color.Default }
        ];
    }

    protected override async void OnLanguageChanged()
    {
        BuildFilterItems();
        await InvokeAsync(StateHasChanged);
    }

    private async Task<GridData<ProductDto>> LoadServerData(GridState<ProductDto> state, CancellationToken ct)
    {
        string? sortBy = state.SortDefinitions.FirstOrDefault()?.SortBy;
        bool ascending = state.SortDefinitions.FirstOrDefault()?.Descending == false;

        GetProductsQuery query = new()
        {
            Page = state.Page + 1,
            PageSize = state.PageSize,
            SortBy = sortBy,
            SortAscending = ascending,
            Search = _searchString,
            IsActive = _filterIsActive
        };

        PagedResult<ProductDto> result = await ProductService.GetPagedAsync(query, ct);

        return new GridData<ProductDto>
        {
            Items = result.Items,
            TotalItems = result.TotalCount
        };
    }

    private string GetRowClass(ProductDto item, int index) =>
        item.IsActive ? "row-status-success" : "row-status-default";

    private async Task OnSearch(string text)
    {
        _searchString = text;
        await _grid.ReloadServerData();
    }

    private async Task OnStatusFilterChanged(bool? value)
    {
        _filterIsActive = value;
        await _grid.ReloadServerData();
    }

    private async void OnRowClick(DataGridRowClickEventArgs<ProductDto> args)
    {
        if (args.MouseEventArgs.Detail == 2)
            Navigation.NavigateTo($"/products/{args.Item.Id}");
    }

    private async Task OpenCreateDialog()
    {
        if (await WisDialog.ShowFormAsync<ProductDialog, bool>(
                Localization.GetString("CreateProduct"), MaxWidth.Small) == true)
            await _grid.ReloadServerData();
    }

    private async Task OpenEditDialog(ProductDto product)
    {
        if (await WisDialog.ShowFormAsync<ProductDialog, bool>(
                Localization.GetString("EditProduct"),
                p => p.Add(x => x.Product, product),
                MaxWidth.Small) == true)
            await _grid.ReloadServerData();
    }

    private async Task ClearAllFilters()
    {
        _filterIsActive = null;
        await _grid.ReloadServerData();
    }

    private List<WisDetailActionItem> BuildRowActions(ProductDto item) =>
    [
        new WisDetailActionItem
        {
            Icon    = Icons.Material.Filled.Edit,
            Label   = Localization.GetString("Edit"),
            OnClick = EventCallback.Factory.Create(this, () => OpenEditDialog(item))
        },
        new WisDetailActionItem
        {
            Icon    = Icons.Material.Filled.CompareArrows,
            Label   = Localization.GetString("Compare"),
            OnClick = EventCallback.Factory.Create(this, () => Navigation.NavigateTo($"/products/{item.Id}/compare"))
        },
        new WisDetailActionItem
        {
            Icon            = Icons.Material.Filled.PowerSettingsNew,
            Label           = item.IsActive ? Localization.GetString("Deactivate") : Localization.GetString("Activate"),
            Color           = item.IsActive ? Color.Warning : Color.Success,
            IsDividerBefore = true,
            OnClick         = EventCallback.Factory.Create(this, () => SetActiveStatus(item, !item.IsActive))
        },
    ];

    private async Task SetActiveStatus(ProductDto item, bool isActive)
    {
        if (!isActive)
        {
            bool confirmed = await WisDialog.ConfirmAsync(
                Localization.GetString("DeactivateProduct"),
                Localization.GetString("DeactivateProductConfirm"),
                Localization.GetString("Deactivate"),
                Localization.GetString("Cancel"));
            if (!confirmed) return;
        }

        try
        {
            await ProductService.SetActiveStatusAsync(item.Id, isActive);
            string key = isActive ? "ProductActivated" : "ProductDeactivated";
            Snackbar.Add(Localization.GetString(key), Severity.Success);
            await _grid.ReloadServerData();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error updating product status: {ex.Message}");
            Snackbar.Add(Localization.GetString("ErrorUpdatingProduct"), Severity.Error);
        }
    }

}
