@page "/products"
@implements IDisposable
@using WarehouseInvoiceSystem.Application.Interfaces
@using WarehouseInvoiceSystem.Application.DTOs.Product
@using WarehouseInvoiceSystem.Domain.Queries
@using WarehouseInvoiceSystem.Domain.Queries.Common
@inject IProductService ProductService
@inject ILocalizationService Localization
@inject NavigationManager Navigation
@inject IDialogService DialogService
@inject ISnackbar Snackbar

<PageTitle>@Localization.GetString("Products") - @Localization.GetString("InvoiceSystem")</PageTitle>

<div style="margin-bottom: 24px; padding: 4px 0;">
    <MudText Typo="Typo.h3" Class="wis-page-title">
        @Localization.GetString("Products")
    </MudText>
</div>

<WisGridToolbar CreateAction="OpenCreateDialog"
                CreateLabel="@Localization.GetString("CreateProduct")"
                SearchValue="@_searchString"
                SearchValueChanged="OnSearch"
                HasAnyActiveFilter="@(_filterIsActive.HasValue)"
                OnClearAll="ClearAllFilters">
    <Filters>
        <FilterPopoverList TValue="bool?"
                           Title="@Localization.GetString("FilterByStatus")"
                           Label="@Localization.GetString("Status")"
                           Items="_statusFilterItems"
                           Mode="FilterSelectionMode.Single"
                           SelectedValue="_filterIsActive"
                           SelectedValueChanged="OnStatusFilterChanged" />
    </Filters>
</WisGridToolbar>

<MudCard Elevation="2" Class="mb-4">
    <MudCardContent Class="pa-0">
        <MudDataGrid T="ProductDto"
                     @ref="_grid"
                     ServerData="LoadServerData"
                     RowClick="OnRowClick"
                     RowClassFunc="GetRowClass"
                     ReadOnly="true"
                     Hover="true"
                     FixedHeader="true"
                     Height="710px"
                     Filterable="false"
                     ShowColumnOptions="false"
                     ColumnResizeMode="ResizeMode.Column"
                     SortMode="SortMode.Single"
                     Class="wis-data-grid">
            <Columns>

                <PropertyColumn Property="x => x.Code"
                                Title="@Localization.GetString("Code")"
                                Sortable="true"
                                IsEditable="false"
                                CellStyle="font-family: monospace; font-weight: 500;" />

                <PropertyColumn Property="x => x.Name"
                                Title="@Localization.GetString("Name")"
                                Sortable="true"
                                IsEditable="false"
                                CellStyle="font-weight: 600;" />

                <PropertyColumn Property="x => x.Description"
                                Title="@Localization.GetString("Description")"
                                Sortable="false"
                                IsEditable="false" />

                <PropertyColumn Property="x => x.Unit"
                                Title="@Localization.GetString("Unit")"
                                Sortable="false"
                                IsEditable="false" />

                <PropertyColumn Property="x => x.DefaultPrice"
                                Title="@Localization.GetString("Price")"
                                Sortable="true"
                                IsEditable="false">
                    <CellTemplate>
                        <MudText Typo="Typo.body2" Style="font-weight: 600;">
                            @context.Item.DefaultPrice.ToString("C")
                        </MudText>
                    </CellTemplate>
                </PropertyColumn>

                <PropertyColumn Property="x => x.IsActive"
                                Title="@Localization.GetString("Status")"
                                Sortable="false"
                                IsEditable="false">
                    <CellTemplate>
                        <MudChip T="string"
                                 Size="Size.Small"
                                 Color="@(context.Item.IsActive ? Color.Success : Color.Default)">
                            @(context.Item.IsActive ? Localization.GetString("ProductActive")
                                                        : Localization.GetString("ProductInactive"))
                        </MudChip>
                    </CellTemplate>
                </PropertyColumn>

                <TemplateColumn Sortable="false"
                                Filterable="false"
                                IsEditable="false"
                                MinWidth="90"
                                HeaderStyle="width: 90px;"
                                CellStyle="width: 90px;">
                    <CellTemplate>
                        <MudStack Row="true" Spacing="0">
                            <MudIconButton Icon="@Icons.Material.Filled.Edit"
                                           Size="Size.Small"
                                           Color="Color.Primary"
                                           Title="@Localization.GetString("Edit")"
                                           OnClick="@(() => OpenEditDialog(context.Item))" />
                            <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                           Size="Size.Small"
                                           Color="Color.Error"
                                           Title="@Localization.GetString("Delete")"
                                           OnClick="@(() => DeleteProduct(context.Item.Id))" />
                        </MudStack>
                    </CellTemplate>
                </TemplateColumn>

            </Columns>

            <NoRecordsContent>
                <div class="pa-8 d-flex flex-column align-center">
                    <MudIcon Icon="@Icons.Material.Filled.Inventory2"
                             Size="Size.Large"
                             Color="Color.Secondary"
                             Class="mb-2" />
                    <MudText Color="Color.Secondary">
                        @Localization.GetString("NoProductsFound")
                    </MudText>
                </div>
            </NoRecordsContent>

            <LoadingContent>
                <div class="pa-6">
                    <MudProgressLinear Color="Color.Primary" Indeterminate="true" />
                </div>
            </LoadingContent>

            <PagerContent>
                <WisPagerContent T="ProductDto" />
            </PagerContent>

        </MudDataGrid>
    </MudCardContent>
</MudCard>

@code {
    private MudDataGrid<ProductDto> _grid = null!;
    private string _searchString = string.Empty;
    private bool? _filterIsActive = null;

    private List<FilterPopoverItem<bool?>> _statusFilterItems = [];

    protected override void OnInitialized()
    {
        Localization.OnLanguageChanged += OnLanguageChanged;
        BuildFilterItems();
    }

    private void BuildFilterItems()
    {
        _statusFilterItems =
        [
            new() { Label = Localization.GetString("All"),              Value = null,  Color = Color.Info },
            new() { Label = Localization.GetString("ActiveProducts"),   Value = true,  Color = Color.Success },
            new() { Label = Localization.GetString("InactiveProducts"), Value = false, Color = Color.Default }
        ];
    }

    private async void OnLanguageChanged()
    {
        BuildFilterItems();
        await InvokeAsync(StateHasChanged);
    }

    private async Task<GridData<ProductDto>> LoadServerData(GridState<ProductDto> state, CancellationToken ct)
    {
        string? sortBy = state.SortDefinitions.FirstOrDefault()?.SortBy;
        bool ascending = state.SortDefinitions.FirstOrDefault()?.Descending == false;

        GetProductsQuery query = new()
        {
            Page = state.Page + 1,
            PageSize = state.PageSize,
            SortBy = sortBy,
            SortAscending = ascending,
            Search = _searchString,
            IsActive = _filterIsActive
        };

        PagedResult<ProductDto> result = await ProductService.GetPagedAsync(query);

        return new GridData<ProductDto>
        {
            Items = result.Items,
            TotalItems = result.TotalCount
        };
    }

    private string GetRowClass(ProductDto item, int index) =>
        item.IsActive ? "row-status-active" : "row-status-inactive";

    private async Task OnSearch(string text)
    {
        _searchString = text;
        await _grid.ReloadServerData();
    }

    private async Task OnStatusFilterChanged(bool? value)
    {
        _filterIsActive = value;
        await _grid.ReloadServerData();
    }

    private async void OnRowClick(DataGridRowClickEventArgs<ProductDto> args)
    {
        if (args.MouseEventArgs.Detail == 2)
            Navigation.NavigateTo($"/products/{args.Item.Id}");
    }

    private async Task OpenCreateDialog()
    {
        DialogOptions options = new()
        {
            MaxWidth = MaxWidth.Small,
            FullWidth = true,
            CloseOnEscapeKey = true
        };

        IDialogReference dialog = await DialogService.ShowAsync<ProductDialog>(
            Localization.GetString("CreateProduct"), options);

        DialogResult? result = await dialog.Result;

        if (result is { Canceled: false, Data: ProductDto created })
            await CreateProduct(created);
    }

    private async Task OpenEditDialog(ProductDto product)
    {
        DialogParameters<ProductDialog> parameters = new();
        parameters.Add(x => x.Product, product);

        DialogOptions options = new()
        {
            MaxWidth = MaxWidth.Small,
            FullWidth = true,
            CloseOnEscapeKey = true
        };

        IDialogReference dialog = await DialogService.ShowAsync<ProductDialog>(
            Localization.GetString("EditProduct"), parameters, options);

        DialogResult? result = await dialog.Result;

        if (result is { Canceled: false, Data: ProductDto edited })
            await SaveProduct(edited);
    }

    private async Task SaveProduct(ProductDto item)
    {
        try
        {
            UpdateProductDto updateDto = new()
            {
                Code = item.Code,
                Name = item.Name,
                Description = item.Description,
                Unit = item.Unit,
                DefaultPrice = item.DefaultPrice,
                IsActive = item.IsActive
            };

            await ProductService.UpdateProductAsync(item.Id, updateDto);
            Snackbar.Add(Localization.GetString("ProductUpdated"), Severity.Success);
            await _grid.ReloadServerData();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error saving product: {ex.Message}");
            Snackbar.Add(Localization.GetString("ErrorUpdatingProduct"), Severity.Error);
        }
    }

    private async Task CreateProduct(ProductDto item)
    {
        try
        {
            CreateProductDto createDto = new()
            {
                Code = item.Code,
                Name = item.Name,
                Description = item.Description,
                Unit = item.Unit,
                DefaultPrice = item.DefaultPrice,
                IsActive = item.IsActive
            };

            await ProductService.CreateProductAsync(createDto);
            Snackbar.Add(Localization.GetString("ProductCreated"), Severity.Success);
            await _grid.ReloadServerData();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error creating product: {ex.Message}");
            Snackbar.Add(Localization.GetString("ErrorCreatingProduct"), Severity.Error);
        }
    }

    private async Task DeleteProduct(Guid id)
    {
        bool? result = await DialogService.ShowMessageBoxAsync(new MessageBoxOptions
        {
            Title = Localization.GetString("ConfirmDelete"),
            Message = Localization.GetString("DeleteProductConfirm"),
            YesText = Localization.GetString("Yes"),
            CancelText = Localization.GetString("No")
        });

        if (result == true)
        {
            try
            {
                bool deleted = await ProductService.DeleteProductAsync(id);
                if (deleted)
                {
                    Snackbar.Add(Localization.GetString("ProductDeleted"), Severity.Success);
                    await _grid.ReloadServerData();
                }
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Error deleting product: {ex.Message}");
                Snackbar.Add(Localization.GetString("ErrorDeletingProduct"), Severity.Error);
            }
        }
    }

    private async Task ClearAllFilters()
    {
        _filterIsActive = null;
        await _grid.ReloadServerData();
    }

    public void Dispose()
    {
        Localization.OnLanguageChanged -= OnLanguageChanged;
    }
}
