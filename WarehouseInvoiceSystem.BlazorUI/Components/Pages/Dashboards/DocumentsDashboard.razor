@page "/documents-dashboard"
@inherits PageBase
@using WarehouseInvoiceSystem.Application.DTOs.Payment
@using WarehouseInvoiceSystem.Application.DTOs.Invoice
@using WarehouseInvoiceSystem.Application.DTOs.PurchaseNote
@using WarehouseInvoiceSystem.Domain.Enums
@inject IInvoiceService InvoiceService
@inject IPurchaseNoteService PurchaseNoteService
@inject IPaymentService PaymentService

<PageTitle>@Localization.GetString("DocumentsDashboard") - @Localization.GetString("InvoiceSystem")</PageTitle>

<MudText Typo="Typo.h4" Class="mb-6">@Localization.GetString("FinancialDocuments")</MudText>

@if (_loading)
{
    <MudProgressLinear Color="Color.Primary" Indeterminate="true" />
}
else
{
    <MudGrid>

        <!-- ── Financial Position ── -->
        <MudItem xs="12" Class="mb-2">
            <MudText Typo="Typo.h6">@Localization.GetString("FinancialPosition")</MudText>
            <MudText Typo="Typo.caption" Color="Color.Secondary">@Localization.GetString("FinancialPositionSubtitle")</MudText>
        </MudItem>

        <MudItem xs="12" sm="6" md="3">
            <DashboardCard Title="@Localization.GetString("TotalReceivables")"
                           Value="@_receivableOutstandingAmount.ToString("C")"
                           Subtitle="@($"{_receivableOutstandingCount} {Localization.GetString("Invoices")}")"
                           Icon="@Icons.Material.Filled.AccountBalance"
                           IconColor="@(_receivableOutstandingAmount > 0 ? Color.Success : Color.Default)" />
        </MudItem>

        <MudItem xs="12" sm="6" md="3">
            <DashboardCard Title="@Localization.GetString("TotalPayables")"
                           Value="@_totalPayablesOutstanding.ToString("C")"
                           Subtitle="@($"{_unpaidPurchaseNoteCount} {Localization.GetString("PurchaseNotes")} · {_payableOutstandingCount} {Localization.GetString("Invoices")}")"
                           Icon="@Icons.Material.Filled.AccountBalanceWallet"
                           IconColor="@(_totalPayablesOutstanding > 0 ? Color.Warning : Color.Default)" />
        </MudItem>

        <MudItem xs="12" sm="6" md="3">
            <DashboardCard Title="@Localization.GetString("NetBalance")"
                           Value="@_netBalanceOutstanding.ToString("C")"
                           Icon="@Icons.Material.Filled.Balance"
                           IconColor="@(_netBalanceOutstanding > 0 ? Color.Success : _netBalanceOutstanding < 0 ? Color.Error : Color.Default)" />
        </MudItem>

        <MudItem xs="12" sm="6" md="3">
            <DashboardCard Title="@Localization.GetString("OverdueReceivables")"
                           Value="@_overdueReceivableAmount.ToString("C")"
                           Subtitle="@($"{_overdueReceivableCount} {Localization.GetString("Invoices")}")"
                           Icon="@Icons.Material.Filled.RunningWithErrors"
                           IconColor="@(_overdueReceivableCount > 0 ? Color.Error : Color.Default)" />
        </MudItem>

        <!-- ── Today's Activity ── -->
        <MudItem xs="12" Class="mt-6">
            <div class="d-flex align-center flex-wrap gap-2 mb-4">
                <MudText Typo="Typo.h6">@Localization.GetString("TodaysActivity")</MudText>
                <WisDatePicker @bind-Date="_selectedDay"
                               @bind-Date:after="OnDayChanged"
                               Label="@Localization.GetString("SelectDay")"
                               MaxDate="DateTime.Today" />
            </div>
        </MudItem>

        <MudItem xs="12" sm="6" md="3">
            <DashboardCard Title="@Localization.GetString("PurchaseNotesToday")"
                           Value="@_purchaseNotesDay.Count.ToString()"
                           Subtitle="@_purchaseNotesDayAmount.ToString("C")"
                           Icon="@Icons.Material.Filled.Receipt"
                           IconColor="Color.Info" />
        </MudItem>

        <MudItem xs="12" sm="6" md="3">
            <DashboardCard Title="@Localization.GetString("PayableInvoicesToday")"
                           Value="@_invoicesPayableDayCount.ToString()"
                           Subtitle="@_amountPayableInvoicesDay.ToString("C")"
                           Icon="@Icons.Material.Filled.ShoppingCart"
                           IconColor="Color.Warning" />
        </MudItem>

        <MudItem xs="12" sm="6" md="3">
            <DashboardCard Title="@Localization.GetString("InvoicesIssuedToday")"
                           Value="@_invoicesReceivableDayCount.ToString()"
                           Subtitle="@_amountToReceiveDay.ToString("C")"
                           Icon="@Icons.Material.Filled.RequestQuote"
                           IconColor="Color.Success" />
        </MudItem>

        <MudItem xs="12" sm="6" md="3">
            <DashboardCard Title="@Localization.GetString("Profit")"
                           Value="@_profitDay.ToString("C")"
                           Icon="@Icons.Material.Filled.TrendingUp"
                           IconColor="@(_profitDay >= 0 ? Color.Success : Color.Error)" />
        </MudItem>

        <!-- ── Financial Summary ── -->
        <MudItem xs="12" Class="mt-6">
            <div class="d-flex align-center flex-wrap gap-2 mb-4">
                <MudText Typo="Typo.h6">
                    @Localization.GetString("FinancialSummary") — @_selectedMonth.ToString("MMMM yyyy")
                </MudText>
                <WisDatePicker @bind-Date="_selectedMonthDate"
                               @bind-Date:after="OnMonthChanged"
                               DateFormat="MMM yyyy"
                               OpenTo="OpenTo.Month"
                               Label="@Localization.GetString("SelectMonth")"
                               MaxDate="DateTime.Today" />
            </div>
        </MudItem>

        <MudItem xs="12" sm="6" md="3">
            <DashboardCard Title="@Localization.GetString("TotalToPay")"
                           Value="@_totalPurchasesMonth.ToString("C")"
                           Subtitle="@($"{_purchaseNotesMonth.Count} {Localization.GetString("PurchaseNotes")} | {_invoicesToPayMonthCount} {Localization.GetString("Invoices")}")"
                           Icon="@Icons.Material.Filled.ShoppingCart"
                           IconColor="Color.Primary" />
        </MudItem>

        <MudItem xs="12" sm="6" md="3">
            <DashboardCard Title="@Localization.GetString("TotalSales")"
                           Value="@_totalSalesMonth.ToString("C")"
                           Subtitle="@($"{_invoicesToReceiveMonthCount} {Localization.GetString("Invoices")}")"
                           Icon="@Icons.Material.Filled.PointOfSale"
                           IconColor="Color.Success" />
        </MudItem>

        <MudItem xs="12" sm="6" md="3">
            <DashboardCard Title="@Localization.GetString("Profit")"
                           Value="@_profitMonth.ToString("C")"
                           Subtitle="@_marginMonth.ToString("P1")"
                           Icon="@Icons.Material.Filled.Savings"
                           IconColor="_profitMonth < 0 ? Color.Error : Color.Tertiary" />
        </MudItem>

        <MudItem xs="12" sm="6" md="3">
            <DashboardCard Title="@Localization.GetString("OverdueInvoices")"
                           Value="@_totalOverdueCount.ToString()"
                           Icon="@Icons.Material.Filled.Warning"
                           IconColor="@(_totalOverdueCount > 0 ? Color.Error : Color.Default)" />
        </MudItem>

        <!-- ── Recent Activity (Tabbed) ── -->
        <MudItem xs="12" Class="mt-6">
            <MudText Typo="Typo.h6" Class="mb-4">@Localization.GetString("RecentActivity")</MudText>
        </MudItem>

        <MudItem xs="12">
            <MudCard Elevation="2">
                <MudTabs Elevation="0"
                         Rounded="false"
                         ApplyEffectsToContainer="true"
                         PanelClass="pa-0"
                         Color="Color.Default">

                    <!-- ── Purchase Notes Tab ── -->
                    <MudTabPanel Text="@Localization.GetString("PurchaseNotes")"
                                 Icon="@Icons.Material.Filled.Receipt"
                                 Class="mr-5">
                        <MudCardHeader>
                            <CardHeaderContent>
                                <MudText Typo="Typo.body2" Color="Color.Secondary">
                                    @Localization.GetString("RecentPurchaseNotes")
                                </MudText>
                            </CardHeaderContent>
                            <CardHeaderActions>
                                <WisButton Action="@(new WisDetailActionItem { Icon = Icons.Material.Filled.Add, Label = Localization.GetString("PurchaseNote"), Color = Color.Primary, OnClick = EventCallback.Factory.Create(this, () => Navigation.NavigateTo("/purchase-notes/create")) })" />
                            </CardHeaderActions>
                        </MudCardHeader>
                        @if (_recentPurchaseNotes.Any())
                        {
                            <MudTable Items="_recentPurchaseNotes"
                                      Hover="true"
                                      Dense="true"
                                      Elevation="0"
                                      Class="wis-secondary-list"
                                      T="PurchaseNoteDto"
                                      RowClass="table-row-clickable"
                                      OnRowClick="@((TableRowClickEventArgs<PurchaseNoteDto> args) => Navigation.NavigateTo($"/purchase-notes/{args.Item!.Id}"))">
                                <HeaderContent>
                                    <MudTh>@Localization.GetString("NoteNumber")</MudTh>
                                    <MudTh>@Localization.GetString("Individual")</MudTh>
                                    <MudTh>@Localization.GetString("Status")</MudTh>
                                    <MudTh>@Localization.GetString("Date")</MudTh>
                                    <MudTh Class="text-right">@Localization.GetString("Amount")</MudTh>
                                </HeaderContent>
                                <RowTemplate>
                                    <MudTd DataLabel="@Localization.GetString("NoteNumber")">
                                        <MudText Typo="Typo.body2" Class="font-weight-medium">@context.NoteNumber</MudText>
                                    </MudTd>
                                    <MudTd DataLabel="@Localization.GetString("Individual")">
                                        <MudText Typo="Typo.body2" Color="Color.Secondary">@context.IndividualFullName</MudText>
                                    </MudTd>
                                    <MudTd DataLabel="@Localization.GetString("Status")">
                                        <MudChip T="string" Size="Size.Small" Color="@GetPurchaseNoteStatusColor(context.Status)" Variant="Variant.Outlined">
                                            @GetPurchaseNoteStatusText(context.Status)
                                        </MudChip>
                                    </MudTd>
                                    <MudTd DataLabel="@Localization.GetString("Date")">
                                        <MudText Typo="Typo.body2" Color="Color.Secondary">@context.PurchaseDate.ToString("dd MMM yyyy")</MudText>
                                    </MudTd>
                                    <MudTd DataLabel="@Localization.GetString("Amount")" Class="text-right">
                                        <MudText Typo="Typo.body2" Class="font-weight-bold">@context.TotalAmount.ToString("C")</MudText>
                                    </MudTd>
                                </RowTemplate>
                            </MudTable>
                        }
                        else
                        {
                            <div class="pa-6 text-center d-flex align-center">
                                <MudIcon Icon="@Icons.Material.Filled.Receipt" Size="Size.Large" Color="Color.Secondary" Class="mb-2 mr-2" />
                                <MudText Color="Color.Secondary">@Localization.GetString("NoPurchaseNotesFound")</MudText>
                            </div>
                        }
                        <MudCardActions Class="pa-4">
                            <WisButton Action="@NavAction(Icons.Material.Filled.List, Localization.GetString("PurchaseNotes"), "/purchase-notes", Color.Secondary)" />
                        </MudCardActions>
                    </MudTabPanel>

                    <!-- ── Invoices Tab ── -->
                    <MudTabPanel Text="@Localization.GetString("Invoices")"
                                 Icon="@Icons.Material.Filled.RequestQuote"
                                 Class="mr-5">
                        <MudCardHeader>
                            <CardHeaderContent>
                                <MudText Typo="Typo.body2" Color="Color.Secondary">
                                    @Localization.GetString("RecentInvoices")
                                </MudText>
                            </CardHeaderContent>
                            <CardHeaderActions>
                                <WisButton Action="@(new WisDetailActionItem { Icon = Icons.Material.Filled.Add, Label = Localization.GetString("Invoice"), Color = Color.Primary, OnClick = EventCallback.Factory.Create(this, () => Navigation.NavigateTo("/invoices/create")) })" />
                            </CardHeaderActions>
                        </MudCardHeader>
                        @if (_recentInvoices.Any())
                        {
                            <MudTable Items="_recentInvoices"
                                      Hover="true"
                                      Dense="true"
                                      Elevation="0"
                                      Class="wis-secondary-list"
                                      T="InvoiceDto"
                                      RowClass="table-row-clickable"
                                      OnRowClick="@((TableRowClickEventArgs<InvoiceDto> args) => Navigation.NavigateTo($"/invoices/{args.Item!.Id}"))">
                                <HeaderContent>
                                    <MudTh>@Localization.GetString("InvoiceNumber")</MudTh>
                                    <MudTh>@Localization.GetString("Type")</MudTh>
                                    <MudTh>@Localization.GetString("Company")</MudTh>
                                    <MudTh>@Localization.GetString("Status")</MudTh>
                                    <MudTh>@Localization.GetString("Date")</MudTh>
                                    <MudTh Class="text-right">@Localization.GetString("Amount")</MudTh>
                                </HeaderContent>
                                <RowTemplate>
                                    <MudTd DataLabel="@Localization.GetString("InvoiceNumber")">
                                        <MudText Typo="Typo.body2" Class="font-weight-medium">@context.InvoiceNumber</MudText>
                                    </MudTd>
                                    <MudTd DataLabel="@Localization.GetString("Type")">
                                        <MudChip T="string"
                                                 Size="Size.Small"
                                                 Variant="Variant.Outlined"
                                                 Color="@(context.Type == InvoiceType.Receivable ? Color.Success : Color.Warning)">
                                            @(Localization.GetString(context.Type.ToString()))
                                        </MudChip>
                                    </MudTd>
                                    <MudTd DataLabel="@Localization.GetString("Company")">
                                        <MudText Typo="Typo.body2" Color="Color.Secondary">@context.CompanyName</MudText>
                                    </MudTd>
                                    <MudTd DataLabel="@Localization.GetString("Status")">
                                        <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Color="GetInvoiceStatusColor(context.Status)">
                                            @GetInvoiceStatusText(context.Status)
                                        </MudChip>
                                    </MudTd>
                                    <MudTd DataLabel="@Localization.GetString("Date")">
                                        <MudText Typo="Typo.body2" Color="Color.Secondary">@context.IssueDate.ToString("dd MMM yyyy")</MudText>
                                    </MudTd>
                                    <MudTd DataLabel="@Localization.GetString("Amount")" Class="text-right">
                                        <MudText Typo="Typo.body2" Class="font-weight-bold">@context.TotalAmount.ToString("C")</MudText>
                                    </MudTd>
                                </RowTemplate>
                            </MudTable>
                        }
                        else
                        {
                            <div class="pa-6 text-center d-flex align-center">
                                <MudIcon Icon="@Icons.Material.Filled.RequestQuote" Size="Size.Large" Color="Color.Secondary" Class="mb-2 mr-2" />
                                <MudText Color="Color.Secondary">@Localization.GetString("NoInvoicesFound")</MudText>
                            </div>
                        }
                        <MudCardActions Class="pa-4">
                            <WisButton Action="@NavAction(Icons.Material.Filled.List, Localization.GetString("Invoices"), "/invoices", Color.Secondary)" />
                        </MudCardActions>
                    </MudTabPanel>

                    <!-- ── Payments Tab ── -->
                    <MudTabPanel Text="@Localization.GetString("Payments")"
                                 Icon="@Icons.Material.Filled.Payment"
                                 Class="mr-5">
                        <MudCardHeader>
                            <CardHeaderContent>
                                <MudText Typo="Typo.body2" Color="Color.Secondary">
                                    @Localization.GetString("RecentPayments")
                                </MudText>
                            </CardHeaderContent>
                            <CardHeaderActions>
                                <WisButton Action="@(new WisDetailActionItem { Icon = Icons.Material.Filled.Add, Label = Localization.GetString("Payment"), Color = Color.Primary, OnClick = EventCallback.Factory.Create(this, async () => await OpenPaymentDialog()) })" />
                            </CardHeaderActions>
                        </MudCardHeader>
                        @if (_recentPayments.Any())
                        {
                            <MudTable Items="_recentPayments"
                                      Hover="true"
                                      Dense="true"
                                      Elevation="0"
                                      Class="wis-secondary-list"
                                      T="PaymentDto"
                                      RowClass="table-row-clickable"
                                      OnRowClick="@((TableRowClickEventArgs<PaymentDto> args) => Navigation.NavigateTo($"/payments/{args.Item!.Id}"))">
                                <HeaderContent>
                                    <MudTh>@Localization.GetString("Invoice")</MudTh>
                                    <MudTh>@Localization.GetString("ReferenceNumber")</MudTh>
                                    <MudTh>@Localization.GetString("PaymentMethod")</MudTh>
                                    <MudTh>@Localization.GetString("Date")</MudTh>
                                    <MudTh Class="text-right">@Localization.GetString("Amount")</MudTh>
                                </HeaderContent>
                                <RowTemplate>
                                    <MudTd DataLabel="@Localization.GetString("Invoice")">
                                        <MudText Typo="Typo.body2" Color="Color.Secondary">@context.InvoiceNumber</MudText>
                                    </MudTd>
                                    <MudTd DataLabel="@Localization.GetString("ReferenceNumber")">
                                        <MudText Typo="Typo.body2" Class="font-weight-medium">
                                            @(string.IsNullOrEmpty(context.ReferenceNumber) ? "-" : context.ReferenceNumber)
                                        </MudText>
                                    </MudTd>
                                    <MudTd DataLabel="@Localization.GetString("PaymentMethod")">
                                        <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Color="@GetPaymentMethodColor(context.PaymentMethod)">
                                            @GetPaymentMethodText(context.PaymentMethod)
                                        </MudChip>
                                    </MudTd>
                                    <MudTd DataLabel="@Localization.GetString("Date")">
                                        <MudText Typo="Typo.body2" Color="Color.Secondary">@context.PaymentDate.ToString("dd MMM yyyy")</MudText>
                                    </MudTd>
                                    <MudTd DataLabel="@Localization.GetString("Amount")" Class="text-right">
                                        <MudText Typo="Typo.body2" Class="font-weight-bold" Color="Color.Success">
                                            @context.Amount.ToString("C")
                                        </MudText>
                                    </MudTd>
                                </RowTemplate>
                            </MudTable>
                        }
                        else
                        {
                            <div class="pa-6 text-center d-flex align-center">
                                <MudIcon Icon="@Icons.Material.Filled.Payment" Size="Size.Large" Color="Color.Secondary" Class="mb-2 mr-2" />
                                <MudText Color="Color.Secondary">@Localization.GetString("NoPaymentsFound")</MudText>
                            </div>
                        }
                        <MudCardActions Class="pa-4">
                            <WisButton Action="@NavAction(Icons.Material.Filled.List, Localization.GetString("Payments"), "/payments", Color.Secondary)" />
                        </MudCardActions>
                    </MudTabPanel>

                </MudTabs>
            </MudCard>
        </MudItem>

    </MudGrid>
}

@code {
    // ── Financial position (DB aggregate) ──
    private int _receivableOutstandingCount;
    private decimal _receivableOutstandingAmount;
    private int _overdueReceivableCount;
    private decimal _overdueReceivableAmount;
    private int _payableOutstandingCount;
    private decimal _payableOutstandingAmount;
    private int _unpaidPurchaseNoteCount;
    private decimal _unpaidPurchaseNoteAmount;
    private int _totalOverdueCount;

    private decimal _totalPayablesOutstanding => _payableOutstandingAmount + _unpaidPurchaseNoteAmount;
    private decimal _netBalanceOutstanding => _receivableOutstandingAmount - _totalPayablesOutstanding;

    // ── Day filter ──
    private DateTime? _selectedDay = DateTime.Today;
    private DateTime _selectedDate => _selectedDay ?? DateTime.Today;

    // ── Month filter ──
    private DateTime? _selectedMonthDate = new DateTime(DateTime.Today.Year, DateTime.Today.Month, 1);
    private DateTime _selectedMonth => _selectedMonthDate ?? new DateTime(DateTime.Today.Year, DateTime.Today.Month, 1);

    // ── Day data (reloaded on day change) ──
    private List<InvoiceDto> _invoicesDay = [];
    private List<PurchaseNoteDto> _purchaseNotesDay = [];

    private int _invoicesPayableDayCount;
    private decimal _amountPayableInvoicesDay;
    private int _invoicesReceivableDayCount;
    private decimal _amountToReceiveDay;
    private decimal _purchaseNotesDayAmount;
    private decimal _profitDay;

    // ── Month data (reloaded on month change) ──
    private List<InvoiceDto> _invoicesMonth = [];
    private List<PurchaseNoteDto> _purchaseNotesMonth = [];

    private int _invoicesToPayMonthCount;
    private int _invoicesToReceiveMonthCount;
    private decimal _totalPurchasesMonth;
    private decimal _totalSalesMonth;
    private decimal _profitMonth;
    private decimal _marginMonth;

    // ── Recent activity (last 5, loaded once) ──
    private List<InvoiceDto> _recentInvoices = [];
    private List<PurchaseNoteDto> _recentPurchaseNotes = [];
    private List<PaymentDto> _recentPayments = [];

    protected override async Task OnInitializedAsync()
    {
        await base.OnInitializedAsync();
        await LoadData();
    }

    private async Task LoadData()
    {
        _loading = true;

        try
        {
            await Task.WhenAll(
                LoadFinancialPosition(),
                LoadDayData(),
                LoadMonthData(),
                LoadRecentActivity()
            );
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading documents data: {ex.Message}");
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task LoadFinancialPosition()
    {
        var posTask = InvoiceService.GetOutstandingPositionAsync(CancellationToken.None);
        var pnTask = PurchaseNoteService.GetOutstandingPositionAsync(CancellationToken.None);

        await Task.WhenAll(posTask, pnTask);

        var pos = posTask.Result;
        _receivableOutstandingCount = pos.ReceivableCount;
        _receivableOutstandingAmount = pos.ReceivableAmount;
        _overdueReceivableCount = pos.OverdueReceivableCount;
        _overdueReceivableAmount = pos.OverdueReceivableAmount;
        _payableOutstandingCount = pos.PayableCount;
        _payableOutstandingAmount = pos.PayableAmount;
        _totalOverdueCount = pos.TotalOverdueCount;

        var (unpaidCount, unpaidAmount) = pnTask.Result;
        _unpaidPurchaseNoteCount = unpaidCount;
        _unpaidPurchaseNoteAmount = unpaidAmount;
    }

    private async Task LoadDayData()
    {
        var invoicesTask = InvoiceService.GetByIssueDateAsync(_selectedDate, CancellationToken.None);
        var notesTask = PurchaseNoteService.GetByPurchaseDateAsync(_selectedDate, CancellationToken.None);

        await Task.WhenAll(invoicesTask, notesTask);

        _invoicesDay = invoicesTask.Result.ToList();
        _purchaseNotesDay = notesTask.Result.ToList();

        var payableDay = _invoicesDay.Where(i => i.Type == InvoiceType.Payable).ToList();
        var receivableDay = _invoicesDay.Where(i => i.Type == InvoiceType.Receivable).ToList();
        _invoicesPayableDayCount = payableDay.Count;
        _amountPayableInvoicesDay = payableDay.Sum(i => i.TotalAmount);
        _invoicesReceivableDayCount = receivableDay.Count;
        _amountToReceiveDay = receivableDay.Sum(i => i.TotalAmount);
        _purchaseNotesDayAmount = _purchaseNotesDay.Sum(pn => pn.TotalAmount);
        _profitDay = _amountToReceiveDay - _purchaseNotesDayAmount - _amountPayableInvoicesDay;
    }

    private async Task LoadMonthData()
    {
        var invoicesTask = InvoiceService.GetByIssueDateMonthAsync(_selectedMonth.Year, _selectedMonth.Month, CancellationToken.None);
        var notesTask = PurchaseNoteService.GetByPurchaseDateMonthAsync(_selectedMonth.Year, _selectedMonth.Month, CancellationToken.None);

        await Task.WhenAll(invoicesTask, notesTask);

        _invoicesMonth = invoicesTask.Result.ToList();
        _purchaseNotesMonth = notesTask.Result.ToList();

        var payableMonth = _invoicesMonth.Where(i => i.Type == InvoiceType.Payable).ToList();
        var receivableMonth = _invoicesMonth.Where(i => i.Type == InvoiceType.Receivable).ToList();
        _invoicesToPayMonthCount = payableMonth.Count;
        _invoicesToReceiveMonthCount = receivableMonth.Count;
        _totalSalesMonth = receivableMonth.Sum(i => i.TotalAmount);
        _totalPurchasesMonth = _purchaseNotesMonth.Sum(pn => pn.TotalAmount) + payableMonth.Sum(i => i.TotalAmount);
        _profitMonth = _totalSalesMonth - _totalPurchasesMonth;
        _marginMonth = _totalSalesMonth > 0 ? _profitMonth / _totalSalesMonth : 0;
    }

    private async Task LoadRecentActivity()
    {
        var invoicesTask = InvoiceService.GetRecentAsync(5, CancellationToken.None);
        var notesTask = PurchaseNoteService.GetRecentAsync(5, CancellationToken.None);
        var paymentsTask = PaymentService.GetRecentAsync(5, CancellationToken.None);

        await Task.WhenAll(invoicesTask, notesTask, paymentsTask);

        _recentInvoices = invoicesTask.Result.ToList();
        _recentPurchaseNotes = notesTask.Result.ToList();
        _recentPayments = paymentsTask.Result.ToList();
    }

    private async Task OnDayChanged()
    {
        await LoadDayData();
    }

    private async Task OnMonthChanged()
    {
        await LoadMonthData();
    }

    private async Task OpenPaymentDialog()
    {
        try
        {
            bool paid = await WisDialog.ShowPaymentDialogAsync();
            if (paid)
            {
                Snackbar.Add(Localization.GetString("PaymentRecorded"), Severity.Success);
                await LoadRecentActivity();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error recording payment: {ex.Message}");
            Snackbar.Add(Localization.GetString("ErrorRecordingPayment"), Severity.Error);
        }
    }

}
