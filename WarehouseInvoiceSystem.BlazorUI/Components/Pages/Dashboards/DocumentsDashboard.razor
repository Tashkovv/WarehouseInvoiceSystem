@page "/documents-dashboard"
@implements IDisposable
@using WarehouseInvoiceSystem.Application.DTOs.Payment
@using WarehouseInvoiceSystem.Application.DTOs.Invoice
@using WarehouseInvoiceSystem.Application.DTOs.PurchaseNote
@using WarehouseInvoiceSystem.Domain.Enums
@inject IInvoiceService InvoiceService
@inject IPurchaseNoteService PurchaseNoteService
@inject ILocalizationService Localization
@inject IPaymentService PaymentService
@inject NavigationManager Navigation
@inject WisDialogService WisDialog
@inject ISnackbar Snackbar

<PageTitle>@Localization.GetString("DocumentsDashboard") - @Localization.GetString("InvoiceSystem")</PageTitle>

<MudText Typo="Typo.h4" Class="mb-6">@Localization.GetString("FinancialDocuments")</MudText>

@if (_loading)
{
    <MudProgressLinear Color="Color.Primary" Indeterminate="true" />
}
else
{
    <MudGrid>

        <!-- ── Today's Activity ── -->
        <MudItem xs="12">
            <div class="d-flex align-center flex-wrap gap-2 mb-4">
                <MudText Typo="Typo.h6">@Localization.GetString("TodaysActivity")</MudText>
                <div>
                    <MudDatePicker @bind-Date="_selectedDay"
                                   Variant="Variant.Outlined"
                                   Margin="Margin.Dense"
                                   DateFormat="dd MMM yyyy"
                                   Label="@Localization.GetString("SelectDay")"
                                   MaxDate="DateTime.Today"
                                   PickerVariant="PickerVariant.Inline"
                                   Style="min-width: 315px;" />
                </div>
            </div>
        </MudItem>

        <MudItem xs="12" sm="6" md="3">
            <DashboardCard Title="@Localization.GetString("PurchaseNotesToday")"
                           Value="@_purchaseNotesDay.Count().ToString()"
                           Subtitle="@_purchaseNotesDay.Sum(pn => pn.TotalAmount).ToString("C")"
                           Icon="@Icons.Material.Filled.Receipt"
                           IconColor="Color.Info"
                           Link="/purchase-notes" />
        </MudItem>

        <MudItem xs="12" sm="6" md="3">
            <DashboardCard Title="@Localization.GetString("PayableInvoicesToday")"
                           Value="@_invoicesPayableDay.Count().ToString()"
                           Subtitle="@_amountPayableInvoicesDay.ToString("C")"
                           Icon="@Icons.Material.Filled.ShoppingCart"
                           IconColor="Color.Warning"
                           Link="/invoices" />
        </MudItem>

        <MudItem xs="12" sm="6" md="3">
            <DashboardCard Title="@Localization.GetString("InvoicesIssuedToday")"
                           Value="@_invoicesReceivableDay.Count().ToString()"
                           Subtitle="@_amountToReceiveDay.ToString("C")"
                           Icon="@Icons.Material.Filled.RequestQuote"
                           IconColor="Color.Success"
                           Link="/invoices" />
        </MudItem>

        <MudItem xs="12" sm="6" md="3">
            <DashboardCard Title="@Localization.GetString("Profit")"
                           Value="@_profitDay.ToString("C")"
                           Icon="@Icons.Material.Filled.TrendingUp"
                           IconColor="@(_profitDay >= 0 ? Color.Success : Color.Error)" />
        </MudItem>

        <!-- ── Financial Summary ── -->
        <MudItem xs="12" Class="mt-6">
            <div class="d-flex align-center flex-wrap gap-2 mb-4">
                <MudText Typo="Typo.h6">
                    @Localization.GetString("FinancialSummary") — @_selectedMonth.ToString("MMMM yyyy")
                </MudText>
                <div>
                    <MudDatePicker @bind-Date="_selectedMonthDate"
                                   Variant="Variant.Outlined"
                                   Margin="Margin.Dense"
                                   DateFormat="MMM yyyy"
                                   OpenTo="OpenTo.Month"
                                   Label="@Localization.GetString("SelectMonth")"
                                   MaxDate="DateTime.Today"
                                   PickerVariant="PickerVariant.Inline"
                                   Style="min-width: 315px;" />
                </div>
            </div>
        </MudItem>

        <MudItem xs="12" sm="6" md="3">
            <DashboardCard Title="@Localization.GetString("TotalToPay")"
                           Value="@_totalPurchasesMonth.ToString("C")"
                           Subtitle="@($"{_purchaseNotesMonth.Count()} {Localization.GetString("PurchaseNotes")} | {_invoicesToPayMonth.Count()} {Localization.GetString("Invoices")}")"
                           Icon="@Icons.Material.Filled.ShoppingCart"
                           IconColor="Color.Primary" />
        </MudItem>

        <MudItem xs="12" sm="6" md="3">
            <DashboardCard Title="@Localization.GetString("TotalSales")"
                           Value="@_totalSalesMonth.ToString("C")"
                           Subtitle="@($"{_invoicesToReceiveMonth.Count()} {Localization.GetString("Invoices")}")"
                           Icon="@Icons.Material.Filled.PointOfSale"
                           IconColor="Color.Success" />
        </MudItem>

        <MudItem xs="12" sm="6" md="3">
            <DashboardCard Title="@Localization.GetString("Profit")"
                           Value="@_profitMonth.ToString("C")"
                           Subtitle="@_marginMonth.ToString("P1")"
                           Icon="@Icons.Material.Filled.Savings"
                           IconColor="Color.Tertiary" />
        </MudItem>

        <MudItem xs="12" sm="6" md="3">
            <DashboardCard Title="@Localization.GetString("OverdueInvoices")"
                           Value="@_attentionCount.ToString()"
                           Icon="@Icons.Material.Filled.Warning"
                           IconColor="@(_attentionCount > 0 ? Color.Error : Color.Default)"
                           Link="@($"/invoices?status={InvoiceStatus.Overdue}")" />
        </MudItem>

        <!-- ── Recent Activity (Tabbed) ── -->
        <MudItem xs="12" Class="mt-6">
            <MudText Typo="Typo.h6" Class="mb-4">@Localization.GetString("RecentActivity")</MudText>
        </MudItem>

        <MudItem xs="12">
            <MudCard Elevation="2">
                <MudTabs Elevation="0"
                         Rounded="false"
                         ApplyEffectsToContainer="true"
                         PanelClass="pa-0"
                         Color="Color.Default">

                    <!-- ── Purchase Notes Tab ── -->
                    <MudTabPanel Text="@Localization.GetString("PurchaseNotes")"
                                 Icon="@Icons.Material.Filled.Receipt"
                                 BadgeData="@_recentPurchaseNotes.Count()"
                                 BadgeColor="Color.Info"
                                 Class="mr-5">
                        <MudCardHeader>
                            <CardHeaderContent>
                                <MudText Typo="Typo.body2" Color="Color.Secondary">
                                    @Localization.GetString("RecentPurchaseNotes")
                                </MudText>
                            </CardHeaderContent>
                            <CardHeaderActions>
                                <MudButton Href="/purchase-notes/create"
                                           Color="Color.Primary"
                                           Variant="Variant.Filled"
                                           Size="Size.Small"
                                           StartIcon="@Icons.Material.Filled.Add">
                                    @Localization.GetString("NewPurchaseNote")
                                </MudButton>
                            </CardHeaderActions>
                        </MudCardHeader>
                        @if (_recentPurchaseNotes.Any())
                        {
                            <MudTable Items="_recentPurchaseNotes"
                                      Hover="true"
                                      Dense="true"
                                      Elevation="0"
                                      T="PurchaseNoteDto"
                                      RowClass="table-row-clickable"
                                      OnRowClick="@((TableRowClickEventArgs<PurchaseNoteDto> args) => Navigation.NavigateTo($"/purchase-notes/{args.Item!.Id}"))">
                                <HeaderContent>
                                    <MudTh>@Localization.GetString("NoteNumber")</MudTh>
                                    <MudTh>@Localization.GetString("Individual")</MudTh>
                                    <MudTh Style="text-align: right;">@Localization.GetString("Amount")</MudTh>
                                    <MudTh>@Localization.GetString("Date")</MudTh>
                                    <MudTh>@Localization.GetString("Status")</MudTh>
                                </HeaderContent>
                                <RowTemplate>
                                    <MudTd DataLabel="@Localization.GetString("NoteNumber")">
                                        <MudText Typo="Typo.body2" Class="font-weight-medium">@context.NoteNumber</MudText>
                                    </MudTd>
                                    <MudTd DataLabel="@Localization.GetString("Individual")">
                                        <MudText Typo="Typo.caption" Color="Color.Secondary">@context.IndividualFullName</MudText>
                                    </MudTd>
                                    <MudTd DataLabel="@Localization.GetString("Amount")" Style="text-align: right;">
                                        <MudText Typo="Typo.body2" Class="font-weight-bold">@context.TotalAmount.ToString("C")</MudText>
                                    </MudTd>
                                    <MudTd DataLabel="@Localization.GetString("Date")">
                                        <MudText Typo="Typo.caption" Color="Color.Secondary">@context.PurchaseDate.ToString("dd MMM yyyy")</MudText>
                                    </MudTd>
                                    <MudTd DataLabel="@Localization.GetString("Status")">
                                        <MudChip T="string" Size="Size.Small" Color="@GetPurchaseNoteStatusColor(context.Status)">
                                            @GetPurchaseNoteStatusText(context.Status)
                                        </MudChip>
                                    </MudTd>
                                </RowTemplate>
                            </MudTable>
                        }
                        else
                        {
                            <div class="pa-6 text-center d-flex align-center">
                                <MudIcon Icon="@Icons.Material.Filled.Receipt" Size="Size.Large" Color="Color.Secondary" Class="mb-2 mr-2" />
                                <MudText Color="Color.Secondary">@Localization.GetString("NoPurchaseNotesFound")</MudText>
                            </div>
                        }
                        <MudCardActions Class="pa-4">
                            <MudButton Href="/purchase-notes"
                                       Color="Color.Default"
                                       Variant="Variant.Outlined"
                                       StartIcon="@Icons.Material.Filled.List">
                                @Localization.GetString("AllPurchaseNotes")
                            </MudButton>
                        </MudCardActions>
                    </MudTabPanel>

                    <!-- ── Invoices Tab ── -->
                    <MudTabPanel Text="@Localization.GetString("Invoices")"
                                 Icon="@Icons.Material.Filled.RequestQuote"
                                 BadgeData="@_recentInvoices.Count()"
                                 BadgeColor="Color.Warning"
                                 Class="mr-5">
                        <MudCardHeader>
                            <CardHeaderContent>
                                <MudText Typo="Typo.body2" Color="Color.Secondary">
                                    @Localization.GetString("RecentInvoices")
                                </MudText>
                            </CardHeaderContent>
                            <CardHeaderActions>
                                <MudButton Href="/invoices/create"
                                           Color="Color.Primary"
                                           Variant="Variant.Filled"
                                           Size="Size.Small"
                                           StartIcon="@Icons.Material.Filled.Add">
                                    @Localization.GetString("NewInvoice")
                                </MudButton>
                            </CardHeaderActions>
                        </MudCardHeader>
                        @if (_recentInvoices.Any())
                        {
                            <MudTable Items="_recentInvoices"
                                      Hover="true"
                                      Dense="true"
                                      Elevation="0"
                                      T="InvoiceDto"
                                      RowClass="table-row-clickable"
                                      OnRowClick="@((TableRowClickEventArgs<InvoiceDto> args) => Navigation.NavigateTo($"/invoices/{args.Item!.Id}"))">
                                <HeaderContent>
                                    <MudTh>@Localization.GetString("InvoiceNumber")</MudTh>
                                    <MudTh>@Localization.GetString("Company")</MudTh>
                                    <MudTh>@Localization.GetString("Type")</MudTh>
                                    <MudTh Style="text-align: right;">@Localization.GetString("Amount")</MudTh>
                                    <MudTh>@Localization.GetString("Date")</MudTh>
                                    <MudTh>@Localization.GetString("Status")</MudTh>
                                </HeaderContent>
                                <RowTemplate>
                                    <MudTd DataLabel="@Localization.GetString("InvoiceNumber")">
                                        <MudText Typo="Typo.body2" Class="font-weight-medium">@context.InvoiceNumber</MudText>
                                    </MudTd>
                                    <MudTd DataLabel="@Localization.GetString("Company")">
                                        <MudText Typo="Typo.caption" Color="Color.Secondary">@context.CompanyName</MudText>
                                    </MudTd>
                                    <MudTd DataLabel="@Localization.GetString("Type")">
                                        <MudChip T="string"
                                                 Size="Size.Small"
                                                 Color="@(context.Type == InvoiceType.Receivable ? Color.Success : Color.Warning)">
                                            @(Localization.GetString(context.Type.ToString()))
                                        </MudChip>
                                    </MudTd>
                                    <MudTd DataLabel="@Localization.GetString("Amount")" Style="text-align: right;">
                                        <MudText Typo="Typo.body2" Class="font-weight-bold">@context.TotalAmount.ToString("C")</MudText>
                                    </MudTd>
                                    <MudTd DataLabel="@Localization.GetString("Date")">
                                        <MudText Typo="Typo.caption" Color="Color.Secondary">@context.IssueDate.ToString("dd MMM yyyy")</MudText>
                                    </MudTd>
                                    <MudTd DataLabel="@Localization.GetString("Status")">
                                        <MudChip T="string" Size="Size.Small" Color="GetInvoiceStatusColor(context.Status)">
                                            @GetInvoiceStatusText(context.Status)
                                        </MudChip>
                                    </MudTd>
                                </RowTemplate>
                            </MudTable>
                        }
                        else
                        {
                            <div class="pa-6 text-center d-flex align-center">
                                <MudIcon Icon="@Icons.Material.Filled.RequestQuote" Size="Size.Large" Color="Color.Secondary" Class="mb-2 mr-2" />
                                <MudText Color="Color.Secondary">@Localization.GetString("NoInvoicesFound")</MudText>
                            </div>
                        }
                        <MudCardActions Class="pa-4">
                            <MudButton Href="/invoices"
                                       Color="Color.Default"
                                       Variant="Variant.Outlined"
                                       StartIcon="@Icons.Material.Filled.List">
                                @Localization.GetString("AllInvoices")
                            </MudButton>
                        </MudCardActions>
                    </MudTabPanel>

                    <!-- ── Payments Tab ── -->
                    <MudTabPanel Text="@Localization.GetString("Payments")"
                                 Icon="@Icons.Material.Filled.Payment"
                                 BadgeData="@_recentPayments.Count()"
                                 BadgeColor="Color.Success"
                                 Class="mr-5">
                        <MudCardHeader>
                            <CardHeaderContent>
                                <MudText Typo="Typo.body2" Color="Color.Secondary">
                                    @Localization.GetString("RecentPayments")
                                </MudText>
                            </CardHeaderContent>
                            <CardHeaderActions>
                                <MudButton OnClick="OpenPaymentDialog"
                                           Color="Color.Primary"
                                           Variant="Variant.Filled"
                                           Size="Size.Small"
                                           StartIcon="@Icons.Material.Filled.Add">
                                    @Localization.GetString("RecordPayment")
                                </MudButton>
                            </CardHeaderActions>
                        </MudCardHeader>
                        @if (_recentPayments.Any())
                        {
                            <MudTable Items="_recentPayments"
                                      Hover="true"
                                      Dense="true"
                                      Elevation="0"
                                      T="PaymentDto"
                                      RowClass="table-row-clickable"
                                      OnRowClick="@((TableRowClickEventArgs<PaymentDto> args) => Navigation.NavigateTo($"/payments/{args.Item!.Id}"))">
                                <HeaderContent>
                                    <MudTh>@Localization.GetString("ReferenceNumber")</MudTh>
                                    <MudTh>@Localization.GetString("Invoice")</MudTh>
                                    <MudTh Style="text-align: right;">@Localization.GetString("Amount")</MudTh>
                                    <MudTh>@Localization.GetString("Date")</MudTh>
                                    <MudTh>@Localization.GetString("PaymentMethod")</MudTh>
                                </HeaderContent>
                                <RowTemplate>
                                    <MudTd DataLabel="@Localization.GetString("ReferenceNumber")">
                                        <MudText Typo="Typo.body2" Class="font-weight-medium">
                                            @(string.IsNullOrEmpty(context.ReferenceNumber) ? "-" : context.ReferenceNumber)
                                        </MudText>
                                    </MudTd>
                                    <MudTd DataLabel="@Localization.GetString("Invoice")">
                                        <MudText Typo="Typo.caption" Color="Color.Secondary">@context.InvoiceNumber</MudText>
                                    </MudTd>
                                    <MudTd DataLabel="@Localization.GetString("Amount")" Style="text-align: right;">
                                        <MudText Typo="Typo.body2" Class="font-weight-bold" Color="Color.Success">
                                            @context.Amount.ToString("C")
                                        </MudText>
                                    </MudTd>
                                    <MudTd DataLabel="@Localization.GetString("Date")">
                                        <MudText Typo="Typo.caption" Color="Color.Secondary">@context.PaymentDate.ToString("dd MMM yyyy")</MudText>
                                    </MudTd>
                                    <MudTd DataLabel="@Localization.GetString("PaymentMethod")">
                                        <MudChip T="string" Size="Size.Small" Color="@GetMethodColor(context.PaymentMethod)">
                                            @GetPaymentMethodText(context.PaymentMethod)
                                        </MudChip>
                                    </MudTd>
                                </RowTemplate>
                            </MudTable>
                        }
                        else
                        {
                            <div class="pa-6 text-center d-flex align-center">
                                <MudIcon Icon="@Icons.Material.Filled.Payment" Size="Size.Large" Color="Color.Secondary" Class="mb-2 mr-2" />
                                <MudText Color="Color.Secondary">@Localization.GetString("NoPaymentsFound")</MudText>
                            </div>
                        }
                        <MudCardActions Class="pa-4">
                            <MudButton Href="/payments"
                                       Color="Color.Default"
                                       Variant="Variant.Outlined"
                                       StartIcon="@Icons.Material.Filled.List">
                                @Localization.GetString("AllPayments")
                            </MudButton>
                        </MudCardActions>
                    </MudTabPanel>

                </MudTabs>
            </MudCard>
        </MudItem>

    </MudGrid>
}

@code {
    private readonly CancellationTokenSource _cts = new();
    private bool _loading = true;
    private List<InvoiceDto> _invoices = [];
    private List<PurchaseNoteDto> _purchaseNotes = [];
    private List<PaymentDto> _payments = [];

    // ── Day filter ──
    private DateTime? _selectedDay = DateTime.Today;
    private DateTime _selectedDate => _selectedDay ?? DateTime.Today;

    // ── Month filter ──
    private DateTime? _selectedMonthDate = new DateTime(DateTime.Today.Year, DateTime.Today.Month, 1);
    private DateTime _selectedMonth => _selectedMonthDate ?? new DateTime(DateTime.Today.Year, DateTime.Today.Month, 1);

    // ── Day computed ──
    private IEnumerable<PurchaseNoteDto> _purchaseNotesDay =>
        _purchaseNotes.Where(pn => pn.PurchaseDate.Date == _selectedDate.Date);

    private IEnumerable<InvoiceDto> _invoicesDay =>
        _invoices.Where(i => i.IssueDate.Date == _selectedDate.Date);

    private IEnumerable<InvoiceDto> _invoicesPayableDay =>
        _invoicesDay.Where(i => i.Type == InvoiceType.Payable);

    private IEnumerable<InvoiceDto> _invoicesReceivableDay =>
        _invoicesDay.Where(i => i.Type == InvoiceType.Receivable);

    private decimal _amountPurchaseNotesDay =>
        _purchaseNotesDay.Sum(pn => pn.TotalAmount);

    private decimal _amountToReceiveDay =>
        _invoicesReceivableDay.Sum(i => i.TotalAmount);

    private decimal _amountPayableInvoicesDay =>
        _invoicesPayableDay.Sum(i => i.TotalAmount);

    private decimal _profitDay => _amountToReceiveDay - _amountPurchaseNotesDay - _amountPayableInvoicesDay;

    // ── Month computed ──
    private IEnumerable<PurchaseNoteDto> _purchaseNotesMonth =>
        _purchaseNotes.Where(pn => pn.PurchaseDate.Year == _selectedMonth.Year && pn.PurchaseDate.Month == _selectedMonth.Month);

    private IEnumerable<InvoiceDto> _invoicesMonth =>
        _invoices.Where(i => i.IssueDate.Year == _selectedMonth.Year && i.IssueDate.Month == _selectedMonth.Month);

    private IEnumerable<InvoiceDto> _invoicesToPayMonth =>
        _invoicesMonth.Where(i => i.Type == InvoiceType.Payable);

    private IEnumerable<InvoiceDto> _invoicesToReceiveMonth =>
        _invoicesMonth.Where(i => i.Type == InvoiceType.Receivable);

    private decimal _totalPurchasesMonth =>
        _purchaseNotesMonth.Sum(pn => pn.TotalAmount) + _invoicesToPayMonth.Sum(i => i.TotalAmount);

    private decimal _totalSalesMonth =>
        _invoicesToReceiveMonth.Sum(i => i.TotalAmount);

    private decimal _profitMonth => _totalSalesMonth - _totalPurchasesMonth;

    private decimal _marginMonth =>
        _totalSalesMonth > 0 ? _profitMonth / _totalSalesMonth : 0;

    // ── Overdue ──
    private int _attentionCount =>
        _invoices.Count(i => i.Status == InvoiceStatus.Overdue);

    // ── Recent activity (always last 5, unfiltered) ──
    private IEnumerable<PurchaseNoteDto> _recentPurchaseNotes =>
        _purchaseNotes.OrderByDescending(pn => pn.PurchaseDate).Take(5);

    private IEnumerable<InvoiceDto> _recentInvoices =>
        _invoices.OrderByDescending(i => i.IssueDate).Take(5);

    private IEnumerable<PaymentDto> _recentPayments =>
        _payments.OrderByDescending(p => p.PaymentDate).Take(5);

    protected override async Task OnInitializedAsync()
    {
        Localization.OnLanguageChanged += OnLanguageChanged;
        await LoadData();
    }

    private async void OnLanguageChanged()
    {
        await InvokeAsync(StateHasChanged);
    }

    private async Task LoadData()
    {
        _loading = true;

        try
        {
            IEnumerable<InvoiceDto> invoices = await InvoiceService.GetAllInvoicesAsync(_cts.Token);
            _invoices = invoices.ToList();

            IEnumerable<PurchaseNoteDto> purchaseNotes = await PurchaseNoteService.GetAllPurchaseNotesAsync(_cts.Token);
            _purchaseNotes = purchaseNotes.ToList();

            IEnumerable<PaymentDto> payments = await PaymentService.GetAllPaymentsAsync(_cts.Token);
            _payments = payments.ToList();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading documents data: {ex.Message}");
        }
        finally
        {
            _loading = false;
        }
    }

    // ── Helpers ───────────────────────────────────────────────────────────────

    private Color GetPurchaseNoteStatusColor(PurchaseNoteStatus status) => status switch
    {
        PurchaseNoteStatus.Draft => Color.Default,
        PurchaseNoteStatus.Pending => Color.Warning,
        PurchaseNoteStatus.Paid => Color.Success,
        PurchaseNoteStatus.Cancelled => Color.Error,
        _ => Color.Default
    };

    private string GetPurchaseNoteStatusText(PurchaseNoteStatus status) => status switch
    {
        PurchaseNoteStatus.Draft => Localization.GetString("Draft"),
        PurchaseNoteStatus.Pending => Localization.GetString("PendingStatus"),
        PurchaseNoteStatus.Paid => Localization.GetString("PaidStatus"),
        PurchaseNoteStatus.Cancelled => Localization.GetString("CancelledStatus"),
        _ => status.ToString()
    };

    private Color GetInvoiceStatusColor(InvoiceStatus status) => status switch
    {
        InvoiceStatus.Draft => Color.Default,
        InvoiceStatus.Sent => Color.Info,
        InvoiceStatus.PartiallyPaid => Color.Warning,
        InvoiceStatus.Paid => Color.Success,
        InvoiceStatus.Overdue => Color.Error,
        InvoiceStatus.Cancelled => Color.Dark,
        _ => Color.Default
    };

    private string GetInvoiceStatusText(InvoiceStatus status) => status switch
    {
        InvoiceStatus.Draft => Localization.GetString("Draft"),
        InvoiceStatus.Sent => Localization.GetString("Sent"),
        InvoiceStatus.PartiallyPaid => Localization.GetString("PartiallyPaid"),
        InvoiceStatus.Paid => Localization.GetString("PaidStatus"),
        InvoiceStatus.Overdue => Localization.GetString("OverdueStatus"),
        InvoiceStatus.Cancelled => Localization.GetString("CancelledStatus"),
        _ => status.ToString()
    };

    private string GetPaymentMethodText(PaymentMethod method) => method switch
    {
        PaymentMethod.Cash => Localization.GetString("Cash"),
        PaymentMethod.BankTransfer => Localization.GetString("BankTransfer"),
        PaymentMethod.CreditCard => Localization.GetString("CreditCard"),
        PaymentMethod.Other => Localization.GetString("Other"),
        _ => method.ToString()
    };

    private Color GetMethodColor(PaymentMethod method) => method switch
    {
        PaymentMethod.Cash => Color.Success,
        PaymentMethod.BankTransfer => Color.Primary,
        PaymentMethod.CreditCard => Color.Secondary,
        PaymentMethod.Other => Color.Default,
        _ => Color.Default
    };

    private async Task OpenPaymentDialog()
    {
        try
        {
            bool paid = await WisDialog.ShowPaymentDialogAsync();
            if (paid)
            {
                Snackbar.Add(Localization.GetString("PaymentRecorded"), Severity.Success);
                await LoadData();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error recording payment: {ex.Message}");
            Snackbar.Add(Localization.GetString("ErrorRecordingPayment"), Severity.Error);
        }
    }

    public void Dispose()
    {
        _cts.Cancel();
        _cts.Dispose();
        Localization.OnLanguageChanged -= OnLanguageChanged;
    }
}
