@page "/partners-dashboard"
@attribute [Authorize]
@inherits PageBase
@using WarehouseInvoiceSystem.Application.DTOs.Dashboard
@using WarehouseInvoiceSystem.Domain.Enums
@inject ICompanyService CompanyService
@inject IIndividualService IndividualService
@inject IInvoiceService InvoiceService
@inject IPurchaseNoteService PurchaseNoteService

<PageTitle>@Localization.GetString("PartnersDashboard") - @Localization.GetString("InvoiceSystem")</PageTitle>

<MudText Typo="Typo.h4" Class="mb-6">@Localization.GetString("BusinessPartners")</MudText>

@if (_loading)
{
    <MudProgressLinear Color="Color.Primary" Indeterminate="true" />
}
else
{
    <MudGrid>

        <!-- â”€â”€ Summary Cards â”€â”€ -->
        <MudItem xs="12" sm="6" md="4">
            <DashboardCard Title="@Localization.GetString("TotalCompanies")"
                           Subtitle="@($"{Localization.GetString("ActiveCompanies")}: {_activeCompaniesCount}")"
                           Value="@_totalCompanies.ToString()"
                           Icon="@Icons.Material.Filled.Business"
                           IconColor="Color.Default"
                           Link="/companies" />
        </MudItem>

        <MudItem xs="12" sm="6" md="4">
            <DashboardCard Title="@Localization.GetString("CompanyBreakdown")"
                           Value="@($"{_clientCount} / {_vendorCount}")"
                           Subtitle="@($"{Localization.GetString("Clients")} / {Localization.GetString("Vendors")}")"
                           Icon="@Icons.Material.Filled.PieChart"
                           IconColor="Color.Default" />
        </MudItem>

        <MudItem xs="12" sm="6" md="4">
            <DashboardCard Title="@Localization.GetString("TotalIndividuals")"
                           Value="@_totalIndividuals.ToString()"
                           Subtitle="@($"{Localization.GetString("DashboardActiveIndividuals")}: {_activeIndividualsCount}")"
                           Icon="@Icons.Material.Filled.Person"
                           IconColor="Color.Default"
                           Link="/individuals" />
        </MudItem>

        <!-- â”€â”€ Top Partners (left) + Attention Needed (right) â”€â”€ -->

        <MudItem xs="12" md="6">
            <div class="d-flex align-center flex-wrap gap-2 mb-3">
                <MudText Typo="Typo.h6">@Localization.GetString("TopPartners")</MudText>
                <WisDateRangeFilter @bind-DateRange="_partnerDateRange"
                                    @bind-DatePreset="_partnerDatePreset"
                                    Label="@Localization.GetString("Period")"
                                    MaxDate="DateTime.Today"
                                    OnChanged="RecalculateSummaries" />
            </div>
            <MudCard Elevation="2">
                <MudTabs Elevation="0"
                         Rounded="false"
                         ApplyEffectsToContainer="true"
                         >

                    <!-- Company Vendors (payable invoices) -->
                    <MudTabPanel Icon="@Icons.Material.Filled.Business"
                                 Text="@Localization.GetString("Vendor")"
                                 PanelClass="pa-0">
                        <div class="px-4 pt-3 pb-1">
                            <MudText Typo="Typo.caption" Color="Color.Secondary">
                                @Localization.GetString("ByTotalSpend")
                            </MudText>
                        </div>
                        @if (_topPayableVendors.Any())
                        {
                            <MudTable Items="_topPayableVendors"
                                      Hover="true"
                                      Dense="true"
                                      Elevation="0"
                                      Class="wis-secondary-list"
                                      T="PartnerSummaryDto"
                                      RowClass="table-row-clickable"
                                      OnRowClick="@((TableRowClickEventArgs<PartnerSummaryDto> args) => NavigateTo($"/companies/{args.Item!.PartnerId}"))">
                                <HeaderContent>
                                    <MudTh>#</MudTh>
                                    <MudTh>@Localization.GetString("Name")</MudTh>
                                    <MudTh>@Localization.GetString("Invoices")</MudTh>
                                    <MudTh Class="text-right">@Localization.GetString("Spent")</MudTh>
                                </HeaderContent>
                                <RowTemplate>
                                    <MudTd DataLabel="#">
                                        <MudText Typo="Typo.body2" Color="Color.Secondary">
                                            @(_topPayableVendors.IndexOf(context) + 1)
                                        </MudText>
                                    </MudTd>
                                    <MudTd DataLabel="@Localization.GetString("Name")">
                                        <MudText Typo="Typo.body2" Class="font-weight-medium">@context.PartnerName</MudText>
                                    </MudTd>
                                    <MudTd DataLabel="@Localization.GetString("Invoices")">
                                        <MudText Typo="Typo.body2" Color="Color.Secondary">@context.DocumentCount</MudText>
                                    </MudTd>
                                    <MudTd DataLabel="@Localization.GetString("Spent")" Class="text-right">
                                        <MudText Typo="Typo.body2" Class="font-weight-bold" Color="Color.Info">
                                            @context.TotalAmount.ToString("C")
                                        </MudText>
                                    </MudTd>
                                </RowTemplate>
                            </MudTable>
                        }
                        else
                        {
                            <WisNoRecordsContent Icon="@Icons.Material.Filled.Business"
                                                 Message="@Localization.GetString("NoInvoicesFound")" />
                        }
                    </MudTabPanel>

                    <!-- Company Clients (receivable invoices) -->
                    <MudTabPanel Icon="@Icons.Material.Filled.Business"
                                 Text="@Localization.GetString("Client")"
                                 PanelClass="pa-0">
                        <div class="px-4 pt-3 pb-1">
                            <MudText Typo="Typo.caption" Color="Color.Secondary">
                                @Localization.GetString("ByTotalRevenue")
                            </MudText>
                        </div>
                        @if (_topClients.Any())
                        {
                            <MudTable Items="_topClients"
                                      Hover="true"
                                      Dense="true"
                                      Elevation="0"
                                      Class="wis-secondary-list"
                                      T="PartnerSummaryDto"
                                      RowClass="table-row-clickable"
                                      OnRowClick="@((TableRowClickEventArgs<PartnerSummaryDto> args) => NavigateTo($"/companies/{args.Item!.PartnerId}"))">
                                <HeaderContent>
                                    <MudTh>#</MudTh>
                                    <MudTh>@Localization.GetString("Name")</MudTh>
                                    <MudTh>@Localization.GetString("Invoices")</MudTh>
                                    <MudTh Class="text-right">@Localization.GetString("Revenue")</MudTh>
                                </HeaderContent>
                                <RowTemplate>
                                    <MudTd DataLabel="#">
                                        <MudText Typo="Typo.body2" Color="Color.Secondary">
                                            @(_topClients.IndexOf(context) + 1)
                                        </MudText>
                                    </MudTd>
                                    <MudTd DataLabel="@Localization.GetString("Name")">
                                        <MudText Typo="Typo.body2" Class="font-weight-medium">@context.PartnerName</MudText>
                                    </MudTd>
                                    <MudTd DataLabel="@Localization.GetString("Invoices")">
                                        <MudText Typo="Typo.body2" Color="Color.Secondary">@context.DocumentCount</MudText>
                                    </MudTd>
                                    <MudTd DataLabel="@Localization.GetString("Revenue")" Class="text-right">
                                        <MudText Typo="Typo.body2" Class="font-weight-bold" Color="Color.Success">
                                            @context.TotalAmount.ToString("C")
                                        </MudText>
                                    </MudTd>
                                </RowTemplate>
                            </MudTable>
                        }
                        else
                        {
                            <WisNoRecordsContent Icon="@Icons.Material.Filled.Business"
                                                 Message="@Localization.GetString("NoInvoicesFound")" />
                        }
                    </MudTabPanel>

                    <!-- Individual Vendors (purchase notes) -->
                    <MudTabPanel Icon="@Icons.Material.Filled.Person"
                                 Text="@Localization.GetString("Vendor")"
                                 PanelClass="pa-0">
                        <div class="px-4 pt-3 pb-1">
                            <MudText Typo="Typo.caption" Color="Color.Secondary">
                                @Localization.GetString("ByTotalSpend")
                            </MudText>
                        </div>
                        @if (_topVendors.Any())
                        {
                            <MudTable Items="_topVendors"
                                      Hover="true"
                                      Dense="true"
                                      Elevation="0"
                                      Class="wis-secondary-list"
                                      T="PartnerSummaryDto"
                                      RowClass="table-row-clickable"
                                      OnRowClick="@((TableRowClickEventArgs<PartnerSummaryDto> args) => NavigateTo($"/individuals/{args.Item!.PartnerId}"))">
                                <HeaderContent>
                                    <MudTh>#</MudTh>
                                    <MudTh>@Localization.GetString("Name")</MudTh>
                                    <MudTh>@Localization.GetString("PurchaseNotesShort")</MudTh>
                                    <MudTh Class="text-right">@Localization.GetString("Spent")</MudTh>
                                </HeaderContent>
                                <RowTemplate>
                                    <MudTd DataLabel="#">
                                        <MudText Typo="Typo.body2" Color="Color.Secondary">
                                            @(_topVendors.IndexOf(context) + 1)
                                        </MudText>
                                    </MudTd>
                                    <MudTd DataLabel="@Localization.GetString("Name")">
                                        <MudText Typo="Typo.body2" Class="font-weight-medium">@context.PartnerName</MudText>
                                    </MudTd>
                                    <MudTd DataLabel="@Localization.GetString("PurchaseNotesShort")">
                                        <MudText Typo="Typo.body2" Color="Color.Secondary">@context.DocumentCount</MudText>
                                    </MudTd>
                                    <MudTd DataLabel="@Localization.GetString("Spent")" Class="text-right">
                                        <MudText Typo="Typo.body2" Class="font-weight-bold" Color="Color.Warning">
                                            @context.TotalAmount.ToString("C")
                                        </MudText>
                                    </MudTd>
                                </RowTemplate>
                            </MudTable>
                        }
                        else
                        {
                            <WisNoRecordsContent Icon="@Icons.Material.Filled.Person"
                                                 Message="@Localization.GetString("NoPurchaseNotesFound")" />
                        }
                    </MudTabPanel>

                </MudTabs>
            </MudCard>
        </MudItem>

        <!-- â”€â”€ Attention Needed â”€â”€ -->

        <MudItem xs="12" md="6">
            @{
                bool anyAttention = _overduePayableCompanies.Any() || _overdueClients.Any() || _unpaidVendors.Any();
            }
            <div class="d-flex align-center flex-wrap gap-2" style="margin-bottom: 18px;">
                <MudText Typo="Typo.h6" Class="d-flex align-center">
                    <MudIcon Icon="@(anyAttention ? Icons.Material.Filled.Warning : Icons.Material.Filled.CheckCircle)"
                             Class="mr-2"
                             Color="@(anyAttention ? Color.Warning : Color.Success)" />
                    @Localization.GetString("AttentionNeeded")
                </MudText>
            </div>
            <MudCard Elevation="2">
                <MudTabs Elevation="0"
                         Rounded="false"
                         ApplyEffectsToContainer="true"
                         >

                    <!-- Overdue Payables (companies) -->
                    <MudTabPanel Icon="@Icons.Material.Filled.AccountBalance"
                                 Text="@Localization.GetString("Payables")"
                                 PanelClass="pa-0"
                                 BadgeColor="Color.Error"
                                 BadgeDot="@(_overduePayableCompanies.Any())">
                        <div class="px-4 pt-3 pb-1">
                            <MudText Typo="Typo.caption" Color="Color.Secondary">
                                @Localization.GetString("OverduePayables")
                            </MudText>
                        </div>
                        @if (_overduePayableCompanies.Any())
                        {
                            <MudTable Items="_overduePayableCompanies"
                                      Hover="true"
                                      Dense="true"
                                      Elevation="0"
                                      Class="wis-secondary-list"
                                      T="PartnerAttentionDto"
                                      RowClass="table-row-clickable"
                                      OnRowClick="@((TableRowClickEventArgs<PartnerAttentionDto> args) => NavigateTo($"/invoices?companyId={args.Item!.PartnerId}&status=Overdue"))">
                                <HeaderContent>
                                    <MudTh>@Localization.GetString("Company")</MudTh>
                                    <MudTh>@Localization.GetString("Invoices")</MudTh>
                                    <MudTh Class="text-right">@Localization.GetString("Amount")</MudTh>
                                </HeaderContent>
                                <RowTemplate>
                                    <MudTd DataLabel="@Localization.GetString("Company")">
                                        <MudText Typo="Typo.body2" Class="font-weight-medium">@context.PartnerName</MudText>
                                    </MudTd>
                                    <MudTd DataLabel="@Localization.GetString("Invoices")">
                                        <MudChip T="string" Size="Size.Small" Color="Color.Error" Variant="Variant.Outlined">
                                            @context.Count
                                        </MudChip>
                                    </MudTd>
                                    <MudTd DataLabel="@Localization.GetString("Amount")" Class="text-right">
                                        <MudText Typo="Typo.body2" Class="font-weight-bold" Color="Color.Error">
                                            @context.Amount.ToString("C")
                                        </MudText>
                                    </MudTd>
                                </RowTemplate>
                            </MudTable>
                        }
                        else
                        {
                            <div class="pa-4 d-flex align-center gap-2">
                                <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Size="Size.Small" Color="Color.Success" />
                                <MudText Typo="Typo.caption" Color="Color.Success">@Localization.GetString("NoOpenPayables")</MudText>
                            </div>
                        }
                    </MudTabPanel>

                    <!-- Overdue Receivables (clients) -->
                    <MudTabPanel Icon="@Icons.Material.Filled.RequestQuote"
                                 Text="@Localization.GetString("Receivables")"
                                 PanelClass="pa-0"
                                 BadgeColor="Color.Error"
                                 BadgeDot="@(_overdueClients.Any())">
                        <div class="px-4 pt-3 pb-1">
                            <MudText Typo="Typo.caption" Color="Color.Secondary">
                                @Localization.GetString("OverdueReceivables")
                            </MudText>
                        </div>
                        @if (_overdueClients.Any())
                        {
                            <MudTable Items="_overdueClients"
                                      Hover="true"
                                      Dense="true"
                                      Elevation="0"
                                      Class="wis-secondary-list"
                                      T="PartnerAttentionDto"
                                      RowClass="table-row-clickable"
                                      OnRowClick="@((TableRowClickEventArgs<PartnerAttentionDto> args) => NavigateTo($"/invoices?companyId={args.Item!.PartnerId}&status=Overdue"))">
                                <HeaderContent>
                                    <MudTh>@Localization.GetString("Company")</MudTh>
                                    <MudTh>@Localization.GetString("Invoices")</MudTh>
                                    <MudTh Class="text-right">@Localization.GetString("Amount")</MudTh>
                                </HeaderContent>
                                <RowTemplate>
                                    <MudTd DataLabel="@Localization.GetString("Company")">
                                        <MudText Typo="Typo.body2" Class="font-weight-medium">@context.PartnerName</MudText>
                                    </MudTd>
                                    <MudTd DataLabel="@Localization.GetString("Invoices")">
                                        <MudChip T="string" Size="Size.Small" Color="Color.Error" Variant="Variant.Outlined">
                                            @context.Count
                                        </MudChip>
                                    </MudTd>
                                    <MudTd DataLabel="@Localization.GetString("Amount")" Class="text-right">
                                        <MudText Typo="Typo.body2" Class="font-weight-bold" Color="Color.Error">
                                            @context.Amount.ToString("C")
                                        </MudText>
                                    </MudTd>
                                </RowTemplate>
                            </MudTable>
                        }
                        else
                        {
                            <div class="pa-4 d-flex align-center gap-2">
                                <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Size="Size.Small" Color="Color.Success" />
                                <MudText Typo="Typo.caption" Color="Color.Success">@Localization.GetString("NoOverdueClients")</MudText>
                            </div>
                        }
                    </MudTabPanel>

                    <!-- Unpaid Purchase Notes (individuals) -->
                    <MudTabPanel Icon="@Icons.Material.Filled.Receipt"
                                 Text="@Localization.GetString("PurchaseNotesShort")"
                                 PanelClass="pa-0"
                                 BadgeColor="Color.Warning"
                                 BadgeDot="@(_unpaidVendors.Any())">
                        <div class="px-4 pt-3 pb-1">
                            <MudText Typo="Typo.caption" Color="Color.Secondary">
                                @Localization.GetString("UnpaidPurchaseNotes")
                            </MudText>
                        </div>
                        @if (_unpaidVendors.Any())
                        {
                            <MudTable Items="_unpaidVendors"
                                      Hover="true"
                                      Dense="true"
                                      Elevation="0"
                                      Class="wis-secondary-list"
                                      T="PartnerAttentionDto"
                                      RowClass="table-row-clickable"
                                      OnRowClick="@((TableRowClickEventArgs<PartnerAttentionDto> args) => NavigateTo($"/purchase-notes?individualId={args.Item!.PartnerId}&status=Pending"))">
                                <HeaderContent>
                                    <MudTh>@Localization.GetString("Individual")</MudTh>
                                    <MudTh>@Localization.GetString("PurchaseNotes")</MudTh>
                                    <MudTh Class="text-right">@Localization.GetString("Amount")</MudTh>
                                </HeaderContent>
                                <RowTemplate>
                                    <MudTd DataLabel="@Localization.GetString("Individual")">
                                        <MudText Typo="Typo.body2" Class="font-weight-medium">@context.PartnerName</MudText>
                                    </MudTd>
                                    <MudTd DataLabel="@Localization.GetString("PurchaseNotes")">
                                        <MudChip T="string" Size="Size.Small" Color="Color.Warning" Variant="Variant.Outlined">
                                            @context.Count
                                        </MudChip>
                                    </MudTd>
                                    <MudTd DataLabel="@Localization.GetString("Amount")" Class="text-right">
                                        <MudText Typo="Typo.body2" Class="font-weight-bold" Color="Color.Warning">
                                            @context.Amount.ToString("C")
                                        </MudText>
                                    </MudTd>
                                </RowTemplate>
                            </MudTable>
                        }
                        else
                        {
                            <div class="pa-4 d-flex align-center gap-2">
                                <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Size="Size.Small" Color="Color.Success" />
                                <MudText Typo="Typo.caption" Color="Color.Success">@Localization.GetString("NoUnpaidVendors")</MudText>
                            </div>
                        }
                    </MudTabPanel>

                </MudTabs>
            </MudCard>
        </MudItem>

    </MudGrid>
}

@code {
    private int _totalCompanies;
    private int _activeCompaniesCount;
    private int _clientCount;
    private int _vendorCount;
    private int _totalIndividuals;
    private int _activeIndividualsCount;

    private List<PartnerSummaryDto> _topPayableVendors = [];
    private List<PartnerSummaryDto> _topClients = [];
    private List<PartnerSummaryDto> _topVendors = [];
    private List<PartnerAttentionDto> _overdueClients = [];
    private List<PartnerAttentionDto> _unpaidVendors = [];
    private List<PartnerAttentionDto> _overduePayableCompanies = [];

    // â”€â”€ Partner stats date range â”€â”€
    private int? _partnerDatePreset = 365;
    private DateRange _partnerDateRange = new(DateTime.Today.AddDays(-365), DateTime.Today);
    private DateTime _partnerFromDate => _partnerDateRange.Start ?? DateTime.Today.AddDays(-365);
    private DateTime _partnerToDate => _partnerDateRange.End ?? DateTime.Today;
    private CancellationTokenSource _summaryCts = new();

    protected override async Task OnInitializedAsync()
    {
        await base.OnInitializedAsync();
        await LoadData();
    }

    private async Task LoadData()
    {
        _loading = true;

        try
        {
            var countsTask = CompanyService.GetPartnerCountsAsync(_cts.Token);
            var indsTask = IndividualService.GetCountsAsync(_cts.Token);
            var summariesTask = LoadPartnerSummaries(_cts.Token);

            await Task.WhenAll(countsTask, indsTask, summariesTask);

            var counts = countsTask.Result;
            _totalCompanies = counts.Total;
            _activeCompaniesCount = counts.Active;
            _clientCount = counts.Clients;
            _vendorCount = counts.Vendors;

            var (indTotal, indActive) = indsTask.Result;
            _totalIndividuals = indTotal;
            _activeIndividualsCount = indActive;
        }
        catch (Exception)
        {
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task LoadPartnerSummaries(CancellationToken ct)
    {
        var t1 = InvoiceService.GetTopPayableVendorsBySpendAsync(_partnerFromDate, _partnerToDate, 5, ct);
        var t2 = InvoiceService.GetTopClientsByRevenueAsync(_partnerFromDate, _partnerToDate, 5, ct);
        var t3 = PurchaseNoteService.GetTopVendorsBySpendAsync(_partnerFromDate, _partnerToDate, 5, ct);
        var t4 = InvoiceService.GetOverdueClientSummariesAsync(ct);
        var t5 = PurchaseNoteService.GetUnpaidVendorSummariesAsync(ct);
        var t6 = InvoiceService.GetOverduePayableCompanySummariesAsync(ct);

        await Task.WhenAll(t1, t2, t3, t4, t5, t6);

        if (ct.IsCancellationRequested) return;

        _topPayableVendors = t1.Result.ToList();
        _topClients = t2.Result.ToList();
        _topVendors = t3.Result.ToList();
        _overdueClients = t4.Result.ToList();
        _unpaidVendors = t5.Result.ToList();
        _overduePayableCompanies = t6.Result.ToList();
    }

    private async Task RecalculateSummaries()
    {
        await _summaryCts.CancelAsync();
        _summaryCts = new CancellationTokenSource();
        var ct = _summaryCts.Token;

        try
        {
            await Task.Delay(300, ct);
            await LoadPartnerSummaries(ct);
        }
        catch (OperationCanceledException) { }
    }

    protected override void Dispose(bool disposing)
    {
        if (disposing)
        {
            _summaryCts.Cancel();
            _summaryCts.Dispose();
        }
        base.Dispose(disposing);
    }

}
