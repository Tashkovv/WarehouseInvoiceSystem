@page "/partners-dashboard"
@inherits PageBase
@using WarehouseInvoiceSystem.Application.DTOs.Dashboard
@using WarehouseInvoiceSystem.Domain.Enums
@inject ICompanyService CompanyService
@inject IIndividualService IndividualService
@inject IInvoiceService InvoiceService
@inject IPurchaseNoteService PurchaseNoteService

<PageTitle>@Localization.GetString("PartnersDashboard") - @Localization.GetString("InvoiceSystem")</PageTitle>

<MudText Typo="Typo.h4" Class="mb-6">@Localization.GetString("BusinessPartners")</MudText>

@if (_loading)
{
    <MudProgressLinear Color="Color.Primary" Indeterminate="true" />
}
else
{
    <MudGrid>

        <!-- ── Summary Cards ── -->
        <MudItem xs="12" sm="6" md="4">
            <DashboardCard Title="@Localization.GetString("TotalCompanies")"
                           Subtitle="@($"{Localization.GetString("ActiveCompanies")}: {_activeCompaniesCount}")"
                           Value="@_totalCompanies.ToString()"
                           Icon="@Icons.Material.Filled.Business"
                           IconColor="Color.Primary" />
        </MudItem>

        <MudItem xs="12" sm="6" md="4">
            <DashboardCard Title="@Localization.GetString("CompanyBreakdown")"
                           Value="@($"{_clientCount} / {_vendorCount}")"
                           Subtitle="@($"{Localization.GetString("Clients")} / {Localization.GetString("Vendors")}")"
                           Icon="@Icons.Material.Filled.PieChart"
                           IconColor="Color.Info" />
        </MudItem>

        <MudItem xs="12" sm="6" md="4">
            <DashboardCard Title="@Localization.GetString("TotalIndividuals")"
                           Value="@_totalIndividuals.ToString()"
                           Subtitle="@($"{Localization.GetString("DashboardActiveIndividuals")}: {_activeIndividualsCount}")"
                           Icon="@Icons.Material.Filled.Person"
                           IconColor="Color.Secondary" />
        </MudItem>

        <!-- ── Top Clients / Top Vendors ── -->
        <MudItem xs="12">
            <div class="d-flex align-center flex-wrap gap-2 mb-2">
                <MudText Typo="Typo.h6">@Localization.GetString("TopPartners")</MudText>
                <WisDateRangeFilter @bind-DateRange="_partnerDateRange"
                                    @bind-DatePreset="_partnerDatePreset"
                                    Label="@Localization.GetString("Period")"
                                    MaxDate="DateTime.Today"
                                    OnChanged="RecalculateSummaries" />
            </div>
        </MudItem>

        <MudItem xs="12" md="4">
            <MudCard Elevation="2">
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudText Typo="Typo.h6">@Localization.GetString("TopPayableVendorsBySpend")</MudText>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">
                            @Localization.GetString("ByTotalSpend")
                        </MudText>
                    </CardHeaderContent>
                    <CardHeaderActions>
                        <WisButton Action="@NavAction(Icons.Material.Filled.List, Localization.GetString("Companies"), "/companies")" />
                    </CardHeaderActions>
                </MudCardHeader>
                <MudCardContent Class="pa-0">
                    @if (_topPayableVendors.Any())
                    {
                        <MudTable Items="_topPayableVendors"
                                  Hover="true"
                                  Dense="true"
                                  Elevation="0"
                                  Class="wis-secondary-list"
                                  T="PartnerSummaryDto"
                                  RowClass="table-row-clickable"
                                  OnRowClick="@((TableRowClickEventArgs<PartnerSummaryDto> args) => NavigateTo($"/companies/{args.Item!.PartnerId}"))">
                            <HeaderContent>
                                <MudTh>#</MudTh>
                                <MudTh>@Localization.GetString("Name")</MudTh>
                                <MudTh>@Localization.GetString("Invoices")</MudTh>
                                <MudTh Class="text-right">@Localization.GetString("TotalSpend")</MudTh>
                            </HeaderContent>
                            <RowTemplate>
                                <MudTd DataLabel="#">
                                    <MudText Typo="Typo.body2" Color="Color.Secondary">
                                        @(_topPayableVendors.IndexOf(context) + 1)
                                    </MudText>
                                </MudTd>
                                <MudTd DataLabel="@Localization.GetString("Name")">
                                    <MudText Typo="Typo.body2" Class="font-weight-medium">@context.PartnerName</MudText>
                                </MudTd>
                                <MudTd DataLabel="@Localization.GetString("Invoices")">
                                    <MudText Typo="Typo.body2" Color="Color.Secondary">@context.DocumentCount</MudText>
                                </MudTd>
                                <MudTd DataLabel="@Localization.GetString("TotalSpend")" Class="text-right">
                                    <MudText Typo="Typo.body2" Class="font-weight-bold" Color="Color.Info">
                                        @context.TotalAmount.ToString("C")
                                    </MudText>
                                </MudTd>
                            </RowTemplate>
                        </MudTable>
                    }
                    else
                    {
                        <div class="pa-6 text-center d-flex align-center">
                            <MudIcon Icon="@Icons.Material.Filled.Business"
                                     Size="Size.Large"
                                     Color="Color.Secondary"
                                     Class="mb-2" />
                            <MudText Color="Color.Secondary">@Localization.GetString("NoInvoicesFound")</MudText>
                        </div>
                    }
                </MudCardContent>
            </MudCard>
        </MudItem>

        <MudItem xs="12" md="4">
            <MudCard Elevation="2">
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudText Typo="Typo.h6">@Localization.GetString("TopClientsBySales")</MudText>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">
                            @Localization.GetString("ByTotalRevenue")
                        </MudText>
                    </CardHeaderContent>
                    <CardHeaderActions>
                        <WisButton Action="@NavAction(Icons.Material.Filled.List, Localization.GetString("Companies"), "/companies")" />
                    </CardHeaderActions>
                </MudCardHeader>
                <MudCardContent Class="pa-0">
                    @if (_topClients.Any())
                    {
                        <MudTable Items="_topClients"
                                  Hover="true"
                                  Dense="true"
                                  Elevation="0"
                                  Class="wis-secondary-list"
                                  T="PartnerSummaryDto"
                                  RowClass="table-row-clickable"
                                  OnRowClick="@((TableRowClickEventArgs<PartnerSummaryDto> args) => NavigateTo($"/companies/{args.Item!.PartnerId}"))">
                            <HeaderContent>
                                <MudTh>#</MudTh>
                                <MudTh>@Localization.GetString("Name")</MudTh>
                                <MudTh>@Localization.GetString("Invoices")</MudTh>
                                <MudTh Class="text-right">@Localization.GetString("TotalRevenue")</MudTh>
                            </HeaderContent>
                            <RowTemplate>
                                <MudTd DataLabel="#">
                                    <MudText Typo="Typo.body2" Color="Color.Secondary">
                                        @(_topClients.IndexOf(context) + 1)
                                    </MudText>
                                </MudTd>
                                <MudTd DataLabel="@Localization.GetString("Name")">
                                    <MudText Typo="Typo.body2" Class="font-weight-medium">@context.PartnerName</MudText>
                                </MudTd>
                                <MudTd DataLabel="@Localization.GetString("Invoices")">
                                    <MudText Typo="Typo.body2" Color="Color.Secondary">@context.DocumentCount</MudText>
                                </MudTd>
                                <MudTd DataLabel="@Localization.GetString("TotalRevenue")" Class="text-right">
                                    <MudText Typo="Typo.body2" Class="font-weight-bold" Color="Color.Success">
                                        @context.TotalAmount.ToString("C")
                                    </MudText>
                                </MudTd>
                            </RowTemplate>
                        </MudTable>
                    }
                    else
                    {
                        <div class="pa-6 text-center d-flex align-center">
                            <MudIcon Icon="@Icons.Material.Filled.Business"
                                     Size="Size.Large"
                                     Color="Color.Secondary"
                                     Class="mb-2" />
                            <MudText Color="Color.Secondary">@Localization.GetString("NoInvoicesFound")</MudText>
                        </div>
                    }
                </MudCardContent>
            </MudCard>
        </MudItem>

        <MudItem xs="12" md="4">
            <MudCard Elevation="2">
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudText Typo="Typo.h6">@Localization.GetString("TopVendorsBySpend")</MudText>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">
                            @Localization.GetString("ByTotalSpend")
                        </MudText>
                    </CardHeaderContent>
                    <CardHeaderActions>
                        <WisButton Action="@NavAction(Icons.Material.Filled.List, Localization.GetString("Individuals"), "/individuals")" />
                    </CardHeaderActions>
                </MudCardHeader>
                <MudCardContent Class="pa-0">
                    @if (_topVendors.Any())
                    {
                        <MudTable Items="_topVendors"
                                  Hover="true"
                                  Dense="true"
                                  Elevation="0"
                                  Class="wis-secondary-list"
                                  T="PartnerSummaryDto"
                                  RowClass="table-row-clickable"
                                  OnRowClick="@((TableRowClickEventArgs<PartnerSummaryDto> args) => NavigateTo($"/individuals/{args.Item!.PartnerId}"))">
                            <HeaderContent>
                                <MudTh>#</MudTh>
                                <MudTh>@Localization.GetString("Name")</MudTh>
                                <MudTh>@Localization.GetString("PurchaseNotes")</MudTh>
                                <MudTh Class="text-right">@Localization.GetString("TotalSpend")</MudTh>
                            </HeaderContent>
                            <RowTemplate>
                                <MudTd DataLabel="#">
                                    <MudText Typo="Typo.body2" Color="Color.Secondary">
                                        @(_topVendors.IndexOf(context) + 1)
                                    </MudText>
                                </MudTd>
                                <MudTd DataLabel="@Localization.GetString("Name")">
                                    <MudText Typo="Typo.body2" Class="font-weight-medium">@context.PartnerName</MudText>
                                </MudTd>
                                <MudTd DataLabel="@Localization.GetString("PurchaseNotes")">
                                    <MudText Typo="Typo.body2" Color="Color.Secondary">@context.DocumentCount</MudText>
                                </MudTd>
                                <MudTd DataLabel="@Localization.GetString("TotalSpend")" Class="text-right">
                                    <MudText Typo="Typo.body2" Class="font-weight-bold" Color="Color.Warning">
                                        @context.TotalAmount.ToString("C")
                                    </MudText>
                                </MudTd>
                            </RowTemplate>
                        </MudTable>
                    }
                    else
                    {
                        <div class="pa-6 text-center d-flex align-center">
                            <MudIcon Icon="@Icons.Material.Filled.Person"
                                     Size="Size.Large"
                                     Color="Color.Secondary"
                                     Class="mb-2" />
                            <MudText Color="Color.Secondary">@Localization.GetString("NoPurchaseNotesFound")</MudText>
                        </div>
                    }
                </MudCardContent>
            </MudCard>
        </MudItem>

        <!-- ── Partners Needing Attention ── -->
        <MudItem xs="12" Class="mt-2">
                <MudCard Elevation="2">
                    <MudCardHeader>
                        <CardHeaderContent>
                            @{
                                    bool anyAttention = _overdueClients.Any() || _unpaidVendors.Any() || _unpaidPayableCompanies.Any();
                                }
                            <MudText Typo="Typo.h6" Class="d-flex align-center">
                                <MudIcon Icon="@(anyAttention ? Icons.Material.Filled.Warning : Icons.Material.Filled.CheckCircle)"
                                         Class="mr-2"
                                         Color="@(anyAttention ? Color.Warning : Color.Success)" />
                                @Localization.GetString("AttentionNeeded")
                            </MudText>
                        </CardHeaderContent>
                    </MudCardHeader>
                    <MudCardContent Class="pa-0">
                        <MudGrid Spacing="0">

                            @* Companies with open payable invoices *@
                            <MudItem xs="12" md="4" Style="border-right: 2px solid var(--mud-palette-divider)">
                                <div class="pa-3 pb-1">
                                    <MudText Typo="Typo.subtitle2" Color="Color.Info" Class="mb-2 d-flex align-center">
                                        <MudIcon Icon="@Icons.Material.Filled.AccountBalance" Size="Size.Small" Class="mr-1" />
                                        @Localization.GetString("CompaniesWithOpenPayables")
                                    </MudText>
                                </div>
                                @if (_unpaidPayableCompanies.Any())
                                {
                                    <MudTable Items="_unpaidPayableCompanies"
                                              Hover="true"
                                              Dense="true"
                                              Elevation="0"
                                              Class="wis-secondary-list"
                                              T="PartnerAttentionDto"
                                              RowClass="table-row-clickable"
                                              OnRowClick="@((TableRowClickEventArgs<PartnerAttentionDto> args) => NavigateTo($"/companies/{args.Item!.PartnerId}"))">
                                        <HeaderContent>
                                            <MudTh>@Localization.GetString("Company")</MudTh>
                                            <MudTh>@Localization.GetString("Invoices")</MudTh>
                                            <MudTh Class="text-right">@Localization.GetString("Amount")</MudTh>
                                        </HeaderContent>
                                        <RowTemplate>
                                            <MudTd DataLabel="@Localization.GetString("Company")">
                                                <MudText Typo="Typo.body2" Class="font-weight-medium">@context.PartnerName</MudText>
                                            </MudTd>
                                            <MudTd DataLabel="@Localization.GetString("Invoices")">
                                                <MudChip T="string" Size="Size.Small" Color="Color.Info" Variant="Variant.Outlined">
                                                    @context.Count
                                                </MudChip>
                                            </MudTd>
                                            <MudTd DataLabel="@Localization.GetString("Amount")" Class="text-right">
                                                <MudText Typo="Typo.body2" Class="font-weight-bold" Color="Color.Info">
                                                    @context.Amount.ToString("C")
                                                </MudText>
                                            </MudTd>
                                        </RowTemplate>
                                    </MudTable>
                                }
                                else
                                {
                                    <div class="pa-4 pb-3 d-flex align-center gap-2">
                                        <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Size="Size.Small" Color="Color.Success" />
                                        <MudText Typo="Typo.caption" Color="Color.Success">@Localization.GetString("NoOpenPayables")</MudText>
                                    </div>
                                }
                            </MudItem>
                            
                            @* Clients with overdue invoices *@
                            <MudItem xs="12" md="4" Style="border-right: 2px solid var(--mud-palette-divider)">
                                <div class="pa-3 pb-1">
                                    <MudText Typo="Typo.subtitle2" Color="Color.Error" Class="mb-2 d-flex align-center">
                                        <MudIcon Icon="@Icons.Material.Filled.RequestQuote" Size="Size.Small" Class="mr-1" />
                                        @Localization.GetString("ClientsWithOverdueInvoices")
                                    </MudText>
                                </div>
                                @if (_overdueClients.Any())
                                {
                                    <MudTable Items="_overdueClients"
                                              Hover="true"
                                              Dense="true"
                                              Elevation="0"
                                              Class="wis-secondary-list"
                                              T="PartnerAttentionDto"
                                              RowClass="table-row-clickable"
                                              OnRowClick="@((TableRowClickEventArgs<PartnerAttentionDto> args) => NavigateTo($"/companies/{args.Item!.PartnerId}"))">
                                        <HeaderContent>
                                            <MudTh>@Localization.GetString("Company")</MudTh>
                                            <MudTh>@Localization.GetString("Invoices")</MudTh>
                                            <MudTh Class="text-right">@Localization.GetString("Amount")</MudTh>
                                        </HeaderContent>
                                        <RowTemplate>
                                            <MudTd DataLabel="@Localization.GetString("Company")">
                                                <MudText Typo="Typo.body2" Class="font-weight-medium">@context.PartnerName</MudText>
                                            </MudTd>
                                            <MudTd DataLabel="@Localization.GetString("Invoices")">
                                                <MudChip T="string" Size="Size.Small" Color="Color.Error" Variant="Variant.Outlined">
                                                    @context.Count
                                                </MudChip>
                                            </MudTd>
                                            <MudTd DataLabel="@Localization.GetString("Amount")" Class="text-right">
                                                <MudText Typo="Typo.body2" Class="font-weight-bold" Color="Color.Error">
                                                    @context.Amount.ToString("C")
                                                </MudText>
                                            </MudTd>
                                        </RowTemplate>
                                    </MudTable>
                                }
                                else
                                {
                                    <div class="pa-4 pb-3 d-flex align-center gap-2">
                                        <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Size="Size.Small" Color="Color.Success" />
                                        <MudText Typo="Typo.caption" Color="Color.Success">@Localization.GetString("NoOverdueClients")</MudText>
                                    </div>
                                }
                            </MudItem>
                            
                            @* Vendors with unpaid purchase notes *@
                            <MudItem xs="12" md="4">
                                <div class="pa-3 pb-1">
                                    <MudText Typo="Typo.subtitle2" Color="Color.Warning" Class="mb-2 d-flex align-center">
                                        <MudIcon Icon="@Icons.Material.Filled.Receipt" Size="Size.Small" Class="mr-1" />
                                        @Localization.GetString("VendorsWithUnpaidNotes")
                                    </MudText>
                                </div>
                                @if (_unpaidVendors.Any())
                                {
                                    <MudTable Items="_unpaidVendors"
                                              Hover="true"
                                              Dense="true"
                                              Elevation="0"
                                              Class="wis-secondary-list"
                                              T="PartnerAttentionDto"
                                              RowClass="table-row-clickable"
                                              OnRowClick="@((TableRowClickEventArgs<PartnerAttentionDto> args) => NavigateTo($"/individuals/{args.Item!.PartnerId}"))">
                                        <HeaderContent>
                                            <MudTh>@Localization.GetString("Individual")</MudTh>
                                            <MudTh>@Localization.GetString("PurchaseNotes")</MudTh>
                                            <MudTh Class="text-right">@Localization.GetString("Amount")</MudTh>
                                        </HeaderContent>
                                        <RowTemplate>
                                            <MudTd DataLabel="@Localization.GetString("Individual")">
                                                <MudText Typo="Typo.body2" Class="font-weight-medium">@context.PartnerName</MudText>
                                            </MudTd>
                                            <MudTd DataLabel="@Localization.GetString("PurchaseNotes")">
                                                <MudChip T="string" Size="Size.Small" Color="Color.Warning" Variant="Variant.Outlined">
                                                    @context.Count
                                                </MudChip>
                                            </MudTd>
                                            <MudTd DataLabel="@Localization.GetString("Amount")" Class="text-right">
                                                <MudText Typo="Typo.body2" Class="font-weight-bold" Color="Color.Warning">
                                                    @context.Amount.ToString("C")
                                                </MudText>
                                            </MudTd>
                                        </RowTemplate>
                                    </MudTable>
                                }
                                else
                                {
                                    <div class="pa-4 pb-3 d-flex align-center gap-2">
                                        <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Size="Size.Small" Color="Color.Success" />
                                        <MudText Typo="Typo.caption" Color="Color.Success">@Localization.GetString("NoUnpaidVendors")</MudText>
                                    </div>
                                }
                            </MudItem>

                        </MudGrid>
                    </MudCardContent>
                </MudCard>
        </MudItem>

    </MudGrid>
}

@code {
    private int _totalCompanies;
    private int _activeCompaniesCount;
    private int _clientCount;
    private int _vendorCount;
    private int _totalIndividuals;
    private int _activeIndividualsCount;

    private List<PartnerSummaryDto> _topPayableVendors = [];
    private List<PartnerSummaryDto> _topClients = [];
    private List<PartnerSummaryDto> _topVendors = [];
    private List<PartnerAttentionDto> _overdueClients = [];
    private List<PartnerAttentionDto> _unpaidVendors = [];
    private List<PartnerAttentionDto> _unpaidPayableCompanies = [];

    // ── Partner stats date range ──
    private int? _partnerDatePreset = 30;
    private DateRange _partnerDateRange = new(DateTime.Today.AddDays(-30), DateTime.Today);
    private DateTime _partnerFromDate => _partnerDateRange.Start ?? DateTime.Today.AddDays(-30);
    private DateTime _partnerToDate => _partnerDateRange.End ?? DateTime.Today;

    protected override async Task OnInitializedAsync()
    {
        await base.OnInitializedAsync();
        await LoadData();
    }

    private async Task LoadData()
    {
        _loading = true;

        try
        {
            var countsTask = CompanyService.GetPartnerCountsAsync(_cts.Token);
            var indsTask = IndividualService.GetCountsAsync(_cts.Token);
            var summariesTask = LoadPartnerSummaries();

            await Task.WhenAll(countsTask, indsTask, summariesTask);

            var counts = countsTask.Result;
            _totalCompanies = counts.Total;
            _activeCompaniesCount = counts.Active;
            _clientCount = counts.Clients;
            _vendorCount = counts.Vendors;

            var (indTotal, indActive) = indsTask.Result;
            _totalIndividuals = indTotal;
            _activeIndividualsCount = indActive;
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading partners data: {ex.Message}");
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task LoadPartnerSummaries()
    {
        var t1 = InvoiceService.GetTopPayableVendorsBySpendAsync(_partnerFromDate, _partnerToDate, 5, _cts.Token);
        var t2 = InvoiceService.GetTopClientsByRevenueAsync(_partnerFromDate, _partnerToDate, 5, _cts.Token);
        var t3 = PurchaseNoteService.GetTopVendorsBySpendAsync(_partnerFromDate, _partnerToDate, 5, _cts.Token);
        var t4 = InvoiceService.GetOverdueClientSummariesAsync(_cts.Token);
        var t5 = PurchaseNoteService.GetUnpaidVendorSummariesAsync(_cts.Token);
        var t6 = InvoiceService.GetUnpaidPayableCompanySummariesAsync(_cts.Token);

        await Task.WhenAll(t1, t2, t3, t4, t5, t6);

        _topPayableVendors = t1.Result.ToList();
        _topClients = t2.Result.ToList();
        _topVendors = t3.Result.ToList();
        _overdueClients = t4.Result.ToList();
        _unpaidVendors = t5.Result.ToList();
        _unpaidPayableCompanies = t6.Result.ToList();
    }

    private async Task RecalculateSummaries()
    {
        await LoadPartnerSummaries();
    }

}
