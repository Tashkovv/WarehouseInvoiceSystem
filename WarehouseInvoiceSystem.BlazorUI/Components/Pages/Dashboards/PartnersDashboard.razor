@page "/partners-dashboard"
@implements IDisposable
@using WarehouseInvoiceSystem.Application.DTOs.Company
@using WarehouseInvoiceSystem.Application.DTOs.Individual
@inject ICompanyService CompanyService
@inject IIndividualService IndividualService
@inject ILocalizationService Localization
@inject NavigationManager Navigation

<PageTitle>@Localization.GetString("PartnersDashboard") - @Localization.GetString("InvoiceSystem")</PageTitle>

<MudText Typo="Typo.h4" Class="mb-6">@Localization.GetString("BusinessPartners")</MudText>

@if (_loading)
{
    <MudProgressLinear Color="Color.Primary" Indeterminate="true" />
}
else
{
    <MudGrid>
        <!-- Summary Cards -->
        <MudItem xs="12" sm="6" md="4">
            <DashboardCard Title="@Localization.GetString("TotalCompanies")"
                           Subtitle="@($"{Localization.GetString("ActiveCompanies")}: {_activeCompanies.Count()}")"
                           Value="@_companies.Count.ToString()"
                           Icon="@Icons.Material.Filled.Business"
                           IconColor="Color.Primary"
                           Link="/companies" />
        </MudItem>

        <MudItem xs="12" sm="6" md="4">
            <DashboardCard Title="@Localization.GetString("CompanyBreakdown")"
                           Value="@($"{_clientCount} / {_vendorCount}")"
                           Subtitle="@($"{Localization.GetString("Clients")} / {Localization.GetString("Vendors")}")"
                           Icon="@Icons.Material.Filled.PieChart"
                           IconColor="Color.Info" />
        </MudItem>

        <MudItem xs="12" sm="6" md="4">
            <DashboardCard Title="@Localization.GetString("TotalIndividuals")"
                           Value="@_individuals.Count.ToString()"
                           Subtitle="@($"{Localization.GetString("DashboardActiveIndividuals")}: {_activeIndividuals.Count()}")"
                           Icon="@Icons.Material.Filled.Person"
                           IconColor="Color.Secondary"
                           Link="/individuals" />
        </MudItem>

        <!-- Recent Companies -->
        <MudItem xs="12" md="6">
            <MudCard Elevation="2">
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudText Typo="Typo.h6">@Localization.GetString("RecentlyAdded") — @Localization.GetString("Companies")</MudText>
                    </CardHeaderContent>
                    <CardHeaderActions>
                        <MudButton Href="/companies/create"
                                   Color="Color.Primary"
                                   Variant="Variant.Filled"
                                   Size="Size.Small"
                                   StartIcon="@Icons.Material.Filled.Add">
                            @Localization.GetString("Company")
                        </MudButton>
                    </CardHeaderActions>
                </MudCardHeader>
                <MudCardContent Class="pa-0">
                    @if (_recentCompanies.Any())
                    {
                        <MudTable Items="_recentCompanies"
                                  Hover="true"
                                  Dense="true"
                                  Elevation="0"
                                  T="CompanyDto"
                                  RowClass="table-row-clickable"
                                  OnRowClick="@((TableRowClickEventArgs<CompanyDto> args) => NavigateTo($"/companies/{args.Item!.Id}"))">
                            <HeaderContent>
                                <MudTh>@Localization.GetString("Name")</MudTh>
                                <MudTh>@Localization.GetString("Type")</MudTh>
                                <MudTh>@Localization.GetString("Status")</MudTh>
                                <MudTh>@Localization.GetString("Created")</MudTh>
                            </HeaderContent>
                            <RowTemplate>
                                <MudTd DataLabel="@Localization.GetString("Name")">
                                    <div class="d-flex align-center">
                                        <MudAvatar Color="Color.Primary" Size="Size.Small" Class="mr-2" Style="font-size: 0.75rem;">
                                            @context.Name.Substring(0, 1).ToUpper()
                                        </MudAvatar>
                                        <MudText Typo="Typo.body2" Class="font-weight-medium">@context.Name</MudText>
                                    </div>
                                </MudTd>
                                <MudTd DataLabel="@Localization.GetString("Type")">
                                    <MudChip T="string" Size="Size.Small"
                                             Color="@GetTypeColor(context.Type)">
                                        @GetTypeText(context.Type)
                                    </MudChip>
                                </MudTd>
                                <MudTd DataLabel="@Localization.GetString("Status")">
                                    <MudChip T="string" Size="Size.Small"
                                             Color="@(context.IsActive ? Color.Success : Color.Default)">
                                        @(context.IsActive? Localization.GetString("ActiveCompany") : Localization.GetString("InactiveCompany"))
                                    </MudChip>
                                </MudTd>
                                <MudTd DataLabel="@Localization.GetString("Created")">
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">
                                        @context.CreatedAt.ToString("dd MMM yyyy")
                                    </MudText>
                                </MudTd>
                            </RowTemplate>
                        </MudTable>
                    }
                    else
                    {
                        <div class="pa-6 text-center">
                            <MudIcon Icon="@Icons.Material.Filled.Business"
                                     Size="Size.Large"
                                     Color="Color.Secondary"
                                     Class="mb-2" />
                            <MudText Color="Color.Secondary">@Localization.GetString("NoCompaniesFound")</MudText>
                        </div>
                    }
                </MudCardContent>
                <MudCardActions Class="pa-4">
                    <MudButton Href="/companies"
                               Color="Color.Default"
                               Variant="Variant.Outlined"
                               StartIcon="@Icons.Material.Filled.List">
                        @Localization.GetString("Companies")
                    </MudButton>
                </MudCardActions>
            </MudCard>
        </MudItem>

        <!-- Recent Individuals -->
        <MudItem xs="12" md="6">
            <MudCard Elevation="2">
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudText Typo="Typo.h6">@Localization.GetString("RecentlyAdded") — @Localization.GetString("Individuals")</MudText>
                    </CardHeaderContent>
                    <CardHeaderActions>
                        <MudButton Href="/individuals/create"
                                   Color="Color.Primary"
                                   Variant="Variant.Filled"
                                   Size="Size.Small"
                                   StartIcon="@Icons.Material.Filled.Add">
                            @Localization.GetString("Individual")
                        </MudButton>
                    </CardHeaderActions>
                </MudCardHeader>
                <MudCardContent Class="pa-0">
                    @if (_recentIndividuals.Any())
                    {
                        <MudTable Items="_recentIndividuals"
                                  Hover="true"
                                  Dense="true"
                                  Elevation="0"
                                  T="IndividualDto"
                                  RowClass="table-row-clickable"
                                  OnRowClick="@((TableRowClickEventArgs<IndividualDto> args) => NavigateTo($"/individuals/{args.Item!.Id}"))">
                            <HeaderContent>
                                <MudTh>@Localization.GetString("Name")</MudTh>
                                <MudTh>@Localization.GetString("IdentificationNumber")</MudTh>
                                <MudTh>@Localization.GetString("Status")</MudTh>
                                <MudTh>@Localization.GetString("Created")</MudTh>
                            </HeaderContent>
                            <RowTemplate>
                                <MudTd DataLabel="@Localization.GetString("Name")">
                                    <div class="d-flex align-center">
                                        <MudAvatar Color="Color.Secondary" Size="Size.Small" Class="mr-2" Style="font-size: 0.75rem;">
                                            @context.FullName.Substring(0, 1).ToUpper()
                                        </MudAvatar>
                                        <MudText Typo="Typo.body2" Class="font-weight-medium">@context.FullName</MudText>
                                    </div>
                                </MudTd>
                                <MudTd DataLabel="@Localization.GetString("IdentificationNumber")">
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">
                                        @context.IdentificationNumber
                                    </MudText>
                                </MudTd>
                                <MudTd DataLabel="@Localization.GetString("Status")">
                                    <MudChip T="string" Size="Size.Small"
                                             Color="@(context.IsActive ? Color.Success : Color.Default)">
                                        @(context.IsActive? Localization.GetString("ActiveIndividual") : Localization.GetString("InactiveIndividual"))
                                    </MudChip>
                                </MudTd>
                                <MudTd DataLabel="@Localization.GetString("Created")">
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">
                                        @context.CreatedAt.ToString("dd MMM yyyy")
                                    </MudText>
                                </MudTd>
                            </RowTemplate>
                        </MudTable>
                    }
                    else
                    {
                        <div class="pa-6 text-center">
                            <MudIcon Icon="@Icons.Material.Filled.Person"
                                     Size="Size.Large"
                                     Color="Color.Secondary"
                                     Class="mb-2" />
                            <MudText Color="Color.Secondary">@Localization.GetString("NoIndividualsFound")</MudText>
                        </div>
                    }
                </MudCardContent>
                <MudCardActions Class="pa-4">
                    <MudButton Href="/individuals"
                               Color="Color.Default"
                               Variant="Variant.Outlined"
                               StartIcon="@Icons.Material.Filled.List">
                        @Localization.GetString("Individuals")
                    </MudButton>
                </MudCardActions>
            </MudCard>
        </MudItem>
    </MudGrid>
}

@code {
    private readonly CancellationTokenSource _cts = new();
    private bool _loading = true;
    private List<CompanyDto> _companies = [];
    private List<IndividualDto> _individuals = [];

    private IEnumerable<CompanyDto> _activeCompanies => _companies.Where(c => c.IsActive);
    private IEnumerable<IndividualDto> _activeIndividuals => _individuals.Where(i => i.IsActive);
    private IEnumerable<CompanyDto> _recentCompanies => _companies.OrderByDescending(c => c.CreatedAt).Take(5);
    private IEnumerable<IndividualDto> _recentIndividuals => _individuals.OrderByDescending(i => i.CreatedAt).Take(5);

    private int _clientCount = 0;
    private int _vendorCount = 0;

    protected override async Task OnInitializedAsync()
    {
        Localization.OnLanguageChanged += OnLanguageChanged;
        await LoadData();
    }

    private async void OnLanguageChanged()
    {
        await InvokeAsync(StateHasChanged);
    }

    private async Task LoadData()
    {
        _loading = true;

        try
        {
            IEnumerable<CompanyDto> companies = await CompanyService.GetAllCompaniesAsync(_cts.Token);
            _companies = companies.ToList();

            IEnumerable<IndividualDto> individuals = await IndividualService.GetAllIndividualsAsync(_cts.Token);
            _individuals = individuals.ToList();

            _clientCount = _companies.Count(c => c.Type == Domain.Enums.CompanyType.Client || c.Type == Domain.Enums.CompanyType.Both);
            _vendorCount = _companies.Count(c => c.Type == Domain.Enums.CompanyType.Vendor || c.Type == Domain.Enums.CompanyType.Both);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading partners data: {ex.Message}");
        }
        finally
        {
            _loading = false;
        }
    }

    private void NavigateTo(string url) => Navigation.NavigateTo(url);

    private Color GetTypeColor(Domain.Enums.CompanyType type) => type switch
    {
        Domain.Enums.CompanyType.Client => Color.Success,
        Domain.Enums.CompanyType.Vendor => Color.Warning,
        Domain.Enums.CompanyType.Both => Color.Info,
        _ => Color.Default
    };

    private string GetTypeText(Domain.Enums.CompanyType type) => type switch
    {
        Domain.Enums.CompanyType.Client => Localization.GetString("Client"),
        Domain.Enums.CompanyType.Vendor => Localization.GetString("Vendor"),
        Domain.Enums.CompanyType.Both => Localization.GetString("ClientAndVendor"),
        _ => type.ToString()
    };

    public void Dispose()
    {
        _cts.Cancel();
        _cts.Dispose();
        Localization.OnLanguageChanged -= OnLanguageChanged;
    }
}
