@code {
    private bool _loading = true;
    private List<ProductDto> _products = [];
    private List<WarehouseDto> _warehouses = [];
    private List<StockLevelDto> _stockLevels = [];
    private List<InventoryTransactionDto> _recentTransactions = [];

    private IEnumerable<ProductDto> _activeProducts => _products.Where(p => p.IsActive);

    private IEnumerable<StockLevelDto> _lowStockItems => _stockLevels.Where(sl => 
        sl.Quantity <= sl.MinimumQuantity && sl.Quantity > 0);
    // private IEnumerable<StockLevelDto> _outOfStockItems => _stockLevels.Where(sl => sl.Quantity == 0);

    private decimal _totalStockValue => _stockLevels.Sum(sl => sl.Quantity * GetProductPrice(sl.ProductId));

    private List<ProductStockSummary> _topByStock = [];
    //private List<ProductMovementSummary> _mostPurchased = [];
    //private List<ProductMovementSummary> _mostSold = [];

    private Guid _selectedWarehouseId;
    private string _selectedWarehouseName => _warehouses.FirstOrDefault(w => w.Id == _selectedWarehouseId)?.Name ?? "";

    protected override async Task OnInitializedAsync()
    {
        Localization.OnLanguageChanged += OnLanguageChanged;
        await LoadData(true);
    }

    private async void OnLanguageChanged()
    {
        await InvokeAsync(StateHasChanged);
    }

    private async Task LoadData(bool firstLoad)
    {
        _loading = true;

        try
        {
            // Load warehouses
            IEnumerable<WarehouseDto> warehouses = await WarehouseService.GetAllWarehousesAsync();
            _warehouses = warehouses.ToList();

            if (firstLoad)
            {
                _selectedWarehouseId = _warehouses.FirstOrDefault(w => w.IsDefault)?.Id ?? _warehouses.FirstOrDefault()?.Id ?? Guid.Empty;
            }

            if (_selectedWarehouseId == Guid.Empty) return;

            // Load stock levels for selected warehouse
            IEnumerable<StockLevelDto> stockLevels = await InventoryService.GetStockByWarehouseAsync(_selectedWarehouseId);
            _stockLevels = stockLevels.ToList();

            // Load all products
            IEnumerable<ProductDto> products = await ProductService.GetAllProductsAsync();
            _products = products.ToList();

            // Load recent transactions for selected warehouse
            IEnumerable<InventoryTransactionDto> transactions = await InventoryService.GetTransactionsByWarehouseAsync(_selectedWarehouseId);
            _recentTransactions = transactions.OrderByDescending(t => t.CreatedAt).Take(5).ToList();

            CalculateTopProducts();
            //await CalculateProductStatistics();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading inventory data: {ex.Message}");
        }
        finally
        {
            _loading = false;
        }
    }

    private void CalculateTopProducts()
    {
        var productGroups = _stockLevels
            .Where(sl => sl.Quantity > 0)
            .GroupBy(sl => sl.ProductId)
            .Select(g => new ProductStockSummary
            {
                ProductId = g.Key,
                ProductCode = _products.FirstOrDefault(p => p.Id == g.Key)?.Code ?? "",
                ProductName = _products.FirstOrDefault(p => p.Id == g.Key)?.Name ?? "",
                ProductUnit = _products.FirstOrDefault(p => p.Id == g.Key)?.Unit ?? "",
                TotalQuantity = g.Sum(sl => sl.Quantity),
                TotalValue = g.Sum(sl => sl.Quantity * GetProductPrice(g.Key))
            })
            .OrderByDescending(p => p.TotalQuantity)
            .ToList();

        _topByStock = productGroups;
    }

