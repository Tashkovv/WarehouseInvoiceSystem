@page "/inventory-dashboard"
@implements IDisposable
@using WarehouseInvoiceSystem.Application.Interfaces
@using WarehouseInvoiceSystem.Application.DTOs.Product
@using WarehouseInvoiceSystem.Application.DTOs.Warehouse
@using WarehouseInvoiceSystem.Application.DTOs.StockLevel
@inject IProductService ProductService
@inject IWarehouseService WarehouseService
@inject IInventoryService InventoryService
@inject ILocalizationService Localization

<PageTitle>@Localization.GetString("InventoryDashboard") - @Localization.GetString("InvoiceSystem")</PageTitle>

<MudText Typo="Typo.h4" Class="mb-6">@Localization.GetString("StockManagement")</MudText>

@if (_loading)
{
    <MudProgressLinear Color="Color.Primary" Indeterminate="true" />
}
else
{
    <MudGrid>
        <!-- Inventory Summary -->
        <MudItem xs="12">
            <MudText Typo="Typo.h6" Class="mb-4">@Localization.GetString("InventorySummary")</MudText>
        </MudItem>

        <MudItem xs="12" sm="6" md="3">
            <DashboardCard Title="@Localization.GetString("TotalProducts")"
                          Value="@_products.Count.ToString()"
                          Subtitle="@($"{Localization.GetString("Active")}: {_activeProducts.Count()}")"
                          Icon="@Icons.Material.Filled.Inventory2"
                          IconColor="Color.Primary"
                          Link="/products" />
        </MudItem>

        <MudItem xs="12" sm="6" md="3">
            <DashboardCard Title="@Localization.GetString("TotalStockValue")"
                          Value="@_totalStockValue.ToString("C")"
                          Subtitle="@Localization.GetString("AllWarehouses")"
                          Icon="@Icons.Material.Filled.AttachMoney"
                          IconColor="Color.Success"
                          Link="/inventory-dashboard" />
        </MudItem>

        <MudItem xs="12" sm="6" md="3">
            <DashboardCard Title="@Localization.GetString("Warehouses")"
                          Value="@_warehouses.Count.ToString()"
                          Subtitle="@Localization.GetString("Active")"
                          Icon="@Icons.Material.Filled.Warehouse"
                          IconColor="Color.Info"
                          Link="/warehouses" />
        </MudItem>

        <MudItem xs="12" sm="6" md="3">
            <DashboardCard Title="@Localization.GetString("LowStock")"
                          Value="@_lowStockItems.Count().ToString()"
                          Subtitle="@Localization.GetString("ProductsBelowMinimum")"
                          Icon="@Icons.Material.Filled.Warning"
                          IconColor="Color.Error"
                          Link="/inventory?filter=low-stock" />
        </MudItem>

        <!-- Alerts & Warnings -->
        @if (_lowStockItems.Any() || _outOfStockItems.Any())
        {
            <MudItem xs="12" Class="mt-6">
                <MudCard Elevation="2">
                    <MudCardHeader>
                        <CardHeaderContent>
                            <MudText Typo="Typo.h6" Color="Color.Error">
                                <MudIcon Icon="@Icons.Material.Filled.Warning" Class="mr-2" />
                                @Localization.GetString("AlertsAndWarnings")
                            </MudText>
                        </CardHeaderContent>
                    </MudCardHeader>
                    <MudCardContent>
                        <MudStack Spacing="3">
                            @if (_outOfStockItems.Any())
                            {
                                <MudAlert Severity="Severity.Error">
                                    <strong>@_outOfStockItems.Count()</strong> @Localization.GetString("ProductsOutOfStock")
                                </MudAlert>
                            }
                            @if (_lowStockItems.Any())
                            {
                                <MudAlert Severity="Severity.Warning">
                                    <strong>@_lowStockItems.Count()</strong> @Localization.GetString("ProductsBelowMinimum")
                                </MudAlert>
                            }
                        </MudStack>
                    </MudCardContent>
                    <MudCardActions>
                        <MudButton Href="/inventory" 
                                  Color="Color.Error" 
                                  Variant="Variant.Text"
                                  EndIcon="@Icons.Material.Filled.ArrowForward">
                            @Localization.GetString("ViewDetails")
                        </MudButton>
                    </MudCardActions>
                </MudCard>
            </MudItem>
        }

        <!-- Stock by Warehouse -->
        <MudItem xs="12" Class="mt-6">
            <MudText Typo="Typo.h6" Class="mb-4">@Localization.GetString("StockByWarehouse")</MudText>
        </MudItem>

        @foreach (var warehouse in _warehouses)
        {
            var warehouseStock = _stockLevels.Where(sl => sl.WarehouseId == warehouse.Id);
            var warehouseValue = warehouseStock.Sum(sl => sl.Quantity * GetProductPrice(sl.ProductId));
            var productCount = warehouseStock.Count();

            <MudItem xs="12" sm="6" md="4">
                <MudCard Elevation="2" Style="cursor: pointer;" @onclick="@(() => NavigateToWarehouse(warehouse.Id))">
                    <MudCardContent>
                        <MudStack Spacing="2">
                            <div class="d-flex justify-space-between align-center">
                                <MudText Typo="Typo.h6">@warehouse.Name</MudText>
                                @if (warehouse.IsDefault)
                                {
                                    <MudChip T="string" Size="Size.Small" Color="Color.Primary">@Localization.GetString("Default")</MudChip>
                                }
                            </div>
                            <MudDivider />
                            <div class="d-flex justify-space-between">
                                <MudText Typo="Typo.body2">@Localization.GetString("Products"):</MudText>
                                <MudText Typo="Typo.body2" Class="font-weight-bold">@productCount</MudText>
                            </div>
                            <div class="d-flex justify-space-between">
                                <MudText Typo="Typo.body2">@Localization.GetString("Value"):</MudText>
                                <MudText Typo="Typo.body2" Class="font-weight-bold">@warehouseValue.ToString("C")</MudText>
                            </div>
                        </MudStack>
                    </MudCardContent>
                </MudCard>
            </MudItem>
        }

        <!-- Top Products -->
        <MudItem xs="12" Class="mt-6">
            <MudCard Elevation="2">
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudText Typo="Typo.h6">@Localization.GetString("TopProducts")</MudText>
                    </CardHeaderContent>
                </MudCardHeader>
                <MudCardContent>
                    <MudGrid>
                        <MudItem xs="12" md="4">
                            <MudText Typo="Typo.subtitle2" Color="Color.Secondary">@Localization.GetString("HighestStock")</MudText>
                            @if (_topByStock.Any())
                            {
                                <MudList T="ProductStockSummary" Dense="true">
                                    @foreach (var item in _topByStock.Take(5))
                                    {
                                        <MudListItem Icon="@Icons.Material.Filled.Inventory2">
                                            <MudText Typo="Typo.body2">@item.ProductName</MudText>
                                            <MudText Typo="Typo.caption" Color="Color.Secondary">@item.TotalQuantity units</MudText>
                                        </MudListItem>
                                    }
                                </MudList>
                            }
                            else
                            {
                                <MudText Color="Color.Secondary">@Localization.GetString("NoProducts")</MudText>
                            }
                        </MudItem>

                        <MudItem xs="12" md="4">
                            <MudText Typo="Typo.subtitle2" Color="Color.Secondary">@Localization.GetString("HighestValue")</MudText>
                            @if (_topByValue.Any())
                            {
                                <MudList T="ProductStockSummary" Dense="true">
                                    @foreach (var item in _topByValue.Take(5))
                                    {
                                        <MudListItem Icon="@Icons.Material.Filled.AttachMoney">
                                            <MudText Typo="Typo.body2">@item.ProductName</MudText>
                                            <MudText Typo="Typo.caption" Color="Color.Secondary">@item.TotalValue.ToString("C")</MudText>
                                        </MudListItem>
                                    }
                                </MudList>
                            }
                            else
                            {
                                <MudText Color="Color.Secondary">@Localization.GetString("NoProducts")</MudText>
                            }
                        </MudItem>

                        <MudItem xs="12" md="4">
                            <MudText Typo="Typo.subtitle2" Color="Color.Secondary">@Localization.GetString("RecentlyAdded")</MudText>
                            @if (_recentProducts.Any())
                            {
                                <MudList T="ProductDto" Dense="true">
                                    @foreach (var product in _recentProducts.Take(5))
                                    {
                                        <MudListItem Icon="@Icons.Material.Filled.FiberNew" 
                                                    Href="@($"/products/{product.Id}")">
                                            <MudText Typo="Typo.body2">@product.Name</MudText>
                                            <MudText Typo="Typo.caption" Color="Color.Secondary">@product.Code</MudText>
                                        </MudListItem>
                                    }
                                </MudList>
                            }
                            else
                            {
                                <MudText Color="Color.Secondary">@Localization.GetString("NoProducts")</MudText>
                            }
                        </MudItem>
                    </MudGrid>
                </MudCardContent>
            </MudCard>
        </MudItem>

        <!-- Quick Actions -->
        <MudItem xs="12">
            <MudCard Elevation="2">
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudText Typo="Typo.h6">@Localization.GetString("QuickActions")</MudText>
                    </CardHeaderContent>
                </MudCardHeader>
                <MudCardContent>
                    <MudStack Row="true" Spacing="2" Wrap="Wrap.Wrap">
                        <MudButton Href="/products/create"
                                  Color="Color.Primary"
                                  Variant="Variant.Filled"
                                  StartIcon="@Icons.Material.Filled.Add">
                            @Localization.GetString("NewProduct")
                        </MudButton>
                        <MudButton Href="/inventory"
                                  Color="Color.Warning"
                                  Variant="Variant.Filled"
                                  StartIcon="@Icons.Material.Filled.Warning">
                            @Localization.GetString("ViewLowStock")
                        </MudButton>
                        <MudButton Href="/products"
                                  Color="Color.Default"
                                  Variant="Variant.Outlined"
                                  StartIcon="@Icons.Material.Filled.List">
                            @Localization.GetString("ViewAllProducts")
                        </MudButton>
                        <MudButton Href="/warehouses"
                                  Color="Color.Default"
                                  Variant="Variant.Outlined"
                                  StartIcon="@Icons.Material.Filled.Warehouse">
                            @Localization.GetString("ViewAllWarehouses")
                        </MudButton>
                    </MudStack>
                </MudCardContent>
            </MudCard>
        </MudItem>
    </MudGrid>
}

@code {
    private bool _loading = true;
    private List<ProductDto> _products = [];
    private List<WarehouseDto> _warehouses = [];
    private List<StockLevelDto> _stockLevels = [];

    private IEnumerable<ProductDto> _activeProducts => _products.Where(p => p.IsActive);
    private IEnumerable<ProductDto> _recentProducts => _products.OrderByDescending(p => p.CreatedAt).Take(5);
    
    private IEnumerable<StockLevelDto> _lowStockItems => _stockLevels.Where(sl => 
        sl.Quantity <= sl.MinimumQuantity && sl.Quantity > 0);
    private IEnumerable<StockLevelDto> _outOfStockItems => _stockLevels.Where(sl => sl.Quantity == 0);

    private decimal _totalStockValue => _stockLevels.Sum(sl => sl.Quantity * GetProductPrice(sl.ProductId));

    private List<ProductStockSummary> _topByStock = [];
    private List<ProductStockSummary> _topByValue = [];

    protected override async Task OnInitializedAsync()
    {
        Localization.OnLanguageChanged += OnLanguageChanged;
        await LoadData();
    }

    private async void OnLanguageChanged()
    {
        await InvokeAsync(StateHasChanged);
    }

    private async Task LoadData()
    {
        _loading = true;

        try
        {
            IEnumerable<ProductDto> products = await ProductService.GetAllProductsAsync();
            _products = products.ToList();

            IEnumerable<WarehouseDto> warehouses = await WarehouseService.GetAllWarehousesAsync();
            _warehouses = warehouses.ToList();

            // Load all stock levels (you'll need to implement this method in InventoryService)
            // For now, we'll use an empty list
            _stockLevels = []; // TODO: Implement GetAllStockLevelsAsync()

            CalculateTopProducts();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading inventory data: {ex.Message}");
        }
        finally
        {
            _loading = false;
        }
    }

    private void CalculateTopProducts()
    {
        // Group by product and calculate totals
        var productGroups = _stockLevels
            .GroupBy(sl => sl.ProductId)
            .Select(g => new ProductStockSummary
            {
                ProductId = g.Key,
                ProductName = _products.FirstOrDefault(p => p.Id == g.Key)?.Name ?? "",
                TotalQuantity = g.Sum(sl => sl.Quantity),
                TotalValue = g.Sum(sl => sl.Quantity * GetProductPrice(g.Key))
            })
            .ToList();

        _topByStock = productGroups.OrderByDescending(p => p.TotalQuantity).ToList();
        _topByValue = productGroups.OrderByDescending(p => p.TotalValue).ToList();
    }

    private decimal GetProductPrice(Guid productId)
    {
        return _products.FirstOrDefault(p => p.Id == productId)?.DefaultPrice ?? 0;
    }

    private void NavigateToWarehouse(Guid warehouseId)
    {
        // TODO: Navigate to warehouse inventory view
    }

    public void Dispose()
    {
        Localization.OnLanguageChanged -= OnLanguageChanged;
    }

    private class ProductStockSummary
    {
        public Guid ProductId { get; set; }
        public string ProductName { get; set; } = string.Empty;
        public decimal TotalQuantity { get; set; }
        public decimal TotalValue { get; set; }
    }
}