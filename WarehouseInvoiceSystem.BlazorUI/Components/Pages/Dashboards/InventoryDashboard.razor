    private string GetQuantityText(InventoryTransactionType type, decimal quantity)
    {
        if (type == InventoryTransactionType.Inbound)
        {
            return $"+{quantity.ToString("N2")}";
        }
        else if (type == InventoryTransactionType.Adjustment)
        {
            return quantity > 0 ? $"+{quantity.ToString("N2")}" : quantity.ToString("N2");
        }
        else
        {
            return $"-{quantity.ToString("N2")}";
        }
    }

    private Color GetQuantityColor(InventoryTransactionType type, decimal quantity)
    {
        if (type == InventoryTransactionType.Inbound)
        {
            return Color.Success;
        }
        else if (type == InventoryTransactionType.Adjustment)
        {
            return quantity > 0 ? Color.Success : Color.Error;
        }
        else
        {
            return Color.Error;
        }
    }

    private decimal GetProductPrice(Guid productId)
    {
        return _products.FirstOrDefault(p => p.Id == productId)?.DefaultPrice ?? 0;
    }

    private async Task OnWarehouseChanged(Guid id)
    {
        _selectedWarehouseId = id;
        await LoadData(false);
    }

    public void Dispose()
    {
        Localization.OnLanguageChanged -= OnLanguageChanged;
    }

    private class ProductStockSummary
    {
        public Guid ProductId { get; set; }
        public string ProductCode { get; set; } = string.Empty;
        public string ProductName { get; set; } = string.Empty;
        public string ProductUnit { get; set; } = string.Empty;
        public decimal TotalQuantity { get; set; }
        public decimal TotalValue { get; set; }
    }

