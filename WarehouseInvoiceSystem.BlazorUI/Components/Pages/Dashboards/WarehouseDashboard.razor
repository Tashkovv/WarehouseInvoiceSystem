        AdjustStockDialog.AdjustStockResult? dto = await WisDialog.ShowFormAsync<AdjustStockDialog, AdjustStockDialog.AdjustStockResult>(
            Localization.GetString("AdjustStock"),
            p => p.Add(x => x.PreSelectedWarehouseId, _selectedWarehouseId),
            MaxWidth.Small);

        if (dto is not null)
        {
            try
            {
                await InventoryService.AdjustStockAsync(dto.ProductId, dto.WarehouseId, dto.QuantityChange, dto.Reason);
                Snackbar.Add(Localization.GetString("StockAdjusted"), Severity.Success);
                await LoadData(false);
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Error adjusting stock: {ex.Message}");
                Snackbar.Add(Localization.GetString("ErrorAdjustingStock"), Severity.Error);
            }
        }
    }

