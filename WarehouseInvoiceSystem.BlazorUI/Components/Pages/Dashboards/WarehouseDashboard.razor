@page "/warehouse-dashboard"
@inherits PageBase
@using WarehouseInvoiceSystem.Application.DTOs.Product
@using WarehouseInvoiceSystem.Application.DTOs.Warehouse
@using WarehouseInvoiceSystem.Application.DTOs.StockLevel
@using WarehouseInvoiceSystem.Application.DTOs.InventoryTransaction
@using WarehouseInvoiceSystem.Application.DTOs.Dashboard
@using WarehouseInvoiceSystem.Domain.Enums
@using WarehouseInvoiceSystem.Domain.Queries
@using WarehouseInvoiceSystem.Domain.Queries.Common
@inject IProductService ProductService
@inject IWarehouseService WarehouseService
@inject IInventoryService InventoryService
@inject IInvoiceService InvoiceService
@inject IPurchaseNoteService PurchaseNoteService

<PageTitle>@Localization.GetString("WarehouseDashboard") - @Localization.GetString("InvoiceSystem")</PageTitle>

<div class="d-flex align-center justify-space-between flex-wrap gap-3 mb-6">
    <MudText Typo="Typo.h4">@Localization.GetString("Warehouse")</MudText>
    @if (!_loading && _warehouses.Any())
    {
        <WisAutocompleteFilter TValue="Guid"
                               Label="@Localization.GetString("Warehouse")"
                               Icon="@Icons.Material.Filled.Warehouse"
                               LoadItems="LoadWarehouseItems"
                               SelectedValue="@_selectedWarehouseId"
                               SelectedValueChanged="@(async (Guid v) => await OnWarehouseChanged(v))"
                               InitialLabel="@_selectedWarehouseName"
                               MinWidth="220px" />
    }
</div>

@if (_loading)
{
    <MudProgressLinear Color="Color.Primary" Indeterminate="true" />
}
else if (_selectedWarehouseId == Guid.Empty)
{
    <MudGrid>
        <MudItem xs="12">
            <MudCard Elevation="2">
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudText Typo="Typo.h6">@Localization.GetString("NoWarehousesCreateOne")</MudText>
                    </CardHeaderContent>
                </MudCardHeader>
                <MudCardContent Class="pa-6">
                    <MudButton StartIcon="@Icons.Material.Filled.Add"
                               Color="Color.Primary"
                               Variant="Variant.Filled"
                               Href="/warehouses/create">
                        @Localization.GetString("CreateWarehouse")
                    </MudButton>
                </MudCardContent>
            </MudCard>
        </MudItem>
    </MudGrid>
}
else
{
    <MudGrid>

        <!-- ── Summary Cards ── -->
        <MudItem xs="12" sm="6" md="3">
            <DashboardCard Title="@Localization.GetString("TotalProducts")"
                           Value="@_warehouseProducts.Count().ToString()"
                           Subtitle="@($"{Localization.GetString("ActiveProducts")}: {_activeProducts.Count()}")"
                           Icon="@Icons.Material.Filled.Inventory2"
                           IconColor="Color.Primary" />
        </MudItem>

        <MudItem xs="12" sm="6" md="3">
            <DashboardCard Title="@Localization.GetString("TotalStockValue")"
                           Value="@_totalStockValue.ToString("C")"
                           Subtitle="@_selectedWarehouseName"
                           Icon="@Icons.Material.Filled.AttachMoney"
                           IconColor="Color.Success" />
        </MudItem>

        <MudItem xs="12" sm="6" md="3">
            <DashboardCard Title="@Localization.GetString("LowStock")"
                           Value="@_lowStockItems.Count().ToString()"
                           Subtitle="@Localization.GetString("ProductsBelowMinimum")"
                           Icon="@Icons.Material.Filled.Warning"
                           IconColor="@(_lowStockItems.Any() ? Color.Error : Color.Success)" />
        </MudItem>

        <MudItem xs="12" sm="6" md="3">
            <DashboardCard Title="@Localization.GetString("OutOfStock")"
                           Value="@_outOfStockItems.Count().ToString()"
                           Icon="@Icons.Material.Filled.RemoveShoppingCart"
                           IconColor="@(_outOfStockItems.Any() ? Color.Error : Color.Success)" />
        </MudItem>

        <!-- ── Alerts & Warnings ── -->
        @if (_outOfStockItems.Any() || _lowStockItems.Any())
        {
            <MudItem xs="12" md="6" Style="display: flex;">
                <MudCard Elevation="2" Style="flex: 1;">
                    <MudCardHeader>
                        <CardHeaderContent>
                            <MudText Typo="Typo.h6" Class="d-flex align-center">
                                <MudIcon Icon="@Icons.Material.Filled.Warning" Class="mr-2" Color="Color.Error" />
                                @Localization.GetString("AlertsAndWarnings")
                            </MudText>
                        </CardHeaderContent>
                        <CardHeaderActions>
                            <WisButton Action="@NavAction(Icons.Material.Filled.Inventory2, Localization.GetString("Inventory"), "/inventory", Color.Secondary)" />
                        </CardHeaderActions>
                    </MudCardHeader>
                    <MudCardContent Class="pa-6">
                        <MudStack Spacing="2">
                            @if (_outOfStockItems.Any())
                            {
                                <MudAlert Severity="Severity.Error" Dense="true" NoIcon="false" Class="pa-2">
                                    <MudText Typo="Typo.body2">
                                        <strong>@_outOfStockItems.Count()</strong> @Localization.GetString("ProductsOutOfStock"):
                                        @string.Join(", ", _outOfStockItems.Take(5).Select(s =>
                                        _productDict.TryGetValue(s.ProductId, out var p) ? $"{p.Code} - {p.Name}" : ""))
                            @if (_outOfStockItems.Count() > 5)
                                        {
                                            <text> @($"{Localization.GetString("AndMore")} {_outOfStockItems.Count() - 5}")</text>
                                        }
                                    </MudText>
                                </MudAlert>
                            }
                            @if (_lowStockItems.Any())
                            {
                                <MudAlert Severity="Severity.Warning" Dense="true" NoIcon="false" Class="pa-2">
                                    <MudText Typo="Typo.body2">
                                        <strong>@_lowStockItems.Count()</strong> @Localization.GetString("ProductsBelowMinimum"):
                                        @string.Join(", ", _lowStockItems.Take(5).Select(s =>
                                        _productDict.TryGetValue(s.ProductId, out var p) ? $"{p.Code} - {p.Name}" : ""))
                            @if (_lowStockItems.Count() > 5)
                                        {
                                            <text> @($"{Localization.GetString("AndMore")} {_lowStockItems.Count() - 5}")</text>
                                        }
                                    </MudText>
                                </MudAlert>
                            }
                        </MudStack>
                    </MudCardContent>
                </MudCard>
            </MudItem>

            <MudItem xs="12" md="6" Class="d-flex align-center">
                <MudCard Elevation="2" Style="flex: 1;">
                    <MudCardHeader>
                        <CardHeaderContent>
                            <MudText Typo="Typo.h6">@Localization.GetString("QuickActions")</MudText>
                        </CardHeaderContent>
                    </MudCardHeader>
                    <MudCardContent>
                        <div class="d-flex justify-space-between gap-3 flex-wrap">
                            <WisButton Action="@(new WisDetailActionItem { Icon = Icons.Material.Filled.Tune, Label = Localization.GetString("AdjustStock"), OnClick = EventCallback.Factory.Create(this, OpenAdjustDialog) })"
                                       ButtonSize="Size.Large" />
                            <WisButton Action="@(new WisDetailActionItem { Icon = Icons.Material.Filled.CallMade, Label = Localization.GetString("TransferStock"), OnClick = EventCallback.Factory.Create(this, OpenTransferDialog) })"
                                       ButtonSize="Size.Large" />
                            <WisButton Action="@NavAction(Icons.Material.Filled.Add, Localization.GetString("PurchaseNote"), "/purchase-notes/create", Color.Primary)"
                                       ButtonSize="Size.Large" />
                        </div>
                    </MudCardContent>
                </MudCard>
            </MudItem>
        }

        <!-- ── Top Products By Stock ── -->
        <MudItem xs="12">
            <MudCard Elevation="2">
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudText Typo="Typo.h6">@Localization.GetString("TopProductsByStock")</MudText>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">@_selectedWarehouseName</MudText>
                    </CardHeaderContent>
                </MudCardHeader>
                <MudCardContent Class="pa-0">
                    @if (_topByStock.Any())
                    {
                        <MudTable Items="_topByStock.Take(10)"
                                  Hover="true"
                                  Dense="true"
                                  Elevation="0"
                                  Class="wis-secondary-list"
                                  T="ProductStockSummary"
                                  RowClass="table-row-clickable"
                                  OnRowClick="@((TableRowClickEventArgs<ProductStockSummary> args) => Navigation.NavigateTo($"/products/{args.Item!.ProductId}"))">
                            <HeaderContent>
                                <MudTh>#</MudTh>
                                <MudTh>@Localization.GetString("Product")</MudTh>
                                <MudTh Class="text-right">@Localization.GetString("Quantity")</MudTh>
                                <MudTh>@Localization.GetString("Status")</MudTh>
                                <MudTh Class="text-right">@Localization.GetString("Value")</MudTh>
                            </HeaderContent>
                            <RowTemplate Context="item">
                                <MudTd DataLabel="#">
                                    <MudText Typo="Typo.body2" Color="Color.Secondary">
                                        @(_topByStock.IndexOf(item) + 1)
                                    </MudText>
                                </MudTd>
                                <MudTd DataLabel="@Localization.GetString("Product")">
                                    <MudText Typo="Typo.body2" Class="font-weight-medium">@item.ProductCode - @item.ProductName</MudText>
                                </MudTd>
                                <MudTd DataLabel="@Localization.GetString("Quantity")" Class="text-right">
                                    <MudText Typo="Typo.body2" Class="font-weight-bold"
                                             Color="@(item.IsOutOfStock ? Color.Error : item.IsLowStock ? Color.Warning : Color.Default)">
                                        @item.TotalQuantity.ToString("N2") @item.ProductUnit
                                    </MudText>
                                </MudTd>
                                <MudTd DataLabel="@Localization.GetString("Status")">
                                    @if (item.IsOutOfStock)
                                    {
                                        <MudChip T="string" Size="Size.Small" Color="Color.Error" Variant="Variant.Outlined">
                                            @Localization.GetString("OutOfStock")
                                        </MudChip>
                                    }
                                    else if (item.IsLowStock)
                                    {
                                        <MudChip T="string" Size="Size.Small" Color="Color.Warning" Variant="Variant.Outlined">
                                            @Localization.GetString("LowStock")
                                        </MudChip>
                                    }
                                    else
                                    {
                                        <MudChip T="string" Size="Size.Small" Color="Color.Success" Variant="Variant.Outlined">
                                            @Localization.GetString("InStock")
                                        </MudChip>
                                    }
                                </MudTd>
                                <MudTd DataLabel="@Localization.GetString("Value")" Class="text-right">
                                    <MudText Typo="Typo.body2">@item.TotalValue.ToString("C")</MudText>
                                </MudTd>
                            </RowTemplate>
                        </MudTable>
                    }
                    else
                    {
                        <div class="pa-6 text-center d-flex align-center">
                            <MudIcon Icon="@Icons.Material.Filled.Inventory2" Size="Size.Large" Color="Color.Secondary" Class="mb-2" />
                            <MudText Color="Color.Secondary">@Localization.GetString("NoStockData")</MudText>
                        </div>
                    }
                </MudCardContent>
            </MudCard>
        </MudItem>

        <!-- ── Most Purchased / Most Sold ── -->
        <MudItem xs="12">
            <div class="d-flex align-center flex-wrap gap-2 mb-4">
                <MudText Typo="Typo.h6">@Localization.GetString("ProductStatistics")</MudText>
                <WisDateRangeFilter @bind-DateRange="_statsDateRange"
                                    @bind-DatePreset="_statsDatePreset"
                                    Label="@Localization.GetString("Period")"
                                    MaxDate="DateTime.Today"
                                    OnChanged="RecalculateStatistics" />
            </div>
        </MudItem>

        <!-- Most Purchased -->
        <MudItem xs="12" md="6">
            <MudCard Elevation="2">
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudText Typo="Typo.h6" Color="Color.Info" Class="d-flex align-center">
                            <MudIcon Icon="@Icons.Material.Filled.ShoppingCart" Class="mr-2" />
                            @Localization.GetString("MostPurchased")
                        </MudText>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">
                            @Localization.GetString("ByTotalSpend") — @_statsFromDate.ToString("dd MMM yyyy") - @_statsToDate.ToString("dd MMM yyyy")
                        </MudText>
                    </CardHeaderContent>
                </MudCardHeader>
                <MudCardContent Class="pa-0">
                    @if (_mostPurchased.Any())
                    {
                        <MudTable Items="_mostPurchased.Take(5)"
                                  Hover="true"
                                  Dense="true"
                                  Elevation="0"
                                  Class="wis-secondary-list"
                                  T="ProductMovementSummary"
                                  RowClass="table-row-clickable"
                                  OnRowClick="@((TableRowClickEventArgs<ProductMovementSummary> args) => Navigation.NavigateTo($"/products/{args.Item!.ProductId}"))">
                            <HeaderContent>
                                <MudTh>#</MudTh>
                                <MudTh>@Localization.GetString("Product")</MudTh>
                                <MudTh Class="text-right">@Localization.GetString("Quantity")</MudTh>
                                <MudTh Class="text-right">@Localization.GetString("Spent")</MudTh>
                            </HeaderContent>
                            <RowTemplate Context="item">
                                <MudTd DataLabel="#">
                                    <MudText Typo="Typo.body2" Color="Color.Secondary">
                                        @(_mostPurchased.IndexOf(item) + 1)
                                    </MudText>
                                </MudTd>
                                <MudTd DataLabel="@Localization.GetString("Product")">
                                    <MudText Typo="Typo.body2" Class="font-weight-medium">@item.ProductCode - @item.ProductName</MudText>
                                </MudTd>
                                <MudTd DataLabel="@Localization.GetString("Quantity")" Class="text-right">
                                    <MudText Typo="Typo.body2">@item.Quantity.ToString("N2") @item.Unit</MudText>
                                </MudTd>
                                <MudTd DataLabel="@Localization.GetString("Spent")" Class="text-right">
                                    <MudText Typo="Typo.body2" Class="font-weight-bold" Color="Color.Info">
                                        @item.TotalValue.ToString("C")
                                    </MudText>
                                </MudTd>
                            </RowTemplate>
                        </MudTable>
                    }
                    else
                    {
                        <div class="pa-6 text-center">
                            <MudText Color="Color.Secondary">@Localization.GetString("NoPurchaseData")</MudText>
                        </div>
                    }
                </MudCardContent>
            </MudCard>
        </MudItem>

        <!-- Most Sold -->
        <MudItem xs="12" md="6">
            <MudCard Elevation="2">
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudText Typo="Typo.h6" Color="Color.Success" Class="d-flex align-center">
                            <MudIcon Icon="@Icons.Material.Filled.PointOfSale" Class="mr-2" />
                            @Localization.GetString("MostSold")
                        </MudText>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">
                            @Localization.GetString("ByTotalRevenue") — @_statsFromDate.ToString("dd MMM yyyy") - @_statsToDate.ToString("dd MMM yyyy")
                        </MudText>
                    </CardHeaderContent>
                </MudCardHeader>
                <MudCardContent Class="pa-0">
                    @if (_mostSold.Any())
                    {
                        <MudTable Items="_mostSold.Take(5)"
                                  Hover="true"
                                  Dense="true"
                                  Elevation="0"
                                  Class="wis-secondary-list"
                                  T="ProductMovementSummary"
                                  RowClass="table-row-clickable"
                                  OnRowClick="@((TableRowClickEventArgs<ProductMovementSummary> args) => Navigation.NavigateTo($"/products/{args.Item!.ProductId}"))">
                            <HeaderContent>
                                <MudTh>#</MudTh>
                                <MudTh>@Localization.GetString("Product")</MudTh>
                                <MudTh Class="text-right">@Localization.GetString("Quantity")</MudTh>
                                <MudTh Class="text-right">@Localization.GetString("Revenue")</MudTh>
                            </HeaderContent>
                            <RowTemplate Context="item">
                                <MudTd DataLabel="#">
                                    <MudText Typo="Typo.body2" Color="Color.Secondary">
                                        @(_mostSold.IndexOf(item) + 1)
                                    </MudText>
                                </MudTd>
                                <MudTd DataLabel="@Localization.GetString("Product")">
                                    <MudText Typo="Typo.body2" Class="font-weight-medium">@item.ProductCode - @item.ProductName</MudText>
                                </MudTd>
                                <MudTd DataLabel="@Localization.GetString("Quantity")" Class="text-right">
                                    <MudText Typo="Typo.body2">@item.Quantity.ToString("N2") @item.Unit</MudText>
                                </MudTd>
                                <MudTd DataLabel="@Localization.GetString("Revenue")" Class="text-right">
                                    <MudText Typo="Typo.body2" Class="font-weight-bold" Color="Color.Success">
                                        @item.TotalValue.ToString("C")
                                    </MudText>
                                </MudTd>
                            </RowTemplate>
                        </MudTable>
                    }
                    else
                    {
                        <div class="pa-6 text-center">
                            <MudText Color="Color.Secondary">@Localization.GetString("NoSalesData")</MudText>
                        </div>
                    }
                </MudCardContent>
            </MudCard>
        </MudItem>

        <!-- ── Recent Stock Movements ── -->
        <MudItem xs="12">
            <MudCard Elevation="2">
                <MudCardHeader>
                    <CardHeaderContent>
                        <div class="d-flex align-center justify-space-between">
                            <div>
                                <MudText Typo="Typo.h6">@Localization.GetString("RecentStockMovements")</MudText>
                                <MudText Typo="Typo.caption" Color="Color.Secondary">
                                    @Localization.GetString("Last10Transactions") — @_selectedWarehouseName
                                </MudText>
                            </div>
                            <WisButton Action="@NavAction(Icons.Material.Filled.Inventory2, Localization.GetString("Inventory"), "/inventory", Color.Secondary)" />
                        </div>
                    </CardHeaderContent>
                </MudCardHeader>
                <MudCardContent Class="pa-0">
                    @if (_allTransactions.Any())
                    {
                        <MudTable Items="_allTransactions.Take(10)"
                                  Hover="true"
                                  Dense="true"
                                  Elevation="0"
                                  Class="wis-secondary-list"
                                  Breakpoint="Breakpoint.Sm"
                                  RowClass="table-row-clickable"
                                  T="InventoryTransactionDto"
                                  OnRowClick="@((TableRowClickEventArgs<InventoryTransactionDto> args) => Navigation.NavigateTo($"/products/{args.Item!.ProductId}/transactions?warehouse={_selectedWarehouseId}"))">
                            <HeaderContent>
                                <MudTh>@Localization.GetString("Product")</MudTh>
                                <MudTh>@Localization.GetString("Date")</MudTh>
                                <MudTh Class="text-right">@Localization.GetString("Quantity")</MudTh>
                                <MudTh>@Localization.GetString("Type")</MudTh>
                                <MudTh>@Localization.GetString("Note")</MudTh>
                            </HeaderContent>
                            <RowTemplate>
                                <MudTd DataLabel="@Localization.GetString("Product")">
                                    <MudText Typo="Typo.body2" Class="font-weight-medium">@context.ProductCode - @context.ProductName</MudText>
                                </MudTd>
                                <MudTd DataLabel="@Localization.GetString("Date")">
                                    <MudText Typo="Typo.body2">@context.CreatedAt.ToString("dd MMM yyyy")</MudText>
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">@context.CreatedAt.ToString("HH:mm")</MudText>
                                </MudTd>
                                <MudTd DataLabel="@Localization.GetString("Quantity")" Class="text-right">
                                    <MudText Typo="Typo.body2" Class="font-weight-bold"
                                             Color="@GetQuantityColor(context.Type, context.Quantity)">
                                        @GetQuantityText(context.Type, context.Quantity)
                                    </MudText>
                                </MudTd>
                                <MudTd DataLabel="@Localization.GetString("Type")">
                                    <MudChip T="string" Size="Size.Small" Color="@GetMovementTypeColor(context.Type)" Variant="Variant.Outlined" Icon="@GetMovementTypeIcon(context.Type)">
                                        @GetMovementTypeLabel(context.Type)
                                    </MudChip>
                                </MudTd>
                                <MudTd DataLabel="@Localization.GetString("Note")">
                                    <MudText Typo="Typo.body2">@(string.IsNullOrEmpty(context.Note) ? "-" : context.Note)</MudText>
                                </MudTd>
                            </RowTemplate>
                        </MudTable>
                    }
                    else
                    {
                        <div class="pa-6 text-center d-flex align-center">
                            <MudIcon Icon="@Icons.Material.Filled.SwapVert" Size="Size.Large" Color="Color.Secondary" Class="mb-2" />
                            <MudText Color="Color.Secondary">@Localization.GetString("NoRecentMovements")</MudText>
                        </div>
                    }
                </MudCardContent>
            </MudCard>
        </MudItem>

    </MudGrid>
}

@code {
    private List<ProductDto> _products = [];
    private List<WarehouseDto> _warehouses = [];
    private List<StockLevelDto> _stockLevels = [];
    private List<InventoryTransactionDto> _allTransactions = [];

    // ── Warehouse ──
    private Guid _selectedWarehouseId;
    private string _selectedWarehouseName =>
        _warehouses.FirstOrDefault(w => w.Id == _selectedWarehouseId)?.Name ?? "";

    // ── Stock filters — all already warehouse-scoped via _stockLevels ──
    private List<StockLevelDto> _lowStockItems = [];
    private List<StockLevelDto> _outOfStockItems = [];
    private decimal _totalStockValue;
    private List<ProductDto> _warehouseProducts = [];
    private List<ProductDto> _activeProducts = [];
    private Dictionary<Guid, ProductDto> _productDict = [];

    // ── Top by stock ──
    private List<ProductStockSummary> _topByStock = [];

    // ── Statistics date range ──
    private int? _statsDatePreset = 30;
    private DateRange _statsDateRange = new(DateTime.Today.AddDays(-30), DateTime.Today);
    private DateTime _statsFromDate => _statsDateRange.Start ?? new DateTime(DateTime.Today.Year, DateTime.Today.Month, 1);
    private DateTime _statsToDate => _statsDateRange.End ?? DateTime.Today;

    // ── Most purchased / most sold ──
    private List<ProductMovementDto> _purchasedMovements = [];
    private List<ProductMovementDto> _soldMovements = [];
    private List<ProductMovementSummary> _mostPurchased = [];
    private List<ProductMovementSummary> _mostSold = [];

    protected override async Task OnInitializedAsync()
    {
        await base.OnInitializedAsync();
        await LoadData(true);
    }

    private async Task LoadData(bool firstLoad)
    {
        _loading = true;

        try
        {
            IEnumerable<WarehouseDto> warehouses = await WarehouseService.GetAllWarehousesAsync(_cts.Token);
            _warehouses = warehouses.ToList();

            if (firstLoad)
            {
                _selectedWarehouseId = _warehouses.FirstOrDefault(w => w.IsDefault)?.Id
                    ?? _warehouses.FirstOrDefault()?.Id
                    ?? Guid.Empty;
            }

            if (_selectedWarehouseId == Guid.Empty) return;

            if (firstLoad)
            {
                await Task.WhenAll(LoadWarehouseData(), LoadStaticData());
            }
            else
            {
                await LoadWarehouseData();
            }

            RebuildStockDerivedFields();
            CalculateTopProducts();
            await LoadProductStatistics();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading inventory data: {ex.Message}");
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task LoadWarehouseData()
    {
        var stockTask = InventoryService.GetStockByWarehouseAsync(_selectedWarehouseId);
        var txTask = InventoryService.GetTransactionsByWarehouseAsync(_selectedWarehouseId);

        await Task.WhenAll(stockTask, txTask);

        _stockLevels = stockTask.Result.ToList();
        _allTransactions = txTask.Result
            .OrderByDescending(t => t.CreatedAt)
            .ToList();
    }

    private async Task LoadStaticData()
    {
        IEnumerable<ProductDto> products = await ProductService.GetAllProductsAsync(_cts.Token);
        _products = products.ToList();
        _productDict = _products.ToDictionary(p => p.Id);
    }

    private void RebuildStockDerivedFields()
    {
        _lowStockItems = _stockLevels
            .Where(sl => sl.Quantity > 0 && sl.MinimumQuantity.HasValue && sl.Quantity <= sl.MinimumQuantity)
            .ToList();
        _outOfStockItems = _stockLevels.Where(sl => sl.Quantity == 0).ToList();

        var stockedProductIds = _stockLevels.Select(sl => sl.ProductId).ToHashSet();
        _warehouseProducts = _products.Where(p => stockedProductIds.Contains(p.Id)).ToList();
        _activeProducts = _warehouseProducts.Where(p => p.IsActive).ToList();

        _totalStockValue = _stockLevels.Sum(sl =>
            sl.Quantity * (_productDict.TryGetValue(sl.ProductId, out var p) ? p.DefaultPrice : 0));
    }

    private async Task LoadProductStatistics()
    {
        var noteMovementsTask = PurchaseNoteService.GetProductPurchasesByWarehouseAsync(
            _selectedWarehouseId, _statsFromDate, _statsToDate, _cts.Token);
        var payableMovementsTask = InvoiceService.GetProductMovementByWarehouseAsync(
            _selectedWarehouseId, InvoiceType.Payable, _statsFromDate, _statsToDate, _cts.Token);
        var soldMovementsTask = InvoiceService.GetProductMovementByWarehouseAsync(
            _selectedWarehouseId, InvoiceType.Receivable, _statsFromDate, _statsToDate, _cts.Token);

        await Task.WhenAll(noteMovementsTask, payableMovementsTask, soldMovementsTask);

        // Merge purchase note and payable invoice movements for "most purchased"
        _purchasedMovements = noteMovementsTask.Result
            .Concat(payableMovementsTask.Result)
            .GroupBy(m => m.ProductId)
            .Select(g => new ProductMovementDto
            {
                ProductId = g.Key,
                Quantity = g.Sum(m => m.Quantity),
                TotalAmount = g.Sum(m => m.TotalAmount)
            })
            .ToList();

        _soldMovements = soldMovementsTask.Result.ToList();

        CalculateProductStatistics();
    }

    private async Task OnWarehouseChanged(Guid id)
    {
        _selectedWarehouseId = id;
        await LoadData(false);
    }

    private void CalculateTopProducts()
    {
        _topByStock = _stockLevels
            .GroupBy(sl => sl.ProductId)
            .Select(g =>
            {
                StockLevelDto? first = g.FirstOrDefault();
                _productDict.TryGetValue(g.Key, out ProductDto? product);
                decimal qty = g.Sum(sl => sl.Quantity);
                decimal min = first?.MinimumQuantity ?? 0;

                return new ProductStockSummary
                {
                    ProductId = g.Key,
                    ProductCode = product?.Code ?? "",
                    ProductName = product?.Name ?? "",
                    ProductUnit = product?.Unit ?? "",
                    TotalQuantity = qty,
                    TotalValue = qty * (product?.DefaultPrice ?? 0),
                    IsOutOfStock = qty == 0,
                    IsLowStock = qty > 0 && first?.MinimumQuantity.HasValue == true && qty <= min
                };
            })
            .OrderByDescending(p => p.TotalQuantity)
            .ToList();
    }

    private void CalculateProductStatistics()
    {
        _mostPurchased = _purchasedMovements
            .Select(m =>
            {
                _productDict.TryGetValue(m.ProductId, out ProductDto? product);
                return new ProductMovementSummary
                {
                    ProductId = m.ProductId,
                    ProductCode = product?.Code ?? "",
                    ProductName = product?.Name ?? "",
                    Unit = product?.Unit ?? "",
                    Quantity = m.Quantity,
                    TotalValue = m.TotalAmount
                };
            })
            .OrderByDescending(p => p.TotalValue)
            .ToList();

        _mostSold = _soldMovements
            .Select(m =>
            {
                _productDict.TryGetValue(m.ProductId, out ProductDto? product);
                return new ProductMovementSummary
                {
                    ProductId = m.ProductId,
                    ProductCode = product?.Code ?? "",
                    ProductName = product?.Name ?? "",
                    Unit = product?.Unit ?? "",
                    Quantity = m.Quantity,
                    TotalValue = m.TotalAmount
                };
            })
            .OrderByDescending(p => p.TotalValue)
            .ToList();
    }

    private async Task RecalculateStatistics()
    {
        await LoadProductStatistics();
    }

    private async Task OpenAdjustDialog()
    {
        if (await WisDialog.ShowFormAsync<AdjustStockDialog, bool>(
                Localization.GetString("AdjustStock"),
                p => p.Add(x => x.PreSelectedWarehouseId, _selectedWarehouseId),
                MaxWidth.Small) == true)
            await LoadData(false);
    }

    private async Task OpenTransferDialog()
    {
        if (await WisDialog.ShowFormAsync<TransferStockDialog, bool>(
                Localization.GetString("TransferStock"),
                p => p.Add(x => x.PreSelectedSourceWarehouseId, _selectedWarehouseId),
                MaxWidth.Small) == true)
            await LoadData(false);
    }

    private async Task<PagedResult<WisAutocompleteItem<Guid>>> LoadWarehouseItems(
        string search, int page, CancellationToken ct)
    {
        PagedResult<WarehouseDto> result = await WarehouseService.GetPagedAsync(new GetWarehousesQuery
        {
            Search = search,
            Page = page,
            PageSize = 20,
            SortBy = "Name",
            SortAscending = true,
        }, ct);

        return new PagedResult<WisAutocompleteItem<Guid>>
        {
            Items = result.Items.Select(w => new WisAutocompleteItem<Guid>
            {
                Label = w.Name + (w.IsDefault ? $" ({Localization.GetString("Default")})" : ""),
                Value = w.Id
            }).ToList(),
            TotalCount = result.TotalCount
        };
    }

    private class ProductStockSummary
    {
        public Guid ProductId { get; set; }
        public string ProductCode { get; set; } = string.Empty;
        public string ProductName { get; set; } = string.Empty;
        public string ProductUnit { get; set; } = string.Empty;
        public decimal TotalQuantity { get; set; }
        public decimal TotalValue { get; set; }
        public bool IsOutOfStock { get; set; }
        public bool IsLowStock { get; set; }
    }

    private class ProductMovementSummary
    {
        public Guid ProductId { get; set; }
        public string ProductCode { get; set; } = string.Empty;
        public string ProductName { get; set; } = string.Empty;
        public string Unit { get; set; } = string.Empty;
        public decimal Quantity { get; set; }
        public decimal TotalValue { get; set; }
    }
}
