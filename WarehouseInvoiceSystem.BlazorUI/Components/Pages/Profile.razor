@page "/profile"
@attribute [Authorize(Roles = "Admin")]
@inherits PageBase
@using WarehouseInvoiceSystem.Application.DTOs.Tenant
@inject ITenantService TenantService

<PageTitle>@Localization.GetString("Profile") - @Localization.GetString("InvoiceSystem")</PageTitle>

<div class="wis-page-header">
    <MudText Typo="Typo.h3" Class="wis-page-title">
        @Localization.GetString("Profile")
    </MudText>
</div>

@if (_loading)
{
    <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="mb-4" />
}
else
{
    <MudStack Spacing="4">

        @* ── Row: Company Info + Banking + Email ─────────────────────────── *@
        <MudGrid>
            <MudItem xs="12" md="4">
                <MudCard Elevation="2" Style="height: 100%;">
                    <MudCardHeader Style="align-items: center;">
                        <CardHeaderAvatar>
                            <MudIcon Icon="@Icons.Material.Filled.Business" Color="Color.Primary" />
                        </CardHeaderAvatar>
                        <CardHeaderContent>
                            <MudText Typo="Typo.h6">@Localization.GetString("CompanyInfo")</MudText>
                        </CardHeaderContent>
                        <CardHeaderActions>
                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                @if (_logoPreviewUrl is not null)
                                {
                                    <button type="button" class="wis-logo-preview-btn"
                                            @onclick="@(() => _showLightbox = true)">
                                        <img src="@_logoPreviewUrl"
                                             alt="Logo preview"
                                             style="max-height: 36px; max-width: 120px; object-fit: contain; border-radius: 4px; display: block;" />
                                    </button>
                                    <MudIconButton Icon="@Icons.Material.Filled.DeleteForever"
                                                   Color="Color.Error"
                                                   Size="Size.Small"
                                                   OnClick="RemoveLogo"
                                                   title="@Localization.GetString("Remove")" />
                                }
                                <MudFileUpload @ref="_fileUploadRef"
                                               T="IBrowserFile"
                                               Accept=".png,.jpg,.jpeg"
                                               FilesChanged="OnLogoSelected"
                                               MaximumFileCount="1">
                                    <CustomContent>
                                        <MudIconButton Icon="@Icons.Material.Filled.CloudUpload"
                                                       Color="Color.Primary"
                                                       Size="Size.Small"
                                                       OnClick="OpenFilePickerAsync"
                                                       title="@Localization.GetString("Upload")" />
                                    </CustomContent>
                                </MudFileUpload>
                            </MudStack>
                        </CardHeaderActions>
                    </MudCardHeader>
                    <MudDivider />
                    <MudCardContent>
                        <MudGrid>
                            <MudItem xs="12">
                                <WisInput @bind-Value="_companyName"
                                          Label="@Localization.GetString("Name")"
                                          Required="true" />
                            </MudItem>
                            <MudItem xs="12" sm="6">
                                <WisInput @bind-Value="_taxId"
                                          Label="@Localization.GetString("TaxId")" />
                            </MudItem>
                            <MudItem xs="12" sm="6">
                                <WisInput @bind-Value="_embs"
                                          Label="@Localization.GetString("Embs")" />
                            </MudItem>
                            <MudItem xs="12" sm="6">
                                <WisInput @bind-Value="_phone"
                                          Label="@Localization.GetString("Phone")" />
                            </MudItem>
                            <MudItem xs="12" sm="6">
                                <WisInput @bind-Value="_address"
                                          Label="@Localization.GetString("Address")" />
                            </MudItem>
                        </MudGrid>
                        @if (_logoValidationError is not null)
                        {
                            <MudText Typo="Typo.caption" Color="Color.Error" Class="mt-2 d-block">@_logoValidationError</MudText>
                        }
                    </MudCardContent>
                </MudCard>
            </MudItem>
            <MudItem xs="12" md="4">
                <MudCard Elevation="2" Style="height: 100%;">
                    <MudCardHeader Style="align-items: center;">
                        <CardHeaderAvatar>
                            <MudIcon Icon="@Icons.Material.Filled.AccountBalance" Color="Color.Primary" />
                        </CardHeaderAvatar>
                        <CardHeaderContent>
                            <MudText Typo="Typo.h6">@Localization.GetString("BankingSection")</MudText>
                        </CardHeaderContent>
                    </MudCardHeader>
                    <MudDivider />
                    <MudCardContent>
                        <MudGrid>
                            <MudItem xs="12">
                                <WisInput @bind-Value="_bankAccount"
                                          Label="@Localization.GetString("BankAccount")" />
                            </MudItem>
                            <MudItem xs="12">
                                <WisInput @bind-Value="_bankName"
                                          Label="@Localization.GetString("BankName")" />
                            </MudItem>
                            <MudItem xs="12">
                                <WisInput @bind-Value="_bankBranch"
                                          Label="@Localization.GetString("BankBranch")" />
                            </MudItem>
                        </MudGrid>
                    </MudCardContent>
                </MudCard>
            </MudItem>
            <MudItem xs="12" md="4">
                <MudCard Elevation="2" Style="height: 100%;">
                    <MudCardHeader Style="align-items: center;">
                        <CardHeaderAvatar>
                            <MudIcon Icon="@Icons.Material.Filled.Email" Color="Color.Primary" />
                        </CardHeaderAvatar>
                        <CardHeaderContent>
                            <MudText Typo="Typo.h6">@Localization.GetString("EmailSettings")</MudText>
                        </CardHeaderContent>
                    </MudCardHeader>
                    <MudDivider />
                    <MudCardContent>
                        <MudGrid>
                            <MudItem xs="12">
                                <WisInput @bind-Value="_email"
                                          Label="@Localization.GetString("Email")"
                                          InputType="email" />
                            </MudItem>
                            <MudItem xs="12">
                                <WisInput @bind-Value="_emailPassword"
                                          Label="@Localization.GetString("EmailPassword")"
                                          InputType="@(_showPassword ? "text" : "password")"
                                          HelperText="@PasswordHelperText"
                                          SuffixIcon="@(_showPassword ? Icons.Material.Filled.Visibility : Icons.Material.Filled.VisibilityOff)"
                                          OnSuffixIconClick="@(() => _showPassword = !_showPassword)" />
                            </MudItem>
                        </MudGrid>
                    </MudCardContent>
                </MudCard>
            </MudItem>
        </MudGrid>

        @* ── Save ─────────────────────────────────────────────────────────── *@
        <MudStack Row="true" Justify="Justify.FlexEnd">
            <WisButton Action="@_saveAction" ButtonSize="Size.Large"/>
        </MudStack>

    </MudStack>
}

@if (_showLightbox && _logoPreviewUrl is not null)
{
    <div class="wis-lightbox" @onclick="@(() => _showLightbox = false)">
        <img src="@_logoPreviewUrl"
             class="wis-lightbox__img"
             alt="Logo"
             @onclick:stopPropagation />
        <button type="button" class="wis-lightbox__close" @onclick="@(() => _showLightbox = false)">
            <MudIcon Icon="@Icons.Material.Filled.Close" />
        </button>
    </div>
}

@code {
    // Form state
    private string _companyName = string.Empty;
    private string? _address;
    private string? _phone;
    private string? _taxId;
    private string? _embs;
    private string? _bankAccount;
    private string? _bankName;
    private string? _bankBranch;
    private string? _email;
    private string? _emailPassword;
    private bool _showPassword;
    private bool _showLightbox;
    private bool _hasExistingPassword;

    // Logo state
    private string? _logoPreviewUrl;
    private byte[]? _pendingLogoData;
    private string? _pendingLogoMime;
    private bool _logoRemoved;
    private string? _logoValidationError;

    private bool _saving;

    private MudFileUpload<IBrowserFile>? _fileUploadRef;

    private WisDetailActionItem _saveAction => new()
    {
        Icon = Icons.Material.Filled.Save,
        Label = Localization.GetString("SaveProfile"),
        Color = Color.Primary,
        Disabled = _saving || string.IsNullOrWhiteSpace(_companyName),
        OnClick = EventCallback.Factory.Create(this, SaveAsync)
    };

    private WisDetailActionItem _removeLogo => new()
    {
        Icon = Icons.Material.Filled.DeleteForever,
        Label = Localization.GetString("Remove"),
        Color = Color.Error,
        OnClick = EventCallback.Factory.Create(this, RemoveLogo)
    };

    private WisDetailActionItem _uploadLogoAction => new()
    {
        Icon = Icons.Material.Filled.CloudUpload,
        Label = Localization.GetString("Upload"),
        Color = Color.Primary,
        OnClick = EventCallback.Factory.Create(this, OpenFilePickerAsync)
    };

    private string PasswordHelperText =>
        _hasExistingPassword && string.IsNullOrEmpty(_emailPassword)
            ? $"({Localization.GetString("EmailPasswordSaved")}) {Localization.GetString("EmailPasswordHelp")}"
            : Localization.GetString("EmailPasswordHelp");

    protected override async Task OnInitializedAsync()
    {
        await SafeLoadAsync(async () =>
        {
            TenantDto tenant = await TenantService.GetAsync(_cts.Token);
            PopulateForm(tenant);
        });
    }

    private void PopulateForm(TenantDto tenant)
    {
        _companyName         = tenant.CompanyName;
        _address             = tenant.Address;
        _phone               = tenant.Phone;
        _taxId               = tenant.TaxId;
        _embs                = tenant.Embs;
        _bankAccount         = tenant.BankAccount;
        _bankName            = tenant.BankName;
        _bankBranch          = tenant.BankBranch;
        _email               = tenant.Email;
        _hasExistingPassword = tenant.HasEmailPassword;

        if (tenant.LogoData is { Length: > 0 })
            _logoPreviewUrl = $"data:{tenant.LogoMimeType};base64,{Convert.ToBase64String(tenant.LogoData)}";
    }

    private async Task OnLogoSelected(IBrowserFile? file)
    {
        if (file == null)
            return;

        _logoValidationError = null;
        const long maxBytes = 5 * 1024 * 1024;

        if (file.Size > maxBytes)
        {
            _logoValidationError = $"{file.Name} exceeds 5 MB limit.";
            return;
        }

        using MemoryStream ms = new();
        await using Stream stream = file.OpenReadStream(maxBytes);
        await stream.CopyToAsync(ms);

        _pendingLogoData = ms.ToArray();
        _pendingLogoMime = file.ContentType;
        _logoPreviewUrl  = $"data:{_pendingLogoMime};base64,{Convert.ToBase64String(_pendingLogoData)}";
        _logoRemoved     = false;
    }

    private void RemoveLogo()
    {
        _logoPreviewUrl  = null;
        _pendingLogoData = null;
        _pendingLogoMime = null;
        _logoRemoved     = true;
    }

    private async Task SaveAsync()
    {
        if (string.IsNullOrWhiteSpace(_companyName)) return;

        _saving = true;
        try
        {
            // 1. Save all scalar fields
            await TenantService.UpdateAsync(new UpdateTenantDto
            {
                CompanyName   = _companyName.Trim(),
                OperatorName  = null,
                Address       = _address?.Trim(),
                Phone         = _phone?.Trim(),
                TaxId         = _taxId?.Trim(),
                Embs          = _embs?.Trim(),
                BankAccount   = _bankAccount?.Trim(),
                BankName      = _bankName?.Trim(),
                BankBranch    = _bankBranch?.Trim(),
                Email         = _email?.Trim(),
                EmailPassword = _emailPassword,
            }, _cts.Token);

            // 2. Logo: upload new, remove existing, or leave untouched
            if (_pendingLogoData is not null)
                await TenantService.UpdateLogoAsync(_pendingLogoData, _pendingLogoMime!, _cts.Token);
            else if (_logoRemoved)
                await TenantService.RemoveLogoAsync(_cts.Token);

            // 3. Clear transient state
            _emailPassword       = null;
            _hasExistingPassword = !string.IsNullOrEmpty(_email);
            _pendingLogoData     = null;
            _pendingLogoMime     = null;
            _logoRemoved         = false;

            NotifySuccess("ProfileSaved");
            await InvokeAsync(StateHasChanged);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error saving profile: {ex.Message}");
            NotifyError("ProfileSaveError");
        }
        finally
        {
            _saving = false;
        }
    }

    private async Task OpenFilePickerAsync()
    {
        if (_fileUploadRef != null)
            await _fileUploadRef.OpenFilePickerAsync();
    }
}
