@page "/invoices/create"
@implements IDisposable
@using System.Globalization
@using WarehouseInvoiceSystem.Application.DTOs.Company
@using WarehouseInvoiceSystem.Application.DTOs.Invoice
@using WarehouseInvoiceSystem.Application.DTOs.Product
@using WarehouseInvoiceSystem.Application.DTOs.Warehouse
@using WarehouseInvoiceSystem.Domain.Queries
@using WarehouseInvoiceSystem.Domain.Queries.Common
@inject IInvoiceService InvoiceService
@inject ICompanyService CompanyService
@inject ILocalizationService Localization
@inject NavigationManager Navigation
@inject ISnackbar Snackbar
@inject IProductService ProductService
@inject IWarehouseService WarehouseService

<PageTitle>@Localization.GetString("CreateInvoice") - @Localization.GetString("InvoiceSystem")</PageTitle>

<WisDetailHeader BackHref="/invoices" BackLabel="@Localization.GetString("Invoices")" />

@if (_loading)
{
    <MudProgressLinear Color="Color.Primary" Indeterminate="true" />
}
else
{
    <MudForm @ref="_form" @bind-IsValid="@_isValid">
        <MudGrid>
            <!-- Invoice Information Card -->
            <MudItem xs="12">
                <MudCard Elevation="2">
                    <MudCardHeader>
                        <CardHeaderContent>
                            <MudText Typo="Typo.h6">@Localization.GetString("InvoiceInformation")</MudText>
                        </CardHeaderContent>
                    </MudCardHeader>
                    <MudCardContent>
                        <MudGrid>
                            <MudItem xs="12" md="4">
                                <MudAutocomplete T="CompanyDto"
                                                 Label="@Localization.GetString("Company")"
                                                 Value="@_selectedCompany"
                                                 ValueChanged="@OnCompanySelected"
                                                 SearchFunc="@SearchCompanies"
                                                 ToStringFunc="@(c => c?.Name ?? string.Empty)"
                                                 Required="true"
                                                 RequiredError="@Localization.GetString("SelectCompany")"
                                                 ResetValueOnEmptyText="true"
                                                 CoerceText="false"
                                                 Variant="Variant.Outlined"
                                                 Clearable="true">
                                    <ItemTemplate Context="company">
                                        <MudText Typo="Typo.body2"><strong>@company.Name</strong></MudText>
                                        @if (!string.IsNullOrEmpty(company.TaxId))
                                        {
                                            <MudText Typo="Typo.caption" Color="Color.Secondary">@company.TaxId</MudText>
                                        }
                                    </ItemTemplate>
                                </MudAutocomplete>
                                @if (_selectedCompany != null && !string.IsNullOrEmpty(_selectedCompany.TaxId))
                                {
                                    <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mt-1 ml-1">
                                        @Localization.GetString("TaxId"): @_selectedCompany.TaxId
                                    </MudText>
                                }
                            </MudItem>

                            <MudItem xs="12" md="4">
                                <MudSelect T="InvoiceType?"
                                           @bind-Value="_selectedType"
                                           Label="@Localization.GetString("Type")"
                                           Required="true"
                                           RequiredError="@Localization.GetString("SelectType")"
                                           Variant="Variant.Outlined"
                                           AnchorOrigin="Origin.BottomLeft"
                                           Placeholder="@Localization.GetString("SelectInvoiceType")"
                                           Disabled="@(_selectedCompany != null && _selectedCompany.Type != CompanyType.Both)">
                                    <MudSelectItem T="InvoiceType?" Value="@((InvoiceType?)InvoiceType.Receivable)">
                                        <MudChip T="InvoiceType" Size="Size.Medium" Color="Color.Success">
                                            @Localization.GetString("Receivable")
                                        </MudChip>
                                    </MudSelectItem>
                                    <MudSelectItem T="InvoiceType?" Value="@((InvoiceType?)InvoiceType.Payable)">
                                        <MudChip T="InvoiceType" Size="Size.Medium" Color="Color.Warning">
                                            @Localization.GetString("Payable")
                                        </MudChip>
                                    </MudSelectItem>
                                </MudSelect>
                            </MudItem>

                            <MudItem xs="12" md="4">
                                <MudAutocomplete T="WarehouseDto"
                                                 Label="@Localization.GetString("Warehouse")"
                                                 @bind-Value="_selectedWarehouse"
                                                 SearchFunc="@SearchWarehouses"
                                                 Required="true"
                                                 RequiredError="@Localization.GetString("SelectWarehouse")"
                                                 Clearable="true"
                                                 ToStringFunc="@(w => w?.Name ?? string.Empty)"
                                                 ResetValueOnEmptyText="true"
                                                 Variant="Variant.Outlined" />
                            </MudItem>

                            <MudItem xs="12" md="4">
                                <MudDatePicker @key="_currentCultureKey"
                                               @bind-Date="_issueDate"
                                               @bind-Date:after="OnIssueDateChanged"
                                               Label="@Localization.GetString("IssueDate")"
                                               Required="true"
                                               RequiredError="@Localization.GetString("IssueDateRequired")"
                                               Variant="Variant.Outlined" />
                            </MudItem>

                            <MudItem xs="12" md="4">
                                <MudNumericField T="int"
                                                 Label="@Localization.GetString("Terms")"
                                                 @bind-Value="_paymentTermsDays"
                                                 @bind-Value:after="OnPaymentTermsChanged"
                                                 Variant="Variant.Outlined"
                                                 Adornment="Adornment.End"
                                                 AdornmentText="@Localization.GetString("Days")"
                                                 Min="0" />
                            </MudItem>

                            <MudItem xs="12" md="4">
                                <MudDatePicker @key="_currentCultureKey"
                                               @bind-Date="_dueDate"
                                               Label="@Localization.GetString("DueDate")"
                                               Required="true"
                                               RequiredError="@Localization.GetString("DueDateRequired")"
                                               Variant="Variant.Outlined" />
                            </MudItem>

                            <MudItem xs="12">
                                <MudTextField @bind-Value="_notes"
                                              Label="@Localization.GetString("Notes")"
                                              Variant="Variant.Outlined"
                                              Lines="3" />
                            </MudItem>
                        </MudGrid>
                    </MudCardContent>
                </MudCard>
            </MudItem>

            <!-- Line Items Card -->
            <MudItem xs="12">
                <MudCard Elevation="2">
                    <MudCardHeader>
                        <CardHeaderContent>
                            <MudText Typo="Typo.h6">@Localization.GetString("LineItems")</MudText>
                        </CardHeaderContent>
                        <CardHeaderActions>
                            <WisButton Action="@_addLineItemAction" />
                        </CardHeaderActions>
                    </MudCardHeader>
                    <MudCardContent>
                        <MudTable Items="_lineItems" Dense="true" Hover="true" Elevation="0" Class="mb-2">
                            <HeaderContent>
                                <MudTh>@Localization.GetString("Product")</MudTh>
                                <MudTh Style="width:140px">@Localization.GetString("Quantity")</MudTh>
                                <MudTh Style="width:185px">@Localization.GetString("UnitPrice")</MudTh>
                                <MudTh Style="width:190px">@Localization.GetString("TaxRate")</MudTh>
                                <MudTh Style="width:200px" Class="text-right">@Localization.GetString("Amount")</MudTh>
                                <MudTh Style="width:48px"></MudTh>
                            </HeaderContent>
                            <RowTemplate Context="item">
                                <MudTd>
                                    <MudAutocomplete T="ProductDto"
                                                     Value="item.SelectedProduct"
                                                     SearchFunc="@SearchProducts"
                                                     ToStringFunc="@(p => p?.Name ?? "")"
                                                     ValueChanged="@((ProductDto p) => OnProductSelected(item, p))"
                                                     ResetValueOnEmptyText="true"
                                                     CoerceText="false"
                                                     Variant="Variant.Text"
                                                     Clearable="true"
                                                     FullWidth="true">
                                        <ItemTemplate Context="product">
                                            <MudText Typo="Typo.body2">
                                                <strong>@product.Code</strong> - @product.Name
                                            </MudText>
                                            <MudText Typo="Typo.caption" Color="Color.Secondary">
                                                @product.Unit | @product.DefaultPrice.ToString("C")
                                            </MudText>
                                        </ItemTemplate>
                                    </MudAutocomplete>
                                </MudTd>
                                <MudTd>
                                    <MudNumericField @bind-Value="item.Quantity"
                                                     @bind-Value:after="CalculateTotals"
                                                     Variant="Variant.Text"
                                                     Min="1"
                                                     Step="1" />
                                </MudTd>
                                <MudTd>
                                    <MudNumericField @bind-Value="item.UnitPrice"
                                                     @bind-Value:after="CalculateTotals"
                                                     Variant="Variant.Text"
                                                     Min="0m"
                                                     Step="1"
                                                     Format="N2"
                                                     TextUpdateSuppression="false"
                                                     Adornment="Adornment.End"
                                                     AdornmentText="@Localization.CurrencySymbol" />
                                </MudTd>
                                <MudTd>
                                    <MudNumericField Value="item.TaxRate"
                                                     ValueChanged="@((decimal v) => OnTaxRateChanged(item, v))"
                                                     Variant="Variant.Text"
                                                     Min="0"
                                                     Max="100"
                                                     Step="0.1m"
                                                     Format="N2"
                                                     Adornment="Adornment.End"
                                                     AdornmentText="%"
                                                     TextUpdateSuppression="false" />
                                </MudTd>
                                <MudTd Class="text-right">
                                    <MudText Typo="Typo.body2" Class="font-weight-medium tabular-numbers">
                                        @item.LineTotal.ToString("C")
                                    </MudText>
                                </MudTd>
                                <MudTd>
                                    <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                                   Color="Color.Error"
                                                   Size="Size.Small"
                                                   Variant="Variant.Outlined"
                                                   OnClick="@(() => RemoveLineItem(item))" />
                                </MudTd>
                            </RowTemplate>
                            <NoRecordsContent>
                                <MudText Typo="Typo.body2" Color="Color.Secondary" Class="pa-4">
                                    @Localization.GetString("AddLineItems")
                                </MudText>
                            </NoRecordsContent>
                        </MudTable>

                        <!-- Totals Summary -->
                        <MudDivider Class="my-3" />
                        <div class="d-flex justify-end gap-6 px-2 pb-1">
                            <div class="d-flex align-center gap-2">
                                <MudText Typo="Typo.body2" Color="Color.Secondary">@Localization.GetString("Subtotal"):</MudText>
                                <MudText Typo="Typo.body1" Class="font-weight-medium tabular-numbers">@_subtotal.ToString("C")</MudText>
                            </div>
                            <div class="d-flex align-center gap-2">
                                <MudText Typo="Typo.body2" Color="Color.Secondary">@Localization.GetString("Tax"):</MudText>
                                <MudText Typo="Typo.body1" Class="font-weight-medium tabular-numbers">@_taxAmount.ToString("C")</MudText>
                            </div>
                            <div class="d-flex align-center gap-2">
                                <MudText Typo="Typo.body2" Color="Color.Secondary">@Localization.GetString("Total"):</MudText>
                                <MudText Typo="Typo.h6" Color="Color.Primary" Class="font-weight-bold tabular-numbers">@_total.ToString("C")</MudText>
                            </div>
                        </div>
                    </MudCardContent>
                </MudCard>
            </MudItem>

            <!-- Actions -->
            <MudItem xs="12">
                <div class="d-flex justify-space-between wis-page-actions">
                    <WisDialogActions OnCancel="@(() => Navigation.NavigateTo("/invoices"))"
                                      OnSave="HandleSubmit"
                                      SaveDisabled="@(_saving || !_isValid || !_lineItems.Any() || _lineItems.Any(i => i.SelectedProduct == null))" />
                </div>
            </MudItem>
        </MudGrid>
    </MudForm>
}

@code {
    [Parameter, SupplyParameterFromQuery(Name = "copyFrom")] public Guid? CopyFrom { get; set; }

    private readonly CancellationTokenSource _cts = new();

    private WisDetailActionItem _addLineItemAction => new()
    {
        Icon = Icons.Material.Filled.Add,
        Label = Localization.GetString("AddItem"),
        Color = Color.Info,
        OnClick = EventCallback.Factory.Create(this, AddLineItem)
    };
    private bool _loading = true;
    private bool _saving = false;
    private MudForm _form = null!;
    private bool _isValid;
    private string _currentCultureKey = CultureInfo.CurrentCulture.Name;

    private CompanyDto? _selectedCompany;
    private WarehouseDto? _selectedWarehouse;
    private InvoiceType? _selectedType;
    private DateTime? _issueDate = DateTime.Today;
    private DateTime? _dueDate = DateTime.Today.AddDays(30);
    private int _paymentTermsDays = 30;
    private string? _notes;

    private readonly List<LineItemModel> _lineItems = new();
    private decimal _subtotal = 0;
    private decimal _taxAmount = 0;
    private decimal _total = 0;

    protected override async Task OnInitializedAsync()
    {
        Localization.OnLanguageChanged += OnLanguageChanged;
        if (CopyFrom.HasValue)
            await PrefillFromInvoice(CopyFrom.Value);
        else
        {
            await LoadDefaultWarehouse();
            AddLineItem();
        }
    }

    private async void OnLanguageChanged()
    {
        _currentCultureKey = CultureInfo.CurrentCulture.Name;
        await InvokeAsync(StateHasChanged);
    }

    private async Task LoadDefaultWarehouse()
    {
        _loading = true;
        try
        {
            _selectedWarehouse = await WarehouseService.GetDefaultWarehouseAsync(_cts.Token);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading default warehouse: {ex.Message}");
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task PrefillFromInvoice(Guid sourceId)
    {
        _loading = true;
        try
        {
            InvoiceDto? source = await InvoiceService.GetInvoiceByIdAsync(sourceId, _cts.Token);
            if (source == null)
            {
                await LoadDefaultWarehouse();
                AddLineItem();
                return;
            }

            _selectedCompany = await CompanyService.GetCompanyByIdAsync(source.CompanyId, _cts.Token);
            _selectedType = source.Type;
            _selectedWarehouse = await WarehouseService.GetWarehouseByIdAsync(source.WarehouseId, _cts.Token);

            int termsDays = (int)(source.DueDate - source.IssueDate).TotalDays;
            _paymentTermsDays = termsDays > 0 ? termsDays : 30;
            _issueDate = DateTime.Today;
            _dueDate = DateTime.Today.AddDays(_paymentTermsDays);
            _notes = source.Notes;

            foreach (InvoiceLineDto li in source.LineItems)
            {
                ProductDto? product = await ProductService.GetProductByIdAsync(li.ProductId);
                if (product != null)
                {
                    _lineItems.Add(new LineItemModel
                    {
                        SelectedProduct = product,
                        Description = li.Description,
                        Quantity = li.Quantity,
                        UnitPrice = li.UnitPrice,
                        TaxRate = li.TaxRate
                    });
                }
            }

            CalculateTotals();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error prefilling from invoice: {ex.Message}");
            Snackbar.Add(Localization.GetString("ErrorLoadingInvoice"), Severity.Error);
            AddLineItem();
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task<IEnumerable<CompanyDto>> SearchCompanies(string value, CancellationToken ct)
    {
        GetCompaniesQuery query = new() { PageSize = 10, IsActive = true };
        if (!string.IsNullOrWhiteSpace(value)) query.Search = value;
        PagedResult<CompanyDto> result = await CompanyService.GetPagedAsync(query, ct);
        return result.Items;
    }

    private async Task<IEnumerable<ProductDto>> SearchProducts(string value, CancellationToken ct)
    {
        GetProductsQuery query = new() { PageSize = 10, IsActive = true };
        if (!string.IsNullOrWhiteSpace(value)) query.Search = value;
        PagedResult<ProductDto> result = await ProductService.GetPagedAsync(query, ct);
        return result.Items;
    }

    private async Task<IEnumerable<WarehouseDto>> SearchWarehouses(string value, CancellationToken ct)
    {
        GetWarehousesQuery query = new() { PageSize = 10, IsActive = true };
        if (!string.IsNullOrWhiteSpace(value)) query.Search = value;
        PagedResult<WarehouseDto> result = await WarehouseService.GetPagedAsync(query, ct);
        return result.Items;
    }

    private void OnCompanySelected(CompanyDto? company)
    {
        _selectedCompany = company;
        if (company == null) return;

        _selectedType = company.Type switch
        {
            CompanyType.Client => InvoiceType.Receivable,
            CompanyType.Vendor => InvoiceType.Payable,
            _ => _selectedType
        };

        if (company.PaymentTermsDays > 0)
        {
            _paymentTermsDays = company.PaymentTermsDays;
            OnPaymentTermsChanged();
        }
    }

    private void OnProductSelected(LineItemModel item, ProductDto? product)
    {
        if (product != null)
        {
            item.SelectedProduct = product;
            item.Description = product.Name;
            item.UnitPrice = product.DefaultPrice;
        }
    }

    private void OnTaxRateChanged(LineItemModel item, decimal value)
    {
        item.TaxRate = Math.Clamp(value, 0m, 100m);
        CalculateTotals();
    }

    private void OnIssueDateChanged()
    {
        if (_issueDate.HasValue)
            _dueDate = _issueDate.Value.AddDays(_paymentTermsDays);
    }

    private void OnPaymentTermsChanged()
    {
        if (_issueDate.HasValue)
            _dueDate = _issueDate.Value.AddDays(_paymentTermsDays);
    }

    private void AddLineItem()
    {
        _lineItems.Add(new LineItemModel());
    }

    private void RemoveLineItem(LineItemModel item)
    {
        _lineItems.Remove(item);
        CalculateTotals();
    }

    private void CalculateTotals()
    {
        _subtotal = _lineItems.Sum(i => i.Quantity * i.UnitPrice);
        _taxAmount = _lineItems.Sum(i => (i.Quantity * i.UnitPrice) * (i.TaxRate / 100));
        _total = _subtotal + _taxAmount;
        StateHasChanged();
    }

    private async Task HandleSubmit()
    {
        _saving = true;

        try
        {
            CreateInvoiceDto dto = new()
            {
                CompanyId = _selectedCompany!.Id,
                Type = _selectedType!.Value,
                IssueDate = _issueDate ?? DateTime.UtcNow,
                DueDate = _dueDate ?? DateTime.UtcNow.AddDays(30),
                WarehouseId = _selectedWarehouse!.Id,
                Notes = _notes,
                LineItems = _lineItems
                    .Where(i => i.SelectedProduct != null)
                    .Select(i => new CreateInvoiceLineDto
                    {
                        ProductId = i.SelectedProduct!.Id,
                        Description = i.SelectedProduct.Name,
                        Quantity = i.Quantity,
                        UnitPrice = i.UnitPrice,
                        TaxRate = i.TaxRate
                    }).ToList()
            };

            Guid id = await InvoiceService.CreateInvoiceAsync(dto);
            Snackbar.Add(Localization.GetString("InvoiceCreated"), Severity.Success);
            Navigation.NavigateTo($"/invoices/{id}");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error creating invoice: {ex.Message}");
            Snackbar.Add(Localization.GetString("ErrorCreatingInvoice"), Severity.Error);
        }
        finally
        {
            _saving = false;
        }
    }

    public void Dispose()
    {
        _cts.Cancel();
        _cts.Dispose();
        Localization.OnLanguageChanged -= OnLanguageChanged;
    }

    private sealed class LineItemModel
    {
        public ProductDto? SelectedProduct { get; set; }
        public string Description { get; set; } = string.Empty;
        public int Quantity { get; set; } = 1;
        public decimal UnitPrice { get; set; } = 0m;
        public decimal TaxRate { get; set; } = 0m;
        public decimal LineTotal => (Quantity * UnitPrice) * (1 + TaxRate / 100);
    }
}
