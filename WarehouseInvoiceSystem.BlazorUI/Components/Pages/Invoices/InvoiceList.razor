@page "/invoices"
@inherits PageBase
@using WarehouseInvoiceSystem.Application.DTOs.Invoice
@using WarehouseInvoiceSystem.Application.DTOs.Company
@using WarehouseInvoiceSystem.Application.DTOs.StockLevel
@using WarehouseInvoiceSystem.Domain.Queries
@using WarehouseInvoiceSystem.Domain.Queries.Common
@using WarehouseInvoiceSystem.Domain.Enums
@inject IInvoiceService InvoiceService
@inject IInventoryService InventoryService
@inject ICompanyService CompanyService
@inject IEmailService EmailService
@using WarehouseInvoiceSystem.Application.Models
@inject IExcelExportService ExcelExportService

<PageTitle>@Localization.GetString("Invoices") - @Localization.GetString("InvoiceSystem")</PageTitle>

<div class="wis-page-header">
    <MudText Typo="Typo.h3" Class="wis-page-title">
        @Localization.GetString("Invoices")
    </MudText>
</div>

<WisGridToolbar CreateAction="@(() => Navigation.NavigateTo("/invoices/create"))"
                CreateLabel="@Localization.GetString("Invoice")"
                CreateActions="@_createActions"
                SearchValue="@_searchString"
                SearchValueChanged="OnSearch"
                HasAnyActiveFilter="@(_filterStatuses.Count > 0 || _filterType.HasValue || _activeAdvancedFilterCount > 0)"
                OnClearAll="ClearAllFilters"
                ActiveAdvancedFilterCount="@_activeAdvancedFilterCount">
    <Filters>
        <FilterPopoverList TValue="InvoiceType?"
                           Label="@Localization.GetString("Type")"
                           Items="_typeFilterItems"
                           Mode="FilterSelectionMode.Single"
                           SelectedValue="_filterType"
                           FilterVariant="Variant.Outlined"
                           SelectedValueChanged="OnTypeFilterChanged" />
        <FilterPopoverList TValue="InvoiceStatus"
                           Label="@Localization.GetString("Status")"
                           Items="_statusFilterItems"
                           Mode="FilterSelectionMode.Multiple"
                           SelectedValues="_filterStatuses"
                           SelectedValuesChanged="OnStatusFilterChanged" />
    </Filters>
    <AdvancedFilters>
        <div class="d-flex align-center flex-wrap gap-3">

            <WisAutocompleteFilter TValue="Guid"
                                   Label="@Localization.GetString("Company")"
                                   AllLabel="@Localization.GetString("AllCompanies")"
                                   Icon="@Icons.Material.Filled.Business"
                                   LoadItems="LoadCompanyItems"
                                   SelectedValue="@(_filterCompanyId ?? default)"
                                   SelectedValueChanged="OnCompanyFilterChanged"
                                   InitialLabel="@_filterCompanyInitialLabel"
                                   MinWidth="200px" />

            <WisDateRangeFilter @ref="_issueDateRangeFilter"
                                Label="@Localization.GetString("IssueDate")"
                                DateRange="_filterIssueDateRange"
                                DateRangeChanged="OnIssueDateRangeChanged"
                                DatePreset="_filterIssueDatePreset"
                                DatePresetChanged="OnIssueDatePresetChanged"
                                OnChanged="ReloadGrid"
                                MaxDate="DateTime.Today" />

            <WisDateRangeFilter @ref="_dueDateRangeFilter"
                                Label="@Localization.GetString("DueDate")"
                                DateRange="_filterDueDateRange"
                                DateRangeChanged="OnDueDateRangeChanged"
                                DatePreset="_filterDueDatePreset"
                                FuturePresets="true"
                                DatePresetChanged="OnDueDatePresetChanged"
                                OnChanged="ReloadGrid" />

            <WisAmountRangeFilter @ref="_amountRangeFilter"
                                  Label="@Localization.GetString("AmountRange")"
                                  AmountMin="_filterAmountMin"
                                  AmountMinChanged="OnAmountMinChanged"
                                  AmountMax="_filterAmountMax"
                                  AmountMaxChanged="OnAmountMaxChanged"
                                  AmountPreset="@_filterAmountPreset"
                                  AmountPresetChanged="OnAmountPresetChanged"
                                  OnChanged="ReloadGrid" />

        </div>
    </AdvancedFilters>
</WisGridToolbar>

<MudCard Elevation="2" Class="mb-4">
    <MudCardContent Class="pa-0">
        <MudDataGrid T="InvoiceDto"
                     @ref="_grid"
                     ServerData="LoadServerData"
                     RowClick="OnRowClick"
                     RowClassFunc="GetRowClass"
                     ReadOnly="true"
                     Hover="true"
                     FixedHeader="true"
                     Height="100%"
                     Filterable="false"
                     ShowColumnOptions="false"
                     ColumnResizeMode="ResizeMode.Column"
                     SortMode="SortMode.Single"
                     Class="wis-data-grid">
            <Columns>
                <TemplateColumn Sortable="false"
                                Filterable="false"
                                IsEditable="false"
                                HeaderClass="wis-col-actions-1"
                                CellClass="wis-col-actions-1">
                    <CellTemplate>
                        <MudStack Row="true" Justify="Justify.Center" AlignItems="AlignItems.Center">
                            <WisSplitButton Actions="@BuildRowActions(context.Item)"
                                            AnchorOrigin="Origin.BottomLeft"
                                            TransformOrigin="Origin.TopLeft"
                                            HideLabel="true" />
                        </MudStack>
                    </CellTemplate>
                </TemplateColumn>

                <PropertyColumn Property="x => x.InvoiceNumber"
                                Title="@Localization.GetString("InvoiceNumber")"
                                Sortable="true"
                                IsEditable="false"
                                CellClass="wis-cell-mono" />

                <PropertyColumn Property="x => x.Type"
                                Title="@Localization.GetString("Type")"
                                Sortable="false"
                                IsEditable="false">
                    <CellTemplate>
                        <MudChip T="string" Size="Size.Small"
                                 Variant="Variant.Outlined"
                                 Color="@(context.Item.Type == InvoiceType.Receivable ? Color.Success : Color.Warning)">
                            @(context.Item.Type == InvoiceType.Receivable
                                                     ? Localization.GetString("Receivable")
                                                     : Localization.GetString("Payable"))
                        </MudChip>
                    </CellTemplate>
                </PropertyColumn>

                <PropertyColumn Property="x => x.CompanyName"
                                Title="@Localization.GetString("Company")"
                                Sortable="true"
                                IsEditable="false" />

                <PropertyColumn Property="x => x.Status"
                                Title="@Localization.GetString("Status")"
                                Sortable="false"
                                IsEditable="false">
                    <CellTemplate>
                        <MudChip T="string" Size="Size.Small"
                                 Color="@GetInvoiceStatusColor(context.Item.Status)">
                            @GetInvoiceStatusText(context.Item.Status)
                        </MudChip>
                    </CellTemplate>
                </PropertyColumn>
                
                <PropertyColumn Property="x => x.IssueDate"
                                Title="@Localization.GetString("IssueDate")"
                                Sortable="true"
                                IsEditable="false">
                    <CellTemplate>
                        @context.Item.IssueDate.ToString("dd MMM yyyy")
                    </CellTemplate>
                </PropertyColumn>

                <PropertyColumn Property="x => x.DueDate"
                                Title="@Localization.GetString("DueDate")"
                                Sortable="true"
                                IsEditable="false">
                    <CellTemplate>
                        @if (context.Item.DueDate < DateTime.UtcNow
                                                && context.Item.Status != InvoiceStatus.Paid
                                                && context.Item.Status != InvoiceStatus.Cancelled)
                        {
                            <MudText Color="Color.Error" Typo="Typo.body2">
                                @context.Item.DueDate.ToString("dd MMM yyyy")
                            </MudText>
                        }
                        else
                        {
                            <MudText Typo="Typo.body2">
                                @context.Item.DueDate.ToString("dd MMM yyyy")
                            </MudText>
                        }
                    </CellTemplate>
                </PropertyColumn>

                <PropertyColumn Property="x => x.TotalAmount"
                                Title="@Localization.GetString("Total")"
                                Sortable="true"
                                HeaderClass="text-right"
                                CellClass="text-right"
                                IsEditable="false">
                    <CellTemplate>
                        <MudText Typo="Typo.body2" Class="wis-cell-amount">
                            @context.Item.TotalAmount.ToString("C")
                        </MudText>
                    </CellTemplate>
                </PropertyColumn>

            </Columns>

            <NoRecordsContent>
                <WisNoRecordsContent Icon="@Icons.Material.Filled.Receipt"
                                     Message="@Localization.GetString("NoInvoicesFound")" />
            </NoRecordsContent>

            <LoadingContent>
                <WisLoadingContent />
            </LoadingContent>

            <PagerContent>
                <WisPagerContent T="InvoiceDto" />
            </PagerContent>

        </MudDataGrid>
    </MudCardContent>
</MudCard>

@code {
    [Parameter]
    [SupplyParameterFromQuery(Name = "companyId")]
    public string? CompanyIdParam { get; set; }

    [Parameter]
    [SupplyParameterFromQuery(Name = "status")]
    public string? StatusParam { get; set; }

    [Parameter]
    [SupplyParameterFromQuery(Name = "type")]
    public string? TypeParam { get; set; }

    [Parameter]
    [SupplyParameterFromQuery(Name = "issueDateFrom")]
    public string? IssueDateFromParam { get; set; }

    [Parameter]
    [SupplyParameterFromQuery(Name = "issueDateTo")]
    public string? IssueDateToParam { get; set; }

    [Parameter]
    [SupplyParameterFromQuery(Name = "dueDateFrom")]
    public string? DueDateFromParam { get; set; }

    [Parameter]
    [SupplyParameterFromQuery(Name = "dueDateTo")]
    public string? DueDateToParam { get; set; }

    private MudDataGrid<InvoiceDto> _grid = null!;
    private bool _exporting = false;
    private bool _exportingRow = false;
    private string _searchString = string.Empty;

    // Quick filters
    private HashSet<InvoiceStatus> _filterStatuses = [];
    private InvoiceType? _filterType = null;

    // Advanced filters
    private Guid? _filterCompanyId = null;
    private string? _filterCompanyInitialLabel = null;
    private decimal? _filterAmountMin = null;
    private decimal? _filterAmountMax = null;
    private string? _filterAmountPreset = null;
    private WisAmountRangeFilter? _amountRangeFilter;

    private DateRange _filterIssueDateRange = new(null, null);
    private int? _filterIssueDatePreset = null;
    private WisDateRangeFilter? _issueDateRangeFilter;

    private DateRange _filterDueDateRange = new(null, null);
    private int? _filterDueDatePreset = null;
    private WisDateRangeFilter? _dueDateRangeFilter;
    private List<FilterPopoverItem<InvoiceStatus>> _statusFilterItems = [];
    private List<FilterPopoverItem<InvoiceType?>> _typeFilterItems = [];
    private List<WisDetailActionItem> _createActions = [];

    private int _activeAdvancedFilterCount =>
        (_filterCompanyId.HasValue ? 1 : 0) +
        (_filterIssueDateRange.Start != null || _filterIssueDateRange.End != null ? 1 : 0) +
        (_filterDueDateRange.Start != null || _filterDueDateRange.End != null ? 1 : 0) +
        (_filterAmountMin.HasValue || _filterAmountMax.HasValue ? 1 : 0);

    protected override async Task OnInitializedAsync()
    {
        await base.OnInitializedAsync();
        BuildFilterItems();
        BuildCreateActions();
        ApplyQueryParams();

        // Resolve company name for InitialLabel so filter button shows active state
        if (_filterCompanyId.HasValue)
        {
            try
            {
                CompanyDto? company = await CompanyService.GetCompanyByIdAsync(_filterCompanyId.Value, CancellationToken.None);
                if (company is not null)
                    _filterCompanyInitialLabel = company.Name;
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Error resolving company param: {ex.Message}");
            }
        }
    }

    private void BuildCreateActions()
    {
        _createActions =
        [
            new WisDetailActionItem
            {
                Icon = Icons.Material.Filled.Print,
                Label = Localization.GetString("Export"),
                Disabled = _exporting,
                OnClick = EventCallback.Factory.Create(this, PerformExport)
            }
        ];
    }

    private void ApplyQueryParams()
    {
        if (!string.IsNullOrWhiteSpace(StatusParam) &&
            Enum.TryParse<InvoiceStatus>(StatusParam, ignoreCase: true, out InvoiceStatus parsedStatus))
        {
            _filterStatuses.Add(parsedStatus);
        }

        if (!string.IsNullOrWhiteSpace(CompanyIdParam) &&
            Guid.TryParse(CompanyIdParam, out Guid companyId))
        {
            _filterCompanyId = companyId;
        }

        if (!string.IsNullOrWhiteSpace(TypeParam) &&
            Enum.TryParse<InvoiceType>(TypeParam, ignoreCase: true, out InvoiceType parsedType))
        {
            _filterType = parsedType;
        }

        if (!string.IsNullOrWhiteSpace(IssueDateFromParam) &&
            DateTime.TryParse(IssueDateFromParam, out DateTime issueDateFrom))
        {
            _filterIssueDateRange = new DateRange(issueDateFrom, _filterIssueDateRange.End);
        }

        if (!string.IsNullOrWhiteSpace(IssueDateToParam) &&
            DateTime.TryParse(IssueDateToParam, out DateTime issueDateTo))
        {
            _filterIssueDateRange = new DateRange(_filterIssueDateRange.Start, issueDateTo);
        }

        if (!string.IsNullOrWhiteSpace(DueDateFromParam) &&
            DateTime.TryParse(DueDateFromParam, out DateTime dueDateFrom))
        {
            _filterDueDateRange = new DateRange(dueDateFrom, _filterDueDateRange.End);
        }

        if (!string.IsNullOrWhiteSpace(DueDateToParam) &&
            DateTime.TryParse(DueDateToParam, out DateTime dueDateTo))
        {
            _filterDueDateRange = new DateRange(_filterDueDateRange.Start, dueDateTo);
        }
    }

    private void BuildFilterItems()
    {
        _typeFilterItems =
        [
            new() { Label = Localization.GetString("All"),        Value = null,                   Color = Color.Info    },
            new() { Label = Localization.GetString("Receivable"), Value = InvoiceType.Receivable, Color = Color.Success },
            new() { Label = Localization.GetString("Payable"),    Value = InvoiceType.Payable,    Color = Color.Warning },
        ];

        _statusFilterItems =
        [
            new() { Label = Localization.GetString("Draft"),           Value = InvoiceStatus.Draft,         Color = Color.Default },
            new() { Label = Localization.GetString("Confirmed"),        Value = InvoiceStatus.Confirmed,     Color = Color.Info    },
            new() { Label = Localization.GetString("PartiallyPaid"),   Value = InvoiceStatus.PartiallyPaid, Color = Color.Warning },
            new() { Label = Localization.GetString("PaidStatus"),      Value = InvoiceStatus.Paid,          Color = Color.Success },
            new() { Label = Localization.GetString("OverdueStatus"),   Value = InvoiceStatus.Overdue,       Color = Color.Error   },
            new() { Label = Localization.GetString("CancelledStatus"), Value = InvoiceStatus.Cancelled,     Color = Color.Dark    },
        ];
    }

    protected override async void OnLanguageChanged()
    {
        BuildFilterItems();
        await InvokeAsync(StateHasChanged);
    }

    private async Task<GridData<InvoiceDto>> LoadServerData(GridState<InvoiceDto> state, CancellationToken ct)
    {
        string? sortBy = state.SortDefinitions.FirstOrDefault()?.SortBy;
        bool ascending = state.SortDefinitions.FirstOrDefault()?.Descending == false;

        GetInvoicesQuery query = BuildQuery();
        query.Page = state.Page + 1;
        query.PageSize = state.PageSize;
        query.SortBy = sortBy;
        query.SortAscending = ascending;

        PagedResult<InvoiceDto> result = await InvoiceService.GetPagedAsync(query, ct);

        return new GridData<InvoiceDto>
        {
            Items = result.Items,
            TotalItems = result.TotalCount
        };
    }

    private GetInvoicesQuery BuildQuery() => new()
    {
        Search = _searchString,
        Statuses = _filterStatuses.Count > 0 ? _filterStatuses.ToList() : null,
        Type = _filterType,
        CompanyId = _filterCompanyId,
        AmountMin = _filterAmountMin,
        AmountMax = _filterAmountMax,
        IssueDateFrom = _filterIssueDateRange.Start,
        IssueDateTo = _filterIssueDateRange.End,
        DueDateFrom = _filterDueDateRange.Start,
        DueDateTo = _filterDueDateRange.End,
    };

    private string GetRowClass(InvoiceDto item, int index) => item.Status switch
    {
        InvoiceStatus.Draft => "row-status-default",
        InvoiceStatus.Confirmed => "row-status-info",
        InvoiceStatus.PartiallyPaid => "row-status-warning",
        InvoiceStatus.Paid => "row-status-success",
        InvoiceStatus.Overdue => "row-status-error",
        InvoiceStatus.Cancelled => "row-status-dark",
        _ => "row-status-default"
    };

    private async Task<PagedResult<WisAutocompleteItem<Guid>>> LoadCompanyItems(
        string search, int page, CancellationToken ct)
    {
        PagedResult<CompanyDto> result = await CompanyService.GetPagedAsync(new GetCompaniesQuery
        {
            Search = search,
            Page = page,
            PageSize = 10,
            SortBy = "Name",
            SortAscending = true,
            IsActive = true
        }, ct);

        return new PagedResult<WisAutocompleteItem<Guid>>
        {
            Items = result.Items.Select(c => new WisAutocompleteItem<Guid>
            {
                Label = c.Name,
                Value = c.Id
            }).ToList(),
            TotalCount = result.TotalCount,
            Page = result.Page,
            PageSize = result.PageSize
        };
    }

    private async Task OnCompanyFilterChanged(Guid value)
    {
        _filterCompanyId = value == default ? null : value;
        _filterCompanyInitialLabel = null;
        await _grid.ReloadServerData();
    }

    private Task OnIssueDatePresetChanged(int? days)
    {
        _filterIssueDatePreset = days;
        return Task.CompletedTask;
    }

    private Task OnIssueDateRangeChanged(DateRange range)
    {
        _filterIssueDateRange = range;
        return Task.CompletedTask;
    }

    private Task OnDueDatePresetChanged(int? days)
    {
        _filterDueDatePreset = days;
        return Task.CompletedTask;
    }

    private Task OnDueDateRangeChanged(DateRange range)
    {
        _filterDueDateRange = range;
        return Task.CompletedTask;
    }

    private async Task OnSearch(string text)
    {
        _searchString = text;
        await _grid.ReloadServerData();
    }

    private async Task OnStatusFilterChanged(IReadOnlyCollection<InvoiceStatus> values)
    {
        _filterStatuses = values.ToHashSet();
        await _grid.ReloadServerData();
    }

    private async Task OnTypeFilterChanged(InvoiceType? value)
    {
        _filterType = value;
        await _grid.ReloadServerData();
    }

    private Task OnAmountMinChanged(decimal? value)
    {
        _filterAmountMin = value;
        return Task.CompletedTask;
    }

    private Task OnAmountMaxChanged(decimal? value)
    {
        _filterAmountMax = value;
        return Task.CompletedTask;
    }

    private Task OnAmountPresetChanged(string? key)
    {
        _filterAmountPreset = key;
        return Task.CompletedTask;
    }

    private async Task ReloadGrid() => await _grid.ReloadServerData();

    private async Task ClearAllFilters()
    {
        _filterStatuses = [];
        _filterType = null;
        _filterCompanyId = null;
        _filterCompanyInitialLabel = null;
        _filterAmountMin = null;
        _filterAmountMax = null;
        _filterAmountPreset = null;
        _filterIssueDateRange = new(null, null);
        _filterIssueDatePreset = null;
        _filterDueDateRange = new(null, null);
        _filterDueDatePreset = null;

        await _grid.ReloadServerData();
    }

    private async void OnRowClick(DataGridRowClickEventArgs<InvoiceDto> args)
    {
        if (args.MouseEventArgs.Detail == 2)
            Navigation.NavigateTo($"/invoices/{args.Item.Id}");
    }

    private async Task OpenPaymentDialog(InvoiceDto invoice)
    {
        try
        {
            bool paid = await WisDialog.ShowPaymentDialogAsync(invoice.Id);
            if (paid)
            {
                Snackbar.Add(Localization.GetString("PaymentRecorded"), Severity.Success);
                await _grid.ReloadServerData();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error recording payment: {ex.Message}");
            Snackbar.Add(Localization.GetString("ErrorRecordingPayment"), Severity.Error);
        }
    }

    private async Task ConfirmFromList(InvoiceDto invoice)
    {
        if (invoice.Type == InvoiceType.Receivable)
        {
            // Receivable: confirm + send email
            if (!await HasSufficientStockAsync(invoice))
            {
                Snackbar.Add(Localization.GetString("InsufficientStockToConfirm"), Severity.Error);
                return;
            }

            try
            {
                var (_, isDueDatePassed) = await InvoiceService.ConfirmAsync(invoice.Id);
                if (isDueDatePassed)
                    Snackbar.Add(Localization.GetString("DueDateAlreadyPassed"), Severity.Warning);
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Error confirming invoice: {ex.Message}");
                Snackbar.Add(Localization.GetString("ErrorUpdatingInvoice"), Severity.Error);
                return;
            }

            await OpenSendEmailDialog(invoice);
        }
        else
        {
            // Payable: confirm only
            try
            {
                var (_, isDueDatePassed) = await InvoiceService.ConfirmAsync(invoice.Id);
                if (isDueDatePassed)
                    Snackbar.Add(Localization.GetString("DueDateAlreadyPassed"), Severity.Warning);
                else
                    Snackbar.Add(Localization.GetString("InvoiceConfirmed"), Severity.Success);
                await _grid.ReloadServerData();
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Error confirming invoice: {ex.Message}");
                Snackbar.Add(Localization.GetString("ErrorUpdatingInvoice"), Severity.Error);
            }
        }
    }

    private async Task OpenSendEmailDialog(InvoiceDto invoice)
    {
        string? customMessage = await WisDialog.ShowFormAsync<SendInvoiceEmailDialog, string>(
            Localization.GetString("SendInvoiceEmail"),
            p => p.Add(x => x.Invoice, invoice));

        if (customMessage is null) return;

        Snackbar.Add(Localization.GetString("InvoiceEmailSending"), Severity.Info);
        _ = SendEmailInBackgroundAsync(invoice.Id, customMessage);
    }

    private async Task SendEmailInBackgroundAsync(Guid invoiceId, string customMessage)
    {
        try
        {
            await EmailService.SendInvoiceEmailAsync(invoiceId, customMessage);
            await InvokeAsync(() => Snackbar.Add(Localization.GetString("InvoiceEmailSentSuccessfully"), Severity.Success));
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error sending invoice email: {ex.Message}");
            await InvokeAsync(() => Snackbar.Add(Localization.GetString("ErrorSendingEmail"), Severity.Error));
        }
    }

    private async Task<bool> HasSufficientStockAsync(InvoiceDto invoice)
    {
        if (invoice.Type != InvoiceType.Receivable) return true;

        try
        {
            InvoiceDto? full = await InvoiceService.GetInvoiceByIdAsync(invoice.Id, CancellationToken.None);
            if (full == null || !full.LineItems.Any()) return true;

            IEnumerable<StockLevelDto> levels = await InventoryService.GetStockByWarehouseAsync(invoice.WarehouseId, CancellationToken.None);
            Dictionary<Guid, decimal> stockByProduct = levels.ToDictionary(s => s.ProductId, s => s.AvailableQuantity);

            return !full.LineItems.Any(li =>
                !stockByProduct.TryGetValue(li.ProductId, out decimal available) || li.Quantity > available);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error checking stock: {ex.Message}");
            return true;
        }
    }

    private async Task PerformExport()
    {
        _exporting = true;
        StateHasChanged();

        try
        {
            GetInvoicesQuery exportQuery = BuildQuery();
            IEnumerable<InvoiceDto> invoices = await InvoiceService.GetAllFilteredAsync(exportQuery, CancellationToken.None);

            byte[] fileBytes = await ExcelExportService.ExportListToExcelAsync(
                invoices,
                ExportColumnDefinitions.InvoiceColumns(Localization),
                new ExportListOptions(Localization.GetString("Invoices")));

            string fileName = $"{Localization.GetString("Invoices")}_{DateTime.UtcNow:yyyyMMdd}.xlsx";
            await DownloadFileAsync(fileBytes, fileName);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error exporting invoices: {ex.Message}");
            Snackbar.Add(Localization.GetString("ExportError"), Severity.Error);
        }
        finally
        {
            _exporting = false;
            StateHasChanged();
        }
    }

    private async Task DeleteInvoice(InvoiceDto invoice) =>
        await ConfirmAndExecuteAsync(
            Localization.GetString("ConfirmDelete"),
            Localization.GetString("DeleteInvoiceConfirm"),
            async () => { await InvoiceService.DeleteInvoiceAsync(invoice.Id); await _grid.ReloadServerData(); },
            "InvoiceDeleted", "ErrorUpdatingInvoice",
            Localization.GetString("Delete"), Localization.GetString("Back"));

    private async Task CancelInvoice(InvoiceDto invoice) =>
        await ConfirmAndExecuteAsync(
            Localization.GetString("CancelInvoice"),
            Localization.GetString("CancelInvoiceConfirm"),
            async () => { await InvoiceService.CancelAsync(invoice.Id); await _grid.ReloadServerData(); },
            "InvoiceCancelled", "ErrorUpdatingInvoice",
            Localization.GetString("Cancel"), Localization.GetString("Back"));

    private async Task RevertToDraftFromList(InvoiceDto invoice) =>
        await ConfirmAndExecuteAsync(
            Localization.GetString("RevertInvoiceToDraft"),
            Localization.GetString("RevertInvoiceToDraftConfirm"),
            async () => { await InvoiceService.RevertToDraftAsync(invoice.Id); await _grid.ReloadServerData(); },
            "InvoiceRevertedToDraft", "ErrorUpdatingInvoice",
            Localization.GetString("RevertInvoiceToDraft"), Localization.GetString("Back"));

    private bool CanPay(InvoiceStatus status) =>
        status != InvoiceStatus.Paid && status != InvoiceStatus.Cancelled;

    private bool CanSendEmail(InvoiceType type, InvoiceStatus status) =>
        type == InvoiceType.Receivable &&
        (status == InvoiceStatus.Confirmed ||
         status == InvoiceStatus.PartiallyPaid ||
         status == InvoiceStatus.Overdue);

    private static bool CanConfirm(InvoiceStatus status) => status == InvoiceStatus.Draft;

    private List<WisDetailActionItem> BuildRowActions(InvoiceDto item)
    {
        bool isCancelled = item.Status == InvoiceStatus.Cancelled;
        bool isPaid      = item.Status == InvoiceStatus.Paid;
        bool canEdit     = item.Status == InvoiceStatus.Draft;
        bool canConfirm  = CanConfirm(item.Status);
        bool canSend     = CanSendEmail(item.Type, item.Status);
        bool canPay      = CanPay(item.Status);
        bool canRevert   = item.Status == InvoiceStatus.Confirmed || item.Status == InvoiceStatus.Overdue;
        bool canCancel   = !isCancelled && !isPaid;

        // Confirm action: receivable Draft → "Confirm & Send", payable Draft → "Confirm"
        string confirmLabel = item.Type == InvoiceType.Receivable
            ? Localization.GetString("ConfirmAndSend")
            : Localization.GetString("ConfirmInvoice");
        string confirmIcon = item.Type == InvoiceType.Receivable
            ? Icons.Material.Filled.Send
            : Icons.Material.Filled.CheckCircle;

        List<WisDetailActionItem> actions = [];

        if (canConfirm)
        {
            actions.Add(new WisDetailActionItem
            {
                Icon    = confirmIcon,
                Label   = confirmLabel,
                Color   = Color.Info,
                OnClick = EventCallback.Factory.Create(this, () => ConfirmFromList(item))
            });
        }

        if (canSend)
        {
            actions.Add(new WisDetailActionItem
            {
                Icon    = Icons.Material.Filled.Send,
                Label   = Localization.GetString("Send"),
                Color   = Color.Info,
                OnClick = EventCallback.Factory.Create(this, () => OpenSendEmailDialog(item))
            });
        }

        if (canPay)
        {
            actions.Add(new WisDetailActionItem
            {
                Icon    = Icons.Material.Filled.Payment,
                Label   = Localization.GetString("Payment"),
                Color   = Color.Success,
                OnClick = EventCallback.Factory.Create(this, () => OpenPaymentDialog(item))
            });
        }

        if (canEdit)
        {
            actions.Add(new WisDetailActionItem
            {
                Icon    = Icons.Material.Filled.Edit,
                Label   = Localization.GetString("Edit"),
                OnClick = EventCallback.Factory.Create(this, () => Navigation.NavigateTo($"/invoices/edit/{item.Id}"))
            });
        }

        actions.Add(new WisDetailActionItem
        {
            Icon     = Icons.Material.Filled.FileDownload,
            Label    = Localization.GetString("Export"),
            Disabled = _exportingRow,
            OnClick  = EventCallback.Factory.Create(this, () => ExportInvoiceRow(item))
        });

        actions.Add(new WisDetailActionItem
        {
            Icon    = Icons.Material.Filled.ContentCopy,
            Label   = Localization.GetString("Copy"),
            OnClick = EventCallback.Factory.Create(this, () => Navigation.NavigateTo($"/invoices/create?copyFrom={item.Id}"))
        });

        if (canRevert)
        {
            actions.Add(new WisDetailActionItem
            {
                Icon    = Icons.Material.Filled.Undo,
                Label   = Localization.GetString("Draft"),
                OnClick = EventCallback.Factory.Create(this, () => RevertToDraftFromList(item))
            });
        }

        if (isCancelled)
        {
            actions.Add(new WisDetailActionItem
            {
                Icon            = Icons.Material.Filled.Delete,
                Label           = Localization.GetString("Delete"),
                Color           = Color.Error,
                IsDividerBefore = true,
                OnClick         = EventCallback.Factory.Create(this, () => DeleteInvoice(item))
            });
        }
        else if (canCancel)
        {
            actions.Add(new WisDetailActionItem
            {
                Icon            = Icons.Material.Filled.Cancel,
                Label           = Localization.GetString("Cancel"),
                Color           = Color.Error,
                IsDividerBefore = true,
                OnClick         = EventCallback.Factory.Create(this, () => CancelInvoice(item))
            });
        }

        return actions;
    }

    private async Task ExportInvoiceRow(InvoiceDto item)
    {
        _exportingRow = true;
        try
        {
            byte[] fileBytes = await ExcelExportService.ExportInvoiceForPrintingAsync(item.Id);
            string fileName = $"{Localization.GetString("Invoice")}_{item.InvoiceNumber}_{DateTime.UtcNow:yyyyMMdd}.xlsx";
            await DownloadFileAsync(fileBytes, fileName);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error exporting invoice: {ex.Message}");
            Snackbar.Add(Localization.GetString("ExportError"), Severity.Error);
        }
        finally
        {
            _exportingRow = false;
        }
    }

}
