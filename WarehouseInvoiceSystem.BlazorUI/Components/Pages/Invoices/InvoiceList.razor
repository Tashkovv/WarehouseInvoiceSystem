@page "/invoices"
@implements IDisposable
@using WarehouseInvoiceSystem.Application.DTOs.Invoice
@using WarehouseInvoiceSystem.Application.DTOs.Company
@using WarehouseInvoiceSystem.Application.Interfaces
@using WarehouseInvoiceSystem.Domain.Queries
@using WarehouseInvoiceSystem.Domain.Queries.Common
@using WarehouseInvoiceSystem.Domain.Enums
@inject IInvoiceService InvoiceService
@inject ICompanyService CompanyService
@inject ILocalizationService Localization
@inject NavigationManager Navigation
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject IJSRuntime JSRuntime
@inject IExcelExportService ExcelExportService

<PageTitle>@Localization.GetString("Invoices") - @Localization.GetString("InvoiceSystem")</PageTitle>

<div style="margin-bottom: 24px; padding: 4px 0;">
    <MudText Typo="Typo.h3" Class="wis-page-title">
        @Localization.GetString("Invoices")
    </MudText>
</div>

<WisGridToolbar CreateHref="/invoices/create"
                CreateLabel="@Localization.GetString("CreateInvoice")"
                SearchValue="@_searchString"
                SearchValueChanged="OnSearch"
                HasAnyActiveFilter="@(_filterStatuses.Count > 0 || _filterType.HasValue || _activeAdvancedFilterCount > 0)"
                OnClearAll="ClearAllFilters"
                ActiveAdvancedFilterCount="@_activeAdvancedFilterCount">
    <AdditionalActions>
        <MudButton StartIcon="@Icons.Material.Filled.Download"
                   Color="Color.Secondary"
                   Variant="Variant.Outlined"
                   OnClick="PerformExport"
                   Disabled="_exporting">
            @Localization.GetString("ExportToExcel")
        </MudButton>
    </AdditionalActions>
    <Filters>
        <FilterPopoverList TValue="InvoiceStatus"
                           Title="@Localization.GetString("FilterByStatus")"
                           Label="@Localization.GetString("Status")"
                           Items="_statusFilterItems"
                           Mode="FilterSelectionMode.Multiple"
                           SelectedValues="_filterStatuses"
                           SelectedValuesChanged="OnStatusFilterChanged" />
        <FilterPopoverList TValue="InvoiceType?"
                           Title="@Localization.GetString("Type")"
                           Label="@Localization.GetString("Type")"
                           Items="_typeFilterItems"
                           Mode="FilterSelectionMode.Single"
                           SelectedValue="_filterType"
                           SelectedValueChanged="OnTypeFilterChanged" />
    </Filters>
    <AdvancedFilters>
        <MudGrid Spacing="2" AlignItems="AlignItems.Start">
            <MudItem xs="12" sm="6" md="3">
                <MudText Typo="Typo.caption" Class="mb-1 d-block" Style="visibility: hidden;">
                    &nbsp;
                </MudText>
                <MudAutocomplete T="string"
                                 Value="_filterCompanyName"
                                 ValueChanged="OnCompanyFilterChanged"
                                 Label="@Localization.GetString("Company")"
                                 SearchFunc="SearchCompanyNames"
                                 Variant="Variant.Outlined"
                                 Dense="true"
                                 Clearable="true"
                                 OnClearedClick="@(() => OnCompanyFilterChanged(null))" />
            </MudItem>
            <MudItem xs="12" sm="6" md="3">
                <MudText Typo="Typo.caption" Class="mb-1 d-block" Style="color: var(--mud-palette-text-secondary);">
                    @Localization.GetString("IssueDate")
                </MudText>
                <MudStack Row="true" Spacing="1">
                    <MudDatePicker @bind-Date="_filterIssueDateFrom"
                                   @bind-Date:after="ReloadGrid"
                                   Label="@Localization.GetString("From")"
                                   Variant="Variant.Outlined"
                                   Dense="true" />
                    <MudDatePicker @bind-Date="_filterIssueDateTo"
                                   @bind-Date:after="ReloadGrid"
                                   Label="@Localization.GetString("To")"
                                   Variant="Variant.Outlined"
                                   Dense="true" />
                </MudStack>
            </MudItem>
            <MudItem xs="12" sm="6" md="3">
                <MudText Typo="Typo.caption" Class="mb-1 d-block" Style="color: var(--mud-palette-text-secondary);">
                    @Localization.GetString("DueDate")
                </MudText>
                <MudStack Row="true" Spacing="1">
                    <MudDatePicker @bind-Date="_filterDueDateFrom"
                                   @bind-Date:after="ReloadGrid"
                                   Label="@Localization.GetString("From")"
                                   Variant="Variant.Outlined"
                                   Dense="true" />
                    <MudDatePicker @bind-Date="_filterDueDateTo"
                                   @bind-Date:after="ReloadGrid"
                                   Label="@Localization.GetString("To")"
                                   Variant="Variant.Outlined"
                                   Dense="true" />
                </MudStack>
            </MudItem>
            <MudItem xs="12" sm="6" md="3">
                <MudText Typo="Typo.caption" Class="mb-1 d-block" Style="color: var(--mud-palette-text-secondary);">
                    @Localization.GetString("AmountRange")
                </MudText>
                <MudStack Row="true" Spacing="1">
                    <MudNumericField T="decimal?"
                                     @bind-Value="_filterAmountMin"
                                     @bind-Value:after="ReloadGrid"
                                     Label="@Localization.GetString("Min")"
                                     Variant="Variant.Outlined"
                                     HideSpinButtons="true"
                                     Format="N2"
                                     Dense="true" />
                    <MudNumericField T="decimal?"
                                     @bind-Value="_filterAmountMax"
                                     @bind-Value:after="ReloadGrid"
                                     Label="@Localization.GetString("Max")"
                                     Variant="Variant.Outlined"
                                     HideSpinButtons="true"
                                     Format="N2"
                                     Dense="true" />
                </MudStack>
            </MudItem>
        </MudGrid>
    </AdvancedFilters>
</WisGridToolbar>

<MudCard Elevation="2" Class="mb-4">
    <MudCardContent Class="pa-0">
        <MudDataGrid T="InvoiceDto"
                     @ref="_grid"
                     ServerData="LoadServerData"
                     RowClick="OnRowClick"
                     RowClassFunc="GetRowClass"
                     ReadOnly="true"
                     Hover="true"
                     FixedHeader="true"
                     Height="710px"
                     Filterable="false"
                     ShowColumnOptions="false"
                     ColumnResizeMode="ResizeMode.Column"
                     SortMode="SortMode.Single"
                     Class="wis-data-grid">
            <Columns>

                <PropertyColumn Property="x => x.InvoiceNumber"
                                Title="@Localization.GetString("InvoiceNumber")"
                                Sortable="true"
                                IsEditable="false"
                                CellStyle="font-family: monospace;" />

                <PropertyColumn Property="x => x.CompanyName"
                                Title="@Localization.GetString("Company")"
                                Sortable="true"
                                IsEditable="false" />

                <PropertyColumn Property="x => x.Type"
                                Title="@Localization.GetString("Type")"
                                Sortable="false"
                                IsEditable="false">
                    <CellTemplate>
                        <MudChip T="string" Size="Size.Small"
                                 Color="@(context.Item.Type == InvoiceType.Receivable ? Color.Success : Color.Warning)">
                            @(context.Item.Type == InvoiceType.Receivable
                                                        ? Localization.GetString("Receivable")
                                                        : Localization.GetString("Payable"))
                        </MudChip>
                    </CellTemplate>
                </PropertyColumn>

                <PropertyColumn Property="x => x.IssueDate"
                                Title="@Localization.GetString("IssueDate")"
                                Sortable="true"
                                IsEditable="false">
                    <CellTemplate>
                        @context.Item.IssueDate.ToString("dd MMM yyyy")
                    </CellTemplate>
                </PropertyColumn>

                <PropertyColumn Property="x => x.DueDate"
                                Title="@Localization.GetString("DueDate")"
                                Sortable="true"
                                IsEditable="false">
                    <CellTemplate>
                        @if (context.Item.DueDate < DateTime.UtcNow
                                                && context.Item.Status != InvoiceStatus.Paid
                                                && context.Item.Status != InvoiceStatus.Cancelled)
                        {
                            <MudText Color="Color.Error" Typo="Typo.body2">
                                @context.Item.DueDate.ToString("dd MMM yyyy")
                            </MudText>
                        }
                        else
                        {
                            <MudText Typo="Typo.body2">
                                @context.Item.DueDate.ToString("dd MMM yyyy")
                            </MudText>
                        }
                    </CellTemplate>
                </PropertyColumn>

                <PropertyColumn Property="x => x.TotalAmount"
                                Title="@Localization.GetString("Total")"
                                Sortable="true"
                                IsEditable="false">
                    <CellTemplate>
                        <MudText Typo="Typo.body2" Style="font-weight: 600;">
                            @context.Item.TotalAmount.ToString("N2")
                        </MudText>
                    </CellTemplate>
                </PropertyColumn>

                <PropertyColumn Property="x => x.Status"
                                Title="@Localization.GetString("Status")"
                                Sortable="false"
                                IsEditable="false">
                    <CellTemplate>
                        <MudChip T="string" Size="Size.Small"
                                 Color="@GetStatusColor(context.Item.Status)">
                            @GetStatusText(context.Item.Status)
                        </MudChip>
                    </CellTemplate>
                </PropertyColumn>

                <TemplateColumn Sortable="false"
                                Filterable="false"
                                IsEditable="false"
                                MinWidth="130"
                                HeaderStyle="width: 130px;"
                                CellStyle="width: 130px;">
                    <CellTemplate>
                        <MudStack Row="true" Spacing="0">
                            <MudIconButton Icon="@Icons.Material.Filled.Edit"
                                           Size="Size.Small"
                                           Color="Color.Primary"
                                           Title="@Localization.GetString("Edit")"
                                           OnClick="@(() => Navigation.NavigateTo($"/invoices/edit/{context.Item.Id}"))" />
                            <MudIconButton Icon="@Icons.Material.Filled.Payment"
                                           Size="Size.Small"
                                           Color="Color.Success"
                                           Title="@Localization.GetString("RecordPayment")"
                                           Disabled="@(context.Item.Status == InvoiceStatus.Paid || context.Item.Status == InvoiceStatus.Cancelled)"
                                           OnClick="@(() => Navigation.NavigateTo($"/payments/create?invoiceId={context.Item.Id}"))" />
                            <MudIconButton Icon="@Icons.Material.Filled.Email"
                                           Size="Size.Small"
                                           Color="Color.Secondary"
                                           Title="@Localization.GetString("SendEmail")"
                                           Disabled="@(context.Item.Status == InvoiceStatus.Cancelled)"
                                           OnClick="@(() => OpenSendEmailDialog(context.Item))" />
                            <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                           Size="Size.Small"
                                           Color="Color.Error"
                                           Title="@Localization.GetString("Delete")"
                                           OnClick="@(() => DeleteInvoice(context.Item.Id))" />
                        </MudStack>
                    </CellTemplate>
                </TemplateColumn>

            </Columns>

            <NoRecordsContent>
                <div class="pa-8 d-flex flex-column align-center">
                    <MudIcon Icon="@Icons.Material.Filled.Receipt"
                             Size="Size.Large"
                             Color="Color.Secondary"
                             Class="mb-2" />
                    <MudText Color="Color.Secondary">
                        @Localization.GetString("NoInvoicesFound")
                    </MudText>
                </div>
            </NoRecordsContent>

            <LoadingContent>
                <div class="pa-6">
                    <MudProgressLinear Color="Color.Primary" Indeterminate="true" />
                </div>
            </LoadingContent>

            <PagerContent>
                <WisPagerContent T="InvoiceDto" />
            </PagerContent>

        </MudDataGrid>
    </MudCardContent>
</MudCard>

@code {
    [Parameter]
    [SupplyParameterFromQuery(Name = "companyId")]
    public string? CompanyIdParam { get; set; }

    [Parameter]
    [SupplyParameterFromQuery(Name = "status")]
    public string? StatusParam { get; set; }

    private MudDataGrid<InvoiceDto> _grid = null!;
    private bool _exporting = false;
    private string _searchString = string.Empty;

    // Quick filters
    private HashSet<InvoiceStatus> _filterStatuses = [];
    private InvoiceType? _filterType = null;

    // Advanced filters
    private string? _filterCompanyName = null;
    private decimal? _filterAmountMin = null;
    private decimal? _filterAmountMax = null;
    private DateTime? _filterIssueDateFrom = null;
    private DateTime? _filterIssueDateTo = null;
    private DateTime? _filterDueDateFrom = null;
    private DateTime? _filterDueDateTo = null;

    // Company name suggestions cache
    private List<string> _companyNames = [];

    private List<FilterPopoverItem<InvoiceStatus>> _statusFilterItems = [];
    private List<FilterPopoverItem<InvoiceType?>> _typeFilterItems = [];

    private int _activeAdvancedFilterCount =>
        (!string.IsNullOrWhiteSpace(_filterCompanyName) ? 1 : 0) +
        (_filterIssueDateFrom.HasValue || _filterIssueDateTo.HasValue ? 1 : 0) +
        (_filterDueDateFrom.HasValue || _filterDueDateTo.HasValue ? 1 : 0) +
        (_filterAmountMin.HasValue || _filterAmountMax.HasValue ? 1 : 0);

    protected override async Task OnInitializedAsync()
    {
        Localization.OnLanguageChanged += OnLanguageChanged;
        BuildFilterItems();
        await PreloadCompanyNames();
        ApplyQueryParams();
    }

    private void ApplyQueryParams()
    {
        if (!string.IsNullOrWhiteSpace(StatusParam) &&
            Enum.TryParse<InvoiceStatus>(StatusParam, ignoreCase: true, out InvoiceStatus parsedStatus))
        {
            _filterStatuses.Add(parsedStatus);
        }

        if (!string.IsNullOrWhiteSpace(CompanyIdParam) &&
            Guid.TryParse(CompanyIdParam, out Guid companyId))
        {
            // Resolve company name from preloaded names or leave for autocomplete
            // The query will use CompanyId via CompanyName lookup on the server side
            // For now store the raw id so LoadServerData can pass it
            _pendingCompanyId = companyId;
        }
    }

    private Guid? _pendingCompanyId = null;

    private void BuildFilterItems()
    {
        _statusFilterItems =
        [
            new() { Label = Localization.GetString("Draft"),           Value = InvoiceStatus.Draft,         Color = Color.Transparent },
            new() { Label = Localization.GetString("Sent"),            Value = InvoiceStatus.Sent,          Color = Color.Info    },
            new() { Label = Localization.GetString("PartiallyPaid"),   Value = InvoiceStatus.PartiallyPaid, Color = Color.Warning },
            new() { Label = Localization.GetString("PaidStatus"),      Value = InvoiceStatus.Paid,          Color = Color.Success },
            new() { Label = Localization.GetString("OverdueStatus"),   Value = InvoiceStatus.Overdue,       Color = Color.Error   },
            new() { Label = Localization.GetString("CancelledStatus"), Value = InvoiceStatus.Cancelled,     Color = Color.Default },
        ];

        _typeFilterItems =
        [
            new() { Label = Localization.GetString("All"),        Value = null,                   Color = Color.Transparent },
            new() { Label = Localization.GetString("Receivable"), Value = InvoiceType.Receivable, Color = Color.Success },
            new() { Label = Localization.GetString("Payable"),    Value = InvoiceType.Payable,    Color = Color.Warning },
        ];
    }

    private async Task PreloadCompanyNames()
    {
        try
        {
            IEnumerable<CompanyDto> companies = await CompanyService.GetActiveCompaniesAsync();
            _companyNames = companies.Select(c => c.Name).OrderBy(n => n).ToList();

            // Resolve pending company id to name
            if (_pendingCompanyId.HasValue)
            {
                CompanyDto? match = companies.FirstOrDefault(c => c.Id == _pendingCompanyId.Value);
                if (match is not null)
                    _filterCompanyName = match.Name;
                _pendingCompanyId = null;
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error preloading companies: {ex.Message}");
        }
    }

    private async void OnLanguageChanged()
    {
        BuildFilterItems();
        await InvokeAsync(StateHasChanged);
    }

    private async Task<GridData<InvoiceDto>> LoadServerData(GridState<InvoiceDto> state, CancellationToken ct)
    {
        string? sortBy = state.SortDefinitions.FirstOrDefault()?.SortBy;
        bool ascending = state.SortDefinitions.FirstOrDefault()?.Descending == false;

        GetInvoicesQuery query = BuildQuery();
        query.Page = state.Page + 1;
        query.PageSize = state.PageSize;
        query.SortBy = sortBy;
        query.SortAscending = ascending;

        PagedResult<InvoiceDto> result = await InvoiceService.GetPagedAsync(query);

        return new GridData<InvoiceDto>
        {
            Items = result.Items,
            TotalItems = result.TotalCount
        };
    }

    private GetInvoicesQuery BuildQuery() => new()
    {
        Search = _searchString,
        Statuses = _filterStatuses.Count > 0 ? _filterStatuses.ToList() : null,
        Type = _filterType,
        CompanyName = _filterCompanyName,
        AmountMin = _filterAmountMin,
        AmountMax = _filterAmountMax,
        IssueDateFrom = _filterIssueDateFrom,
        IssueDateTo = _filterIssueDateTo,
        DueDateFrom = _filterDueDateFrom,
        DueDateTo = _filterDueDateTo,
    };

    private string GetRowClass(InvoiceDto item, int index) => item.Status switch
    {
        InvoiceStatus.Draft => "row-status-default",
        InvoiceStatus.Sent => "row-status-info",
        InvoiceStatus.PartiallyPaid => "row-status-warning",
        InvoiceStatus.Paid => "row-status-active",
        InvoiceStatus.Overdue => "row-status-error",
        InvoiceStatus.Cancelled => "row-status-inactive",
        _ => "row-status-default"
    };

    private Color GetStatusColor(InvoiceStatus status) => status switch
    {
        InvoiceStatus.Draft => Color.Default,
        InvoiceStatus.Sent => Color.Info,
        InvoiceStatus.PartiallyPaid => Color.Warning,
        InvoiceStatus.Paid => Color.Success,
        InvoiceStatus.Overdue => Color.Error,
        InvoiceStatus.Cancelled => Color.Default,
        _ => Color.Default
    };

    private string GetStatusText(InvoiceStatus status) => status switch
    {
        InvoiceStatus.Draft => Localization.GetString("Draft"),
        InvoiceStatus.Sent => Localization.GetString("Sent"),
        InvoiceStatus.PartiallyPaid => Localization.GetString("PartiallyPaid"),
        InvoiceStatus.Paid => Localization.GetString("PaidStatus"),
        InvoiceStatus.Overdue => Localization.GetString("OverdueStatus"),
        InvoiceStatus.Cancelled => Localization.GetString("CancelledStatus"),
        _ => status.ToString()
    };

    private async Task<IEnumerable<string>> SearchCompanyNames(string value, CancellationToken ct)
    {
        if (string.IsNullOrWhiteSpace(value))
            return _companyNames;

        string lower = value.ToLower();
        return _companyNames.Where(n => n.ToLower().Contains(lower));
    }

    private async Task OnSearch(string text)
    {
        _searchString = text;
        await _grid.ReloadServerData();
    }

    private async Task OnStatusFilterChanged(IReadOnlyCollection<InvoiceStatus> values)
    {
        _filterStatuses = values.ToHashSet();
        await _grid.ReloadServerData();
    }

    private async Task OnTypeFilterChanged(InvoiceType? value)
    {
        _filterType = value;
        await _grid.ReloadServerData();
    }

    private async Task OnCompanyFilterChanged(string? value)
    {
        _filterCompanyName = value;
        await _grid.ReloadServerData();
    }

    private async Task ReloadGrid() => await _grid.ReloadServerData();

    private async Task ClearAllFilters()
    {
        _filterStatuses = [];
        _filterType = null;
        _filterCompanyName = null;
        _filterAmountMin = null;
        _filterAmountMax = null;
        _filterIssueDateFrom = null;
        _filterIssueDateTo = null;
        _filterDueDateFrom = null;
        _filterDueDateTo = null;
        await _grid.ReloadServerData();
    }

    private async void OnRowClick(DataGridRowClickEventArgs<InvoiceDto> args)
    {
        if (args.MouseEventArgs.Detail == 2)
            Navigation.NavigateTo($"/invoices/{args.Item.Id}");
    }

    private async Task OpenSendEmailDialog(InvoiceDto invoice)
    {
        DialogOptions options = new()
        {
            MaxWidth = MaxWidth.Small,
            FullWidth = true,
            CloseOnEscapeKey = true
        };

        IDialogReference dialog = await DialogService.ShowAsync<SendInvoiceEmailDialog>(
            Localization.GetString("SendInvoiceEmail"), options);

        DialogResult? result = await dialog.Result;

        if (result is { Canceled: false, Data: SendInvoiceEmailDialog.SendEmailResult emailResult })
        {
            try
            {
                await InvoiceService.UpdateInvoiceStatusAsync(invoice.Id, InvoiceStatus.Sent);
                Snackbar.Add(Localization.GetString("InvoiceEmailSentSuccessfully"), Severity.Success);
                await _grid.ReloadServerData();
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Error updating invoice status after email: {ex.Message}");
            }
        }
    }

    private async Task DeleteInvoice(Guid id)
    {
        bool? result = await DialogService.ShowMessageBoxAsync(new MessageBoxOptions
        {
            Title = Localization.GetString("ConfirmDelete"),
            Message = Localization.GetString("DeleteInvoiceConfirm"),
            YesText = Localization.GetString("Yes"),
            CancelText = Localization.GetString("No")
        });

        if (result == true)
        {
            try
            {
                bool deleted = await InvoiceService.DeleteInvoiceAsync(id);
                if (deleted)
                {
                    Snackbar.Add(Localization.GetString("InvoiceDeleted"), Severity.Success);
                    await _grid.ReloadServerData();
                }
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Error deleting invoice: {ex.Message}");
                Snackbar.Add(Localization.GetString("ErrorDeletingInvoice"), Severity.Error);
            }
        }
    }

    private async Task PerformExport()
    {
        _exporting = true;
        StateHasChanged();

        try
        {
            GetInvoicesQuery exportQuery = BuildQuery();
            IEnumerable<InvoiceDto> invoices = await InvoiceService.GetAllFilteredAsync(exportQuery);

            byte[] fileBytes = await ExcelExportService.ExportInvoicesToExcelAsync(invoices);
            string fileName = $"{Localization.GetString("Invoices")}_{DateTime.UtcNow:yyyyMMdd}.xlsx";

            await JSRuntime.InvokeVoidAsync(
                "fileDownloadHelper.downloadFileFromStream",
                fileName,
                new DotNetStreamReference(new MemoryStream(fileBytes)));

            Snackbar.Add(Localization.GetString("ExportSuccess"), Severity.Success);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error exporting invoices: {ex.Message}");
            Snackbar.Add(Localization.GetString("ExportError"), Severity.Error);
        }
        finally
        {
            _exporting = false;
            StateHasChanged();
        }
    }

    public void Dispose()
    {
        Localization.OnLanguageChanged -= OnLanguageChanged;
    }
}
