@page "/invoices"
@implements IDisposable
@using WarehouseInvoiceSystem.Application.DTOs.Invoice
@using WarehouseInvoiceSystem.Application.Interfaces
@inject IInvoiceService InvoiceService
@inject ILocalizationService Localization
@inject NavigationManager Navigation
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject IJSRuntime JSRuntime
@inject IExcelExportService ExcelExportService

<PageTitle>@Localization.GetString("Invoices") - @Localization.GetString("InvoiceSystem")</PageTitle>

<MudText Typo="Typo.h4" Class="mb-6">@Localization.GetString("Invoices")</MudText>

<MudCard Elevation="2" Class="mb-4">
    <MudCardContent>
        <MudGrid>
            <MudItem xs="12" sm="3" md="2">
                <MudButton StartIcon="@Icons.Material.Filled.Add"
                           Color="Color.Primary"
                           Variant="Variant.Filled"
                           FullWidth="true"
                           Href="/invoices/create">
                    @Localization.GetString("CreateInvoice")
                </MudButton>
            </MudItem>
            <MudItem xs="12" sm="3" md="2">
                <MudButton StartIcon="@Icons.Material.Filled.Download"
                           Color="Color.Secondary"
                           Variant="Variant.Outlined"
                           FullWidth="true"
                           OnClick="PerformExport"
                           Disabled="_exporting">
                    @Localization.GetString("ExportToExcel")
                </MudButton>
            </MudItem>
            <MudItem xs="12" sm="3" md="8">
                <MudTextField @bind-Value="_searchString"
                              Placeholder="@Localization.GetString("Search")"
                              Adornment="Adornment.Start"
                              AdornmentIcon="@Icons.Material.Filled.Search"
                              IconSize="Size.Medium"
                              Immediate="true"
                              DebounceInterval="300"
                              OnDebounceIntervalElapsed="OnSearch"
                              Class="mt-0" />
            </MudItem>
        </MudGrid>

        <!-- Filter Toggle Button -->
        <div class="mt-4">
            <MudButton StartIcon="@(_showFilters? Icons.Material.Filled.ExpandLess : Icons.Material.Filled.ExpandMore)"
                       Variant="Variant.Text"
                       Color="Color.Primary"
                       OnClick="@(() => _showFilters = !_showFilters)">
                @Localization.GetString("AdvancedFilters")
                @if (_hasActiveFilters)
                {
                    <MudChip T="int" Size="Size.Small" Class="ml-2">@_activeFilterCount</MudChip>
                }
            </MudButton>
        </div>

        <!-- Filters Panel (Collapsible) -->
        @if (_showFilters)
        {
            <MudDivider Class="my-4" />
            <MudGrid>
                <!-- Status Filter -->
                <MudItem xs="12" sm="6" md="3">
                    <MudSelect T="InvoiceStatus ?"
                               @bind-Value="_filterStatus"
                               @bind-Value:after="ResetPaginationAndApplyFilters"
                               Label="@Localization.GetString("Status")"
                               Clearable="true"
                               Dense="true">
                        @foreach (var status in Enum.GetValues<InvoiceStatus>())
                        {
                            <MudSelectItem T="InvoiceStatus ?" Value="@(status)">
                                <MudChip T="InvoiceStatus"
                                         Size="Size.Small"
                                         Color="GetStatusColor(status)">
                                    @Localization.GetString(status.ToString())
                                </MudChip>
                            </MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>

                <!-- Type Filter -->
                <MudItem xs="12" sm="6" md="3">
                    <MudSelect T="InvoiceType ?"
                               @bind-Value="_filterType"
                               @bind-Value:after="ResetPaginationAndApplyFilters"
                               Label="@Localization.GetString("Type")"
                               Clearable="true">
                        <MudSelectItem T="InvoiceType ?" Value="@((InvoiceType?)InvoiceType.Receivable)">
                            <MudChip T="string" Size="Size.Small" Color="Color.Success">
                                @Localization.GetString("Receivable")
                            </MudChip>
                        </MudSelectItem>
                        <MudSelectItem T="InvoiceType ?" Value="@((InvoiceType?)InvoiceType.Payable)">
                            <MudChip T="string" Size="Size.Small" Color="Color.Warning">
                                @Localization.GetString("Payable")
                            </MudChip>
                        </MudSelectItem>
                    </MudSelect>
                </MudItem>

                <!-- Company Filter -->
                <MudItem xs="12" sm="6" md="3">
                    <MudAutocomplete T="string"
                                     @bind-Value="_filterCompany"
                                     @bind-Value:after="ResetPaginationAndApplyFilters"
                                     Label="@Localization.GetString("Company")"
                                     SearchFunc="@SearchCompanies"
                                     Dense="true"
                                     Clearable="true"
                                     OnClearedClick="@(() => { _filterCompany = null; ResetPaginationAndApplyFilters(); })"/>
                </MudItem>

                <!-- Clear Filters Button -->
                <MudItem xs="12" sm="6" md="3" Class="d-flex align-end">
                    <MudButton StartIcon="@Icons.Material.Filled.FilterAltOff"
                               Variant="Variant.Outlined"
                               Color="Color.Default"
                               OnClick="ClearFilters"
                               Disabled="@(!_hasActiveFilters)">
                        @Localization.GetString("ClearFilters")
                    </MudButton>
                </MudItem>

                <!-- Issue Date Range Filter -->
                <MudItem xs="12" sm="6" md="3">
                    <MudText Typo="Typo.body2" Class="mb-2">@Localization.GetString("IssueDate")</MudText>
                    <MudStack Row="true" Spacing="1">
                        <MudDatePicker @bind-Date="_filterIssueDateFrom"
                                       @bind-Date:after="ResetPaginationAndApplyFilters"
                                       Label="@Localization.GetString("From")"
                                       Dense="true"/>
                        <MudDatePicker @bind-Date="_filterIssueDateTo"
                                       @bind-Date:after="ResetPaginationAndApplyFilters"
                                       Label="@Localization.GetString("To")"
                                       Dense="true"/>
                    </MudStack>
                </MudItem>

                <!-- Due Date Range Filter -->
                <MudItem xs="12" sm="6" md="3">
                    <MudText Typo="Typo.body2" Class="mb-2">@Localization.GetString("DueDate")</MudText>
                    <MudStack Row="true" Spacing="1">
                        <MudDatePicker @bind-Date="_filterDueDateFrom"
                                       @bind-Date:after="ResetPaginationAndApplyFilters"
                                       Label="@Localization.GetString("From")"
                                       Dense="true"/>
                        <MudDatePicker @bind-Date="_filterDueDateTo"
                                       @bind-Date:after="ResetPaginationAndApplyFilters"
                                       Label="@Localization.GetString("To")"
                                       Dense="true"/>
                    </MudStack>
                </MudItem>

                <!-- Amount Range Filter -->
                <MudItem xs="12" sm="6" md="3">
                    <MudText Typo="Typo.body2" Class="mb-2">@Localization.GetString("AmountRange")</MudText>
                    <MudStack Row="true" Spacing="1">
                        <MudNumericField T="decimal?"
                                         @bind-Value="_filterAmountMin"
                                         @bind-Value:after="ResetPaginationAndApplyFilters"
                                         Label="@Localization.GetString("Min")"
                                         HideSpinButtons="true"
                                         Dense="true"
                                         Format="N2"
                                         Immediate="true" />
                        <MudNumericField T="decimal?"
                                         @bind-Value="_filterAmountMax"
                                         @bind-Value:after="ResetPaginationAndApplyFilters"
                                         Label="@Localization.GetString("Max")"
                                         HideSpinButtons="true"
                                         Dense="true"
                                         Format="N2"
                                         Immediate="true" />
                    </MudStack>
                </MudItem>
            </MudGrid>
        }
    </MudCardContent>
</MudCard>

<MudCard Elevation="2" Class="mb-4">
    <MudCardContent Class="pa-0">
        @if (_loading)
        {
            <div class="pa-6">
                <MudProgressLinear Color="Color.Primary" Indeterminate="true" />
            </div>
        }
        else if (_filteredInvoices == null || !_filteredInvoices.Any())
        {
            <div class="pa-6 text-center">
                <MudText Color="Color.Secondary">@Localization.GetString("NoInvoicesFound")</MudText>
            </div>
        }
        else
        {
            <MudTable Items="_paginatedInvoices"
                      Hover="true"
                      Breakpoint="Breakpoint.Sm"
                      Dense="false"
                      FixedHeader="true"
                      RowClass="table-row-clickable"
                      OnRowClick="@((TableRowClickEventArgs<InvoiceDto> args) => OnRowClick(args))"
                      Height="710px"
                      Sort="@((SortDefinition<InvoiceDto> sortDefinition) => HandleSort(sortDefinition))">
                <HeaderContent>
                    <MudTh><MudTableSortLabel SortBy="new Func<InvoiceDto, object>(x => x.InvoiceNumber)">@Localization.GetString("InvoiceNumber")</MudTableSortLabel></MudTh>
                    <MudTh><MudTableSortLabel SortBy="new Func<InvoiceDto, object>(x => x.CompanyName)">@Localization.GetString("Company")</MudTableSortLabel></MudTh>
                    <MudTh>@Localization.GetString("Type")</MudTh>
                    <MudTh><MudTableSortLabel SortBy="new Func<InvoiceDto, object>(x => x.IssueDate)">@Localization.GetString("IssueDate")</MudTableSortLabel></MudTh>
                    <MudTh><MudTableSortLabel SortBy="new Func<InvoiceDto, object>(x => x.DueDate)">@Localization.GetString("DueDate")</MudTableSortLabel></MudTh>
                    <MudTh><MudTableSortLabel SortBy="new Func<InvoiceDto, object>(x => x.TotalAmount)">@Localization.GetString("Total")</MudTableSortLabel></MudTh>
                    <MudTh>@Localization.GetString("Status")</MudTh>
                    <MudTh>@Localization.GetString("Actions")</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="@Localization.GetString("InvoiceNumber")">
                        <MudText Typo="Typo.body2" Class="font-weight-medium">
                            @context.InvoiceNumber
                        </MudText>
                    </MudTd>
                    <MudTd DataLabel="@Localization.GetString("Company")">
                        <MudText>@context.CompanyName</MudText>
                    </MudTd>
                    <MudTd DataLabel="@Localization.GetString("Type")">
                        <MudChip T="string"
                                 Size="Size.Small"
                                 Color="@(context.Type == InvoiceType.Receivable ? Color.Success : Color.Warning)">
                            @(Localization.GetString(context.Type.ToString()))
                        </MudChip>
                    </MudTd>
                    <MudTd DataLabel="@Localization.GetString("IssueDate")">
                        @context.IssueDate.ToString("MMM dd, yyyy")
                    </MudTd>
                    <MudTd DataLabel="@Localization.GetString("DueDate")">
                        @if (context.DueDate < DateTime.UtcNow && context.Status != InvoiceStatus.Paid)
                        {
                            <MudText Color="Color.Error">
                                @context.DueDate.ToString("MMM dd, yyyy")
                            </MudText>
                        }
                        else
                        {
                            <MudText>@context.DueDate.ToString("MMM dd, yyyy")</MudText>
                        }
                    </MudTd>
                    <MudTd DataLabel="@Localization.GetString("Total")">
                        <MudText Typo="Typo.body2" Class="font-weight-medium">
                            @context.TotalAmount.ToString("C")
                        </MudText>
                    </MudTd>
                    <MudTd DataLabel="@Localization.GetString("Status")">
                        <MudChip T="string" Size="Size.Small" Color="GetStatusColor(context.Status)">
                            @GetStatusText(context.Status)
                        </MudChip>
                    </MudTd>
                    <MudTd DataLabel="@Localization.GetString("Actions")">
                        <MudMenu Icon="@Icons.Material.Filled.MoreVert" Size="Size.Small">
                            <MudMenuItem Icon="@Icons.Material.Filled.Edit"
                                         OnClick="@(() => EditInvoice(context.Id))">
                                @Localization.GetString("Edit")
                            </MudMenuItem>
                            <MudMenuItem Icon="@Icons.Material.Filled.Payment"
                                         OnClick="@(() => RecordPayment(context.Id))"
                                         Disabled="@(context.Status == InvoiceStatus.Paid || context.Status == InvoiceStatus.Cancelled)">
                                @Localization.GetString("RecordPayment")
                            </MudMenuItem>
                            <MudDivider />
                            <MudMenuItem Icon="@Icons.Material.Filled.Delete"
                                         IconColor="Color.Error"
                                         OnClick="@(() => DeleteInvoice(context.Id))">
                                @Localization.GetString("Delete")
                            </MudMenuItem>
                        </MudMenu>
                    </MudTd>
                </RowTemplate>
            </MudTable>

            <!-- Pagination Controls -->
            <MudDivider />
            <MudCardContent Class="pa-4">
                <MudGrid>
                    <!-- Left Side: Page Navigation -->
                    <MudItem xs="12" sm="6">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                            <MudButton Variant="Variant.Outlined"
                                       Size="Size.Small"
                                       OnClick="PreviousPage"
                                       Disabled="@(_currentPage == 1)">
                                @Localization.GetString("Previous")
                            </MudButton>

                            <MudText Typo="Typo.body2">
                                @Localization.GetString("Page") @_currentPage @Localization.GetString("Of") @_totalPages
                            </MudText>

                            <MudButton Variant="Variant.Outlined"
                                       Size="Size.Small"
                                       OnClick="NextPage"
                                       Disabled="@(_currentPage == _totalPages)">
                                @Localization.GetString("Next")
                            </MudButton>
                        </MudStack>
                    </MudItem>

                    <!-- Right Side: Items Per Page & Stats -->
                    <MudItem xs="12" sm="6" Class="d-flex justify-end align-center">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1" Class="ml-auto">
                            <MudText Typo="Typo.body2">
                                @Localization.GetString("ItemsPerPage")
                            </MudText>

                            <MudSelect T="int"
                                       @bind-Value="_itemsPerPage"
                                       @bind-Value:after="UpdatePagination"
                                       Dense="true"
                                       Variant="Variant.Outlined"
                                       Style="width: 100px;">
                                <MudSelectItem Value="10">10</MudSelectItem>
                                <MudSelectItem Value="25">25</MudSelectItem>
                                <MudSelectItem Value="50">50</MudSelectItem>
                                <MudSelectItem Value="100">100</MudSelectItem>
                            </MudSelect>

                            <MudText Typo="Typo.body2" Color="Color.Secondary">
                                (@_totalInvoices @Localization.GetString("Total"))
                            </MudText>
                        </MudStack>
                    </MudItem>
                </MudGrid>
            </MudCardContent>
        }
    </MudCardContent>
</MudCard>

@code {
    [Parameter]
    [SupplyParameterFromQuery(Name = "companyId")]
    public string? CompanyIdParameter { get; set; }
    [Parameter]
    [SupplyParameterFromQuery(Name = "status")]
    public string? StatusParameter { get; set; }

    private bool _loading = true;
    private bool _exporting = false;
    private bool _showFilters = false;
    private List<InvoiceDto> _allInvoices = new();
    private List<InvoiceDto> _filteredInvoices = new();
    private List<InvoiceDto> _paginatedInvoices = new();
    private string _searchString = "";
    private int _activeTabIndex = 0;

    private int _currentPage = 1;
    private int _itemsPerPage = 10;
    private int _totalInvoices = 0;
    private int _totalPages = 1;

    private InvoiceStatus? _filterStatus;
    private InvoiceType? _filterType;
    private string? _filterCompany;
    private decimal? _filterAmountMin;
    private decimal? _filterAmountMax;
    private DateTime? _filterIssueDateFrom;
    private DateTime? _filterIssueDateTo;
    private DateTime? _filterDueDateFrom;
    private DateTime? _filterDueDateTo;

    private string _sortBy = "CreatedAt";
    private bool _sortAscending = false;

    private bool _hasActiveFilters =>
        _filterStatus.HasValue ||
        _filterType.HasValue ||
        !string.IsNullOrWhiteSpace(_filterCompany) ||
        _filterAmountMin.HasValue ||
        _filterAmountMax.HasValue ||
        _filterIssueDateFrom.HasValue ||
        _filterIssueDateTo.HasValue ||
        _filterDueDateFrom.HasValue ||
        _filterDueDateTo.HasValue;

    private int _activeFilterCount =>
        (_filterStatus.HasValue ? 1 : 0) +
        (_filterType.HasValue ? 1 : 0) +
        (!string.IsNullOrWhiteSpace(_filterCompany) ? 1 : 0) +
        (_filterAmountMin.HasValue || _filterAmountMax.HasValue ? 1 : 0) +
        (_filterIssueDateFrom.HasValue || _filterIssueDateTo.HasValue ? 1 : 0) +
        (_filterDueDateFrom.HasValue || _filterDueDateTo.HasValue ? 1 : 0);

    protected override async Task OnInitializedAsync()
    {
        Localization.OnLanguageChanged += OnLanguageChanged;
        await LoadInvoices();
    }

    private async void OnLanguageChanged()
    {
        await InvokeAsync(StateHasChanged);
    }

    private async Task LoadInvoices()
    {
        _loading = true;

        try
        {
            IEnumerable<InvoiceDto> invoices;

            if (!string.IsNullOrWhiteSpace(StatusParameter) &&
                Enum.TryParse<InvoiceStatus>(StatusParameter, true, out InvoiceStatus paramStatus))
            {
                invoices = await InvoiceService.GetInvoicesByStatusAsync(paramStatus);

                _filterStatus = paramStatus;
                StatusParameter = string.Empty;
            }
            else if (!string.IsNullOrWhiteSpace(CompanyIdParameter) &&
                     Guid.TryParse(CompanyIdParameter, out Guid companyId))
            {
                invoices = await InvoiceService.GetInvoicesByCompanyAsync(companyId);

                _filterCompany = invoices.FirstOrDefault()?.CompanyName;
                CompanyIdParameter = null;
            }
            else
            {
                invoices = await InvoiceService.GetAllInvoicesAsync();
            }

            _allInvoices = invoices.ToList();

            ApplyFilters();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading invoices: {ex.Message}");
            Snackbar.Add(Localization.GetString("ErrorLoadingInvoice"), Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    private void ApplyFilters()
    {
        IEnumerable<InvoiceDto> filtered = _allInvoices;

        if (_filterStatus.HasValue)
            filtered = filtered.Where(i => i.Status == _filterStatus.Value);

        if (_filterType.HasValue)
            filtered = filtered.Where(i => i.Type == _filterType.Value);

        if (!string.IsNullOrWhiteSpace(_filterCompany))
            filtered = filtered.Where(i => i.CompanyName.Equals(_filterCompany, StringComparison.OrdinalIgnoreCase));

        if (_filterAmountMin.HasValue)
            filtered = filtered.Where(i => i.TotalAmount >= _filterAmountMin.Value);

        if (_filterAmountMax.HasValue)
            filtered = filtered.Where(i => i.TotalAmount <= _filterAmountMax.Value);

        if (_filterIssueDateFrom.HasValue)
            filtered = filtered.Where(i => i.IssueDate.Date >= _filterIssueDateFrom.Value.Date);

        if (_filterIssueDateTo.HasValue)
            filtered = filtered.Where(i => i.IssueDate.Date <= _filterIssueDateTo.Value.Date);

        if (_filterDueDateFrom.HasValue)
            filtered = filtered.Where(i => i.DueDate.Date >= _filterDueDateFrom.Value.Date);

        if (_filterDueDateTo.HasValue)
            filtered = filtered.Where(i => i.DueDate.Date <= _filterDueDateTo.Value.Date);

        if (!string.IsNullOrWhiteSpace(_searchString))
        {
            string search = _searchString.ToLower();
            filtered = filtered.Where(i =>
                i.InvoiceNumber.ToLower().Contains(search) ||
                i.CompanyName.ToLower().Contains(search) ||
                i.TotalAmount.ToString().Contains(search));
        }

        filtered = _sortAscending
            ? filtered.OrderBy(GetSortProperty)
            : filtered.OrderByDescending(GetSortProperty);

        _filteredInvoices = filtered.ToList();
        _totalInvoices = _filteredInvoices.Count;

        UpdatePagination();
    }

    private void UpdatePagination()
    {
        _currentPage = 1;
        _totalPages = (int)Math.Ceiling((double)_totalInvoices / _itemsPerPage);

        if (_currentPage > _totalPages && _totalPages > 0)
            _currentPage = _totalPages;

        int skipCount = (_currentPage - 1) * _itemsPerPage;
        _paginatedInvoices = _filteredInvoices
            .Skip(skipCount)
            .Take(_itemsPerPage)
            .ToList();
    }

    private void ResetPaginationAndApplyFilters()
    {
        _currentPage = 1;
        ApplyFilters();
    }

    private object GetSortProperty(InvoiceDto invoice) => _sortBy switch
    {
        "InvoiceNumber" => invoice.InvoiceNumber,
        "CompanyName" => invoice.CompanyName,
        "IssueDate" => invoice.IssueDate,
        "DueDate" => invoice.DueDate,
        "TotalAmount" => invoice.TotalAmount,
        _ => invoice.CreatedAt
    };

    private void HandleSort(SortDefinition<InvoiceDto> sortDefinition)
    {
        if (sortDefinition == null || string.IsNullOrEmpty(sortDefinition.SortBy))
            return;

        _sortBy = sortDefinition.SortBy;
        _sortAscending = !sortDefinition.Descending;
        ApplyFilters();
    }

    private async Task OnSearch(string text)
    {
        _searchString = text;
        ResetPaginationAndApplyFilters();
        await InvokeAsync(StateHasChanged);
    }

    private void ClearFilters()
    {
        _filterStatus = null;
        _filterType = null;
        _filterCompany = null;
        _filterAmountMin = null;
        _filterAmountMax = null;
        _filterIssueDateFrom = null;
        _filterIssueDateTo = null;
        _filterDueDateFrom = null;
        _filterDueDateTo = null;
        ResetPaginationAndApplyFilters();
    }

    private void PreviousPage()
    {
        if (_currentPage > 1)
        {
            _currentPage--;
            UpdatePagination();
        }
    }

    private void NextPage()
    {
        if (_currentPage < _totalPages)
        {
            _currentPage++;
            UpdatePagination();
        }
    }

    private void OnRowClick(TableRowClickEventArgs<InvoiceDto> args)
    {
        if (args.MouseEventArgs.Detail == 2)
            ViewInvoice(args.Item!.Id);
    }

    private Color GetStatusColor(InvoiceStatus? status) => status switch
    {
        InvoiceStatus.Draft => Color.Default,
        InvoiceStatus.Sent => Color.Info,
        InvoiceStatus.PartiallyPaid => Color.Warning,
        InvoiceStatus.Paid => Color.Success,
        InvoiceStatus.Overdue => Color.Error,
        InvoiceStatus.Cancelled => Color.Default,
        _ => Color.Default
    };

    private string GetStatusText(InvoiceStatus? status) => status switch
    {
        InvoiceStatus.Draft => Localization.GetString("Draft"),
        InvoiceStatus.Sent => Localization.GetString("Sent"),
        InvoiceStatus.PartiallyPaid => Localization.GetString("PartiallyPaid"),
        InvoiceStatus.Paid => Localization.GetString("PaidStatus"),
        InvoiceStatus.Overdue => Localization.GetString("OverdueStatus"),
        InvoiceStatus.Cancelled => Localization.GetString("Cancelled"),
        _ => status?.ToString() ?? string.Empty
    };

    private async Task<IEnumerable<string>> SearchCompanies(string value, CancellationToken cancellationToken)
    {
        if (string.IsNullOrEmpty(value))
            return _allInvoices.Select(i => i.CompanyName).Distinct().OrderBy(c => c);

        string search = value.ToLower();
        return _allInvoices
            .Select(i => i.CompanyName)
            .Distinct()
            .Where(c => c.ToLower().Contains(search))
            .OrderBy(c => c);
    }

    private void ViewInvoice(Guid id) =>
        Navigation.NavigateTo($"/invoices/{id}");

    private void EditInvoice(Guid id) =>
        Navigation.NavigateTo($"/invoices/edit/{id}");

    private void RecordPayment(Guid id) =>
        Navigation.NavigateTo($"/payments/create?invoiceId={id}");

    private async Task DeleteInvoice(Guid id)
    {
        bool? result = await DialogService.ShowMessageBoxAsync(
            new MessageBoxOptions
            {
                Title = Localization.GetString("ConfirmDelete"),
                Message = Localization.GetString("DeleteInvoiceConfirm"),
                YesText = Localization.GetString("Yes"),
                CancelText = Localization.GetString("No")
            });

        if (result == true)
        {
            try
            {
                bool deleted = await InvoiceService.DeleteInvoiceAsync(id);
                if (deleted)
                {
                    Snackbar.Add(Localization.GetString("InvoiceDeleted"), Severity.Success);

                    _allInvoices.RemoveAll(i => i.Id == id);
                    ApplyFilters();
                }
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Error deleting invoice: {ex.Message}");
                Snackbar.Add(Localization.GetString("ErrorDeletingInvoice"), Severity.Error);
            }
        }
    }

    private async Task OnTabChanged(int index)
    {
        _activeTabIndex = index;
        ResetPaginationAndApplyFilters();
        await InvokeAsync(StateHasChanged);
    }

    private async Task PerformExport()
    {
        _exporting = true;

        try
        {
            byte[] fileBytes = await ExcelExportService.ExportInvoicesToExcelAsync(_filteredInvoices);
            string fileName = $"{Localization.GetString("Invoices")}_{DateTime.UtcNow:yyyyMMdd}.xlsx";

            await JSRuntime.InvokeVoidAsync(
                "fileDownloadHelper.downloadFileFromStream",
                fileName,
                new DotNetStreamReference(new MemoryStream(fileBytes)));

            Snackbar.Add(Localization.GetString("ExportSuccess"), Severity.Success);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error exporting invoices: {ex.Message}");
            Snackbar.Add(Localization.GetString("ExportError"), Severity.Error);
        }
        finally
        {
            _exporting = false;
        }
    }

    public void Dispose()
    {
        Localization.OnLanguageChanged -= OnLanguageChanged;
    }
}
