    // ── Inline Warehouse editing ──────────────────────────────────────────────

    private async Task StartWarehouseEdit()
    {
        if (!_warehousesLoaded)
        {
            try
            {
                IEnumerable<WarehouseDto> all = await WarehouseService.GetAllWarehousesAsync();
                _warehouses = all.Where(w => w.IsActive).ToList();
                _warehousesLoaded = true;
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Error loading warehouses: {ex.Message}");
                Snackbar.Add(Localization.GetString("ErrorLoadingWarehouse"), Severity.Error);
                return;
            }
        }
        _warehouseEdit = _warehouses.FirstOrDefault(w => w.Id == _invoice?.WarehouseId);
        _warehouseEditing = true;
    }

    private void CancelWarehouseEdit() => _warehouseEditing = false;

    private async Task SaveWarehouse()
    {
        if (_warehouseEdit is null || _invoice is null) return;
        _warehouseSaving = true;
        try
        {
            await InvoiceService.UpdateWarehouseAsync(Id, _warehouseEdit.Id);
            _warehouseEditing = false;
            await LoadInvoice();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error updating warehouse: {ex.Message}");
            Snackbar.Add(Localization.GetString("ErrorUpdatingInvoice"), Severity.Error);
        }
        finally
        {
            _warehouseSaving = false;
        }
    }

    // ── Inline line items editing ─────────────────────────────────────────────

    private void StartItemsEdit()
    {
        _editItems = _readOnlyLineItems.Select(li => new LineItemEditorModel
        {
            Id = li.Id,
            SelectedProduct = li.SelectedProduct,
            Description = li.Description,
            Quantity = li.Quantity,
            UnitPrice = li.UnitPrice,
            TaxRate = li.TaxRate,
            DiscountPercentage = li.DiscountPercentage
        }).ToList();
        _itemsEditing = true;
    }

    private void DiscardItemsEdit() => _itemsEditing = false;

    private async Task SaveItems()
    {
        if (_invoice is null) return;
        _itemsSaving = true;
        try
        {
            UpdateInvoiceDto dto = new()
            {
                CompanyId = _invoice.CompanyId,
                Type = _invoice.Type,
                WarehouseId = _invoice.WarehouseId,
                IssueDate = _invoice.IssueDate,
                DueDate = _invoice.DueDate,
                Notes = _invoice.Notes,
                LineItems = _editItems
                    .Where(i => i.SelectedProduct != null)
                    .Select(i => new UpdateInvoiceLineDto
                    {
                        Id = i.Id,
                        ProductId = i.SelectedProduct!.Id,
                        Description = i.Description,
                        Quantity = (int)i.Quantity,
                        UnitPrice = i.UnitPrice,
                        TaxRate = i.TaxRate,
                        DiscountPercentage = i.DiscountPercentage
                    }).ToList()
            };

            await InvoiceService.UpdateInvoiceAsync(Id, dto);
            _itemsEditing = false;
            await LoadInvoice();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error saving line items: {ex.Message}");
            Snackbar.Add(Localization.GetString("ErrorUpdatingInvoice"), Severity.Error);
        }
        finally
        {
            _itemsSaving = false;
        }
    }

    // ── Inline notes editing ──────────────────────────────────────────────────

    private async Task SaveNotes()
    {
        if (_invoice is null) return;
        await SaveNotesAsync(async notes =>
        {
            await InvoiceService.UpdateNotesAsync(Id, notes, CancellationToken.None);
            _invoice.Notes = notes;
        }, "ErrorUpdatingInvoice");
    }

}
