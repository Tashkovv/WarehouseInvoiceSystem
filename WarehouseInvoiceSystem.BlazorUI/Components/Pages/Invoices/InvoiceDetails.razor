@page "/invoices/{Id:guid}"
@attribute [Authorize]
@inherits PageBase
@using System.Globalization
@using WarehouseInvoiceSystem.Application.DTOs.Invoice
@using WarehouseInvoiceSystem.Application.DTOs.Payment
@using WarehouseInvoiceSystem.Application.DTOs.Product
@using WarehouseInvoiceSystem.Application.DTOs.StockLevel
@using WarehouseInvoiceSystem.Application.DTOs.Warehouse
@using WarehouseInvoiceSystem.Domain.Enums
@inject IInvoiceService InvoiceService
@inject IInventoryService InventoryService
@inject IPaymentService PaymentService
@inject IWarehouseService WarehouseService
@inject IExcelExportService ExcelExportService
@inject IEmailService EmailService

<PageTitle>@Localization.GetString("InvoiceDetails") - @Localization.GetString("InvoiceSystem")</PageTitle>

@if (_loading)
{
    <MudProgressLinear Color="Color.Primary" Indeterminate="true" />
}
else if (_invoice == null)
{
    <MudAlert Severity="Severity.Error">@Localization.GetString("ErrorLoadingInvoice")</MudAlert>
}
else
{
    <WisDetailHeader BackHref="/invoices"
                     BackLabel="@Localization.GetString("Invoices")"
                     PrimaryAction="@_primaryAction"
                     Actions="@_actions" />

    @if (_hasInsufficientStock && _invoice.Type == InvoiceType.Receivable)
    {
        <MudAlert Severity="Severity.Warning" Class="mb-3">@Localization.GetString("InsufficientStockToSend")</MudAlert>
    }
    @if (_invoice.Status == InvoiceStatus.Draft && _invoice.LineItems.Count == 0)
    {
        <MudAlert Severity="Severity.Info" Class="mb-3">@Localization.GetString("AddItemsBeforeConfirm")</MudAlert>
    }

    <MudGrid>

        @* ── Header card ── *@
        <MudItem xs="12">
            <MudCard Elevation="2">
                <MudCardContent Class="pa-4">

                    @* Top section: identity + pills (left) | notes (right) *@
                    <div class="wis-contact-row mb-4">
                        <div class="wis-contact-row-left">

                            @* Row 1: invoice number + status chip *@
                            <div class="wis-detail-identity mb-3">
                                <MudText Typo="Typo.h4" Class="font-weight-bold mb-0" Style="font-family: monospace;">
                                    @_invoice.InvoiceNumber
                                </MudText>
                                <MudChip T="string" Size="Size.Small" Color="@GetInvoiceStatusColor(_invoice.Status)">
                                    @GetInvoiceStatusText(_invoice.Status)
                                </MudChip>
                            </div>

                            @* Row 2: contact pills *@
                            <div class="wis-detail-contact">
                                <div class="wis-detail-contact-item">
                                    <MudIcon Icon="@Icons.Material.Filled.Business" Size="Size.Small" Color="Color.Secondary" />
                                    <MudText Typo="Typo.body2" Style="font-weight: 500;">@_invoice.CompanyName</MudText>
                                </div>
                                <div class="wis-detail-contact-item">
                                    <MudIcon Icon="@(_invoice.Type == InvoiceType.Receivable ? Icons.Material.Filled.ArrowUpward : Icons.Material.Filled.ArrowDownward)"
                                             Size="Size.Small"
                                             Color="@(_invoice.Type == InvoiceType.Receivable ? Color.Success : Color.Warning)" />
                                    <MudChip T="string" Size="Size.Small"
                                             Color="@(_invoice.Type == InvoiceType.Receivable ? Color.Success : Color.Warning)">
                                        @Localization.GetString(_invoice.Type.ToString())
                                    </MudChip>
                                </div>
                                @if (!string.IsNullOrWhiteSpace(_invoice.WarehouseName))
                                {
                                    @if (_warehouseEditing && _invoice.Status == InvoiceStatus.Draft)
                                    {
                                        <div class="wis-detail-contact-item">
                                            <MudIcon Icon="@Icons.Material.Filled.Warehouse" Size="Size.Small" Color="Color.Secondary" Style="flex-shrink:0" />
                                            <div style="flex:1;min-width:0;">
                                                <WisSelect T="WarehouseDto"
                                                           Items="_warehouses"
                                                           Value="_warehouseEdit"
                                                           ValueChanged="@(w => _warehouseEdit = w)"
                                                           ToStringFunc="@(w => w?.Name ?? "")"
                                                           Label="@Localization.GetString("Warehouse")"
                                                           FullWidth="true" />
                                            </div>
                                            <MudIconButton Icon="@Icons.Material.Filled.Close"
                                                           Size="Size.Small"
                                                           OnClick="CancelWarehouseEdit"
                                                           Disabled="@_warehouseSaving" />
                                            <MudIconButton Icon="@Icons.Material.Filled.Check"
                                                           Size="Size.Small"
                                                           Color="Color.Primary"
                                                           OnClick="SaveWarehouse"
                                                           Disabled="@(_warehouseSaving || _warehouseEdit == null)" />
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="wis-detail-contact-item">
                                            <MudIcon Icon="@Icons.Material.Filled.Warehouse" Size="Size.Small" Color="Color.Secondary" />
                                            <MudText Typo="Typo.body2">@_invoice.WarehouseName</MudText>
                                            @if (_invoice.Status == InvoiceStatus.Draft)
                                            {
                                                <MudIconButton Icon="@Icons.Material.Filled.Edit"
                                                               Size="Size.Small"
                                                               OnClick="StartWarehouseEdit" />
                                            }
                                        </div>
                                    }
                                }
                            </div>

                        </div>

                        <div class="wis-contact-row-divider"></div>
                        <div class="wis-contact-row-right">
                            @if (_notesEditMode)
                            {
                                <div class="d-flex align-center gap-1 mb-0">
                                    <MudIcon Icon="@Icons.Material.Filled.Notes" Size="Size.Small" Color="Color.Secondary" />
                                    <MudText Typo="Typo.caption" Color="Color.Secondary" Class="wis-section-label flex-grow-1" Style="margin-bottom:0">@Localization.GetString("Notes")</MudText>
                                    <MudIconButton Icon="@Icons.Material.Filled.Close"
                                                   Size="Size.Small"
                                                   OnClick="CancelNotesEdit"
                                                   Disabled="@_notesSaving" />
                                    <MudIconButton Icon="@Icons.Material.Filled.Check"
                                                   Size="Size.Small"
                                                   Color="Color.Primary"
                                                   OnClick="SaveNotes"
                                                   Disabled="@_notesSaving" />
                                </div>
                                <WisInput @bind-Value="_notesEditValue"
                                          CssClass="mt-2" />
                            }
                            else
                            {
                                <div class="d-flex align-center gap-1 mb-0">
                                    <MudIcon Icon="@Icons.Material.Filled.Notes" Size="Size.Small" Color="Color.Secondary" />
                                    <MudText Typo="Typo.caption" Color="Color.Secondary" Class="wis-section-label flex-grow-1" Style="margin-bottom:0">@Localization.GetString("Notes")</MudText>
                                    <MudIconButton Icon="@(string.IsNullOrWhiteSpace(_invoice.Notes) ? Icons.Material.Filled.Add : Icons.Material.Filled.Edit)"
                                                   Size="Size.Small"
                                                   OnClick="@(() => StartNotesEdit(_invoice?.Notes))" />
                                </div>
                                <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mt-0" Style="line-height: 1.6;">
                                    @(string.IsNullOrWhiteSpace(_invoice.Notes) ? "—" : _invoice.Notes)
                                </MudText>
                            }
                        </div>
                    </div>

                    <MudDivider Class="mb-4" />

                    @* Stats row: full width *@
                    <MudGrid Spacing="4" Class="wis-detail-stats">

                        <MudItem xs="4">
                            <MudText Typo="Typo.caption" Color="Color.Secondary" Class="wis-section-label">@Localization.GetString("Total")</MudText>
                            <div class="wis-stat-value mud-primary-text">@_invoice.TotalAmount.ToString("C")</div>
                            <div class="d-flex align-center gap-3 mt-1">
                                <MudText Typo="Typo.caption" Color="Color.Secondary">
                                    @Localization.GetString("Subtotal"): @_invoice.SubTotal.ToString("C")
                                </MudText>
                                @if (_invoice.DiscountTotal > 0)
                                {
                                    <MudText Typo="Typo.caption" Class="mud-error-text">
                                        @Localization.GetString("Discount"): -@_invoice.DiscountTotal.ToString("C")
                                    </MudText>
                                }
                                <MudText Typo="Typo.caption" Color="Color.Secondary">
                                    @Localization.GetString("Tax"): @_invoice.TaxAmount.ToString("C")
                                </MudText>
                            </div>
                        </MudItem>

                        <MudItem xs="2">
                            <MudText Typo="Typo.caption" Color="Color.Secondary" Class="wis-section-label">@Localization.GetString("AmountPaid")</MudText>
                            <div class="wis-stat-value mud-success-text">@_invoice.AmountPaid.ToString("C")</div>
                        </MudItem>

                        <MudItem xs="2">
                            <MudText Typo="Typo.caption" Color="Color.Secondary" Class="wis-section-label">@Localization.GetString("AmountDue")</MudText>
                            <div class="wis-stat-value @(_invoice.AmountDue > 0 ? "mud-error-text" : "mud-success-text")">
                                @_invoice.AmountDue.ToString("C")
                            </div>
                        </MudItem>

                        @* ── IssueDate stat (inline edit for Draft) ── *@
                        <MudItem xs="2">
                            <MudText Typo="Typo.caption" Color="Color.Secondary" Class="wis-section-label">@Localization.GetString("IssueDate")</MudText>
                            @if (_issueDateEditing && _invoice.Status == InvoiceStatus.Draft)
                            {
                                <div class="d-flex align-center gap-0">
                                    <WisDateInput Date="@_issueDateEdit"
                                                  DateChanged="@(d => _issueDateEdit = d)"
                                                  Label="" />
                                    <MudIconButton Icon="@Icons.Material.Filled.Close"
                                                   Size="Size.Small"
                                                   OnClick="CancelIssueDateEdit"
                                                   Disabled="@_issueDateSaving" />
                                    <MudIconButton Icon="@Icons.Material.Filled.Check"
                                                   Size="Size.Small"
                                                   Color="Color.Primary"
                                                   OnClick="SaveIssueDate"
                                                   Disabled="@(_issueDateSaving || !_issueDateEdit.HasValue)" />
                                </div>
                            }
                            else
                            {
                                <div class="d-flex align-center gap-1">
                                    <div class="wis-stat-value">@_invoice.IssueDate.ToString("dd MMM yyyy")</div>
                                    @if (_invoice.Status == InvoiceStatus.Draft)
                                    {
                                        <MudIconButton Icon="@Icons.Material.Filled.EditCalendar"
                                                       Size="Size.Small"
                                                       OnClick="StartIssueDateEdit" />
                                    }
                                </div>
                            }
                        </MudItem>

                        @* ── DueDate stat (inline edit for Draft) ── *@
                        <MudItem xs="2">
                            <MudText Typo="Typo.caption" Color="Color.Secondary" Class="wis-section-label">@Localization.GetString("DueDate")</MudText>
                            @if (_dueDateEditing && _invoice.Status == InvoiceStatus.Draft)
                            {
                                <div class="d-flex align-center gap-0">
                                    <WisDateInput Date="@_dueDateEdit"
                                                  DateChanged="@(d => _dueDateEdit = d)"
                                                  Label="" />
                                    <MudIconButton Icon="@Icons.Material.Filled.Close"
                                                   Size="Size.Small"
                                                   OnClick="CancelDueDateEdit"
                                                   Disabled="@_dueDateSaving" />
                                    <MudIconButton Icon="@Icons.Material.Filled.Check"
                                                   Size="Size.Small"
                                                   Color="Color.Primary"
                                                   OnClick="SaveDueDate"
                                                   Disabled="@(_dueDateSaving || !_dueDateEdit.HasValue)" />
                                </div>
                            }
                            else
                            {
                                <div class="d-flex align-center gap-1">
                                    <div class="wis-stat-value @(_invoice.DueDate < DateTime.UtcNow && _invoice.Status != InvoiceStatus.Paid ? "mud-error-text" : "")">
                                        @_invoice.DueDate.ToString("dd MMM yyyy")
                                    </div>
                                    @if (_invoice.Status == InvoiceStatus.Draft)
                                    {
                                        <MudIconButton Icon="@Icons.Material.Filled.EditCalendar"
                                                       Size="Size.Small"
                                                       OnClick="StartDueDateEdit" />
                                    }
                                </div>
                            }
                        </MudItem>

                    </MudGrid>

                </MudCardContent>
            </MudCard>
        </MudItem>

        @* ── Line items ── *@
        <MudItem xs="12">
            <MudCard Elevation="2">
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudText Typo="Typo.h6">@Localization.GetString("LineItems")</MudText>
                    </CardHeaderContent>
                    <CardHeaderActions>
                        @if (_invoice.Status == InvoiceStatus.Draft)
                        {
                            @if (_itemsEditing)
                            {
                                <MudIconButton Icon="@Icons.Material.Filled.Close"
                                               Size="Size.Small"
                                               OnClick="DiscardItemsEdit"
                                               Disabled="@_itemsSaving" />
                                <MudIconButton Icon="@Icons.Material.Filled.Check"
                                               Size="Size.Small"
                                               Color="Color.Primary"
                                               OnClick="SaveItems"
                                               Disabled="@_itemsSaving" />
                            }
                            else
                            {
                                <MudIconButton Icon="@Icons.Material.Filled.Edit"
                                               Size="Size.Small"
                                               OnClick="StartItemsEdit" />
                            }
                        }
                    </CardHeaderActions>
                </MudCardHeader>
                <MudCardContent Class="pa-0">
                    @if (_itemsEditing)
                    {
                        <InvoiceLineItemsEditor Type="@_invoice.Type"
                                                WarehouseId="@_invoice.WarehouseId"
                                                StockByProduct="@_stockByProduct"
                                                @bind-Items="_editItems"
                                                ReadOnly="false" />
                    }
                    else
                    {
                        <InvoiceLineItemsEditor Type="@_invoice.Type"
                                                WarehouseId="@_invoice.WarehouseId"
                                                StockByProduct="@_stockByProduct"
                                                Items="@_readOnlyLineItems"
                                                ReadOnly="true" />
                    }
                </MudCardContent>
            </MudCard>
        </MudItem>

        @* ── Payment history ── *@
        <MudItem xs="12">
            <MudCard Elevation="2">
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudText Typo="Typo.h6">@Localization.GetString("PaymentHistory")</MudText>
                    </CardHeaderContent>
                </MudCardHeader>
                <MudCardContent Class="pa-0">
                    @if (_payments == null || !_payments.Any())
                    {
                        <div class="pa-6 text-center d-flex align-center">
                            <MudIcon Icon="@Icons.Material.Filled.Payment"
                                     Size="Size.Large"
                                     Color="Color.Secondary"
                                     Class="mb-2 mr-2" />
                            <MudText Color="Color.Secondary">@Localization.GetString("NoPaymentsRecorded")</MudText>
                        </div>
                    }
                    else
                    {
                        <MudTable Items="_payments"
                                  Hover="true"
                                  Breakpoint="Breakpoint.Sm"
                                  Elevation="0"
                                  Dense="true"
                                  T="PaymentDto"
                                  Class="wis-secondary-list"
                                  RowClass="table-row-clickable"
                                  OnRowClick="@((TableRowClickEventArgs<PaymentDto> args) => Navigation.NavigateTo($"/payments/{args.Item!.Id}"))">
                            <HeaderContent>
                                <MudTh>@Localization.GetString("ReferenceNumber")</MudTh>
                                <MudTh>@Localization.GetString("RecordedBy")</MudTh>
                                <MudTh>@Localization.GetString("PaymentMethod")</MudTh>
                                <MudTh>@Localization.GetString("PaymentDate")</MudTh>
                                <MudTh Class="text-right">@Localization.GetString("Amount")</MudTh>
                            </HeaderContent>
                            <RowTemplate>
                                <MudTd DataLabel="@Localization.GetString("ReferenceNumber")">
                                    <MudText Typo="Typo.body2">@(string.IsNullOrEmpty(context.ReferenceNumber) ? "-" : context.ReferenceNumber)</MudText>
                                </MudTd>
                                <MudTd DataLabel="@Localization.GetString("RecordedBy")">
                                    <MudText Typo="Typo.body2">
                                        @(string.IsNullOrEmpty(context.RecordedBy) ? "-" : context.RecordedBy)
                                    </MudText>
                                </MudTd>
                                <MudTd DataLabel="@Localization.GetString("PaymentMethod")">
                                    <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Color="@GetPaymentMethodColor(context.PaymentMethod)">
                                        @GetPaymentMethodText(context.PaymentMethod)
                                    </MudChip>
                                </MudTd>
                                <MudTd DataLabel="@Localization.GetString("PaymentDate")">
                                    <MudText Typo="Typo.body2">@context.PaymentDate.ToString("dd MMM yyyy")</MudText>
                                </MudTd>
                                <MudTd DataLabel="@Localization.GetString("Amount")" Class="text-right">
                                    <MudText Typo="Typo.body2" Class="font-weight-bold" Color="Color.Success">
                                        @context.Amount.ToString("C")
                                    </MudText>
                                </MudTd>
                            </RowTemplate>
                        </MudTable>
                    }
                </MudCardContent>
            </MudCard>
        </MudItem>

    </MudGrid>
}

@code {
    [Parameter] public Guid Id { get; set; }

    private InvoiceDto? _invoice;
    private List<PaymentDto> _payments = [];
    private bool _hasInsufficientStock;
    private Dictionary<Guid, StockLevelDto> _stockByProduct = [];

    private WisDetailActionItem? _primaryAction;
    private List<WisDetailActionItem> _actions = [];

    // ── Read-only line items view model ──────────────────────────────────────

    private List<LineItemEditorModel> _readOnlyLineItems = [];

    // ── Inline IssueDate editing (Draft only) ─────────────────────────────────

    private bool _issueDateEditing;
    private bool _issueDateSaving;
    private DateTime? _issueDateEdit;

    // ── Inline DueDate editing (Draft only) ──────────────────────────────────

    private bool _dueDateEditing;
    private bool _dueDateSaving;
    private DateTime? _dueDateEdit;

    // ── Inline Warehouse editing (Draft only) ─────────────────────────────────

    private bool _warehouseEditing;
    private bool _warehouseSaving;
    private WarehouseDto? _warehouseEdit;
    private List<WarehouseDto> _warehouses = [];
    private bool _warehousesLoaded;

    // ── Inline line items editing (Draft only) ────────────────────────────────

    private bool _itemsEditing;
    private bool _itemsSaving;
    private List<LineItemEditorModel> _editItems = [];

    // ─────────────────────────────────────────────────────────────────────────

    protected override async Task OnInitializedAsync()
    {
        await base.OnInitializedAsync();
        await Task.WhenAll(LoadInvoice(), LoadPayments());
    }

    protected override async void OnLanguageChanged() => await InvokeAsync(() =>
    {
        BuildActions();
        StateHasChanged();
    });

    private async Task LoadInvoice() =>
        await SafeLoadAsync(async () =>
        {
            _invoice = await InvoiceService.GetInvoiceByIdAsync(Id, CancellationToken.None);
            await LoadStockAsync();
            BuildReadOnlyLineItems();
            BuildActions();
        }, "ErrorLoadingInvoice");

    private async Task LoadPayments()
    {
        try
        {
            IEnumerable<PaymentDto> payments = await PaymentService.GetPaymentsByInvoiceAsync(Id, CancellationToken.None);
            _payments = payments.ToList();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading payments: {ex.Message}");
        }
    }

    private async Task Reload()
    {
        await Task.WhenAll(LoadInvoice(), LoadPayments());
    }

    // ── Stock check ───────────────────────────────────────────────────────────

    private async Task LoadStockAsync()
    {
        _stockByProduct = [];
        if (_invoice == null || _invoice.Type != InvoiceType.Receivable || _invoice.Status != InvoiceStatus.Draft)
        {
            _hasInsufficientStock = false;
            return;
        }

        try
        {
            IEnumerable<StockLevelDto> levels = await InventoryService.GetStockByWarehouseAsync(_invoice.WarehouseId, CancellationToken.None);
            _stockByProduct = levels.ToDictionary(s => s.ProductId);
            _hasInsufficientStock = _invoice.LineItems.Any(li =>
                !_stockByProduct.TryGetValue(li.ProductId, out StockLevelDto? s) ||
                li.Quantity > s.AvailableQuantity);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading stock: {ex.Message}");
            _hasInsufficientStock = false;
        }
    }

    // ── Read-only line items view model ───────────────────────────────────────

    private void BuildReadOnlyLineItems()
    {
        _readOnlyLineItems = _invoice?.LineItems.Select(li => new LineItemEditorModel
        {
            Id = li.Id,
            SelectedProduct = new ProductDto
            {
                Id = li.ProductId,
                Code = li.ProductCode,
                Name = li.ProductName,
                Unit = li.ProductUnit
            },
            Description = li.Description,
            Quantity = li.Quantity,
            UnitPrice = li.UnitPrice,
            TaxRate = li.TaxRate,
            DiscountPercentage = li.DiscountPercentage
        }).ToList() ?? [];
    }

    // ── Action builder ────────────────────────────────────────────────────────

    private void BuildActions()
    {
        if (_invoice is null) return;

        _primaryAction = null;
        _actions = [];

        switch (_invoice.Status)
        {
            case InvoiceStatus.Draft when _invoice.Type == InvoiceType.Receivable:
                WisDetailActionItem confirmRecAction = _act.Info(Icons.Material.Filled.CheckCircle, Localization.GetString("ConfirmInvoice"), ConfirmInvoice);
                confirmRecAction.Disabled = _hasInsufficientStock || _invoice.LineItems.Count == 0;
                _primaryAction = confirmRecAction;
                _actions =
                [
                    _act.Secondary(Icons.Material.Filled.Print,        Localization.GetString("Export"), ExportForPrinting),
                    _act.Secondary(Icons.Material.Filled.ContentCopy, Localization.GetString("Copy"),   CopyInvoice),
                    _act.Error(Icons.Material.Filled.Cancel,           Localization.GetString("Cancel"), CancelInvoice, dividerBefore: true),
                ];
                break;

            case InvoiceStatus.Draft:
                WisDetailActionItem confirmAction = _act.Info(Icons.Material.Filled.CheckCircle, Localization.GetString("ConfirmInvoice"), ConfirmInvoice);
                confirmAction.Disabled = _invoice.LineItems.Count == 0;
                _primaryAction = confirmAction;
                _actions =
                [
                    _act.Secondary(Icons.Material.Filled.Print,       Localization.GetString("Export"), ExportForPrinting),
                    _act.Secondary(Icons.Material.Filled.ContentCopy, Localization.GetString("Copy"),   CopyInvoice),
                    _act.Error(Icons.Material.Filled.Cancel,          Localization.GetString("Cancel"), CancelInvoice, dividerBefore: true),
                ];
                break;

            case InvoiceStatus.Confirmed:
                _primaryAction = _act.Success(Icons.Material.Filled.Payment, Localization.GetString("Payment"), RecordPayment);
                _actions =
                [
                    _act.Secondary(Icons.Material.Filled.Print,       Localization.GetString("Export"), ExportForPrinting),
                    _act.Secondary(Icons.Material.Filled.ContentCopy, Localization.GetString("Copy"),   CopyInvoice),
                    _act.Primary(Icons.Material.Filled.Undo,          Localization.GetString("Draft"),  RevertToDraft),
                    _act.Error(Icons.Material.Filled.Cancel,          Localization.GetString("Cancel"), CancelInvoice, dividerBefore: true),
                ];
                if (_invoice.Type == InvoiceType.Receivable)
                    _actions.Insert(0, _act.Info(Icons.Material.Filled.Send, Localization.GetString("Send"), OpenSendEmailDialog));
                break;

            case InvoiceStatus.PartiallyPaid:
                _primaryAction = _act.Success(Icons.Material.Filled.Payment, Localization.GetString("Payment"), RecordPayment);
                _actions =
                [
                    _act.Secondary(Icons.Material.Filled.Print,       Localization.GetString("Export"), ExportForPrinting),
                    _act.Secondary(Icons.Material.Filled.ContentCopy, Localization.GetString("Copy"),   CopyInvoice),
                ];
                if (_invoice.Type == InvoiceType.Receivable)
                    _actions.Insert(0, _act.Info(Icons.Material.Filled.Send, Localization.GetString("Send"), OpenSendEmailDialog));
                break;

            case InvoiceStatus.Overdue:
                _primaryAction = _act.Success(Icons.Material.Filled.Payment, Localization.GetString("Payment"), RecordPayment);
                _actions =
                [
                    _act.Secondary(Icons.Material.Filled.Print,       Localization.GetString("Export"), ExportForPrinting),
                    _act.Secondary(Icons.Material.Filled.ContentCopy, Localization.GetString("Copy"),   CopyInvoice),
                    _act.Primary(Icons.Material.Filled.Undo,          Localization.GetString("Draft"),  RevertToDraft),
                    _act.Error(Icons.Material.Filled.Cancel,          Localization.GetString("Cancel"), CancelInvoice, dividerBefore: true),
                ];
                if (_invoice.Type == InvoiceType.Receivable)
                    _actions.Insert(0, _act.Info(Icons.Material.Filled.Send, Localization.GetString("Send"), OpenSendEmailDialog));
                break;

            case InvoiceStatus.Paid:
                _primaryAction = _act.Secondary(Icons.Material.Filled.Print, Localization.GetString("Export"), ExportForPrinting);
                _actions =
                [
                    _act.Secondary(Icons.Material.Filled.ContentCopy, Localization.GetString("Copy"), CopyInvoice),
                ];
                break;

            case InvoiceStatus.Cancelled:
                _primaryAction = _act.Error(Icons.Material.Filled.Delete, Localization.GetString("Delete"), DeleteInvoice);
                _actions =
                [
                    _act.Secondary(Icons.Material.Filled.ContentCopy, Localization.GetString("Copy"), CopyInvoice),
                ];
                break;
        }
    }

    // ── Actions ───────────────────────────────────────────────────────────────

    private async Task CopyInvoice()
    {
        try
        {
            Guid newId = await InvoiceService.DuplicateInvoiceAsync(Id);
            Navigation.NavigateTo($"/invoices/{newId}");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error duplicating invoice: {ex.Message}");
            Snackbar.Add(Localization.GetString("ErrorCreatingInvoice"), Severity.Error);
        }
    }

    private async Task RecordPayment()
    {
        try
        {
            bool paid = await WisDialog.ShowPaymentDialogAsync(Id);
            if (paid)
            {
                Snackbar.Add(Localization.GetString("PaymentRecorded"), Severity.Success);
                await Reload();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error recording payment: {ex.Message}");
            Snackbar.Add(Localization.GetString("ErrorRecordingPayment"), Severity.Error);
        }
    }

    private async Task ConfirmInvoice()
    {
        if (_invoice is null) return;

        if (_invoice.DueDate < DateTime.UtcNow.Date)
        {
            bool confirmed = await WisDialog.ConfirmAsync(
                Localization.GetString("DueDatePassed"),
                Localization.GetString("DueDatePassedConfirmMessage"),
                Localization.GetString("Continue"),
                Localization.GetString("Cancel"));
            if (!confirmed) return;
        }

        try
        {
            await InvoiceService.ConfirmAsync(Id);
            Snackbar.Add(Localization.GetString("InvoiceConfirmed"), Severity.Success);
            await Reload();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error confirming invoice: {ex.Message}");
            Snackbar.Add(Localization.GetString("ErrorUpdatingInvoice"), Severity.Error);
        }
    }

    private async Task OpenSendEmailDialog()
    {
        if (_invoice is null) return;

        string? customMessage = await WisDialog.ShowFormAsync<SendInvoiceEmailDialog, string>(
            Localization.GetString("SendInvoiceEmail"),
            p => p.Add(x => x.Invoice, _invoice));

        if (customMessage is null) return;

        Snackbar.Add(Localization.GetString("InvoiceEmailSending"), Severity.Info);
        _ = SendEmailInBackgroundAsync(_invoice.Id, customMessage);
    }

    private async Task SendEmailInBackgroundAsync(Guid invoiceId, string customMessage)
    {
        try
        {
            await EmailService.SendInvoiceEmailAsync(invoiceId, customMessage);
            await InvokeAsync(() => Snackbar.Add(Localization.GetString("InvoiceEmailSentSuccessfully"), Severity.Success));
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error sending invoice email: {ex.Message}");
            await InvokeAsync(() => Snackbar.Add(Localization.GetString("ErrorSendingEmail"), Severity.Error));
        }
    }

    private async Task RevertToDraft()
    {
        if (_invoice is null) return;
        await ConfirmAndExecuteAsync(
            Localization.GetString("RevertInvoiceToDraft"),
            Localization.GetString("RevertInvoiceToDraftConfirm"),
            async () => { await InvoiceService.RevertToDraftAsync(Id); await Reload(); },
            "InvoiceRevertedToDraft", "ErrorUpdatingInvoice",
            Localization.GetString("RevertInvoiceToDraft"), Localization.GetString("Back"));
    }

    private async Task DeleteInvoice() =>
        await ConfirmAndExecuteAsync(
            Localization.GetString("ConfirmDelete"),
            Localization.GetString("DeleteInvoiceConfirm"),
            async () => { await InvoiceService.DeleteInvoiceAsync(Id); Navigation.NavigateTo("/invoices"); },
            "InvoiceDeleted", "ErrorUpdatingInvoice",
            Localization.GetString("Delete"), Localization.GetString("Back"));

    private async Task CancelInvoice() =>
        await ConfirmAndExecuteAsync(
            Localization.GetString("CancelInvoice"),
            Localization.GetString("CancelInvoiceConfirm"),
            async () => { await InvoiceService.CancelAsync(Id); await Reload(); },
            "InvoiceCancelled", "ErrorUpdatingInvoice",
            Localization.GetString("Cancel"), Localization.GetString("Back"));

    private async Task ExportForPrinting()
    {
        try
        {
            string? username = await GetCurrentUsernameAsync();
            byte[] fileBytes = await ExcelExportService.ExportInvoiceForPrintingAsync(_invoice!, username);
            string fileName = $"{Localization.GetString("Invoice")}_{_invoice?.InvoiceNumber}_{DateTime.UtcNow:yyyyMMdd}.xlsx";
            await DownloadFileAsync(fileBytes, fileName);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error exporting invoice: {ex.Message}");
            Snackbar.Add(Localization.GetString("ExportError"), Severity.Error);
        }
    }

    // ── Inline IssueDate editing ──────────────────────────────────────────────

    private void StartIssueDateEdit()
    {
        _issueDateEdit = _invoice?.IssueDate;
        _issueDateEditing = true;
    }

    private void CancelIssueDateEdit() => _issueDateEditing = false;

    private async Task SaveIssueDate()
    {
        if (!_issueDateEdit.HasValue || _invoice is null) return;
        _issueDateSaving = true;
        try
        {
            await InvoiceService.UpdateIssueDateAsync(Id, _issueDateEdit.Value);
            _issueDateEditing = false;
            await LoadInvoice();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error updating issue date: {ex.Message}");
            Snackbar.Add(Localization.GetString("ErrorUpdatingInvoice"), Severity.Error);
        }
        finally
        {
            _issueDateSaving = false;
        }
    }

    // ── Inline DueDate editing ────────────────────────────────────────────────

    private void StartDueDateEdit()
    {
        _dueDateEdit = _invoice?.DueDate;
        _dueDateEditing = true;
    }

    private void CancelDueDateEdit() => _dueDateEditing = false;

    private async Task SaveDueDate()
    {
        if (!_dueDateEdit.HasValue || _invoice is null) return;
        _dueDateSaving = true;
        try
        {
            await InvoiceService.UpdateDueDateAsync(Id, _dueDateEdit.Value);
            _dueDateEditing = false;
            await LoadInvoice();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error updating due date: {ex.Message}");
            Snackbar.Add(Localization.GetString("ErrorUpdatingInvoice"), Severity.Error);
        }
        finally
        {
            _dueDateSaving = false;
        }
