@page "/invoices/{Id:guid}"
@implements IDisposable
@using System.Globalization
@using WarehouseInvoiceSystem.Application.DTOs.Invoice
@using WarehouseInvoiceSystem.Application.DTOs.Payment
@using WarehouseInvoiceSystem.Application.Interfaces
@inject IInvoiceService InvoiceService
@inject IPaymentService PaymentService
@inject ILocalizationService Localization
@inject NavigationManager Navigation
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject IJSRuntime JSRuntime
@inject IExcelExportService ExcelExportService

<PageTitle>@Localization.GetString("InvoiceDetails") - @Localization.GetString("InvoiceSystem")</PageTitle>

@if (_loading)
{
    <MudProgressLinear Color="Color.Primary" Indeterminate="true" />
}
else if (_invoice == null)
{
    <MudAlert Severity="Severity.Error">@Localization.GetString("ErrorLoadingInvoice")</MudAlert>
}
else
{
    <div class="d-flex justify-space-between align-center mb-4">
        <div>
            <MudButton StartIcon="@Icons.Material.Filled.ArrowBack"
                       Variant="Variant.Text"
                       Href="/invoices">
                @Localization.GetString("BackToInvoices")
            </MudButton>
        </div>
        <div>
            @if (CanSendEmail())
            {
                <MudButton StartIcon="@Icons.Material.Filled.Email"
                           Color="Color.Success"
                           Variant="Variant.Filled"
                           Class="mr-2"
                           OnClick="OpenSendEmailDialog">
                    @Localization.GetString("SendEmail")
                </MudButton>
            }
            <MudButton StartIcon="@Icons.Material.Filled.Print"
                       Style="width:125px"
                       Color="Color.Secondary"
                       Variant="Variant.Outlined"
                       Class="mr-2"
                       OnClick="ExportForPrinting">
                @Localization.GetString("Export")
            </MudButton>
            <MudButton StartIcon="@Icons.Material.Filled.Edit"
                       Style="width:125px"
                       Color="Color.Primary"
                       Variant="Variant.Filled"
                       Class="mr-2"
                       Href="@($"/invoices/edit/{Id}")">
                @Localization.GetString("Edit")
            </MudButton>
            <MudButton StartIcon="@Icons.Material.Filled.Delete"
                       Style="width:125px"
                       Color="Color.Error"
                       Variant="Variant.Outlined"
                       OnClick="DeleteInvoice">
                @Localization.GetString("Delete")
            </MudButton>
        </div>
    </div>

    <MudGrid>
        <!-- Header Card -->
        <MudItem xs="12">
            <MudCard Elevation="2">
                <MudCardContent Class="pa-6">
                    <MudGrid Spacing="4">
                        <!-- Left: Invoice Number + Status -->
                        <MudItem xs="12" md="6">
                            <MudStack Spacing="2">
                                <div class="d-flex align-center gap-3">
                                    <MudText Typo="Typo.h4" Class="mb-0">@_invoice.InvoiceNumber</MudText>
                                    <MudChip T="string" Size="Size.Small" Color="GetStatusColor(_invoice.Status)">
                                        @GetStatusText(_invoice.Status)
                                    </MudChip>
                                </div>

                                <MudDivider Class="my-2" />

                                <div class="d-flex align-center">
                                    <MudIcon Icon="@Icons.Material.Filled.Business" Size="Size.Small" Class="mr-2" Color="Color.Secondary" />
                                    <MudText Typo="Typo.h6" Class="mb-0">@_invoice.CompanyName</MudText>
                                </div>

                                <div class="d-flex align-center">
                                    <MudIcon Icon="@(_invoice.Type == InvoiceType.Receivable ? Icons.Material.Filled.ArrowUpward : Icons.Material.Filled.ArrowDownward)"
                                             Size="Size.Small"
                                             Class="mr-2"
                                             Color="@(_invoice.Type == InvoiceType.Receivable ? Color.Success : Color.Warning)" />
                                    <MudChip T="string"
                                             Size="Size.Small"
                                             Color="@(_invoice.Type == InvoiceType.Receivable ? Color.Success : Color.Warning)">
                                        @(Localization.GetString(_invoice.Type.ToString()))
                                    </MudChip>
                                </div>
                            </MudStack>
                        </MudItem>

                        <!-- Divider (visible on medium+ screens) -->
                        <MudHidden Breakpoint="Breakpoint.SmAndDown">
                            <MudItem md="1" Class="d-flex align-center justify-center">
                                <MudDivider Vertical="true" />
                            </MudItem>
                        </MudHidden>

                        <!-- Right: Amount + Dates -->
                        <MudItem xs="12" md="5">
                            <MudStack Spacing="3">
                                <!-- Total Amount -->
                                <div>
                                    <MudText Typo="Typo.h3" Color="Color.Primary" Class="mb-0">
                                        @_invoice.TotalAmount.ToString("C")
                                    </MudText>
                                </div>

                                <MudDivider />

                                <!-- Paid + Due -->
                                <MudStack Row="true" Spacing="3">
                                    <div style="flex: 1;">
                                        <div class="d-flex align-center mb-1">
                                            <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Size="Size.Small" Class="mr-1" Color="Color.Success" />
                                            <MudText Typo="Typo.caption" Color="Color.Secondary">@Localization.GetString("AmountPaid")</MudText>
                                        </div>
                                        <MudText Typo="Typo.h6" Color="Color.Success" Class="font-weight-medium">
                                            @_invoice.AmountPaid.ToString("C")
                                        </MudText>
                                    </div>
                                    <div style="flex: 1;">
                                        <div class="d-flex align-center mb-1">
                                            <MudIcon Icon="@Icons.Material.Filled.PendingActions" Size="Size.Small" Class="mr-1"
                                                     Color="@(_invoice.AmountDue > 0 ? Color.Error : Color.Success)" />
                                            <MudText Typo="Typo.caption" Color="Color.Secondary">@Localization.GetString("AmountDue")</MudText>
                                        </div>
                                        <MudText Typo="Typo.h6" Class="font-weight-medium"
                                                 Color="@(_invoice.AmountDue > 0 ? Color.Error : Color.Success)">
                                            @_invoice.AmountDue.ToString("C")
                                        </MudText>
                                    </div>
                                </MudStack>

                                <MudDivider />

                                <!-- Dates -->
                                <MudStack Row="true" Spacing="4">
                                    <div style="flex: 1;">
                                        <div class="d-flex align-center mb-1">
                                            <MudIcon Icon="@Icons.Material.Filled.CalendarToday" Size="Size.Small" Class="mr-1" Color="Color.Secondary" />
                                            <MudText Typo="Typo.caption" Color="Color.Secondary">@Localization.GetString("IssueDate")</MudText>
                                        </div>
                                        <MudText Typo="Typo.body1" Class="font-weight-medium">
                                            @_invoice.IssueDate.ToString("dd MMM yyyy")
                                        </MudText>
                                    </div>

                                    <div style="flex: 1;">
                                        <div class="d-flex align-start mb-1">
                                            <MudIcon Icon="@Icons.Material.Filled.Event" Size="Size.Small" Class="mr-1"
                                                     Color="@(_invoice.DueDate < DateTime.UtcNow && _invoice.Status != InvoiceStatus.Paid ? Color.Error : Color.Secondary)" />
                                            <MudText Typo="Typo.caption" Color="Color.Secondary">@Localization.GetString("DueDate")</MudText>
                                        </div>
                                        <MudText Typo="Typo.body1"
                                                 Class="font-weight-medium"
                                                 Color="@(_invoice.DueDate < DateTime.UtcNow && _invoice.Status != InvoiceStatus.Paid ? Color.Error : Color.Default)">
                                            @_invoice.DueDate.ToString("dd MMM yyyy")
                                        </MudText>
                                    </div>
                                </MudStack>
                            </MudStack>
                        </MudItem>
                    </MudGrid>

                    <!-- Notes Section (Full Width) -->
                    @if (!string.IsNullOrWhiteSpace(_invoice.Notes))
                    {
                        <MudDivider Class="my-4" />
                        <div class="d-flex align-start">
                            <MudIcon Icon="@Icons.Material.Filled.Notes" Size="Size.Small" Class="mr-2 mt-1" Color="Color.Secondary" />
                            <div style="flex: 1;">
                                <MudText Typo="Typo.caption" Color="Color.Dark" Class="mb-1">@Localization.GetString("Notes")</MudText>
                                <MudText Typo="Typo.body2" Color="Color.Secondary" Style="line-height: 1.6;">
                                    @_invoice.Notes
                                </MudText>
                            </div>
                        </div>
                    }
                </MudCardContent>
            </MudCard>
        </MudItem>

        <!-- Line Items -->
        <MudItem xs="12">
            <MudCard Elevation="2">
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudText Typo="Typo.h6">@Localization.GetString("LineItems")</MudText>
                    </CardHeaderContent>
                </MudCardHeader>
                <MudCardContent Class="pa-0">
                    <MudTable Items="_invoice.LineItems"
                              Hover="true"
                              Breakpoint="Breakpoint.Sm"
                              Elevation="0"
                              Dense="false">
                        <HeaderContent>
                            <MudTh>@Localization.GetString("Product")</MudTh>
                            <MudTh>@Localization.GetString("Description")</MudTh>
                            <MudTh Style="text-align: right;">@Localization.GetString("Quantity")</MudTh>
                            <MudTh Style="text-align: right;">@Localization.GetString("UnitPrice")</MudTh>
                            <MudTh Style="text-align: right;">@Localization.GetString("TaxRate")</MudTh>
                            <MudTh Style="text-align: right;">@Localization.GetString("Total")</MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd DataLabel="@Localization.GetString("Product")">
                                <MudText Typo="Typo.body2" Class="font-weight-medium">@context.ProductCode</MudText>
                                <MudText Typo="Typo.body2" Color="Color.Dark">@context.ProductName</MudText>
                            </MudTd>
                            <MudTd DataLabel="@Localization.GetString("Description")">
                                <MudText Typo="Typo.body2" Class="font-weight-medium">@context.Description</MudText>
                            </MudTd>
                            <MudTd DataLabel="@Localization.GetString("Quantity")" Style="text-align: right;">
                                <MudText Typo="Typo.body2" Class="font-weight-medium">
                                    @context.Quantity.ToString("N2")
                                    <MudText Typo="Typo.caption" Color="Color.Dark" Inline="true">
                                        @context.ProductUnit
                                    </MudText>
                                </MudText>
                            </MudTd>
                            <MudTd DataLabel="@Localization.GetString("UnitPrice")" Style="text-align: right;">
                                <MudText Typo="Typo.body2" Color="Color.Dark">
                                    @context.UnitPrice.ToString("C")
                                </MudText>
                            </MudTd>
                            <MudTd DataLabel="@Localization.GetString("TaxRate")" Style="text-align: right;">
                                <MudText Typo="Typo.body2" Color="Color.Dark">
                                    @context.TaxRate.ToString("0.00", _currentCultureKey)%
                                </MudText>
                            </MudTd>
                            <MudTd DataLabel="@Localization.GetString("Total")" Style="text-align: right;">
                                <MudText Typo="Typo.body2" Class="font-weight-bold" Color="Color.Primary">
                                    @context.TotalAmount.ToString("C")
                                </MudText>
                            </MudTd>
                        </RowTemplate>
                    </MudTable>

                    <MudDivider />

                    <!-- Totals footer -->
                    <div class="d-flex justify-end pa-4">
                        <MudStack Spacing="1" Style="min-width: 300px;">
                            <!-- Subtotal -->
                            <div class="d-flex justify-space-between align-center">
                                <MudText Typo="Typo.body2" Color="Color.Dark">@Localization.GetString("Subtotal")</MudText>
                                <MudText Typo="Typo.body2" Color="Color.Dark" Class="font-weight-medium">
                                    @_invoice.SubTotal.ToString("C")
                                </MudText>
                            </div>
                            <!-- Tax -->
                            <div class="d-flex justify-space-between align-center">
                                <MudText Typo="Typo.body2" Color="Color.Dark">@Localization.GetString("Tax")</MudText>
                                <MudText Typo="Typo.body2" Color="Color.Dark" Class="font-weight-medium">
                                    @_invoice.TaxAmount.ToString("C")
                                </MudText>
                            </div>
                            <MudDivider Class="my-1" />
                            <!-- Total -->
                            <div class="d-flex justify-space-between align-center">
                                <MudText Typo="Typo.h6" Class="font-weight-bold">@Localization.GetString("Total")</MudText>
                                <MudText Typo="Typo.h5" Class="font-weight-bold" Color="Color.Primary">
                                    @_invoice.TotalAmount.ToString("C")
                                </MudText>
                            </div>
                        </MudStack>
                    </div>
                </MudCardContent>
            </MudCard>
        </MudItem>

        <!-- Payment History -->
        <MudItem xs="12">
            <MudCard Elevation="2">
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudText Typo="Typo.h6">@Localization.GetString("PaymentHistory")</MudText>
                    </CardHeaderContent>
                    <CardHeaderActions>
                        @if (_invoice.Status != InvoiceStatus.Paid && _invoice.Status != InvoiceStatus.Cancelled)
                        {
                            <MudButton StartIcon="@Icons.Material.Filled.Payment"
                                       Color="Color.Primary"
                                       Variant="Variant.Filled"
                                       Size="Size.Small"
                                       OnClick="OpenPaymentDialog">
                                @Localization.GetString("RecordPayment")
                            </MudButton>
                        }
                    </CardHeaderActions>
                </MudCardHeader>
                <MudCardContent Class="pa-0">
                    @if (_payments == null || !_payments.Any())
                    {
                        <div class="pa-6 text-center d-flex align-center">
                            <MudIcon Icon="@Icons.Material.Filled.Payment"
                                     Size="Size.Large"
                                     Color="Color.Secondary"
                                     Class="mb-2 mr-2" />
                            <MudText Color="Color.Secondary">@Localization.GetString("NoPaymentsRecorded")</MudText>
                        </div>
                    }
                    else
                    {
                        <MudTable Items="_payments"
                                  Hover="true"
                                  Breakpoint="Breakpoint.Sm"
                                  Elevation="0"
                                  Dense="true"
                                  T="PaymentDto"
                                  RowClass="table-row-clickable"
                                  OnRowClick="@((TableRowClickEventArgs<PaymentDto> args) => Navigation.NavigateTo($"/payments/{args.Item!.Id}"))">
                            <HeaderContent>
                                <MudTh>@Localization.GetString("PaymentDate")</MudTh>
                                <MudTh>@Localization.GetString("ReferenceNumber")</MudTh>
                                <MudTh>@Localization.GetString("PaymentMethod")</MudTh>
                                <MudTh Style="text-align: right;">@Localization.GetString("Amount")</MudTh>
                                <MudTh>@Localization.GetString("RecordedBy")</MudTh>
                            </HeaderContent>
                            <RowTemplate>
                                <MudTd DataLabel="@Localization.GetString("PaymentDate")">
                                    <MudText Typo="Typo.body2">
                                        @context.PaymentDate.ToString("dd MMM yyyy")
                                    </MudText>
                                </MudTd>
                                <MudTd DataLabel="@Localization.GetString("ReferenceNumber")">
                                    <MudText Typo="Typo.body2">
                                        @(string.IsNullOrEmpty(context.ReferenceNumber) ? "-" : context.ReferenceNumber)
                                    </MudText>
                                </MudTd>
                                <MudTd DataLabel="@Localization.GetString("PaymentMethod")">
                                    <MudChip T="string" Size="Size.Small" Color="@GetMethodColor(context.PaymentMethod)">
                                        @GetPaymentMethodText(context.PaymentMethod)
                                    </MudChip>
                                </MudTd>
                                <MudTd DataLabel="@Localization.GetString("Amount")" Style="text-align: right;">
                                    <MudText Typo="Typo.body2" Class="font-weight-bold" Color="Color.Success">
                                        @context.Amount.ToString("C")
                                    </MudText>
                                </MudTd>
                                <MudTd DataLabel="@Localization.GetString("RecordedBy")">
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">
                                        @(string.IsNullOrEmpty(context.RecordedBy) ? "-" : context.RecordedBy)
                                    </MudText>
                                </MudTd>
                            </RowTemplate>
                        </MudTable>
                    }
                </MudCardContent>
            </MudCard>
        </MudItem>
    </MudGrid>
}

@code {
    [Parameter]
    public Guid Id { get; set; }
    private bool _loading = true;
    private readonly IFormatProvider _currentCultureKey = CultureInfo.CurrentCulture;
    private InvoiceDto? _invoice;
    private List<PaymentDto> _payments = new();

    protected override async Task OnInitializedAsync()
    {
        Localization.OnLanguageChanged += OnLanguageChanged;
        await LoadInvoice();
        await LoadPayments();
    }

    protected override async Task OnParametersSetAsync()
    {
        await LoadInvoice();
        await LoadPayments();
    }

    private async void OnLanguageChanged()
    {
        await InvokeAsync(StateHasChanged);
    }

    private async Task LoadInvoice()
    {
        _loading = true;

        try
        {
            _invoice = await InvoiceService.GetInvoiceByIdAsync(Id);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading invoice: {ex.Message}");
            Snackbar.Add(Localization.GetString("ErrorLoadingInvoice"), Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task LoadPayments()
    {
        try
        {
            IEnumerable<PaymentDto> payments = await PaymentService.GetPaymentsByInvoiceAsync(Id);
            _payments = payments.ToList();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading payments: {ex.Message}");
        }
    }

    private Color GetStatusColor(InvoiceStatus status) => status switch
    {
        InvoiceStatus.Draft => Color.Default,
        InvoiceStatus.Sent => Color.Info,
        InvoiceStatus.PartiallyPaid => Color.Warning,
        InvoiceStatus.Paid => Color.Success,
        InvoiceStatus.Overdue => Color.Error,
        InvoiceStatus.Cancelled => Color.Default,
        _ => Color.Default
    };

    private string GetStatusText(InvoiceStatus status) => status switch
    {
        InvoiceStatus.Draft => Localization.GetString("Draft"),
        InvoiceStatus.Sent => Localization.GetString("Sent"),
        InvoiceStatus.PartiallyPaid => Localization.GetString("PartiallyPaid"),
        InvoiceStatus.Paid => Localization.GetString("PaidStatus"),
        InvoiceStatus.Overdue => Localization.GetString("OverdueStatus"),
        InvoiceStatus.Cancelled => Localization.GetString("Cancelled"),
        _ => status.ToString()
    };

    private string GetPaymentMethodText(PaymentMethod method) => method switch
    {
        PaymentMethod.Cash => Localization.GetString("Cash"),
        PaymentMethod.BankTransfer => Localization.GetString("BankTransfer"),
        PaymentMethod.CreditCard => Localization.GetString("CreditCard"),
        PaymentMethod.Other => Localization.GetString("Other"),
        _ => method.ToString()
    };

    private Color GetMethodColor(PaymentMethod method) => method switch
    {
        PaymentMethod.Cash => Color.Success,
        PaymentMethod.BankTransfer => Color.Primary,
        PaymentMethod.CreditCard => Color.Secondary,
        PaymentMethod.Other => Color.Default,
        _ => Color.Default
    };

    private void OpenPaymentDialog()
    {
        // We'll implement this in the next step
        Navigation.NavigateTo($"/payments/create?invoiceId={Id}");
    }

    private async Task DeleteInvoice()
    {
        bool? result = await DialogService.ShowMessageBoxAsync(
            new MessageBoxOptions
            {
                Title = Localization.GetString("ConfirmDelete"),
                Message = Localization.GetString("DeleteInvoiceConfirm"),
                YesText = Localization.GetString("Yes"),
                CancelText = Localization.GetString("No")
            });

        if (result == true)
        {
            try
            {
                bool deleted = await InvoiceService.DeleteInvoiceAsync(Id);
                if (deleted)
                {
                    Snackbar.Add(Localization.GetString("InvoiceDeleted"), Severity.Success);
                    Navigation.NavigateTo("/invoices");
                }
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Error deleting invoice: {ex.Message}");
                Snackbar.Add(Localization.GetString("ErrorDeletingInvoice"), Severity.Error);
            }
        }
    }

    private async Task ExportForPrinting()
    {
        try
        {
            byte[] fileBytes = await ExcelExportService.ExportInvoiceForPrintingAsync(Id);
            string fileName = $"{Localization.GetString("Invoice")}_{_invoice?.InvoiceNumber}_{DateTime.UtcNow:yyyyMMdd}.xlsx";

            await JSRuntime.InvokeVoidAsync(
                "fileDownloadHelper.downloadFileFromStream",
                fileName,
                new DotNetStreamReference(new MemoryStream(fileBytes)));

            Snackbar.Add(Localization.GetString("ExportSuccess"), Severity.Success);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error exporting to Excel: {ex.Message}");
            Snackbar.Add(Localization.GetString("ExportError"), Severity.Error);
        }
    }

    private bool CanSendEmail() =>
        _invoice?.Type == InvoiceType.Receivable &&
        (_invoice.Status == InvoiceStatus.Draft ||
         _invoice.Status == InvoiceStatus.PartiallyPaid ||
         _invoice.Status == InvoiceStatus.Overdue);

    private async Task OpenSendEmailDialog()
    {
        if (_invoice is null) return;

        DialogParameters<SendInvoiceEmailDialog> parameters = new();
        parameters.Add(x => x.Invoice, _invoice);

        DialogOptions options = new()
        {
            CloseOnEscapeKey = true,
            MaxWidth = MaxWidth.Small,
            FullWidth = true
        };

        IDialogReference dialog = await DialogService.ShowAsync<SendInvoiceEmailDialog>(
            Localization.GetString("SendInvoiceEmail"), parameters, options);

        DialogResult? result = await dialog.Result;

        if (result is { Canceled: false, Data: true })
            await LoadInvoice();
    }

    public void Dispose()
    {
        Localization.OnLanguageChanged -= OnLanguageChanged;
    }
}
