@page "/invoices/edit/{Id:guid}"
@implements IDisposable
@using System.Globalization
@using WarehouseInvoiceSystem.Application.DTOs.Company
@using WarehouseInvoiceSystem.Application.DTOs.Invoice
@using WarehouseInvoiceSystem.Application.DTOs.Product
@using WarehouseInvoiceSystem.Application.DTOs.Warehouse
@inject IInvoiceService InvoiceService
@inject ICompanyService CompanyService
@inject ILocalizationService Localization
@inject NavigationManager Navigation
@inject ISnackbar Snackbar
@inject IProductService ProductService
@inject IWarehouseService WarehouseService

<PageTitle>@Localization.GetString("EditInvoice") - @Localization.GetString("InvoiceSystem")</PageTitle>

<div class="d-flex justify-space-between align-center mb-4">
    <MudText Typo="Typo.h4">@Localization.GetString("EditInvoice")</MudText>
    <MudButton StartIcon="@Icons.Material.Filled.ArrowBack"
               Variant="Variant.Text"
               Href="@($"/invoices/{Id}")">
        @Localization.GetString("BackToInvoices")
    </MudButton>
</div>

@if (_loading)
{
    <MudProgressLinear Color="Color.Primary" Indeterminate="true" />
}
else if (_invoice == null)
{
    <MudAlert Severity="Severity.Error">@Localization.GetString("ErrorLoadingInvoice")</MudAlert>
}
else
{
    <MudForm @ref="_form" @bind-IsValid="@_isValid">
        <MudGrid>
            <!-- Invoice Information Card -->
            <MudItem xs="12">
                <MudCard Elevation="2">
                    <MudCardHeader>
                        <CardHeaderContent>
                            <MudText Typo="Typo.h6">@Localization.GetString("InvoiceInformation")</MudText>
                        </CardHeaderContent>
                        <CardHeaderActions>
                            <MudChip T="string" Size="Size.Small">@_invoice.InvoiceNumber</MudChip>
                        </CardHeaderActions>
                    </MudCardHeader>
                    <MudCardContent>
                        <MudGrid>
                            <MudItem xs="12" md="4">
                                <MudSelect T="Guid"
                                           @bind-Value="_selectedCompanyId"
                                           Label="@Localization.GetString("Company")"
                                           Required="true"
                                           RequiredError="@Localization.GetString("PleaseSelectCompany")"
                                           Variant="Variant.Outlined"
                                           AnchorOrigin="Origin.BottomLeft">
                                    @foreach (CompanyDto company in _companies)
                                    {
                                        <MudSelectItem T="Guid" Value="company.Id">@company.Name</MudSelectItem>
                                    }
                                </MudSelect>
                            </MudItem>

                            <MudItem xs="12" md="4">
                                <MudSelect T="InvoiceType"
                                           @bind-Value="_selectedType"
                                           Label="@Localization.GetString("Type")"
                                           Required="true"
                                           RequiredError="@Localization.GetString("PleaseSelectType")"
                                           Variant="Variant.Outlined"
                                           AnchorOrigin="Origin.BottomLeft">
                                    <MudSelectItem T="InvoiceType" Value="@(InvoiceType.Receivable)">
                                        <MudChip T="string" Size="Size.Small" Color="Color.Success">
                                            @Localization.GetString("Receivable")
                                        </MudChip>
                                    </MudSelectItem>
                                    <MudSelectItem T="InvoiceType" Value="@(InvoiceType.Payable)">
                                        <MudChip T="string" Size="Size.Small" Color="Color.Warning">
                                            @Localization.GetString("Payable")
                                        </MudChip>
                                    </MudSelectItem>
                                </MudSelect>
                            </MudItem>


                            <MudItem xs="12" md="4">
                                <MudAutocomplete T="WarehouseDto"
                                                 Label="@Localization.GetString("SelectWarehouse")"
                                                 @bind-Value="_selectedWarehouse"
                                                 SearchFunc="@SearchWarehouses"
                                                 ToStringFunc="@(w => w?.Name ?? string.Empty)"
                                                 ResetValueOnEmptyText="true"
                                                 Variant="Variant.Outlined"
                                                 Clearable="true" />
                            </MudItem>

                            <MudItem xs="12" md="3">
                                <MudDatePicker @key="_currentCultureKey"
                                               @bind-Date="_issueDate"
                                               @bind-Date:after="OnIssueDateChanged"
                                               Label="@Localization.GetString("IssueDate")"
                                               Required="true"
                                               RequiredError="@Localization.GetString("IssueDateRequired")"
                                               Variant="Variant.Outlined" />
                            </MudItem>

                            <MudItem xs="12" md="3">
                                <MudNumericField T="int"
                                                 @bind-Value="_paymentTermsDays"
                                                 @bind-Value:after="OnPaymentTermsChanged"
                                                 Label="@Localization.GetString("Terms")"
                                                 Variant="Variant.Outlined"
                                                 Adornment="Adornment.End"
                                                 AdornmentText="@Localization.GetString("Days")"
                                                 Min="0" />
                            </MudItem>

                            <MudItem xs="12" md="3">
                                <MudDatePicker @key="_currentCultureKey"
                                               @bind-Date="_dueDate"
                                               Label="@Localization.GetString("DueDate")"
                                               Required="true"
                                               RequiredError="@Localization.GetString("DueDateRequired")"
                                               Variant="Variant.Outlined" />
                            </MudItem>

                            <MudItem xs="12">
                                <MudTextField @bind-Value="_notes"
                                              Label="@Localization.GetString("Notes")"
                                              Variant="Variant.Outlined"
                                              Lines="3" />
                            </MudItem>
                        </MudGrid>
                    </MudCardContent>
                </MudCard>
            </MudItem>

            <!-- Line Items Card -->
            <MudItem xs="12">
                <MudCard Elevation="2">
                    <MudCardHeader>
                        <CardHeaderContent>
                            <MudText Typo="Typo.h6">@Localization.GetString("LineItems")</MudText>
                        </CardHeaderContent>
                    </MudCardHeader>
                    <MudCardContent>
                        @if (!_lineItems.Any())
                        {
                            <MudAlert Severity="Severity.Info" Class="my-4">
                                @Localization.GetString("PleaseAddLineItems")
                            </MudAlert>
                        }
                        else
                        {
                            @foreach (LineItemModel item in _lineItems)
                            {
                                <MudPaper Class="pa-3 mb-3" Elevation="1">
                                    <MudGrid AlignItems="AlignItems.Center">
                                        <MudItem xs="12" sm="6" md="3" Class="d-flex align-center">
                                            <MudAutocomplete T="ProductDto"
                                                             Label="@Localization.GetString("Product")"
                                                             Value="item.SelectedProduct"
                                                             SearchFunc="@SearchProducts"
                                                             ToStringFunc="@(p => p?.Name ?? "")"
                                                             ValueChanged="@((ProductDto p) => OnProductSelected(item, p))"
                                                             ResetValueOnEmptyText="true"
                                                             CoerceText="false"
                                                             Variant="Variant.Outlined"
                                                             Clearable="true"
                                                             Class="flex-grow-1">
                                                <ItemTemplate Context="product">
                                                    <MudText Typo="Typo.body2">
                                                        <strong>@product.Code</strong> - @product.Name
                                                    </MudText>
                                                    <MudText Typo="Typo.caption" Color="Color.Secondary">
                                                        @product.Unit | @product.DefaultPrice.ToString("C")
                                                    </MudText>
                                                </ItemTemplate>
                                            </MudAutocomplete>
                                        </MudItem>

                                        <MudItem xs="6" sm="6" md="2">
                                            <MudNumericField Label="@Localization.GetString("Quantity")"
                                                             @bind-Value="item.Quantity"
                                                             @bind-Value:after="CalculateTotals"
                                                             Variant="Variant.Outlined"
                                                             Required="true"
                                                             RequiredError="@Localization.GetString("EnterQuantity")"
                                                             Min="1"
                                                             Step="1" />
                                        </MudItem>

                                        <MudItem xs="6" sm="6" md="2">
                                            <MudNumericField Label="@Localization.GetString("UnitPrice")"
                                                             @bind-Value="item.UnitPrice"
                                                             @bind-Value:after="CalculateTotals"
                                                             Variant="Variant.Outlined"
                                                             Required="true"
                                                             RequiredError="@Localization.GetString("EnterUnitPrice")"
                                                             Min="0"
                                                             Step="1"
                                                             Format="N2"
                                                             TextUpdateSuppression="false"
                                                             Adornment="Adornment.Start"
                                                             AdornmentText="MKD" />
                                        </MudItem>

                                        <MudItem xs="6" sm="6" md="2">
                                            <MudNumericField Label="@Localization.GetString("TaxRate")"
                                                             Value="item.TaxRate"
                                                             ValueChanged="@((decimal v) => OnTaxRateChanged(item, v))"
                                                             Variant="Variant.Outlined"
                                                             Min="0"
                                                             Max="100"
                                                             Step="0.1m"
                                                             Format="N2"
                                                             Adornment="Adornment.End"
                                                             AdornmentText="%"
                                                             TextUpdateSuppression="false" />
                                        </MudItem>

                                        <MudItem xs="6" sm="6" md="2" Class="d-flex align-center justify-end">
                                            <MudTextField Value="@item.LineTotal.ToString("C")"
                                                          Label="@Localization.GetString("Total")"
                                                          Variant="Variant.Outlined"
                                                          ReadOnly="true" />
                                        </MudItem>

                                        <MudItem xs="12" sm="12" md="1" Class="d-flex align-center justify-center">
                                            <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                                           Color="Color.Error"
                                                           Variant="Variant.Outlined"
                                                           OnClick="@(() => RemoveLineItem(item))"
                                                           Size="Size.Medium" />
                                        </MudItem>
                                    </MudGrid>
                                </MudPaper>
                            }
                        }

                        <MudButton StartIcon="@Icons.Material.Filled.Add"
                                   Color="Color.Info"
                                   Variant="Variant.Outlined"
                                   OnClick="AddLineItem"
                                   FullWidth="true"
                                   Class="mb-4">
                            @Localization.GetString("AddItem")
                        </MudButton>

                        <!-- Totals Summary -->
                        <MudCard Elevation="1" Class="mt-4">
                            <MudCardContent>
                                <div class="d-flex justify-end mb-2">
                                    <MudText Typo="Typo.body1"
                                             Class="mr-4"
                                             Style="min-width: 120px;">
                                        @Localization.GetString("Subtotal"):
                                    </MudText>
                                    <MudText Typo="Typo.body1"
                                             Style="min-width: 160px;"
                                             Class="font-weight-medium text-right tabular-numbers">
                                        @_subtotal.ToString("C")
                                    </MudText>
                                </div>
                                <div class="d-flex justify-end mb-2">
                                    <MudText Typo="Typo.body1"
                                             Class="mr-4"
                                             Style="min-width: 120px;">
                                        @Localization.GetString("Tax"):
                                    </MudText>
                                    <MudText Typo="Typo.body1"
                                             Style="min-width: 160px;"
                                             Class="font-weight-medium text-right tabular-numbers">
                                        @_taxAmount.ToString("C")
                                    </MudText>
                                </div>
                                <MudDivider Class="my-2" />
                                <div class="d-flex justify-end">
                                    <MudText Typo="Typo.h6"
                                             Class="mr-4"
                                             Style="min-width: 120px;">
                                        @Localization.GetString("Total"):
                                    </MudText>
                                    <MudText Typo="Typo.h6"
                                             Color="Color.Primary"
                                             Style="min-width: 160px;"
                                             Class="font-weight-medium text-right tabular-numbers">
                                        @_total.ToString("C")
                                    </MudText>
                                </div>
                            </MudCardContent>
                        </MudCard>
                    </MudCardContent>
                </MudCard>
            </MudItem>

            <!-- Actions -->
            <MudItem xs="12">
                <div class="d-flex justify-end gap-2">
                    <MudButton Variant="Variant.Outlined"
                               OnClick="@(() => Navigation.NavigateTo($"/invoices/{Id}"))">
                        @Localization.GetString("Cancel")
                    </MudButton>
                    <MudButton Variant="Variant.Filled"
                               Color="Color.Primary"
                               OnClick="HandleSubmit"
                               Disabled="@_saving">
                        @if (_saving)
                        {
                            <MudProgressCircular Class="mr-2" Size="Size.Small" Indeterminate="true" />
                            @Localization.GetString("Save")
                        }
                        else
                        {
                            @Localization.GetString("Update")
                        }
                    </MudButton>
                </div>
            </MudItem>
        </MudGrid>
    </MudForm>
}

@code {
    [Parameter]
    public Guid Id { get; set; }

    private bool _loading = true;
    private bool _saving = false;
    private string _currentCultureKey = CultureInfo.CurrentCulture.Name;
    private MudForm _form = null!;
    private bool _isValid;
    private InvoiceDto? _invoice;
    private List<CompanyDto> _companies = new();
    private List<ProductDto> _products = [];
    private List<WarehouseDto> _warehouses = new();
    private WarehouseDto? _selectedWarehouse;
    private readonly UpdateInvoiceDto _updateDto = new();

    private Guid _selectedCompanyId;
    private InvoiceType _selectedType;
    private DateTime? _issueDate;
    private DateTime? _dueDate;
    private int _paymentTermsDays = 30;
    private string? _notes;

    private List<LineItemModel> _lineItems = new();
    private decimal _subtotal = 0;
    private decimal _taxAmount = 0;
    private decimal _total = 0;

    protected override async Task OnInitializedAsync()
    {
        Localization.OnLanguageChanged += OnLanguageChanged;
        await LoadCompanies();
        await LoadProducts();
        await LoadWarehouses();
        await LoadInvoice();
    }

    private async void OnLanguageChanged()
    {
        _currentCultureKey = CultureInfo.CurrentCulture.Name;
        await InvokeAsync(StateHasChanged);
    }

    private async Task LoadCompanies()
    {
        try
        {
            IEnumerable<CompanyDto> companies = await CompanyService.GetActiveCompaniesAsync();
            _companies = companies.ToList();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading companies: {ex.Message}");
            Snackbar.Add("Error loading companies", Severity.Error);
        }
    }

    private async Task LoadWarehouses()
    {
        try
        {
            IEnumerable<WarehouseDto> whs = await WarehouseService.GetAllWarehousesAsync();
            _warehouses = whs.ToList();
            _selectedWarehouse = _warehouses.FirstOrDefault(w => w.IsDefault) ?? _warehouses.FirstOrDefault();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading warehouses: {ex.Message}");
        }
    }

    private async Task LoadProducts()
    {
        try
        {
            IEnumerable<ProductDto> products = await ProductService.GetActiveProductsAsync();
            _products = products.ToList();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading products: {ex.Message}");
            Snackbar.Add("Error loading products", Severity.Error);
        }
    }

    private async Task<IEnumerable<ProductDto>> SearchProducts(string value, CancellationToken cancellationToken)
    {
        if (string.IsNullOrEmpty(value))
            return _products;

        return _products.Where(p =>
            p.Code.Contains(value, StringComparison.OrdinalIgnoreCase) ||
            p.Name.Contains(value, StringComparison.OrdinalIgnoreCase));
    }

    private async Task<IEnumerable<WarehouseDto>> SearchWarehouses(string value, CancellationToken cancellationToken)
    {
        if (string.IsNullOrEmpty(value))
            return _warehouses;

        return _warehouses.Where(w => w.Name.Contains(value, StringComparison.OrdinalIgnoreCase));
    }

    private void OnProductSelected(LineItemModel item, ProductDto? product)
    {
        if (product != null)
        {
            item.SelectedProduct = product;
            item.Description = product.Name;
            item.UnitPrice = product.DefaultPrice;
        }
    }

    private async Task LoadInvoice()
    {
        _loading = true;

        try
        {
            _invoice = await InvoiceService.GetInvoiceByIdAsync(Id);

            if (_invoice != null)
            {
                _selectedCompanyId = _invoice.CompanyId;
                _selectedType = _invoice.Type;
                _issueDate = _invoice.IssueDate;
                _dueDate = _invoice.DueDate;
                _notes = _invoice.Notes;

                // Calculate payment terms from dates
                if (_issueDate.HasValue && _dueDate.HasValue)
                {
                    _paymentTermsDays = (_dueDate.Value - _issueDate.Value).Days;
                }

                // Load line items — fall back to a direct lookup for any product
                // that has been deactivated since the invoice was created
                List<LineItemModel> lineItems = [];
                foreach (InvoiceLineDto li in _invoice.LineItems)
                {
                    ProductDto? product = _products.FirstOrDefault(p => p.Id == li.ProductId)
                        ?? await ProductService.GetProductByIdAsync(li.ProductId);
                    lineItems.Add(new LineItemModel
                    {
                        Id = li.Id,
                        SelectedProduct = product!,
                        Description = li.Description,
                        Quantity = li.Quantity,
                        UnitPrice = li.UnitPrice,
                        TaxRate = li.TaxRate
                    });
                }
                _lineItems = lineItems;

                CalculateTotals();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading invoice: {ex.Message}");
            Snackbar.Add(Localization.GetString("ErrorLoadingInvoice"), Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    private void OnTaxRateChanged(LineItemModel item, decimal value)
    {
        item.TaxRate = Math.Clamp(value, 0m, 100m);
        CalculateTotals();
    }

    private void OnIssueDateChanged()
    {
        if (_issueDate.HasValue)
        {
            _dueDate = _issueDate.Value.AddDays(_paymentTermsDays);
        }
    }

    private void OnPaymentTermsChanged()
    {
        if (_issueDate.HasValue)
        {
            _dueDate = _issueDate.Value.AddDays(_paymentTermsDays);
        }
    }

    private void AddLineItem()
    {
        _lineItems.Add(new LineItemModel());
    }

    private void RemoveLineItem(LineItemModel item)
    {
        _lineItems.Remove(item);
        CalculateTotals();
    }

    private void CalculateTotals()
    {
        _subtotal = _lineItems.Sum(i => i.Quantity * i.UnitPrice);
        _taxAmount = _lineItems.Sum(i => (i.Quantity * i.UnitPrice) * (i.TaxRate / 100));
        _total = _subtotal + _taxAmount;
        StateHasChanged();
    }

    private async Task HandleSubmit()
    {
        // Validation
        if (!_lineItems.Any() || _lineItems.All(i => i.SelectedProduct == null && string.IsNullOrWhiteSpace(i.Description)))
        {
            Snackbar.Add(Localization.GetString("PleaseAddAtLeastOneLineItem"), Severity.Warning);
            return;
        }

        LineItemModel? invalidItem = _lineItems.FirstOrDefault(i => i.SelectedProduct == null && string.IsNullOrWhiteSpace(i.Description));
        if (invalidItem != null)
        {
            Snackbar.Add(Localization.GetString("PleaseSelectProduct"), Severity.Warning);
            return;
        }

        if (_selectedWarehouse == null)
        {
            Snackbar.Add(Localization.GetString("PleaseSelectWarehouse"), Severity.Warning);
            return;
        }

        _saving = true;

        try
        {
            _updateDto.CompanyId = _selectedCompanyId;
            _updateDto.Type = _selectedType;
            _updateDto.IssueDate = _issueDate ?? DateTime.UtcNow;
            _updateDto.DueDate = _dueDate ?? DateTime.UtcNow.AddDays(30);
            _updateDto.WarehouseId = _selectedWarehouse.Id;
            _updateDto.Notes = _notes;
            _updateDto.LineItems = _lineItems
                .Where(i => !string.IsNullOrWhiteSpace(i.Description))
                .Select(i => new UpdateInvoiceLineDto
                {
                    Id = i.Id,
                    ProductId = i.SelectedProduct.Id,
                    Description = i.SelectedProduct?.Name ?? i.Description,
                    Quantity = i.Quantity,
                    UnitPrice = i.UnitPrice,
                    TaxRate = i.TaxRate
                }).ToList();

            InvoiceDto updated = await InvoiceService.UpdateInvoiceAsync(Id, _updateDto);

            Snackbar.Add(Localization.GetString("InvoiceUpdated"), Severity.Success);
            Navigation.NavigateTo($"/invoices/{Id}");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error updating invoice: {ex.Message}");
            Snackbar.Add(Localization.GetString("ErrorUpdatingInvoice"), Severity.Error);
        }
        finally
        {
            _saving = false;
        }
    }

    public void Dispose()
    {
        Localization.OnLanguageChanged -= OnLanguageChanged;
    }

    private sealed class LineItemModel
    {
        public Guid Id { get; set; }
        public ProductDto SelectedProduct { get; set; } = null!;
        public string Description { get; set; } = string.Empty;
        public int Quantity { get; set; } = 1;
        public decimal UnitPrice { get; set; } = 0m;
        public decimal TaxRate { get; set; } = 0m;
        public decimal LineTotal => (Quantity * UnitPrice) * (1 + TaxRate / 100);
    }
}