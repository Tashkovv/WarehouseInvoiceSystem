@inject ILocalizationService Localization
@implements IDisposable

<MudContainer MaxWidth="MaxWidth.False" Class="mt-auto py-4" Style="background-color: #F8FAFC;">
    <MudContainer MaxWidth="MaxWidth.ExtraExtraLarge">
        <div class="d-flex justify-space-between align-center flex-wrap">
            <MudText Typo="Typo.body2" Color="Color.Secondary">
                © @DateTime.UtcNow.Year @Localization.GetString("InvoiceSystem")
            </MudText>
            <div class="d-flex gap-4">
                <MudLink Href="/help" Typo="Typo.body2" Color="Color.Secondary" Underline="Underline.None" Class="wis-footer-link">@Localization.GetString("Help")</MudLink>
                <MudLink Href="/privacy" Typo="Typo.body2" Color="Color.Secondary" Underline="Underline.None" Class="wis-footer-link">@Localization.GetString("Privacy")</MudLink>
            </div>
        </div>
    </MudContainer>
</MudContainer>

@code {
    protected override void OnInitialized()
    {
        Localization.OnLanguageChanged += StateHasChanged;
    }

    private void ChangeLanguage(string language)
    {
        Localization.SetLanguage(language);
    }

    public void Dispose()
    {
        Localization.OnLanguageChanged -= StateHasChanged;
    }
}