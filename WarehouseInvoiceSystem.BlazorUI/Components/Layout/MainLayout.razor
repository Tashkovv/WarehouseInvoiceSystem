@inherits LayoutComponentBase
@implements IDisposable
@inject ILocalizationService Localization
@inject IBackgroundJobService BackgroundJobService
@inject ISnackbar Snackbar
@inject NavigationManager Navigation

<MudThemeProvider Theme="_theme" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="1" Color="Color.Primary">
        <MudIconButton Icon="@Icons.Material.Filled.Dashboard"
                       Color="Color.Inherit"
                       Edge="Edge.Start"
                       Href="/" />
        <MudText Typo="Typo.h5" Class="ml-3">
            @Localization.GetString("InvoiceSystem")
        </MudText>
        <MudSpacer />
        <MudMenu ActivationEvent="@MouseEvent.MouseOver"
                 AnchorOrigin="Origin.BottomLeft"
                 TransformOrigin="Origin.TopLeft"
                 Dense="true">
            <ActivatorContent>
                <MudButton Href="/partners-dashboard"
                           StartIcon="@Icons.Material.Filled.Groups"
                           IconSize="Size.Large"
                           Color="Color.Inherit"
                           @onmouseenter="@(() => { })"
                           Style="text-transform: none;">
                    <MudText Typo="Typo.h5">
                        @Localization.GetString("Partners")
                    </MudText>
                </MudButton>
            </ActivatorContent>
            <ChildContent>
                <MudMenuItem Href="/companies" Icon="@Icons.Material.Filled.Business">
                    @Localization.GetString("Companies")
                </MudMenuItem>
                <MudMenuItem Href="/individuals" Icon="@Icons.Material.Filled.Person">
                    @Localization.GetString("Individuals")
                </MudMenuItem>
            </ChildContent>
        </MudMenu>

        <MudMenu ActivationEvent="@MouseEvent.MouseOver"
                 AnchorOrigin="Origin.BottomLeft"
                 TransformOrigin="Origin.TopLeft"
                 Dense="true">
            <ActivatorContent>
                <MudButton Href="/documents-dashboard"
                           StartIcon="@Icons.Material.Filled.Description"
                           IconSize="Size.Large"
                           Color="Color.Inherit"
                           @onmouseenter="@(() => { })"
                           Style="text-transform: none;">
                    <MudText Typo="Typo.h5">
                        @Localization.GetString("Documents")
                    </MudText>
                </MudButton>
            </ActivatorContent>
            <ChildContent>
                <MudMenuItem Href="/invoices" Icon="@Icons.Material.Filled.RequestQuote">
                    @Localization.GetString("Invoices")
                </MudMenuItem>
                <MudMenuItem Href="/purchase-notes" Icon="@Icons.Material.Filled.Receipt">
                    @Localization.GetString("PurchaseNotes")
                </MudMenuItem>
                <MudMenuItem Href="/payments" Icon="@Icons.Material.Filled.Payment">
                    @Localization.GetString("Payments")
                </MudMenuItem>
            </ChildContent>
        </MudMenu>

        <MudMenu ActivationEvent="@MouseEvent.MouseOver"
                 AnchorOrigin="Origin.BottomLeft"
                 TransformOrigin="Origin.TopLeft"
                 Dense="true">
            <ActivatorContent>
                <MudButton Href="/warehouse-dashboard"
                           StartIcon="@Icons.Material.Filled.Warehouse"
                           IconSize="Size.Large"
                           Color="Color.Inherit"
                           @onmouseenter="@(() => { })"
                           Style="text-transform: none;">
                    <MudText Typo="Typo.h5">
                        @Localization.GetString("Warehouse")
                    </MudText>
                </MudButton>
            </ActivatorContent>
            <ChildContent>
                <MudMenuItem Href="/products" Icon="@Icons.Material.Filled.Inventory2">
                    @Localization.GetString("Products")
                </MudMenuItem>
                <MudMenuItem Href="/inventory" Icon="@Icons.Material.Filled.Assessment">
                    @Localization.GetString("Stock")
                </MudMenuItem>
                <MudMenuItem Href="/warehouses" Icon="@Icons.Material.Filled.Warehouse">
                    @Localization.GetString("Warehouses")
                </MudMenuItem>
            </ChildContent>
        </MudMenu>
        <MudSpacer />

        <!-- Language Switcher -->
        <MudMenu Icon="@Icons.Material.Filled.Language"
                 Color="Color.Inherit"
                 TransformOrigin="Origin.TopRight"
                 AnchorOrigin="Origin.BottomRight">
            <MudMenuItem OnClick="@(() => ChangeLanguage("en"))">
                <div class="d-flex align-center gap-2">
                    <span class="fi fi-gb" style="width: 22px; height: 16px; border-radius: 2px; flex-shrink: 0;"></span>
                    <span>English</span>
                    @if (Localization.CurrentLanguage == "en")
                    {
                        <MudIcon Icon="@Icons.Material.Filled.Check" Size="Size.Small" Color="Color.Success" Class="ml-1" />
                    }
                </div>
            </MudMenuItem>
            <MudMenuItem OnClick="@(() => ChangeLanguage("mk"))">
                <div class="d-flex align-center gap-2">
                    <span class="fi fi-mk" style="width: 22px; height: 16px; border-radius: 2px; flex-shrink: 0;"></span>
                    <span>Македонски</span>
                    @if (Localization.CurrentLanguage == "mk")
                    {
                        <MudIcon Icon="@Icons.Material.Filled.Check" Size="Size.Small" Color="Color.Success" Class="ml-1" />
                    }
                </div>
            </MudMenuItem>
        </MudMenu>

        <MudIconButton Icon="@Icons.Material.Filled.Notifications" Color="Color.Inherit" />
        <MudMenu Icon="@Icons.Material.Filled.Settings"
                 Color="Color.Inherit"
                 AnchorOrigin="Origin.BottomRight"
                 TransformOrigin="Origin.TopRight"
                 Dense="true">
            <MudMenuItem Href="/profile" Icon="@Icons.Material.Filled.Tune">
                @Localization.GetString("Profile")
            </MudMenuItem>
            <MudDivider />
            <MudListSubheader Class="px-4 py-2">
                <MudText Typo="Typo.caption" Color="Color.Secondary" Style="text-transform: uppercase; letter-spacing: 0.05em;">
                    @Localization.GetString("SystemJobs")
                </MudText>
            </MudListSubheader>
            <MudMenuItem OnClick="RunCheckOverdueInvoices"
                         Icon="@Icons.Material.Filled.Schedule"
                         Disabled="_runningJob">
                @if (_runningJob)
                {
                    <div class="d-flex align-center gap-2">
                        <MudProgressCircular Size="Size.Small" Indeterminate="true" />
                        <span>@Localization.GetString("CheckOverdueInvoices")</span>
                    </div>
                }
                else
                {
                    @Localization.GetString("CheckOverdueInvoices")
                }
            </MudMenuItem>
        </MudMenu>
    </MudAppBar>

    <MudMainContent Class="pt-16 px-16" Style="background-color: #F8FAFC; min-height: 100vh;">
        <MudContainer MaxWidth="MaxWidth.ExtraExtraLarge" Class="mt-4 mb-6">
            @Body
        </MudContainer>
        <Footer />
    </MudMainContent>
</MudLayout>

@code {
    private readonly MudTheme _theme = new MudBlazor.MudTheme()
    {
        PaletteLight = new PaletteLight()
        {
            Primary = "#1E40AF",
            Secondary = "#64748B",
            Success = "#10B981",
            Warning = "#F59E0B",
            Error = "#EF4444",
            Info = "#3B82F6",
            Background = "#F8FAFC",
            Surface = "#FFFFFF",
            AppbarBackground = "#1E40AF",
            DrawerBackground = "#FFFFFF",
            TextPrimary = "#0F172A",
            TextSecondary = "#475569",
        },
        Typography = new MudBlazor.Typography()
        {
            Default = new DefaultTypography()
            {
                FontFamily = new[] { "Inter", "Roboto", "Helvetica", "Arial", "sans-serif" },
                FontSize = "1rem",
                LineHeight = "1.5"
            },
            H1 = new H1Typography()
            {
                FontSize = "2rem",
                FontWeight = "700",
                LineHeight = "1.2"
            },
            H2 = new H2Typography()
            {
                FontSize = "1.75rem",
                FontWeight = "600",
                LineHeight = "1.3"
            },
            H3 = new H3Typography()
            {
                FontSize = "1.5rem",
                FontWeight = "600",
                LineHeight = "1.3"
            },
            H4 = new H4Typography()
            {
                FontSize = "1.25rem",
                FontWeight = "600",
                LineHeight = "1.4"
            },
            H5 = new H5Typography()
            {
                FontSize = "1.125rem",
                FontWeight = "600",
                LineHeight = "1.4"
            },
            H6 = new H6Typography()
            {
                FontSize = "1rem",
                FontWeight = "600",
                LineHeight = "1.4"
            },
            Body1 = new Body1Typography()
            {
                FontSize = "1rem",
                LineHeight = "1.5"
            },
            Body2 = new Body2Typography()
            {
                FontSize = "0.875rem",
                LineHeight = "1.5"
            }
        },
        LayoutProperties = new LayoutProperties()
        {
            DefaultBorderRadius = "8px"
        }
    };

    private bool _runningJob = false;

    protected override void OnInitialized()
    {
        Localization.OnLanguageChanged += StateHasChanged;
    }

    private void ChangeLanguage(string language)
    {
        Localization.SetLanguage(language);
    }

    private async Task RunCheckOverdueInvoices()
    {
        _runningJob = true;
        try
        {
            await BackgroundJobService.CheckAndUpdateOverdueInvoicesAsync();
            Snackbar.Add(Localization.GetString("CheckOverdueInvoicesSuccess"), Severity.Success);
            Navigation.NavigateTo(Navigation.Uri, forceLoad: true);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error running overdue check: {ex.Message}");
            Snackbar.Add(Localization.GetString("CheckOverdueInvoicesError"), Severity.Error);
            _runningJob = false;
        }
    }

    public void Dispose()
    {
        Localization.OnLanguageChanged -= StateHasChanged;
    }
}