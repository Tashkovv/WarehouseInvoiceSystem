@using WarehouseInvoiceSystem.Application.Interfaces
@inherits LayoutComponentBase
@implements IDisposable
@inject ILocalizationService Localization

<MudThemeProvider Theme="_theme" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="1" Color="Color.Primary">
        <MudIconButton Icon="@Icons.Material.Filled.Dashboard"
                       Color="Color.Inherit"
                       Edge="Edge.Start"
                       Href="/" />
        <MudText Typo="Typo.h5" Class="ml-3">
            @Localization.GetString("InvoiceSystem")
        </MudText>
        <MudSpacer />
        <MudButton Href="/companies"
                   StartIcon="@Icons.Material.Filled.Business"
                   Color="Color.Inherit">
            @Localization.GetString("Companies")
        </MudButton>
        <MudButton Href="/invoices"
                   StartIcon="@Icons.Material.Filled.Receipt"
                   Color="Color.Inherit">
            @Localization.GetString("Invoices")
        </MudButton>
        <MudButton Href="/payments"
                   StartIcon="@Icons.Material.Filled.Payment"
                   Color="Color.Inherit">
            @Localization.GetString("Payments")
        </MudButton>
        <MudButton Href="/products"
                   StartIcon="@Icons.Material.Filled.Inventory2"
                   Color="Color.Inherit">
            @Localization.GetString("Products")
        </MudButton>
        <MudButton Href="/warehouses"
                   StartIcon="@Icons.Material.Filled.Warehouse"
                   Color="Color.Inherit">
            @Localization.GetString("Warehouses")
        </MudButton>
        <MudSpacer />

        <!-- Language Switcher -->
        <MudMenu Icon="@Icons.Material.Filled.Language" Color="Color.Inherit" AnchorOrigin="Origin.BottomRight">
            <MudMenuItem OnClick="@(() => ChangeLanguage("en"))">
                <div class="d-flex align-center">
                    @if (Localization.CurrentLanguage == "en")
                    {
                        <MudIcon Icon="@Icons.Material.Filled.Check" Size="Size.Small" Class="mr-2" />
                    }
                    else
                    {
                        <div style="width: 24px;" class="mr-2"></div>
                    }
                    English
                </div>
            </MudMenuItem>
            <MudMenuItem OnClick="@(() => ChangeLanguage("mk"))">
                <div class="d-flex align-center">
                    @if (Localization.CurrentLanguage == "mk")
                    {
                        <MudIcon Icon="@Icons.Material.Filled.Check" Size="Size.Small" Class="mr-2" />
                    }
                    else
                    {
                        <div style="width: 24px;" class="mr-2"></div>
                    }
                    Македонски
                </div>
            </MudMenuItem>
        </MudMenu>

        <MudIconButton Icon="@Icons.Material.Filled.Notifications" Color="Color.Inherit" />
        <MudIconButton Icon="@Icons.Material.Filled.Settings" Color="Color.Inherit" />
    </MudAppBar>

    <MudMainContent Class="pt-16 px-16" Style="background-color: #F8FAFC; min-height: 100vh;">
        <MudContainer MaxWidth="MaxWidth.ExtraExtraLarge" Class="mt-4">
            @Body
        </MudContainer>
        <Footer />
    </MudMainContent>
</MudLayout>

@code {
    private readonly MudTheme _theme = new MudBlazor.MudTheme()
    {
        PaletteLight = new PaletteLight()
        {
            Primary = "#1E40AF",
            Secondary = "#64748B",
            Success = "#10B981",
            Warning = "#F59E0B",
            Error = "#EF4444",
            Info = "#3B82F6",
            Background = "#F8FAFC",
            Surface = "#FFFFFF",
            AppbarBackground = "#1E40AF",
            DrawerBackground = "#FFFFFF",
            TextPrimary = "#0F172A",
            TextSecondary = "#475569",
        },
        Typography = new MudBlazor.Typography()
        {
            Default = new DefaultTypography()
            {
                FontFamily = new[] { "Inter", "Roboto", "Helvetica", "Arial", "sans-serif" },
                FontSize = "1rem",
                LineHeight = "1.5"
            },
            H1 = new H1Typography()
            {
                FontSize = "2rem",
                FontWeight = "700",
                LineHeight = "1.2"
            },
            H2 = new H2Typography()
            {
                FontSize = "1.75rem",
                FontWeight = "600",
                LineHeight = "1.3"
            },
            H3 = new H3Typography()
            {
                FontSize = "1.5rem",
                FontWeight = "600",
                LineHeight = "1.3"
            },
            H4 = new H4Typography()
            {
                FontSize = "1.25rem",
                FontWeight = "600",
                LineHeight = "1.4"
            },
            H5 = new H5Typography()
            {
                FontSize = "1.125rem",
                FontWeight = "600",
                LineHeight = "1.4"
            },
            H6 = new H6Typography()
            {
                FontSize = "1rem",
                FontWeight = "600",
                LineHeight = "1.4"
            },
            Body1 = new Body1Typography()
            {
                FontSize = "1rem",
                LineHeight = "1.5"
            },
            Body2 = new Body2Typography()
            {
                FontSize = "0.875rem",
                LineHeight = "1.5"
            }
        },
        LayoutProperties = new LayoutProperties()
        {
            DefaultBorderRadius = "8px"
        }
    };

    protected override void OnInitialized()
    {
        Localization.OnLanguageChanged += StateHasChanged;
    }

    private void ChangeLanguage(string language)
    {
        Localization.SetLanguage(language);
    }

    public void Dispose()
    {
        Localization.OnLanguageChanged -= StateHasChanged;
    }
}