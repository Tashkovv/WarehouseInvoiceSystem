@inherits LayoutComponentBase
@implements IDisposable
@using Microsoft.Extensions.Options
@using System.Security.Claims
@using WarehouseInvoiceSystem.Application.Settings
@inject ILocalizationService Localization
@inject IBackgroundJobService BackgroundJobService
@inject INotificationService NotificationService
@inject ISnackbar Snackbar
@inject NavigationManager Navigation
@inject IOptions<NotificationSettings> NotificationSettingsOptions
@inject ILicenseService LicenseService
@inject WisDialogService WisDialog

<MudThemeProvider Theme="_theme" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    @if (_licenseStatus is LicenseStatus.Locked or LicenseStatus.NotActivated)
    {
        @* ── Locked: minimal app bar (title + language only), License page instead of Body ── *@
        <MudAppBar Elevation="1" Color="Color.Primary">
            <MudIcon Icon="@Icons.Material.Filled.Key" Color="Color.Inherit" Class="ml-2" />
            <MudText Typo="Typo.h5" Class="ml-3">
                @Localization.GetString("InvoiceSystem")
            </MudText>
            <MudSpacer />
            <LanguageSwitcher />
        </MudAppBar>

        <MudMainContent Class="pt-16 px-16" Style="background-color: #F8FAFC; min-height: 100vh; display: flex; flex-direction: column;">
            <WarehouseInvoiceSystem.BlazorUI.Components.Pages.License @key="Localization.CurrentLanguage" />
        </MudMainContent>
    }
    else
    {
        @* ── Licensed: full app bar with navigation ── *@
        <MudAppBar Elevation="1" Color="Color.Primary">
            <MudIconButton Icon="@Icons.Material.Filled.Dashboard"
                           Color="Color.Inherit"
                           Edge="Edge.Start"
                           Href="/" />
            <MudText Typo="Typo.h5" Class="ml-3">
                @Localization.GetString("InvoiceSystem")
            </MudText>
            <MudSpacer />
            <MudMenu ActivationEvent="@MouseEvent.MouseOver"
                     AnchorOrigin="Origin.BottomLeft"
                     TransformOrigin="Origin.TopLeft"
                     Dense="true">
                <ActivatorContent>
                    <MudButton Href="/partners-dashboard"
                               StartIcon="@Icons.Material.Filled.Groups"
                               IconSize="Size.Large"
                               Color="Color.Inherit"
                               @onmouseenter="@(() => { })"
                               Style="text-transform: none;">
                        <MudText Typo="Typo.h5">
                            @Localization.GetString("Partners")
                        </MudText>
                    </MudButton>
                </ActivatorContent>
                <ChildContent>
                    <MudMenuItem Href="/companies" Icon="@Icons.Material.Filled.Business">
                        @Localization.GetString("Companies")
                    </MudMenuItem>
                    <MudMenuItem Href="/individuals" Icon="@Icons.Material.Filled.Person">
                        @Localization.GetString("Individuals")
                    </MudMenuItem>
                </ChildContent>
            </MudMenu>

            <MudMenu ActivationEvent="@MouseEvent.MouseOver"
                     AnchorOrigin="Origin.BottomLeft"
                     TransformOrigin="Origin.TopLeft"
                     Dense="true">
                <ActivatorContent>
                    <MudButton Href="/documents-dashboard"
                               StartIcon="@Icons.Material.Filled.Description"
                               IconSize="Size.Large"
                               Color="Color.Inherit"
                               @onmouseenter="@(() => { })"
                               Style="text-transform: none;">
                        <MudText Typo="Typo.h5">
                            @Localization.GetString("Documents")
                        </MudText>
                    </MudButton>
                </ActivatorContent>
                <ChildContent>
                    <MudMenuItem Href="/invoices" Icon="@Icons.Material.Filled.RequestQuote">
                        @Localization.GetString("Invoices")
                    </MudMenuItem>
                    <MudMenuItem Href="/purchase-notes" Icon="@Icons.Material.Filled.Receipt">
                        @Localization.GetString("PurchaseNotes")
                    </MudMenuItem>
                    <MudMenuItem Href="/payments" Icon="@Icons.Material.Filled.Payment">
                        @Localization.GetString("Payments")
                    </MudMenuItem>
                </ChildContent>
            </MudMenu>

            <MudMenu ActivationEvent="@MouseEvent.MouseOver"
                     AnchorOrigin="Origin.BottomLeft"
                     TransformOrigin="Origin.TopLeft"
                     Dense="true">
                <ActivatorContent>
                    <MudButton Href="/warehouse-dashboard"
                               StartIcon="@Icons.Material.Filled.Warehouse"
                               IconSize="Size.Large"
                               Color="Color.Inherit"
                               @onmouseenter="@(() => { })"
                               Style="text-transform: none;">
                        <MudText Typo="Typo.h5">
                            @Localization.GetString("Warehouse")
                        </MudText>
                    </MudButton>
                </ActivatorContent>
                <ChildContent>
                    <MudMenuItem Href="/products" Icon="@Icons.Material.Filled.Inventory2">
                        @Localization.GetString("Products")
                    </MudMenuItem>
                    <MudMenuItem Href="/inventory" Icon="@Icons.Material.Filled.Assessment">
                        @Localization.GetString("Stock")
                    </MudMenuItem>
                    <MudMenuItem Href="/warehouses" Icon="@Icons.Material.Filled.Warehouse">
                        @Localization.GetString("Warehouses")
                    </MudMenuItem>
                </ChildContent>
            </MudMenu>
            <MudSpacer />
            <LanguageSwitcher />
            <NotificationBell />

            <!-- User info chip -->
            <AuthorizeView>
                <Authorized>
                    <MudChip T="string" Color="Color.Default" Size="Size.Small"
                             Icon="@Icons.Material.Filled.Person"
                             Style="color: white; border: 1px solid rgba(255,255,255,0.3);">
                        @context.User.Identity?.Name
                        @if (context.User.IsInRole("Admin"))
                        {
                            <MudText Typo="Typo.caption" Style="margin-left: 4px; opacity: 0.7;">(Admin)</MudText>
                        }
                    </MudChip>
                </Authorized>
            </AuthorizeView>

            <!-- Settings -->
            <div class="appbar-popover-anchor">
                <MudIconButton Icon="@Icons.Material.Filled.Settings"
                               Color="Color.Inherit"
                               OnClick="@(() => _settingsOpen = !_settingsOpen)" />

                @if (_settingsOpen)
                {
                    <MudOverlay Visible="true" OnClick="@(() => _settingsOpen = false)" LockScroll="false" />
                    <MudPopover Open="true" Fixed="false" Class="pa-0 mud-elevation-4"
                                AnchorOrigin="Origin.BottomRight"
                                TransformOrigin="Origin.TopRight"
                                Style="z-index: 1301; min-width: 220px;">
                    <MudList T="string" Dense="true" Class="pa-0">
                        <AuthorizeView Roles="Admin">
                            <Authorized>
                                <MudListItem OnClick="@(() => { Navigation.NavigateTo("/profile"); _settingsOpen = false; })"
                                             Class="px-3 py-2" Style="cursor: pointer;">
                                    <div class="d-flex align-center gap-2">
                                        <MudIcon Icon="@Icons.Material.Filled.Tune" Size="Size.Small" Color="Color.Secondary" />
                                        <span>@Localization.GetString("Profile")</span>
                                    </div>
                                </MudListItem>
                            </Authorized>
                        </AuthorizeView>
                        <MudListItem OnClick="@(() => { _settingsOpen = false; _ = OpenChangePasswordDialog(); })"
                                     Class="px-3 py-2" Style="cursor: pointer;">
                            <div class="d-flex align-center gap-2">
                                <MudIcon Icon="@Icons.Material.Filled.Lock" Size="Size.Small" Color="Color.Secondary" />
                                <span>@Localization.GetString("ChangePassword")</span>
                            </div>
                        </MudListItem>
                        <AuthorizeView Roles="Admin">
                            <Authorized>
                                <MudListItem OnClick="@(() => { Navigation.NavigateTo("/users"); _settingsOpen = false; })"
                                             Class="px-3 py-2" Style="cursor: pointer;">
                                    <div class="d-flex align-center gap-2">
                                        <MudIcon Icon="@Icons.Material.Filled.People" Size="Size.Small" Color="Color.Secondary" />
                                        <span>@Localization.GetString("Users")</span>
                                    </div>
                                </MudListItem>
                                <MudListItem OnClick="@(() => { Navigation.NavigateTo("/audit-log"); _settingsOpen = false; })"
                                             Class="px-3 py-2" Style="cursor: pointer;">
                                    <div class="d-flex align-center gap-2">
                                        <MudIcon Icon="@Icons.Material.Filled.History" Size="Size.Small" Color="Color.Secondary" />
                                        <span>@Localization.GetString("AuditLog")</span>
                                    </div>
                                </MudListItem>
                                <MudListItem OnClick="@(() => { Navigation.NavigateTo("/license"); _settingsOpen = false; })"
                                             Class="px-3 py-2" Style="cursor: pointer;">
                                    <div class="d-flex align-center gap-2">
                                        <MudIcon Icon="@Icons.Material.Filled.Key" Size="Size.Small" Color="Color.Secondary" />
                                        <span>@Localization.GetString("License")</span>
                                    </div>
                                </MudListItem>
                                <MudDivider />
                                <div class="px-4 py-2">
                                    <MudText Typo="Typo.caption" Color="Color.Secondary" Style="text-transform: uppercase; letter-spacing: 0.05em;">
                                        @Localization.GetString("SystemJobs")
                                    </MudText>
                                </div>
                                <MudListItem OnClick="@(() => { _settingsOpen = false; _ = RunCheckOverdueInvoices(); })"
                                             Disabled="_runningJob"
                                             Class="px-3 py-2" Style="cursor: pointer;">
                                    <div class="d-flex align-center gap-2">
                                        @if (_runningJob)
                                        {
                                            <MudProgressCircular Size="Size.Small" Indeterminate="true" />
                                        }
                                        else
                                        {
                                            <MudIcon Icon="@Icons.Material.Filled.Schedule" Size="Size.Small" Color="Color.Secondary" />
                                        }
                                        <span>@Localization.GetString("CheckOverdueInvoices")</span>
                                    </div>
                                </MudListItem>
                                <MudListItem OnClick="@(() => { _settingsOpen = false; _ = RunGenerateNotifications(); })"
                                             Disabled="_runningNotifications"
                                             Class="px-3 py-2" Style="cursor: pointer;">
                                    <div class="d-flex align-center gap-2">
                                        @if (_runningNotifications)
                                        {
                                            <MudProgressCircular Size="Size.Small" Indeterminate="true" />
                                        }
                                        else
                                        {
                                            <MudIcon Icon="@Icons.Material.Filled.Notifications" Size="Size.Small" Color="Color.Secondary" />
                                        }
                                        <span>@Localization.GetString("GenerateNotifications")</span>
                                    </div>
                                </MudListItem>
                            </Authorized>
                        </AuthorizeView>
                        <MudDivider />
                        <MudListItem Class="px-3 py-2" Style="cursor: pointer;">
                            <form method="post" action="/api/auth/logout" style="margin: 0;">
                                <button type="submit" style="background: none; border: none; cursor: pointer; padding: 0; width: 100%;">
                                    <div class="d-flex align-center gap-2">
                                        <MudIcon Icon="@Icons.Material.Filled.Logout" Size="Size.Small" Color="Color.Error" />
                                        <span style="color: var(--mud-palette-error);">@Localization.GetString("Logout")</span>
                                    </div>
                                </button>
                            </form>
                        </MudListItem>
                    </MudList>
                    </MudPopover>
                }
            </div>
        </MudAppBar>

        <MudMainContent Class="pt-16 px-16" Style="background-color: #F8FAFC; min-height: 100vh; display: flex; flex-direction: column;">
            <MudContainer MaxWidth="MaxWidth.ExtraExtraLarge" Class="mt-4 mb-6" Style="flex: 1 1 auto;">
                @Body
            </MudContainer>
            <Footer />
        </MudMainContent>
    }
</MudLayout>

@code {
    private readonly MudTheme _theme = new MudBlazor.MudTheme()
    {
        PaletteLight = new PaletteLight()
        {
            Primary = "#1E40AF",
            Secondary = "#64748B",
            Success = "#10B981",
            Warning = "#F59E0B",
            Error = "#EF4444",
            Info = "#3B82F6",
            Background = "#F8FAFC",
            Surface = "#FFFFFF",
            AppbarBackground = "#1E40AF",
            DrawerBackground = "#FFFFFF",
            TextPrimary = "#0F172A",
            TextSecondary = "#475569",
        },
        Typography = new MudBlazor.Typography()
        {
            Default = new DefaultTypography()
            {
                FontFamily = new[] { "Inter", "Roboto", "Helvetica", "Arial", "sans-serif" },
                FontSize = "1rem",
                LineHeight = "1.5"
            },
            H1 = new H1Typography()
            {
                FontSize = "2rem",
                FontWeight = "700",
                LineHeight = "1.2"
            },
            H2 = new H2Typography()
            {
                FontSize = "1.75rem",
                FontWeight = "600",
                LineHeight = "1.3"
            },
            H3 = new H3Typography()
            {
                FontSize = "1.5rem",
                FontWeight = "600",
                LineHeight = "1.3"
            },
            H4 = new H4Typography()
            {
                FontSize = "1.25rem",
                FontWeight = "600",
                LineHeight = "1.4"
            },
            H5 = new H5Typography()
            {
                FontSize = "1.125rem",
                FontWeight = "600",
                LineHeight = "1.4"
            },
            H6 = new H6Typography()
            {
                FontSize = "1rem",
                FontWeight = "600",
                LineHeight = "1.4"
            },
            Body1 = new Body1Typography()
            {
                FontSize = "1rem",
                LineHeight = "1.5"
            },
            Body2 = new Body2Typography()
            {
                FontSize = "0.875rem",
                LineHeight = "1.5"
            }
        },
        LayoutProperties = new LayoutProperties()
        {
            DefaultBorderRadius = "8px"
        }
    };

    private bool _settingsOpen = false;
    private bool _runningJob = false;
    private bool _runningNotifications = false;
    private LicenseStatus _licenseStatus = LicenseStatus.Active;

    protected override async Task OnInitializedAsync()
    {
        Localization.OnLanguageChanged += StateHasChanged;
        LicenseService.OnStatusChanged += OnLicenseStatusChanged;

        await LicenseService.ValidateAsync();
        _licenseStatus = LicenseService.Status;
    }

    private void OnLicenseStatusChanged()
    {
        _licenseStatus = LicenseService.Status;
        InvokeAsync(StateHasChanged);
    }

    private async Task RunCheckOverdueInvoices()
    {
        _runningJob = true;
        try
        {
            List<Guid> overdueIds = await BackgroundJobService.CheckAndUpdateOverdueInvoicesAsync();

            if (overdueIds.Count > 0)
                await NotificationService.CreateOverdueNotificationAsync(overdueIds);

            Snackbar.Add(Localization.GetString("CheckOverdueInvoicesSuccess"), Severity.Success);
            Navigation.NavigateTo(Navigation.Uri, forceLoad: true);
        }
        catch (Exception)
        {
            Snackbar.Add(Localization.GetString("CheckOverdueInvoicesError"), Severity.Error);
            _runningJob = false;
        }
    }

    private async Task RunGenerateNotifications()
    {
        var settings = NotificationSettingsOptions.Value;
        bool hasReceivable = settings.ReceivableDays is { Length: > 0 };
        bool hasPayable = settings.PayableDays is { Length: > 0 };

        if (!hasReceivable && !hasPayable)
        {
            Snackbar.Add(Localization.GetString("NotificationsDisabled"), Severity.Warning);
            return;
        }

        _runningNotifications = true;
        try
        {
            await BackgroundJobService.GenerateAndSendDueDateRemindersAsync();
            Snackbar.Add(Localization.GetString("GenerateNotificationsSuccess"), Severity.Success);
            Navigation.NavigateTo(Navigation.Uri, forceLoad: true);
        }
        catch (Exception)
        {
            Snackbar.Add(Localization.GetString("GenerateNotificationsError"), Severity.Error);
            _runningNotifications = false;
        }
    }

    private async Task OpenChangePasswordDialog()
    {
        await WisDialog.ShowFormAsync<WarehouseInvoiceSystem.BlazorUI.Components.Dialogs.ChangePasswordDialog, bool>(
            Localization.GetString("ChangePassword"),
            maxWidth: MaxWidth.Small);
    }

    public void Dispose()
    {
        Localization.OnLanguageChanged -= StateHasChanged;
        LicenseService.OnStatusChanged -= OnLicenseStatusChanged;
    }
}