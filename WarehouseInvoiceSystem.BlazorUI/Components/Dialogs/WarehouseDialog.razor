@using WarehouseInvoiceSystem.Application.DTOs.Warehouse
@inject ILocalizationService Localization
@inject IWarehouseService WarehouseService
@inject ISnackbar Snackbar

<MudDialog>
    <DialogContent>
        <MudGrid>
            <MudItem xs="12">
                <MudTextField @bind-Value="_name"
                              Label="@Localization.GetString("Name")"
                              Variant="Variant.Outlined"
                              Required="true"
                              RequiredError="@Localization.GetString("WarehouseNameRequired")"
                              MaxLength="200"
                              FullWidth="true" />
            </MudItem>
            <MudItem xs="12">
                <MudTextField @bind-Value="_address"
                              Label="@Localization.GetString("Address")"
                              Variant="Variant.Outlined"
                              MaxLength="500"
                              FullWidth="true" />
            </MudItem>
        </MudGrid>
    </DialogContent>
    <DialogActions>
        <WisDialogActions OnCancel="Cancel"
                          OnSave="Save"
                          SaveDisabled="@(!IsValid || _saving)" />
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter]
    IMudDialogInstance MudDialog { get; set; } = null!;

    /// <summary>Pass an existing WarehouseDto to edit, or null to create.</summary>
    [Parameter]
    public WarehouseDto? Warehouse { get; set; }

    private bool IsEditMode => Warehouse is not null;

    private string _name = string.Empty;
    private string? _address;

    private bool IsValid => !string.IsNullOrWhiteSpace(_name);
    private bool _saving;

    protected override void OnParametersSet()
    {
        if (IsEditMode)
        {
            _name = Warehouse!.Name;
            _address = Warehouse.Address;
        }
        else
        {
            _name = string.Empty;
            _address = null;
        }
    }

    private async Task Save()
    {
        _saving = true;
        try
        {
            string trimmedName = _name.Trim();
            string? trimmedAddress = string.IsNullOrWhiteSpace(_address) ? null : _address.Trim();

            if (IsEditMode)
            {
                await WarehouseService.UpdateWarehouseAsync(Warehouse!.Id, new UpdateWarehouseDto
                {
                    Name = trimmedName,
                    Address = trimmedAddress,
                });
                Snackbar.Add(Localization.GetString("WarehouseUpdated"), Severity.Success);
            }
            else
            {
                await WarehouseService.CreateWarehouseAsync(new CreateWarehouseDto
                {
                    Name = trimmedName,
                    Address = trimmedAddress,
                });
                Snackbar.Add(Localization.GetString("WarehouseCreated"), Severity.Success);
            }
            MudDialog.Close(DialogResult.Ok(true));
        }
        catch (InvalidOperationException ex) { Snackbar.Add(ex.Message, Severity.Error); }
        catch (Exception ex)
        {
            Console.WriteLine($"Error saving warehouse: {ex.Message}");
            Snackbar.Add(Localization.GetString(IsEditMode ? "ErrorUpdatingWarehouse" : "ErrorCreatingWarehouse"), Severity.Error);
        }
        finally { _saving = false; }
    }

    private void Cancel() => MudDialog.Cancel();
}
