@using WarehouseInvoiceSystem.Application.DTOs.Invoice
@using WarehouseInvoiceSystem.Domain.Enums
@inject ILocalizationService Localization
@inject IEmailService EmailService
@inject IInvoiceService InvoiceService
@inject ISnackbar Snackbar

<MudDialog Class="wis-email-dialog">
    <DialogContent>
        @if (_invoice is not null)
        {
            @* ── Compose header ── *@
            <div class="wis-email-compose-header">
                <MudIcon Icon="@Icons.Material.Filled.Email" Class="wis-email-compose-icon" />
                <div class="wis-email-compose-meta">
                    <MudText Typo="Typo.subtitle2" Class="wis-email-compose-invoice">
                        @_invoice.InvoiceNumber
                    </MudText>
                    <MudText Typo="Typo.caption" Color="Color.Secondary">
                        @_invoice.CompanyName · @_invoice.TotalAmount.ToString("C")
                    </MudText>
                </div>
                <MudChip T="string"
                         Size="Size.Small"
                         Color="Color.Success"
                         Variant="Variant.Outlined"
                         Class="ml-auto">
                    @Localization.GetString("Receivable")
                </MudChip>
            </div>

            <MudDivider Class="mb-4" />
        }

        @* ── Message field ── *@
        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-1">
            @Localization.GetString("CustomMessage")
        </MudText>
        <MudTextField T="string"
                      @bind-Value="_customMessage"
                      Placeholder="@Localization.GetString("CustomMessageHelper")"
                      Variant="Variant.Outlined"
                      Lines="5"
                      FullWidth="true"
                      Disabled="_sending" />

        @* ── Error banner ── *@
        @if (_errorMessage is not null)
        {
            <MudAlert Severity="Severity.Error"
                      Variant="Variant.Filled"
                      Dense="true"
                      Class="mt-3 wis-alert-fullwidth">
                @_errorMessage
            </MudAlert>
        }

    </DialogContent>
    <DialogActions>
        <WisDialogActions OnCancel="Cancel"
                          OnSave="Send"
                          SaveLabel="@(_sending ? Localization.GetString("Sending") : Localization.GetString("Send"))"
                          SaveIcon="@Icons.Material.Filled.Send"
                          SaveColor="Color.Info"
                          SaveDisabled="@_sending" />
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter]
    IMudDialogInstance MudDialog { get; set; } = null!;

    /// <summary>The invoice to send. Required.</summary>
    [Parameter, EditorRequired]
    public InvoiceDto Invoice { get; set; } = null!;

    private InvoiceDto? _invoice;
    private string? _customMessage;
    private bool _sending;
    private string? _errorMessage;

    protected override void OnParametersSet()
    {
        _invoice = Invoice;
    }

    private async Task Send()
    {
        _errorMessage = null;
        _sending = true;

        try
        {
            bool success = await EmailService.SendInvoiceEmailAsync(
                _invoice!.Id, _customMessage);

            if (success)
            {
                // Transition Draft → Sent (creates inventory transactions) right here,
                // so the status update happens regardless of whether the caller is the
                // list page or the details page.
                if (_invoice.Status == InvoiceStatus.Draft)
                {
                    await InvoiceService.SendAsync(_invoice.Id);
                }

                Snackbar.Add(Localization.GetString("InvoiceEmailSentSuccessfully"), Severity.Success);
                MudDialog.Close(DialogResult.Ok(true));
            }
            else
            {
                _errorMessage = Localization.GetString("ErrorSendingEmail");
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error sending invoice email: {ex.Message}");
            _errorMessage = Localization.GetString("ErrorSendingEmail");
        }
        finally
        {
            _sending = false;
        }
    }

    private void Cancel() => MudDialog.Cancel();
}
