@using WarehouseInvoiceSystem.Application.DTOs.Company
@using WarehouseInvoiceSystem.Domain.Enums
@inject ILocalizationService Localization
@inject ICompanyService CompanyService
@inject ISnackbar Snackbar

<MudDialog>
    <DialogContent>
        <MudGrid>

            <!-- Identity -->
            <MudItem xs="12" sm="4">
                <WisInput @bind-Value="_company.Name"
                          Label="@Localization.GetString("Name")"
                          Required="true" />
            </MudItem>
            <MudItem xs="12" sm="4">
                <WisInput @bind-Value="_company.ContactPerson"
                          Label="@Localization.GetString("ContactPerson")" />
            </MudItem>
            <MudItem xs="12" sm="4">
                <WisSelect T="CompanyType"
                           Items="_companyTypes"
                           @bind-Value="_company.Type"
                           Label="@Localization.GetString("CompanyType")"
                           Required="true"
                           ItemTemplate="CompanyTypeItem" />
            </MudItem>
            <MudItem xs="12" sm="4">
                <WisInput @bind-Value="_company.Address"
                          Label="@Localization.GetString("Address")" />
            </MudItem>

            <!-- Contact -->
            <MudItem xs="12" sm="4">
                <WisInput @bind-Value="_company.Email"
                          Label="@Localization.GetString("Email")"
                          InputType="email"
                          Autocomplete="email" />
            </MudItem>
            <MudItem xs="12" sm="4">
                <WisInput @bind-Value="_company.Phone"
                          Label="@Localization.GetString("Phone")"
                          InputType="tel"
                          Autocomplete="tel" />
            </MudItem>

            <!-- Financial -->
            <MudItem xs="12" sm="4">
                <WisInput @bind-Value="_company.TaxId"
                          Label="@Localization.GetString("TaxId")" />
            </MudItem>
            <MudItem xs="12" sm="4">
                <WisAmountInput Value="_paymentTermsDays"
                                ValueChanged="OnPaymentTermsChanged"
                                Label="@Localization.GetString("PaymentTerms")"
                                AdornmentText="@Localization.GetString("Days")"
                                FullWidth="true" />
            </MudItem>
            <MudItem xs="12" sm="4">
                <WisAmountInput Value="_creditLimit"
                                ValueChanged="OnCreditLimitChanged"
                                Label="@Localization.GetString("CreditLimit")"
                                AdornmentText="@Localization.CurrencySymbol"
                                FullWidth="true" />
            </MudItem>

        </MudGrid>
    </DialogContent>
    <DialogActions>
        <WisDialogActions OnCancel="Cancel"
                          OnSave="Save"
                          SaveDisabled="@(!IsValid || _saving)" />
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter]
    IMudDialogInstance MudDialog { get; set; } = null!;

    /// <summary>
    /// Pass an existing CompanyDto to edit, or null to create a new company.
    /// </summary>
    [Parameter]
    public CompanyDto? Company { get; set; }

    private CompanyDto _company = new();
    private bool IsEditMode => Company is not null;

    private bool IsValid => !string.IsNullOrWhiteSpace(_company.Name);

    private static readonly CompanyType[] _companyTypes =
        [CompanyType.Client, CompanyType.Vendor, CompanyType.Both];

    private RenderFragment<CompanyType> CompanyTypeItem => type => __builder =>
    {
        (string icon, Color color, string key) = type switch
        {
            CompanyType.Client => (Icons.Material.Filled.TrendingUp, Color.Success, "Client"),
            CompanyType.Vendor => (Icons.Material.Filled.TrendingDown, Color.Warning, "Vendor"),
            CompanyType.Both   => (Icons.Material.Filled.SyncAlt, Color.Primary, "ClientAndVendor"),
            _                  => (Icons.Material.Filled.Business, Color.Default, type.ToString())
        };

        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
            <MudIcon Icon="@icon" Size="Size.Small" Color="@color" />
            <MudText>@Localization.GetString(key)</MudText>
        </MudStack>
    };

    // WisAmountInput binds to decimal?; DTO uses int / decimal. Bridge via nullable mirrors.
    private decimal? _paymentTermsDays;
    private decimal? _creditLimit;

    private void OnPaymentTermsChanged(decimal? v)
    {
        _paymentTermsDays = v;
        _company.PaymentTermsDays = v.HasValue ? (int)v.Value : 0;
    }

    private void OnCreditLimitChanged(decimal? v)
    {
        _creditLimit = v;
        _company.CreditLimit = v ?? 0m;
    }

    protected override void OnParametersSet()
    {
        if (Company is not null)
        {
            _company = new CompanyDto
            {
                Id = Company.Id,
                Name = Company.Name,
                Type = Company.Type,
                ContactPerson = Company.ContactPerson,
                Email = Company.Email,
                Phone = Company.Phone,
                Address = Company.Address,
                TaxId = Company.TaxId,
                PaymentTermsDays = Company.PaymentTermsDays,
                CreditLimit = Company.CreditLimit,
                IsActive = Company.IsActive,
                CreatedAt = Company.CreatedAt
            };
        }
        else
        {
            _company = new CompanyDto
            {
                IsActive = true,
                Type = CompanyType.Client,
                PaymentTermsDays = 30
            };
        }

        _paymentTermsDays = _company.PaymentTermsDays;
        _creditLimit = _company.CreditLimit > 0 ? _company.CreditLimit : null;
    }

    private bool _saving;

    private async Task Save()
    {
        _saving = true;
        try
        {
            if (IsEditMode)
            {
                await CompanyService.UpdateCompanyAsync(_company.Id, new UpdateCompanyDto
                {
                    Name = _company.Name,
                    Type = _company.Type,
                    ContactPerson = _company.ContactPerson,
                    Email = _company.Email,
                    Phone = _company.Phone,
                    Address = _company.Address,
                    TaxId = _company.TaxId,
                    PaymentTermsDays = _company.PaymentTermsDays,
                    CreditLimit = _company.CreditLimit,
                    IsActive = _company.IsActive
                });
                Snackbar.Add(Localization.GetString("CompanyUpdated"), Severity.Success);
            }
            else
            {
                await CompanyService.CreateCompanyAsync(new CreateCompanyDto
                {
                    Name = _company.Name,
                    Type = _company.Type,
                    ContactPerson = _company.ContactPerson,
                    Email = _company.Email,
                    Phone = _company.Phone,
                    Address = _company.Address,
                    TaxId = _company.TaxId,
                    PaymentTermsDays = _company.PaymentTermsDays,
                    CreditLimit = _company.CreditLimit
                });
                Snackbar.Add(Localization.GetString("CompanyCreated"), Severity.Success);
            }
            MudDialog.Close(DialogResult.Ok(true));
        }
        catch (InvalidOperationException ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
        catch (Exception)
        {
            Snackbar.Add(Localization.GetString(IsEditMode ? "ErrorUpdatingCompany" : "ErrorCreatingCompany"), Severity.Error);
        }
        finally
        {
            _saving = false;
        }
    }

    private void Cancel() => MudDialog.Cancel();
}
