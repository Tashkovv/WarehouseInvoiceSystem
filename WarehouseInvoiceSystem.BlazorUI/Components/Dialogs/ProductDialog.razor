@using WarehouseInvoiceSystem.Application.DTOs.Product
@inject ILocalizationService Localization
@inject IProductService ProductService
@inject ISnackbar Snackbar

<MudDialog>
    <DialogContent>
        <MudGrid>
            <MudItem xs="12" sm="6">
                <WisInput @bind-Value="_product.Code"
                          Label="@Localization.GetString("Code")"
                          Required="true"
                          ReadOnly="@IsEditMode" />
            </MudItem>
            <MudItem xs="12" sm="6">
                <WisInput @bind-Value="_product.Name"
                          Label="@Localization.GetString("Name")"
                          Required="true" />
            </MudItem>
            <MudItem xs="12" sm="6">
                <WisInput @bind-Value="_product.Unit"
                          Label="@Localization.GetString("Unit")"
                          Required="true" />
            </MudItem>
            <MudItem xs="12" sm="6">
                <WisInput @bind-Value="_product.Description"
                          Label="@Localization.GetString("Description")" />
            </MudItem>
            <MudItem xs="12" sm="6">
                <WisAmountInput @bind-Value="_costPrice"
                                Label="@Localization.GetString("CostPrice")"
                                AdornmentText="@Localization.CurrencySymbol"
                                FullWidth="true" />
            </MudItem>
            <MudItem xs="12" sm="6">
                <WisAmountInput @bind-Value="_sellingPrice"
                                Label="@Localization.GetString("SellingPrice")"
                                AdornmentText="@Localization.CurrencySymbol"
                                FullWidth="true" />
            </MudItem>
        </MudGrid>
    </DialogContent>
    <DialogActions>
        <WisDialogActions OnCancel="Cancel"
                          OnSave="Save"
                          SaveDisabled="@(!IsValid || _saving)" />
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter]
    IMudDialogInstance MudDialog { get; set; } = null!;

    /// <summary>
    /// Pass an existing ProductDto to edit, or null to create a new product.
    /// </summary>
    [Parameter]
    public ProductDto? Product { get; set; }

    private ProductDto _product = new();
    private decimal? _costPrice;
    private decimal? _sellingPrice;
    private bool IsEditMode => Product is not null;

    private bool IsValid =>
        !string.IsNullOrWhiteSpace(_product.Code) &&
        !string.IsNullOrWhiteSpace(_product.Name) &&
        !string.IsNullOrWhiteSpace(_product.Unit) &&
        _costPrice is > 0 &&
        _sellingPrice is > 0;

    protected override void OnParametersSet()
    {
        if (Product is not null)
        {
            // Edit mode — work on a clone so cancel discards changes
            _product = new ProductDto
            {
                Id = Product.Id,
                Code = Product.Code,
                Name = Product.Name,
                Description = Product.Description,
                Unit = Product.Unit,
                CostPrice = Product.CostPrice,
                SellingPrice = Product.SellingPrice,
                IsActive = Product.IsActive,
                CreatedAt = Product.CreatedAt
            };
            _costPrice = Product.CostPrice;
            _sellingPrice = Product.SellingPrice;
        }
        else
        {
            // Create mode — fresh product, active by default
            _product = new ProductDto { IsActive = true };
            _costPrice = null;
            _sellingPrice = null;
        }
    }

    private bool _saving;

    private async Task Save()
    {
        _saving = true;
        try
        {
            if (IsEditMode)
            {
                await ProductService.UpdateProductAsync(_product.Id, new UpdateProductDto
                {
                    Code = _product.Code,
                    Name = _product.Name,
                    Description = _product.Description,
                    Unit = _product.Unit,
                    CostPrice = _costPrice!.Value,
                    SellingPrice = _sellingPrice!.Value,
                    IsActive = _product.IsActive
                });
                Snackbar.Add(Localization.GetString("ProductUpdated"), Severity.Success);
            }
            else
            {
                await ProductService.CreateProductAsync(new CreateProductDto
                {
                    Code = _product.Code,
                    Name = _product.Name,
                    Description = _product.Description,
                    Unit = _product.Unit,
                    CostPrice = _costPrice!.Value,
                    SellingPrice = _sellingPrice!.Value,
                    IsActive = _product.IsActive
                });
                Snackbar.Add(Localization.GetString("ProductCreated"), Severity.Success);
            }
            MudDialog.Close(DialogResult.Ok(true));
        }
        catch (InvalidOperationException ex)
        {
            string msg = ex.Message == "ProductCodeAlreadyExists"
                ? string.Format(Localization.GetString("ProductCodeAlreadyExists"), _product.Code)
                : ex.Message;
            Snackbar.Add(msg, Severity.Error);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error saving product: {ex.Message}");
            Snackbar.Add(Localization.GetString(IsEditMode ? "ErrorUpdatingProduct" : "ErrorCreatingProduct"), Severity.Error);
        }
        finally
        {
            _saving = false;
        }
    }

    private void Cancel() => MudDialog.Cancel();
}
