@using WarehouseInvoiceSystem.Application.DTOs.StockLevel
@using WarehouseInvoiceSystem.Application.DTOs.Product
@using WarehouseInvoiceSystem.Application.DTOs.Warehouse
@using WarehouseInvoiceSystem.Domain.Queries.Common
@inject ILocalizationService Localization
@inject IProductService ProductService
@inject IWarehouseService WarehouseService
@inject IInventoryService InventoryService
@inject ISnackbar Snackbar

<MudDialog>
    <DialogContent>
        @if (_loading)
        {
            <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="mb-4" />
        }
        else
        {
            <MudGrid>

                @* Product *@
                <MudItem xs="12">
                    @if (_productLocked)
                    {
                        <WisInput Value="@(_selectedProduct is null ? string.Empty : $"{_selectedProduct.Code} - {_selectedProduct.Name}")"
                                  Label="@Localization.GetString("Product")"
                                  ReadOnly="true" />
                    }
                    else
                    {
                        <WisAutocompleteInput TValue="Guid"
                                             SelectedValue="@(_selectedProduct?.Id ?? Guid.Empty)"
                                             SelectedValueChanged="OnProductSelected"
                                             LoadItems="LoadProductItems"
                                             Label="@Localization.GetString("Product")"
                                             Required="true" />
                    }
                </MudItem>

                @* Source Warehouse *@
                <MudItem xs="12" sm="6">
                    @if (_sourceWarehouseLocked)
                    {
                        <WisInput Value="@(_warehouses.FirstOrDefault(w => w.Id == _sourceWarehouseId)?.Name ?? "")"
                                  Label="@Localization.GetString("SourceWarehouse")"
                                  ReadOnly="true" />
                    }
                    else
                    {
                        <WisSelect T="WarehouseDto"
                                   Items="_warehouses"
                                   Value="@(_warehouses.FirstOrDefault(w => w.Id == _sourceWarehouseId))"
                                   ValueChanged="OnSourceWarehouseSelected"
                                   Label="@Localization.GetString("SourceWarehouse")"
                                   ToStringFunc="@(w => w?.Name ?? "")"
                                   Required="true" />
                    }
                </MudItem>

                @* Destination Warehouse *@
                <MudItem xs="12" sm="6">
                    <WisSelect T="WarehouseDto"
                               Items="@(_warehouses.Where(w => w.Id != _sourceWarehouseId).ToList())"
                               Value="@(_warehouses.FirstOrDefault(w => w.Id == _destinationWarehouseId))"
                               ValueChanged="@(w => _destinationWarehouseId = w?.Id)"
                               Label="@Localization.GetString("DestinationWarehouse")"
                               ToStringFunc="@(w => w?.Name ?? "")"
                               Required="true" />
                </MudItem>

                @* Current stock at source *@
                @if (_sourceStock is not null)
                {
                    <MudItem xs="12">
                        <MudAlert Severity="@(_sourceStock.Quantity <= 0 ? Severity.Warning : Severity.Info)"
                                  Variant="Variant.Outlined"
                                  Class="py-2 wis-alert-fullwidth">
                            <MudGrid Spacing="0">
                                <MudItem xs="4" Class="text-center">
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">@Localization.GetString("CurrentStock")</MudText>
                                    <MudText Typo="Typo.subtitle2"
                                             Color="@(_sourceStock.Quantity <= 0 ? Color.Warning : Color.Primary)">
                                        @_sourceStock.Quantity.ToString("N0") @_selectedProduct?.Unit
                                    </MudText>
                                </MudItem>
                                <MudItem xs="4" Class="text-center">
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">@Localization.GetString("MinimumQuantity")</MudText>
                                    <MudText Typo="Typo.subtitle2" Color="Color.Default">
                                        @(_sourceStock.MinimumQuantity?.ToString("N0") ?? "—")
                                    </MudText>
                                </MudItem>
                                <MudItem xs="4" Class="text-center">
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">@Localization.GetString("ReorderPoint")</MudText>
                                    <MudText Typo="Typo.subtitle2" Color="Color.Default">
                                        @(_sourceStock.ReorderPoint?.ToString("N0") ?? "—")
                                    </MudText>
                                </MudItem>
                            </MudGrid>
                        </MudAlert>
                    </MudItem>
                }

                @* Quantity *@
                <MudItem xs="12" sm="6">
                    <WisAmountInput @bind-Value="_quantity"
                                    Label="@Localization.GetString("Quantity")"
                                    AdornmentText="@(_selectedProduct?.Unit ?? "")"
                                    FullWidth="true"
                                    HasError="@_quantityExceedsStock"
                                    ErrorText="@(_quantityExceedsStock ? $"{Localization.GetString("ExceedsStock")} ({_sourceStock!.Quantity:N0} {_selectedProduct?.Unit})" : null)" />
                </MudItem>

                @* Note *@
                <MudItem xs="12" sm="6">
                    <WisInput @bind-Value="_note"
                              Label="@Localization.GetString("Note")" />
                </MudItem>

            </MudGrid>
        }
    </DialogContent>
    <DialogActions>
        <WisDialogActions OnCancel="Cancel"
                          OnSave="Save"
                          SaveLabel="@(Localization.GetString("Transfer"))"
                          SaveDisabled="@(!IsValid || _loading || _saving)" />
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter]
    IMudDialogInstance MudDialog { get; set; } = null!;

    [Parameter] public Guid? PreSelectedProductId { get; set; }
    [Parameter] public Guid? PreSelectedSourceWarehouseId { get; set; }

    private bool _loading = true;
    private bool _saving;
    private bool _productLocked;
    private bool _sourceWarehouseLocked;

    private List<ProductDto> _products = [];
    private List<WarehouseDto> _warehouses = [];

    private ProductDto? _selectedProduct;
    private Guid? _sourceWarehouseId;
    private Guid? _destinationWarehouseId;
    private StockLevelDto? _sourceStock;

    private decimal? _quantity;
    private string? _note;

    private bool _quantityExceedsStock =>
        _sourceStock is not null && _quantity.HasValue && _quantity.Value > _sourceStock.Quantity;

    private bool IsValid =>
        _selectedProduct is not null &&
        _sourceWarehouseId.HasValue &&
        _destinationWarehouseId.HasValue &&
        _sourceWarehouseId != _destinationWarehouseId &&
        _quantity is > 0 &&
        !_quantityExceedsStock;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _products = (await ProductService.GetActiveProductsAsync())
                .OrderBy(p => p.Name).ToList();
            _warehouses = (await WarehouseService.GetAllWarehousesAsync())
                .OrderByDescending(w => w.IsDefault).ThenBy(w => w.Name).ToList();

            if (PreSelectedProductId.HasValue)
            {
                _selectedProduct = _products.FirstOrDefault(p => p.Id == PreSelectedProductId.Value)
                    ?? await ProductService.GetProductByIdAsync(PreSelectedProductId.Value);
                _productLocked = true;
            }

            if (PreSelectedSourceWarehouseId.HasValue)
            {
                _sourceWarehouseId = PreSelectedSourceWarehouseId.Value;
                _sourceWarehouseLocked = true;
            }

            await LoadSourceStock();
        }
        catch (Exception)
        {
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task LoadSourceStock()
    {
        if (_selectedProduct is null || !_sourceWarehouseId.HasValue)
        {
            _sourceStock = null;
            return;
        }

        try
        {
            _sourceStock = await InventoryService.GetStockLevelAsync(
                _selectedProduct.Id, _sourceWarehouseId.Value);
        }
        catch
        {
            _sourceStock = null;
        }
    }

    private Task<PagedResult<WisAutocompleteItem<Guid>>> LoadProductItems(
        string search, int page, CancellationToken ct)
    {
        var filtered = string.IsNullOrWhiteSpace(search)
            ? _products
            : _products.Where(p =>
                p.Name.Contains(search, StringComparison.OrdinalIgnoreCase) ||
                p.Code.Contains(search, StringComparison.OrdinalIgnoreCase)).ToList();

        return Task.FromResult(new PagedResult<WisAutocompleteItem<Guid>>
        {
            Items = filtered.Select(p => new WisAutocompleteItem<Guid>
            {
                Value = p.Id,
                Label = p.Name,
                SubLabel = p.Code,
            }).ToList(),
            Page = 1,
            PageSize = Math.Max(1, filtered.Count),
            TotalCount = filtered.Count,
        });
    }

    private async Task OnProductSelected(Guid id)
    {
        _selectedProduct = id == Guid.Empty ? null : _products.FirstOrDefault(p => p.Id == id);
        await LoadSourceStock();
    }

    private async Task OnSourceWarehouseSelected(WarehouseDto? warehouse)
    {
        _sourceWarehouseId = warehouse?.Id;
        // If destination was the same as new source, clear it
        if (_destinationWarehouseId == _sourceWarehouseId)
            _destinationWarehouseId = null;
        await LoadSourceStock();
    }

    private async Task Save()
    {
        _saving = true;
        try
        {
            await InventoryService.TransferStockAsync(
                _selectedProduct!.Id, _sourceWarehouseId!.Value,
                _destinationWarehouseId!.Value, _quantity!.Value, _note);
            Snackbar.Add(Localization.GetString("StockTransferred"), Severity.Success);
            MudDialog.Close(DialogResult.Ok(true));
        }
        catch (Exception)
        {
            Snackbar.Add(Localization.GetString("ErrorTransferringStock"), Severity.Error);
        }
        finally
        {
            _saving = false;
        }
    }

    private void Cancel() => MudDialog.Cancel();
}
