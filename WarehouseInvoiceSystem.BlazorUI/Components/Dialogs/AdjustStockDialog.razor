@using WarehouseInvoiceSystem.Application.DTOs.StockLevel
@using WarehouseInvoiceSystem.Application.DTOs.Product
@using WarehouseInvoiceSystem.Application.DTOs.Warehouse
@using WarehouseInvoiceSystem.Domain.Queries.Common
@inject ILocalizationService Localization
@inject IProductService ProductService
@inject IWarehouseService WarehouseService
@inject IInventoryService InventoryService
@inject ISnackbar Snackbar

<MudDialog>
    <DialogContent>
        @if (_loading)
        {
            <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="mb-4" />
        }
        else
        {
            <MudGrid>

                @* Product *@
                <MudItem xs="12" sm="6">
                    @if (_productLocked)
                    {
                        <WisInput Value="@(_selectedProduct is null ? string.Empty : $"{_selectedProduct.Code} - {_selectedProduct.Name}")"
                                  Label="@Localization.GetString("Product")"
                                  ReadOnly="true" />
                    }
                    else
                    {
                        <WisAutocompleteInput TValue="Guid"
                                             SelectedValue="@(_selectedProduct?.Id ?? Guid.Empty)"
                                             SelectedValueChanged="OnProductSelected"
                                             LoadItems="LoadProductItems"
                                             Label="@Localization.GetString("Product")"
                                             Required="true" />
                    }
                </MudItem>

                @* Warehouse *@
                <MudItem xs="12" sm="6">
                    @if (_warehouseLocked)
                    {
                        <WisInput Value="@(_warehouses.FirstOrDefault(w => w.Id == _selectedWarehouseId)?.Name ?? "")"
                                  Label="@Localization.GetString("Warehouse")"
                                  ReadOnly="true" />
                    }
                    else
                    {
                        <WisSelect T="WarehouseDto"
                                   Items="_warehouses"
                                   Value="@(_warehouses.FirstOrDefault(w => w.Id == _selectedWarehouseId))"
                                   ValueChanged="OnWarehouseSelected"
                                   Label="@Localization.GetString("Warehouse")"
                                   ToStringFunc="@(w => w?.Name ?? "")"
                                   Required="true" />
                    }
                </MudItem>

                @* Current stock summary panel *@
                @if (_currentStock is not null)
                {
                    <MudItem xs="12">
                        <MudAlert Severity="Severity.Info"
                                  Variant="Variant.Outlined"
                                  Class="py-2 wis-alert-fullwidth">
                            <MudGrid Spacing="0">
                                <MudItem xs="4" Class="text-center">
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">@Localization.GetString("CurrentStock")</MudText>
                                    <MudText Typo="Typo.subtitle2"
                                             Color="@(IsLowStock(_currentStock) ? Color.Error : Color.Primary)">
                                        @_currentStock.Quantity.ToString("N0")
                                    </MudText>
                                </MudItem>
                                <MudItem xs="4" Class="text-center">
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">@Localization.GetString("MinimumQuantity")</MudText>
                                    <MudText Typo="Typo.subtitle2" Color="Color.Default">
                                        @(_currentStock.MinimumQuantity?.ToString("N0") ?? "—")
                                    </MudText>
                                </MudItem>
                                <MudItem xs="4" Class="text-center">
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">@Localization.GetString("ReorderPoint")</MudText>
                                    <MudText Typo="Typo.subtitle2" Color="Color.Default">
                                        @(_currentStock.ReorderPoint?.ToString("N0") ?? "—")
                                    </MudText>
                                </MudItem>
                            </MudGrid>
                        </MudAlert>
                    </MudItem>
                }

                @* Adjustment type *@
                <MudItem xs="12" sm="6">
                    <WisSelect T="AdjustmentDirection"
                               Items="_adjustmentDirections"
                               Value="@_direction"
                               ValueChanged="@(v => _direction = v)"
                               Label="@Localization.GetString("AdjustmentType")"
                               Required="true">
                        <ItemTemplate Context="d">
                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                <MudIcon Icon="@(d == AdjustmentDirection.Add ? Icons.Material.Filled.AddCircle : Icons.Material.Filled.RemoveCircle)"
                                         Color="@(d == AdjustmentDirection.Add ? Color.Success : Color.Error)"
                                         Size="Size.Small" />
                                <MudText>@(d == AdjustmentDirection.Add ? Localization.GetString("IncreaseStock") : Localization.GetString("DecreaseStock"))</MudText>
                            </MudStack>
                        </ItemTemplate>
                    </WisSelect>
                </MudItem>

                @* Quantity *@
                <MudItem xs="12" sm="6">
                    <WisAmountInput @bind-Value="_quantity"
                                    Label="@Localization.GetString("Quantity")"
                                    AdornmentText="@(_selectedProduct?.Unit ?? "")"
                                    FullWidth="true" />
                </MudItem>

                @* Reason *@
                <MudItem xs="12">
                    <WisInput @bind-Value="_reason"
                              Label="@Localization.GetString("AdjustmentReason")" />
                </MudItem>

            </MudGrid>
        }
    </DialogContent>
    <DialogActions>
        <WisDialogActions OnCancel="Cancel"
                          OnSave="Save"
                          SaveLabel="@(Localization.GetString("Adjust"))"
                          SaveDisabled="@(!IsValid || _loading || _saving)" />
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter]
    IMudDialogInstance MudDialog { get; set; } = null!;

    /// <summary>Pre-select and lock the product. Pass from inventory list row action.</summary>
    [Parameter] public Guid? PreSelectedProductId { get; set; }

    /// <summary>Pre-select and lock the warehouse. Pass from inventory list row action.</summary>
    [Parameter] public Guid? PreSelectedWarehouseId { get; set; }

    public enum AdjustmentDirection { Add, Remove }

    private static readonly AdjustmentDirection[] _adjustmentDirections =
        [AdjustmentDirection.Add, AdjustmentDirection.Remove];

    private bool _loading = true;
    private bool _saving;
    private bool _productLocked;
    private bool _warehouseLocked;

    private List<ProductDto> _products = [];
    private List<WarehouseDto> _warehouses = [];

    private ProductDto? _selectedProduct;
    private Guid? _selectedWarehouseId;
    private StockLevelDto? _currentStock;

    private AdjustmentDirection _direction = AdjustmentDirection.Add;
    private decimal? _quantity;
    private string? _reason;

    private bool IsValid =>
        _selectedProduct is not null &&
        _selectedWarehouseId.HasValue &&
        _quantity is > 0;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _products = (await ProductService.GetActiveProductsAsync())
                .OrderBy(p => p.Name).ToList();
            _warehouses = (await WarehouseService.GetAllWarehousesAsync())
                .OrderByDescending(w => w.IsDefault).ThenBy(w => w.Name).ToList();

            if (PreSelectedProductId.HasValue)
            {
                _selectedProduct = _products.FirstOrDefault(p => p.Id == PreSelectedProductId.Value)
                    ?? await ProductService.GetProductByIdAsync(PreSelectedProductId.Value);
                _productLocked = true;
            }

            if (PreSelectedWarehouseId.HasValue)
            {
                _selectedWarehouseId = PreSelectedWarehouseId.Value;
                _warehouseLocked = true;
            }

            await LoadCurrentStock();
        }
        catch (Exception)
        {
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task LoadCurrentStock()
    {
        if (_selectedProduct is null || !_selectedWarehouseId.HasValue)
        {
            _currentStock = null;
            return;
        }

        try
        {
            _currentStock = await InventoryService.GetStockLevelAsync(
                _selectedProduct.Id, _selectedWarehouseId.Value);
        }
        catch
        {
            _currentStock = null;
        }
    }

    private Task<PagedResult<WisAutocompleteItem<Guid>>> LoadProductItems(
        string search, int page, CancellationToken ct)
    {
        var filtered = string.IsNullOrWhiteSpace(search)
            ? _products
            : _products.Where(p =>
                p.Name.Contains(search, StringComparison.OrdinalIgnoreCase) ||
                p.Code.Contains(search, StringComparison.OrdinalIgnoreCase)).ToList();

        return Task.FromResult(new PagedResult<WisAutocompleteItem<Guid>>
        {
            Items = filtered.Select(p => new WisAutocompleteItem<Guid>
            {
                Value = p.Id,
                Label = p.Name,
                SubLabel = p.Code,
            }).ToList(),
            Page = 1,
            PageSize = Math.Max(1, filtered.Count),
            TotalCount = filtered.Count,
        });
    }

    private async Task OnProductSelected(Guid id)
    {
        _selectedProduct = id == Guid.Empty ? null : _products.FirstOrDefault(p => p.Id == id);
        await LoadCurrentStock();
    }

    private async Task OnWarehouseSelected(WarehouseDto? warehouse)
    {
        _selectedWarehouseId = warehouse?.Id;
        await LoadCurrentStock();
    }

    private bool IsLowStock(StockLevelDto stock) =>
        stock.MinimumQuantity.HasValue && stock.Quantity <= stock.MinimumQuantity.Value;

    private async Task Save()
    {
        _saving = true;
        try
        {
            decimal change = _direction == AdjustmentDirection.Add ? _quantity!.Value : -_quantity!.Value;
            await InventoryService.AdjustStockAsync(
                _selectedProduct!.Id, _selectedWarehouseId!.Value, change, _reason ?? string.Empty);
            Snackbar.Add(Localization.GetString("StockAdjusted"), Severity.Success);
            MudDialog.Close(DialogResult.Ok(true));
        }
        catch (Exception)
        {
            Snackbar.Add(Localization.GetString("ErrorAdjustingStock"), Severity.Error);
        }
        finally
        {
            _saving = false;
        }
    }

    private void Cancel() => MudDialog.Cancel();
}
