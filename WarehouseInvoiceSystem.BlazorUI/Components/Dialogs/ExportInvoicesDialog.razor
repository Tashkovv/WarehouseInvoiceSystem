@using WarehouseInvoiceSystem.Application.Interfaces
@inject ILocalizationService Localization

<MudDialog>
    <DialogContent>
        <MudRadioGroup T="bool" Value="_exportAll" ValueChanged="OnExportTypeChanged">
            <MudRadio T="bool" Value="true" Color="Color.Primary">
                @Localization.GetString("ExportAllInvoices")
            </MudRadio>
            <MudRadio T="bool" Value="false" Color="Color.Primary">
                @Localization.GetString("ExportByDateRange")
            </MudRadio>
        </MudRadioGroup>

        @if (!_exportAll)
        {
            <MudGrid Class="mt-4">
                <MudItem xs="12" sm="6">
                    <MudDatePicker Date="_startDate"
                                   DateChanged="@((DateTime? val) => _startDate = val)"
                                   Label="@Localization.GetString("StartDate")"
                                   Variant="Variant.Outlined"
                                   Required="true" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudDatePicker Date="_endDate"
                                   DateChanged="@((DateTime? val) => _endDate = val)"
                                   Label="@Localization.GetString("EndDate")"
                                   Variant="Variant.Outlined"
                                   Required="true" />
                </MudItem>
            </MudGrid>
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">@Localization.GetString("Cancel")</MudButton>
        <MudButton Color="Color.Primary"
                   Variant="Variant.Filled"
                   OnClick="Export"
                   StartIcon="@Icons.Material.Filled.Download">
            @Localization.GetString("Export")
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter]
    IMudDialogInstance MudDialog { get; set; } = null!;

    private bool _exportAll = true;
    private DateTime? _startDate = DateTime.Now.AddMonths(-1);
    private DateTime? _endDate = DateTime.UtcNow;

    private void OnExportTypeChanged(bool exportAll)
    {
        _exportAll = exportAll;
    }

    private void Cancel()
    {
        MudDialog.Cancel();
    }

    private void Export()
    {
        if (!_exportAll && (_startDate == null || _endDate == null))
        {
            return;
        }

        ExportDialogResult result = new ExportDialogResult
        {
            ExportAll = _exportAll,
            StartDate = _startDate ?? DateTime.UtcNow.AddMonths(-1),
            EndDate = _endDate ?? DateTime.UtcNow
        };

        MudDialog.Close(DialogResult.Ok(result));
    }
}