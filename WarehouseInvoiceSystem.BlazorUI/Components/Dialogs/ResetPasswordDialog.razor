@inject ILocalizationService Localization
@inject IUserService UserService
@inject ISnackbar Snackbar

<MudDialog>
    <DialogContent>
        <MudGrid>
            <MudItem xs="12">
                <MudTextField @bind-Value="_newPassword"
                              Label="@Localization.GetString("NewPassword")"
                              Variant="Variant.Outlined"
                              Required="true"
                              RequiredError="@Localization.GetString("PasswordRequired")"
                              InputType="@(_showPassword ? InputType.Text : InputType.Password)"
                              Adornment="Adornment.End"
                              AdornmentIcon="@(_showPassword ? Icons.Material.Filled.Visibility : Icons.Material.Filled.VisibilityOff)"
                              OnAdornmentClick="@(() => _showPassword = !_showPassword)"
                              FullWidth="true"
                              MaxLength="100" />
            </MudItem>
            <MudItem xs="12">
                <MudTextField @bind-Value="_confirmPassword"
                              Label="@Localization.GetString("ConfirmPassword")"
                              Variant="Variant.Outlined"
                              Required="true"
                              RequiredError="@Localization.GetString("ConfirmPasswordRequired")"
                              InputType="@(_showPassword ? InputType.Text : InputType.Password)"
                              FullWidth="true"
                              MaxLength="100" />
            </MudItem>
        </MudGrid>
    </DialogContent>
    <DialogActions>
        <WisDialogActions OnCancel="Cancel"
                          OnSave="Save"
                          SaveLabel="@Localization.GetString("ResetPassword")"
                          SaveIcon="@Icons.Material.Filled.LockReset"
                          SaveDisabled="@(!IsValid || _saving)" />
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter]
    IMudDialogInstance MudDialog { get; set; } = null!;

    [Parameter]
    public Guid UserId { get; set; }

    private string _newPassword = string.Empty;
    private string _confirmPassword = string.Empty;
    private bool _showPassword;
    private bool _saving;

    private bool IsValid =>
        !string.IsNullOrWhiteSpace(_newPassword) &&
        _newPassword.Length >= 6 &&
        _newPassword == _confirmPassword;

    private async Task Save()
    {
        if (_newPassword != _confirmPassword)
        {
            Snackbar.Add(Localization.GetString("PasswordsDoNotMatch"), Severity.Warning);
            return;
        }

        _saving = true;
        try
        {
            await UserService.ResetPasswordAsync(UserId, _newPassword);
            Snackbar.Add(Localization.GetString("PasswordResetSuccess"), Severity.Success);
            MudDialog.Close(DialogResult.Ok(true));
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error resetting password: {ex.Message}");
            Snackbar.Add(Localization.GetString("ErrorResettingPassword"), Severity.Error);
        }
        finally
        {
            _saving = false;
        }
    }

    private void Cancel() => MudDialog.Cancel();
}
