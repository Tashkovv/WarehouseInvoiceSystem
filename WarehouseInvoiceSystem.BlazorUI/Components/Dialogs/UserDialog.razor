@using WarehouseInvoiceSystem.Application.DTOs.User
@using WarehouseInvoiceSystem.Domain.Enums
@inject ILocalizationService Localization
@inject IUserService UserService
@inject ISnackbar Snackbar

<MudDialog>
    <DialogContent>
        <MudGrid>
            <MudItem xs="12" sm="4">
                <WisInput @bind-Value="_username"
                          Label="@Localization.GetString("Username")"
                          Required="true" />
            </MudItem>
            <MudItem xs="12" sm="4">
                <WisInput @bind-Value="_email"
                          Label="@Localization.GetString("Email")"
                          InputType="email"
                          Required="true" />                
            </MudItem>
            <MudItem xs="12" sm="4">
                <WisSelect T="UserRole"
                           Items="_userRoles"
                           Value="@_role"
                           ValueChanged="@(v => _role = v)"
                           Label="@Localization.GetString("Role")"
                           ToStringFunc="@(r => r == UserRole.Admin ? Localization.GetString("AdminRole") : Localization.GetString("UserRole"))"
                           Required="true" />
            </MudItem>
            @if (!IsEditMode)
            {
                <MudItem xs="12" sm="6">
                    <WisInput @bind-Value="_password"
                              Label="@Localization.GetString("Password")"
                              InputType="@(_showPassword ? "text" : "password")"
                              Required="true"
                              SuffixIcon="@(_showPassword ? Icons.Material.Filled.Visibility : Icons.Material.Filled.VisibilityOff)"
                              OnSuffixIconClick="@(() => _showPassword = !_showPassword)" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <WisInput @bind-Value="_confirmPassword"
                              Label="@Localization.GetString("ConfirmPassword")"
                              InputType="@(_showPassword ? "text" : "password")"
                              Required="true" />
                </MudItem>
            }
        </MudGrid>
    </DialogContent>
    <DialogActions>
        <WisDialogActions OnCancel="Cancel"
                          OnSave="Save"
                          SaveDisabled="@(!IsValid || _saving)" />
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter]
    IMudDialogInstance MudDialog { get; set; } = null!;

    [Parameter]
    public UserDto? User { get; set; }

    private static readonly UserRole[] _userRoles = [UserRole.Admin, UserRole.User];

    private string _username = string.Empty;
    private string _email = string.Empty;
    private string _password = string.Empty;
    private string _confirmPassword = string.Empty;
    private UserRole _role = UserRole.User;
    private bool _showPassword;
    private bool _saving;

    private bool IsEditMode => User is not null;

    private bool IsValid
    {
        get
        {
            if (string.IsNullOrWhiteSpace(_username) || string.IsNullOrWhiteSpace(_email))
                return false;

            if (!IsEditMode)
            {
                if (string.IsNullOrWhiteSpace(_password) || _password.Length < 6)
                    return false;
                if (_password != _confirmPassword)
                    return false;
            }

            return true;
        }
    }

    protected override void OnParametersSet()
    {
        if (User is not null)
        {
            _username = User.Username;
            _email = User.Email;
            _role = User.Role;
        }
    }

    private async Task Save()
    {
        if (!IsEditMode && _password != _confirmPassword)
        {
            Snackbar.Add(Localization.GetString("PasswordsDoNotMatch"), Severity.Warning);
            return;
        }

        _saving = true;
        try
        {
            if (IsEditMode)
            {
                await UserService.UpdateUserAsync(User!.Id, new UpdateUserDto
                {
                    Username = _username,
                    Email = _email,
                    Role = _role
                });
                Snackbar.Add(Localization.GetString("UserUpdated"), Severity.Success);
            }
            else
            {
                await UserService.CreateUserAsync(new CreateUserDto
                {
                    Username = _username,
                    Email = _email,
                    Password = _password,
                    Role = _role
                });
                Snackbar.Add(Localization.GetString("UserCreated"), Severity.Success);
            }
            MudDialog.Close(DialogResult.Ok(true));
        }
        catch (InvalidOperationException ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
        catch (Exception)
        {
            Snackbar.Add(Localization.GetString(IsEditMode ? "ErrorUpdatingUser" : "ErrorCreatingUser"), Severity.Error);
        }
        finally
        {
            _saving = false;
        }
    }

    private void Cancel() => MudDialog.Cancel();
}
