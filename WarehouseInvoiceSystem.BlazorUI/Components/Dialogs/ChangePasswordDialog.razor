@using System.Security.Claims
@using WarehouseInvoiceSystem.Application.DTOs.User
@inject ILocalizationService Localization
@inject IUserService UserService
@inject ISnackbar Snackbar
@inject AuthenticationStateProvider AuthStateProvider

<MudDialog>
    <DialogContent>
        <MudGrid>
            <MudItem xs="12">
                <WisInput @bind-Value="_currentPassword"
                          Label="@Localization.GetString("CurrentPassword")"
                          InputType="@(_showPasswords ? "text" : "password")"
                          Required="true"
                          SuffixIcon="@(_showPasswords ? Icons.Material.Filled.Visibility : Icons.Material.Filled.VisibilityOff)"
                          OnSuffixIconClick="@(() => _showPasswords = !_showPasswords)" />
            </MudItem>
            <MudItem xs="12">
                <WisInput @bind-Value="_newPassword"
                          Label="@Localization.GetString("NewPassword")"
                          InputType="@(_showPasswords ? "text" : "password")"
                          Required="true" />
            </MudItem>
            <MudItem xs="12">
                <WisInput @bind-Value="_confirmPassword"
                          Label="@Localization.GetString("ConfirmPassword")"
                          InputType="@(_showPasswords ? "text" : "password")"
                          Required="true" />
            </MudItem>
        </MudGrid>
    </DialogContent>
    <DialogActions>
        <WisDialogActions OnCancel="Cancel"
                          OnSave="Save"
                          SaveLabel="@Localization.GetString("ChangePassword")"
                          SaveIcon="@Icons.Material.Filled.Lock"
                          SaveDisabled="@(!IsValid || _saving)" />
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter]
    IMudDialogInstance MudDialog { get; set; } = null!;

    private string _currentPassword = string.Empty;
    private string _newPassword = string.Empty;
    private string _confirmPassword = string.Empty;
    private bool _showPasswords;
    private bool _saving;
    private Guid _userId;

    private bool IsValid =>
        !string.IsNullOrWhiteSpace(_currentPassword) &&
        !string.IsNullOrWhiteSpace(_newPassword) &&
        _newPassword.Length >= 6 &&
        _newPassword == _confirmPassword;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var userIdClaim = authState.User.FindFirst(ClaimTypes.NameIdentifier)?.Value;
        if (Guid.TryParse(userIdClaim, out var id))
            _userId = id;
    }

    private async Task Save()
    {
        if (_newPassword != _confirmPassword)
        {
            Snackbar.Add(Localization.GetString("PasswordsDoNotMatch"), Severity.Warning);
            return;
        }

        _saving = true;
        try
        {
            bool success = await UserService.ChangePasswordAsync(_userId, new ChangePasswordDto
            {
                CurrentPassword = _currentPassword,
                NewPassword = _newPassword
            });

            if (success)
            {
                Snackbar.Add(Localization.GetString("PasswordChanged"), Severity.Success);
                MudDialog.Close(DialogResult.Ok(true));
            }
            else
            {
                Snackbar.Add(Localization.GetString("InvalidCurrentPassword"), Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error changing password: {ex.Message}");
            Snackbar.Add(Localization.GetString("ErrorChangingPassword"), Severity.Error);
        }
        finally
        {
            _saving = false;
        }
    }

    private void Cancel() => MudDialog.Cancel();
}
