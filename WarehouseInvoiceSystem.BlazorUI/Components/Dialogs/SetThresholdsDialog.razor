@using WarehouseInvoiceSystem.Application.DTOs.StockLevel
@inject ILocalizationService Localization
@inject IInventoryService InventoryService
@inject ISnackbar Snackbar

<MudDialog>
    <DialogContent>
        <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-4">
            @StockLevel.ProductCode — @StockLevel.ProductName
        </MudText>
        <MudGrid>
            <MudItem xs="12" sm="6">
                <WisAmountInput @bind-Value="_minimumQuantity"
                                Label="@Localization.GetString("MinimumQuantity")"
                                AdornmentText="@StockLevel.ProductUnit"
                                FullWidth="true" />
            </MudItem>
            <MudItem xs="12" sm="6">
                <WisAmountInput @bind-Value="_reorderPoint"
                                Label="@Localization.GetString("ReorderPoint")"
                                AdornmentText="@StockLevel.ProductUnit"
                                FullWidth="true" />
            </MudItem>
        </MudGrid>
    </DialogContent>
    <DialogActions>
        <WisDialogActions OnCancel="Cancel" OnSave="Save" SaveDisabled="@_saving" />
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = null!;
    [Parameter, EditorRequired] public StockLevelDto StockLevel { get; set; } = null!;

    private decimal? _minimumQuantity;
    private decimal? _reorderPoint;
    private bool _saving;

    protected override void OnInitialized()
    {
        _minimumQuantity = StockLevel.MinimumQuantity;
        _reorderPoint = StockLevel.ReorderPoint;
    }

    private void Cancel() => MudDialog.Cancel();

    private async Task Save()
    {
        _saving = true;
        try
        {
            await InventoryService.UpdateStockLevelAsync(
                StockLevel.ProductId,
                StockLevel.WarehouseId,
                new UpdateStockLevelDto
                {
                    Quantity = StockLevel.Quantity,
                    MinimumQuantity = _minimumQuantity,
                    ReorderPoint = _reorderPoint
                });
            Snackbar.Add(Localization.GetString("ThresholdsUpdated"), Severity.Success);
            MudDialog.Close(DialogResult.Ok(true));
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error updating thresholds: {ex.Message}");
            Snackbar.Add(Localization.GetString("ErrorUpdatingThresholds"), Severity.Error);
        }
        finally
        {
            _saving = false;
        }
    }
}
