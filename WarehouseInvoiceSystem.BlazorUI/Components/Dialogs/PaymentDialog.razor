@using WarehouseInvoiceSystem.Application.DTOs.Payment
@using WarehouseInvoiceSystem.Application.DTOs.Invoice
@using WarehouseInvoiceSystem.Domain.Enums
@using WarehouseInvoiceSystem.Domain.Queries
@using WarehouseInvoiceSystem.Domain.Queries.Common
@using System.Security.Claims
@inject ILocalizationService Localization
@inject IInvoiceService InvoiceService
@inject AuthenticationStateProvider AuthStateProvider

<MudDialog>
    <DialogContent>
        <MudGrid>
            @* Invoice selector — shown in create mode, read-only info in edit mode *@
            @if (IsEditMode)
            {
                <MudItem xs="12" sm="6">
                    <WisInput Value="@Payment!.InvoiceNumber"
                              Label="@Localization.GetString("InvoiceNumber")"
                              ReadOnly="true" />
                </MudItem>
            }
            else
            {
                <MudItem xs="12" sm="6">
                    <WisAutocompleteInput TValue="Guid"
                                         SelectedValue="@(_selectedInvoiceId ?? default)"
                                         SelectedValueChanged="OnInvoiceSelected"
                                         LoadItems="LoadInvoiceItems"
                                         Label="@Localization.GetString("Invoice")"
                                         InitialLabel="@_invoiceInitialLabel"
                                         Required="true"
                                         Disabled="@_invoiceReadonly" />
                </MudItem>
            }

            @* Payment date *@
            <MudItem xs="12" sm="6">
                <WisDateInput Date="@_paymentDate"
                              DateChanged="@(d => _paymentDate = d)"
                              Label="@Localization.GetString("PaymentDate")"
                              Required="true" />
            </MudItem>

            @if (_selectedInvoice is not null)
            {
                <MudItem xs="12">
                    <MudAlert Severity="Severity.Info"
                              Variant="Variant.Outlined"
                              Class="py-2 wis-alert-fullwidth">
                        <MudGrid Spacing="0">
                            <MudItem xs="4" Class="text-center">
                                <MudText Typo="Typo.body2" Color="Color.Secondary">@Localization.GetString("InvoiceAmount")</MudText>
                                <MudText Typo="Typo.subtitle2" Color="Color.Primary">@_selectedInvoice.TotalAmount.ToString("C")</MudText>
                            </MudItem>
                            <MudItem xs="4" Class="text-center">
                                <MudText Typo="Typo.body2" Color="Color.Secondary">@Localization.GetString("AlreadyPaid")</MudText>
                                <MudText Typo="Typo.subtitle2" Color="Color.Success">@_selectedInvoice.AmountPaid.ToString("C")</MudText>
                            </MudItem>
                            <MudItem xs="4" Class="text-center">
                                <MudText Typo="Typo.body2" Color="Color.Secondary">@Localization.GetString("RemainingBalance")</MudText>
                                <MudText Typo="Typo.subtitle2" Color="Color.Warning">@_selectedInvoice.AmountDue.ToString("C")</MudText>
                            </MudItem>
                        </MudGrid>
                    </MudAlert>
                </MudItem>
            }

            @* Payment method / Amount / Reference number
               Edit mode: all three in one row (sm=4 each)
               Create mode: method + amount (sm=6 each), then ref + recorded-by (sm=6 each) *@
            @{ int threeColSm = IsEditMode ? 4 : 6; }

            <MudItem xs="12" sm="@threeColSm">
                <WisSelect T="PaymentMethod"
                           Items="_paymentMethods"
                           Value="@_method"
                           ValueChanged="@(v => _method = v)"
                           Label="@Localization.GetString("PaymentMethod")"
                           Required="true">
                    <ItemTemplate Context="m">
                        @{
                            var (icon, color) = m switch
                            {
                                PaymentMethod.Cash         => (Icons.Material.Filled.Money,          Color.Success),
                                PaymentMethod.BankTransfer => (Icons.Material.Filled.AccountBalance, Color.Primary),
                                PaymentMethod.CreditCard   => (Icons.Material.Filled.CreditCard,     Color.Secondary),
                                _                          => (Icons.Material.Filled.MoreHoriz,      Color.Default),
                            };
                        }
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                            <MudIcon Icon="@icon" Size="Size.Small" Color="@color" />
                            <MudText>@GetPaymentMethodLabel(m)</MudText>
                        </MudStack>
                    </ItemTemplate>
                </WisSelect>
            </MudItem>

            <MudItem xs="12" sm="@threeColSm">
                <WisAmountInput @bind-Value="_amount"
                                Label="@Localization.GetString("Amount")"
                                AdornmentText="@Localization.CurrencySymbol"
                                FullWidth="true" />
            </MudItem>

            <MudItem xs="12" sm="@threeColSm">
                <WisInput @bind-Value="_referenceNumber"
                          Label="@Localization.GetString("ReferenceNumber")" />
            </MudItem>

            @* Recorded by — create mode only *@
            @if (!IsEditMode)
            {
                <MudItem xs="12" sm="6">
                    <WisInput @bind-Value="_recordedBy"
                              Label="@Localization.GetString("RecordedBy")" />
                </MudItem>
            }

            @* Notes *@
            <MudItem xs="12">
                <WisInput @bind-Value="_notes"
                          Label="@Localization.GetString("Notes")" />
            </MudItem>
        </MudGrid>
    </DialogContent>
    <DialogActions>
        <WisDialogActions OnCancel="Cancel"
                          OnSave="Save"
                          SaveDisabled="@(!IsValid)" />
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter]
    IMudDialogInstance MudDialog { get; set; } = null!;

    /// <summary>Pass an existing PaymentDto to edit, or null to create.</summary>
    [Parameter]
    public PaymentDto? Payment { get; set; }

    /// <summary>
    /// Pre-select and lock an invoice when opening from the invoice list's Payment button.
    /// Ignored in edit mode.
    /// </summary>
    [Parameter]
    public Guid? PreSelectedInvoiceId { get; set; }

    private bool IsEditMode => Payment is not null;

    // State
    private bool _invoiceReadonly;
    private InvoiceDto? _selectedInvoice;
    private Guid? _selectedInvoiceId;
    private string? _invoiceInitialLabel;

    private PaymentMethod _method = PaymentMethod.BankTransfer;
    private decimal? _amount;
    private DateTime? _paymentDate = DateTime.UtcNow;
    private string? _referenceNumber;
    private string? _notes;
    private string? _recordedBy;

    private static readonly PaymentMethod[] _paymentMethods =
        [PaymentMethod.Cash, PaymentMethod.BankTransfer, PaymentMethod.CreditCard, PaymentMethod.Other];

    private bool IsValid =>
        _amount is > 0 &&
        _paymentDate.HasValue &&
        (IsEditMode || _selectedInvoiceId.HasValue);

    protected override async Task OnInitializedAsync()
    {
        if (IsEditMode)
        {
            _method = Payment!.PaymentMethod;
            _amount = Payment.Amount;
            _paymentDate = Payment.PaymentDate;
            _referenceNumber = Payment.ReferenceNumber;
            _notes = Payment.Notes;

            try
            {
                _selectedInvoice = await InvoiceService.GetInvoiceByIdAsync(Payment.InvoiceId);
            }
            catch { /* summary panel just won't show */ }
        }
        else
        {
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            var username = authState.User.Identity?.Name;
            if (!string.IsNullOrWhiteSpace(username))
                _recordedBy = username;

            if (PreSelectedInvoiceId.HasValue)
            {
                try
                {
                    _selectedInvoice = await InvoiceService.GetInvoiceByIdAsync(PreSelectedInvoiceId.Value);
                }
                catch { }

                _selectedInvoiceId = PreSelectedInvoiceId.Value;
                _invoiceReadonly = true;
                _amount = _selectedInvoice?.AmountDue;
                _invoiceInitialLabel = _selectedInvoice is not null
                    ? $"{_selectedInvoice.InvoiceNumber} — {_selectedInvoice.CompanyName}"
                    : null;
            }
        }
    }

    private async Task<PagedResult<WisAutocompleteItem<Guid>>> LoadInvoiceItems(
        string search, int page, CancellationToken ct)
    {
        var paged = await InvoiceService.GetPagedAsync(new GetInvoicesQuery
        {
            Search = search,
            Page = page,
            PageSize = 10,
            Statuses = [InvoiceStatus.Confirmed, InvoiceStatus.PartiallyPaid, InvoiceStatus.Overdue],
            SortBy = "DueDate",
            SortAscending = true
        }, ct);

        return new PagedResult<WisAutocompleteItem<Guid>>
        {
            Items = paged.Items
                .Where(i => i.AmountDue > 0)
                .Select(i => new WisAutocompleteItem<Guid>
                {
                    Value = i.Id,
                    Label = i.InvoiceNumber,
                    SubLabel = i.CompanyName,
                })
                .ToList(),
            Page = paged.Page,
            PageSize = paged.PageSize,
            TotalCount = paged.TotalCount,
        };
    }

    private async Task OnInvoiceSelected(Guid id)
    {
        // Guid.Empty = the "clear" sentinel emitted by WisAutocompleteInput
        _selectedInvoiceId = id == Guid.Empty ? null : id;
        if (_selectedInvoiceId.HasValue)
        {
            try { _selectedInvoice = await InvoiceService.GetInvoiceByIdAsync(_selectedInvoiceId.Value); }
            catch { _selectedInvoice = null; }
            _amount = _selectedInvoice?.AmountDue;
        }
        else
        {
            _selectedInvoice = null;
            _amount = null;
        }
    }

    private string GetPaymentMethodLabel(PaymentMethod m) => m switch
    {
        PaymentMethod.Cash         => Localization.GetString("Cash"),
        PaymentMethod.BankTransfer => Localization.GetString("BankTransfer"),
        PaymentMethod.CreditCard   => Localization.GetString("CreditCard"),
        _                          => Localization.GetString("Other"),
    };

    private void Save()
    {
        if (IsEditMode)
        {
            MudDialog.Close(DialogResult.Ok(new UpdatePaymentDto
            {
                PaymentDate = _paymentDate!.Value,
                Amount = _amount!.Value,
                PaymentMethod = _method,
                ReferenceNumber = _referenceNumber,
                Notes = _notes,
            }));
        }
        else
        {
            MudDialog.Close(DialogResult.Ok(new CreatePaymentDto
            {
                InvoiceId = _selectedInvoiceId!.Value,
                PaymentDate = _paymentDate!.Value,
                Amount = _amount!.Value,
                PaymentMethod = _method,
                ReferenceNumber = _referenceNumber,
                Notes = _notes,
                RecordedBy = _recordedBy,
            }));
        }
    }

    private void Cancel() => MudDialog.Cancel();
}
