@using WarehouseInvoiceSystem.Application.DTOs.Individual
@inject ILocalizationService Localization
@inject IIndividualService IndividualService
@inject ISnackbar Snackbar

<MudDialog>
    <DialogContent>
        <MudGrid>
            <MudItem xs="12" sm="4">
                <WisInput @bind-Value="_model.FullName"
                          Label="@Localization.GetString("FullName")"
                          Required="true" />
            </MudItem>
            <MudItem xs="12" sm="4">
                <WisInput @bind-Value="_model.IdentificationNumber"
                          Label="@Localization.GetString("IdentificationNumber")"
                          Required="true" />
            </MudItem>
            <MudItem xs="12" sm="4">
                <WisInput @bind-Value="_model.BankAccount"
                          Label="@Localization.GetString("BankAccount")" />
            </MudItem>
            <MudItem xs="12" sm="4">
                <WisInput @bind-Value="_model.Phone"
                          Label="@Localization.GetString("Phone")"
                          InputType="tel"
                          Autocomplete="tel" />
            </MudItem>
            <MudItem xs="12" sm="4">
                <WisInput @bind-Value="_model.Email"
                          Label="@Localization.GetString("Email")"
                          InputType="email"
                          Autocomplete="email" />
            </MudItem>
            <MudItem xs="12" sm="4">
                <WisInput @bind-Value="_model.Address"
                          Label="@Localization.GetString("Address")" />
            </MudItem>
        </MudGrid>
    </DialogContent>
    <DialogActions>
        <WisDialogActions OnCancel="Cancel"
                          OnSave="Save"
                          SaveDisabled="@(!IsValid || _saving)" />
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter]
    IMudDialogInstance MudDialog { get; set; } = null!;

    /// <summary>
    /// Pass an existing IndividualDto to edit, or null to create a new individual.
    /// </summary>
    [Parameter]
    public IndividualDto? Individual { get; set; }

    private IndividualDto _model = new();
    private bool IsEditMode => Individual is not null;

    private bool IsValid =>
        !string.IsNullOrWhiteSpace(_model.FullName) &&
        !string.IsNullOrWhiteSpace(_model.IdentificationNumber);

    protected override void OnParametersSet()
    {
        if (Individual is not null)
        {
            _model = new IndividualDto
            {
                Id = Individual.Id,
                FullName = Individual.FullName,
                IdentificationNumber = Individual.IdentificationNumber,
                Address = Individual.Address,
                Phone = Individual.Phone,
                Email = Individual.Email,
                BankAccount = Individual.BankAccount,
                IsActive = Individual.IsActive,
                CreatedAt = Individual.CreatedAt,
            };
        }
        else
        {
            _model = new IndividualDto { IsActive = true };
        }
    }

    private bool _saving;

    private async Task Save()
    {
        _saving = true;
        try
        {
            if (IsEditMode)
            {
                await IndividualService.UpdateIndividualAsync(_model.Id, new UpdateIndividualDto
                {
                    FullName = _model.FullName,
                    IdentificationNumber = _model.IdentificationNumber,
                    Phone = _model.Phone,
                    Email = _model.Email,
                    BankAccount = _model.BankAccount,
                    Address = _model.Address,
                    IsActive = _model.IsActive
                });
                Snackbar.Add(Localization.GetString("IndividualUpdated"), Severity.Success);
            }
            else
            {
                await IndividualService.CreateIndividualAsync(new CreateIndividualDto
                {
                    FullName = _model.FullName,
                    IdentificationNumber = _model.IdentificationNumber,
                    Phone = _model.Phone,
                    Email = _model.Email,
                    BankAccount = _model.BankAccount,
                    Address = _model.Address,
                    IsActive = _model.IsActive
                });
                Snackbar.Add(Localization.GetString("IndividualCreated"), Severity.Success);
            }
            MudDialog.Close(DialogResult.Ok(true));
        }
        catch (InvalidOperationException ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error saving individual: {ex.Message}");
            Snackbar.Add(Localization.GetString(IsEditMode ? "ErrorUpdatingIndividual" : "ErrorCreatingIndividual"), Severity.Error);
        }
        finally
        {
            _saving = false;
        }
    }

    private void Cancel() => MudDialog.Cancel();
}
